---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Design System — aethero web v3.1" lang="cs">
  <div class="ds-page">

    <!-- NAV -->
    <nav class="ds-nav">
      <a href="/" class="ds-nav-logo">← web</a>
      <div class="ds-nav-links">
        <a href="#web-v31">web-v3.1</a>
        <a href="#colors">Barvy</a>
        <a href="#rules">Pravidla</a>
        <a href="#typography">Typografie</a>
        <a href="#spacing">Spacing</a>
        <a href="#components">Komponenty</a>
        <a href="#inconsistencies" style="color: #FF5252;">⚠ Nekonzistence</a>
      </div>
    </nav>

    <!-- HEADER -->
    <header class="ds-header">
      <div class="ds-header-inner">
        <div>
          <p class="ds-label">Design System</p>
          <h1 class="ds-title">aethero web</h1>
          <p class="ds-version" id="web-v31">v3.1</p>
        </div>
        <div class="ds-header-meta">
          <div class="ds-meta-item">
            <span class="ds-meta-label">Fonts</span>
            <span class="ds-meta-val">Kanit + Montserrat</span>
          </div>
          <div class="ds-meta-item">
            <span class="ds-meta-label">Framework</span>
            <span class="ds-meta-val">Astro 6 / SSG</span>
          </div>
          <div class="ds-meta-item">
            <span class="ds-meta-label">Deploy</span>
            <span class="ds-meta-val">Cloudflare Pages</span>
          </div>
        </div>
      </div>
    </header>

    <main class="ds-main">

      <!-- LOGO -->
      <section class="ds-section" id="logo">
        <h2 class="ds-section-title">Logo</h2>
        <div class="ds-logo-grid">
          <div class="ds-logo-swatch ds-bg-dark">
            <img src="/ae-logo.svg" alt="æthero" height="40" />
            <span class="ds-swatch-label">Na tmavém pozadí</span>
          </div>
          <div class="ds-logo-swatch ds-bg-teal">
            <img src="/ae-logo.svg" alt="æthero" height="40" />
            <span class="ds-swatch-label">Na teal pozadí</span>
          </div>
          <div class="ds-logo-swatch ds-bg-white">
            <img src="/ae-logo.svg" alt="æthero" height="40" style="filter: invert(1) brightness(0);" />
            <span class="ds-swatch-label ds-label-dark">Na bílém pozadí</span>
          </div>
          <div class="ds-logo-swatch ds-bg-dark" style="align-items: flex-start; gap: 16px;">
            <img src="/ae-logo.svg" alt="æthero" height="28" />
            <img src="/shopify-plus-badge.svg" alt="Shopify Plus Partner" height="28" style="filter: brightness(0) invert(1);" />
            <span class="ds-swatch-label">Logo + badge (footer)</span>
          </div>
        </div>
      </section>

      <!-- COLORS -->
      <section class="ds-section" id="colors">
        <h2 class="ds-section-title">Barvy</h2>

        <h3 class="ds-subsection-title">Pozadí</h3>
        <div class="ds-color-grid">
          <div class="ds-chip2" style="--chip-bg: #000326;">
            <div class="ds-chip2-swatch"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--bg-elevated</code>
                <span class="ds-chip2-hex">#000326</span>
              </div>
              <strong class="ds-chip2-name">Hlavní pozadí</strong>
              <p class="ds-chip2-desc">Základní tmavé pozadí webu. Většina sekcí, karty, dropdowny, header po scrollu.</p>
            </div>
          </div>
          <div class="ds-chip2" style="--chip-bg: #000326;">
            <div class="ds-chip2-swatch" style="background: #000326; border: 1px dashed rgba(255,255,255,0.15);"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--bg-secondary</code>
                <span class="ds-chip2-hex">#000326</span>
              </div>
              <strong class="ds-chip2-name">Alternativní sekce</strong>
              <p class="ds-chip2-desc">Sudé sekce na Co umíme a service pages — opticky odděluje obsah střídáním. V tuto chvíli stejná hodnota jako bg-elevated.</p>
            </div>
          </div>
          <div class="ds-chip2" style="--chip-bg: #030626;">
            <div class="ds-chip2-swatch" style="background: #030626;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--bg-primary-alt</code>
                <span class="ds-chip2-hex">#030626</span>
              </div>
              <strong class="ds-chip2-name">Přechodová tmavá</strong>
              <p class="ds-chip2-desc">Mezivrstva nebo gradient start. Výjimečné použití.</p>
            </div>
          </div>
          <div class="ds-chip2" style="--chip-bg: #171A1C;">
            <div class="ds-chip2-swatch" style="background: #171A1C;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--neutral-900</code>
                <span class="ds-chip2-hex">#171A1C</span>
              </div>
              <strong class="ds-chip2-name">Neutrální tmavá</strong>
              <p class="ds-chip2-desc">Hero Co umíme, design system. Teplejší (šedavá) než navy pozadí — vhodná pro sekce s fotkou nebo grafickým hereem.</p>
            </div>
          </div>
          <div class="ds-chip2" style="--chip-bg: #092066;">
            <div class="ds-chip2-swatch" style="background: #092066;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--brand-dark</code>
                <span class="ds-chip2-hex">#092066</span>
              </div>
              <strong class="ds-chip2-name">Brand Dark</strong>
              <p class="ds-chip2-desc">Text na světlém nebo barevném pozadí — čísla ve stats baru, kontaktní info v cyan CTA bloku. Nikdy jako pozadí.</p>
            </div>
          </div>
        </div>

        <h3 class="ds-subsection-title">Akcenty</h3>
        <div class="ds-color-grid">
          <div class="ds-chip2 ds-chip2-accent">
            <div class="ds-chip2-swatch" style="background: #16BECF;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--action</code>
                <span class="ds-chip2-hex">#16BECF</span>
              </div>
              <strong class="ds-chip2-name">Primární akcent — cyan</strong>
              <p class="ds-chip2-desc">Výhradně pro klikací prvky: nav linky při hoveru, nadpisy-linky (.t-ac třída), quick-nav, CTA sekce pozadí na app stránkách.</p>
              <span class="ds-chip2-rule ds-rule-link">📌 Cyan = vždy odkaz nebo CTA</span>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #0DD4CD;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--action-hover</code>
                <span class="ds-chip2-hex">#0DD4CD</span>
              </div>
              <strong class="ds-chip2-name">Action hover / Footer CTA bg</strong>
              <p class="ds-chip2-desc">Hover stav action barvy. Zároveň pozadí footer CTA sekce (Máme spolu co probrat?) a teal tlačítek.</p>
            </div>
          </div>
          <div class="ds-chip2 ds-chip2-accent">
            <div class="ds-chip2-swatch" style="background: #A081D1;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--text-secondary</code>
                <span class="ds-chip2-hex">#A081D1</span>
              </div>
              <strong class="ds-chip2-name">Zvýraznění textu / Stats bar</strong>
              <p class="ds-chip2-desc">Tučné zvýraznění klíčových frází v popisech sekcí (třída .ac, font-weight 900). Pozadí stats baru na homepage. Nikdy odkaz.</p>
              <span class="ds-chip2-rule ds-rule-nolink">🚫 Fialová = nikdy odkaz</span>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #CB00D7;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--accent-purple</code>
                <span class="ds-chip2-hex">#CB00D7</span>
              </div>
              <strong class="ds-chip2-name">Gradient čísel SVG</strong>
              <p class="ds-chip2-desc">Výhradně v gradientu číslovacích SVG souborů sekcí (no-01.svg až no-07.svg). V textu na webu nepoužívat — příliš agresivní.</p>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #96BF48;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--accent-shopify</code>
                <span class="ds-chip2-hex">#96BF48</span>
              </div>
              <strong class="ds-chip2-name">Shopify zelená</strong>
              <p class="ds-chip2-desc">Pouze pro Shopify branding — badge, ikona, explicitní zmínky o Shopify platformě.</p>
            </div>
          </div>
        </div>

        <h3 class="ds-subsection-title">Neutralní</h3>
        <div class="ds-color-grid">
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #F8F9F9;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--neutral-100</code>
                <span class="ds-chip2-hex ds-chip2-hex-dark">#F8F9F9</span>
              </div>
              <strong class="ds-chip2-name ds-chip2-name-dark">Téměř bílá</strong>
              <p class="ds-chip2-desc ds-chip2-desc-dark">Text nebo pozadí na světlých prvcích. Zatím nevyužito.</p>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #D2D2D2;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--neutral-300</code>
                <span class="ds-chip2-hex ds-chip2-hex-dark">#D2D2D2</span>
              </div>
              <strong class="ds-chip2-name ds-chip2-name-dark">Světle šedá</strong>
              <p class="ds-chip2-desc ds-chip2-desc-dark">Sekundární text v kartách — popis pod názvem (app karty, reference karty).</p>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #A0A3BD;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--neutral-500</code>
                <span class="ds-chip2-hex ds-chip2-hex-dark">#A0A3BD</span>
              </div>
              <strong class="ds-chip2-name ds-chip2-name-dark">Středně šedá</strong>
              <p class="ds-chip2-desc ds-chip2-desc-dark">Muted text — metadata, poznámky, nav linky v klidovém stavu.</p>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #686868;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--neutral-700</code>
                <span class="ds-chip2-hex">#686868</span>
              </div>
              <strong class="ds-chip2-name">Tmavě šedá</strong>
              <p class="ds-chip2-desc">Velmi tlumený text. Zatím minimální využití.</p>
            </div>
          </div>
        </div>

        <h3 class="ds-subsection-title">Sémantické</h3>
        <div class="ds-color-grid ds-color-grid-4">
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #FF5252;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top"><code>--semantic-error</code><span class="ds-chip2-hex">#FF5252</span></div>
              <strong class="ds-chip2-name">Chyba</strong>
              <p class="ds-chip2-desc">Chybové stavy formulářů, upozornění.</p>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #4ECCA3;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top"><code>--semantic-success</code><span class="ds-chip2-hex">#4ECCA3</span></div>
              <strong class="ds-chip2-name">Úspěch</strong>
              <p class="ds-chip2-desc">Potvrzení, úspěšný stav.</p>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #FFA940;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top"><code>--semantic-warning</code><span class="ds-chip2-hex">#FFA940</span></div>
              <strong class="ds-chip2-name">Varování</strong>
              <p class="ds-chip2-desc">Upozornění, nedokončený stav.</p>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #5DADE2;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top"><code>--semantic-info</code><span class="ds-chip2-hex">#5DADE2</span></div>
              <strong class="ds-chip2-name">Info</strong>
              <p class="ds-chip2-desc">Informační zprávy, tooltips.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- PRAVIDLA -->
      <section class="ds-section" id="rules">
        <h2 class="ds-section-title">Pravidla barev</h2>

        <div class="ds-rules">

          <div class="ds-rule-card">
            <div class="ds-rule-pill" style="background: #16BECF; color: #000326;">CYAN</div>
            <div class="ds-rule-body">
              <strong>Cyan je vždy klikací prvek</strong>
              <p>Pokud je něco cyan, musí jít kliknout. Cyan slouží jako vizuální signál interaktivity — uživatel instinktivně ví, že na to může sáhnout.</p>
              <div class="ds-rule-cols">
                <div class="ds-rule-ok">
                  <span class="ds-rule-badge-ok">✓ správně</span>
                  <ul>
                    <li>Nav položka při hoveru</li>
                    <li>Nadpis sekce jako odkaz (.t-ac)</li>
                    <li>Quick-nav sekce</li>
                    <li>Pozadí CTA bloku (celý blok je klikací zóna)</li>
                  </ul>
                </div>
                <div class="ds-rule-bad">
                  <span class="ds-rule-badge-bad">✗ špatně</span>
                  <ul>
                    <li>Zvýraznění klíčového slova v textu</li>
                    <li>Dekorativní label nebo badge</li>
                    <li>Čísla sekcí nebo ikonky</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <div class="ds-rule-card">
            <div class="ds-rule-pill" style="background: #A081D1; color: #000326;">FIALOVÁ</div>
            <div class="ds-rule-body">
              <strong>Fialová je zvýraznění — nikdy odkaz</strong>
              <p>Fialová (--text-secondary) označuje důležité fráze v body textu. Je to ekvivalent tučného písma, jen s barvou navíc. Nesmí být zaměnitelná za odkaz.</p>
              <div class="ds-rule-cols">
                <div class="ds-rule-ok">
                  <span class="ds-rule-badge-ok">✓ správně</span>
                  <ul>
                    <li>&lt;strong class="ac"&gt; v popisech sekcí Co umíme</li>
                    <li>Pozadí stats baru</li>
                  </ul>
                </div>
                <div class="ds-rule-bad">
                  <span class="ds-rule-badge-bad">✗ špatně</span>
                  <ul>
                    <li>&lt;a&gt; tag s fialovou barvou</li>
                    <li>Tlačítko nebo CTA</li>
                    <li>Nav položka</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <div class="ds-rule-card">
            <div class="ds-rule-pill" style="background: #fff; color: #000326;">BÍLÁ</div>
            <div class="ds-rule-body">
              <strong>Bílá tlačítka = primární akce na tmavém pozadí</strong>
              <p>Bílé solid tlačítko je nejvýraznější CTA na stránce. Používá se max. jednou za sekci — vždy pro nejdůležitější akci.</p>
              <div class="ds-rule-cols">
                <div class="ds-rule-ok">
                  <span class="ds-rule-badge-ok">✓ správně</span>
                  <ul>
                    <li>Hlavní CTA v service sekcích Co umíme</li>
                    <li>Primární call-to-action na hero</li>
                  </ul>
                </div>
                <div class="ds-rule-bad">
                  <span class="ds-rule-badge-bad">✗ špatně</span>
                  <ul>
                    <li>Dvě bílé tlačítka vedle sebe</li>
                    <li>Sekundární nebo doplňková akce</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <div class="ds-rule-card">
            <div class="ds-rule-pill ds-rule-pill-outline">GHOST</div>
            <div class="ds-rule-body">
              <strong>Ghost tlačítko = sekundární nebo doplňková akce</strong>
              <p>Průhledné tlačítko s border (2px solid white nebo rgba). Vždy v páru s primárním tlačítkem nebo samostatně jako méně důležitá akce.</p>
              <div class="ds-rule-cols">
                <div class="ds-rule-ok">
                  <span class="ds-rule-badge-ok">✓ správně</span>
                  <ul>
                    <li>Hero sekce — "Jak pracujeme" vedle primárního CTA</li>
                    <li>Demo tlačítko (DEMO PŘIPRAVUJEME)</li>
                    <li>Odkaz na PDF nebo externí zdroj</li>
                  </ul>
                </div>
                <div class="ds-rule-bad">
                  <span class="ds-rule-badge-bad">✗ špatně</span>
                  <ul>
                    <li>Ghost jako jediné tlačítko v hero (bez primárního)</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <div class="ds-rule-card">
            <div class="ds-rule-pill" style="background: linear-gradient(135deg,#CB00D7,#A081D1); color: #fff;">GRADIENT</div>
            <div class="ds-rule-body">
              <strong>Magenta (#CB00D7) patří jen do SVG čísel</strong>
              <p>Výrazná neonová magenta se používá pouze v gradientu číslovacích SVG souborů (no-01.svg – no-07.svg). V UI textu nebo komponentách ji nepoužívat — je příliš agresivní a matoucí.</p>
            </div>
          </div>

          <div class="ds-rule-card">
            <div class="ds-rule-pill" style="background: var(--ds-surface); border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.5);">POZADÍ</div>
            <div class="ds-rule-body">
              <strong>Sekce se střídají pro vizuální rytmus</strong>
              <p>Na Co umíme a service pages se liché a sudé sekce střídají mezi --bg-elevated a --bg-secondary. Vytváří to optický dech bez nutnosti přidávat oddělovače.</p>
            </div>
          </div>

        </div>
      </section>

      <!-- TYPOGRAPHY -->
      <section class="ds-section" id="typography">
        <h2 class="ds-section-title">Typografie</h2>

        <h3 class="ds-subsection-title">Fonty</h3>
        <div class="ds-font-stack">
          <div class="ds-font-card">
            <span class="ds-font-var"><code>--font-primary</code></span>
            <span class="ds-font-name" style="font-family: var(--font-primary);">Kanit</span>
            <span class="ds-font-weights" style="font-family: var(--font-primary);">
              <span style="font-weight:400;">400 Regular</span>
              <span style="font-weight:500;">500 Medium</span>
              <span style="font-weight:600;">600 SemiBold</span>
              <span style="font-weight:700;">700 Bold</span>
              <span style="font-weight:900;">900 Black</span>
            </span>
            <span class="ds-font-use">Nadpisy, navigace, tlačítka, čísla</span>
          </div>
          <div class="ds-font-card">
            <span class="ds-font-var"><code>--font-secondary</code></span>
            <span class="ds-font-name" style="font-family: var(--font-secondary);">Montserrat</span>
            <span class="ds-font-weights" style="font-family: var(--font-secondary);">
              <span style="font-weight:400;">400 Regular</span>
              <span style="font-weight:500;">500 Medium</span>
              <span style="font-weight:600;">600 SemiBold</span>
            </span>
            <span class="ds-font-use">Body text, popisky, metadata</span>
          </div>
        </div>

        <h3 class="ds-subsection-title">Typografická škála — skutečně používáno</h3>
        <div class="ds-type-specimens">

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>H1 · hero pages</code>
              <span>var(--font-primary) · 700</span>
              <span>clamp(56px, 7.8vw, 100px)</span>
              <span>lh 1.15 · ls 0</span>
              <em>→ index, esyncer, ae-translator, co-umime</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
              <span style="font-family: var(--font-primary); font-size: clamp(40px,5.5vw,80px); font-weight: 700; line-height: 1.15; color: #fff; letter-spacing: 0;">Jsme<br />Shopify<br />specialisté</span>
            </div>
          </div>

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>H1 · service pages</code>
              <span>var(--font-primary) · 700</span>
              <span>clamp(40px, 5vw, 64px)</span>
              <span>lh 1.1</span>
              <em>→ ServiceHero.astro</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
              <span style="font-family: var(--font-primary); font-size: clamp(32px,3.8vw,64px); font-weight: 700; line-height: 1.1; color: #fff;">Potřebuji<br />brand</span>
            </div>
          </div>

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>H2 · sekce nadpis</code>
              <span>var(--font-primary) · 700</span>
              <span>clamp(32px, 3.6vw, 52px)</span>
              <span>lh 1.15–1.2</span>
              <em>→ index.astro, service pages</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
