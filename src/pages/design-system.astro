---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Design System — aethero web v3.1" lang="cs">
  <div class="ds-page">

    <!-- NAV -->
    <nav class="ds-nav">
      <a href="/" class="ds-nav-logo">← web</a>
      <div class="ds-nav-links">
        <a href="#web-v31">web-v3.1</a>
        <a href="#colors">Barvy</a>
        <a href="#typography">Typografie</a>
        <a href="#spacing">Spacing</a>
        <a href="#components">Komponenty</a>
        <a href="#inconsistencies" style="color: #FF5252;">⚠ Nekonzistence</a>
      </div>
    </nav>

    <!-- HEADER -->
    <header class="ds-header">
      <div class="ds-header-inner">
        <div>
          <p class="ds-label">Design System</p>
          <h1 class="ds-title">aethero web</h1>
          <p class="ds-version" id="web-v31">v3.1</p>
        </div>
        <div class="ds-header-meta">
          <div class="ds-meta-item">
            <span class="ds-meta-label">Fonts</span>
            <span class="ds-meta-val">Kanit + Montserrat</span>
          </div>
          <div class="ds-meta-item">
            <span class="ds-meta-label">Framework</span>
            <span class="ds-meta-val">Astro 6 / SSG</span>
          </div>
          <div class="ds-meta-item">
            <span class="ds-meta-label">Deploy</span>
            <span class="ds-meta-val">Cloudflare Pages</span>
          </div>
        </div>
      </div>
    </header>

    <main class="ds-main">

      <!-- LOGO -->
      <section class="ds-section" id="logo">
        <h2 class="ds-section-title">Logo</h2>
        <div class="ds-logo-grid">
          <div class="ds-logo-swatch ds-bg-dark">
            <img src="/ae-logo.svg" alt="æthero" height="40" />
            <span class="ds-swatch-label">Na tmavém pozadí</span>
          </div>
          <div class="ds-logo-swatch ds-bg-teal">
            <img src="/ae-logo.svg" alt="æthero" height="40" />
            <span class="ds-swatch-label">Na teal pozadí</span>
          </div>
          <div class="ds-logo-swatch ds-bg-white">
            <img src="/ae-logo.svg" alt="æthero" height="40" style="filter: invert(1) brightness(0);" />
            <span class="ds-swatch-label ds-label-dark">Na bílém pozadí</span>
          </div>
          <div class="ds-logo-swatch ds-bg-dark" style="align-items: flex-start; gap: 16px;">
            <img src="/ae-logo.svg" alt="æthero" height="28" />
            <img src="/shopify-plus-badge.svg" alt="Shopify Plus Partner" height="28" style="filter: brightness(0) invert(1);" />
            <span class="ds-swatch-label">Logo + badge (footer)</span>
          </div>
        </div>
      </section>

      <!-- COLORS -->
      <section class="ds-section" id="colors">
        <h2 class="ds-section-title">Barvy</h2>

        <h3 class="ds-subsection-title">Brand</h3>
        <div class="ds-color-row">
          <div class="ds-color-chip" style="background: #000326;">
            <span class="ds-color-name">bg-elevated</span>
            <span class="ds-color-hex">#000326</span>
          </div>
          <div class="ds-color-chip" style="background: #0C0C42;">
            <span class="ds-color-name">bg-secondary</span>
            <span class="ds-color-hex">#0C0C42</span>
          </div>
          <div class="ds-color-chip" style="background: #030626;">
            <span class="ds-color-name">bg-primary-alt</span>
            <span class="ds-color-hex">#030626</span>
          </div>
          <div class="ds-color-chip" style="background: #171A1C;">
            <span class="ds-color-name">neutral-900 (hero)</span>
            <span class="ds-color-hex">#171A1C</span>
          </div>
          <div class="ds-color-chip" style="background: #092066;">
            <span class="ds-color-name">brand-dark / stats</span>
            <span class="ds-color-hex">#092066</span>
          </div>
        </div>

        <h3 class="ds-subsection-title">Akcenty</h3>
        <div class="ds-color-row">
          <div class="ds-color-chip" style="background: #0DD4CD;">
            <span class="ds-color-name">action (teal)</span>
            <span class="ds-color-hex">#0DD4CD</span>
          </div>
          <div class="ds-color-chip" style="background: #16BECF;">
            <span class="ds-color-name">action-hover / footer-cta</span>
            <span class="ds-color-hex">#16BECF</span>
          </div>
          <div class="ds-color-chip" style="background: #A081D1;">
            <span class="ds-color-name">text-secondary / stats-bar</span>
            <span class="ds-color-hex">#A081D1</span>
          </div>
          <div class="ds-color-chip" style="background: #CB00D7;">
            <span class="ds-color-name">accent-purple</span>
            <span class="ds-color-hex">#CB00D7</span>
          </div>
          <div class="ds-color-chip" style="background: #96BF48;">
            <span class="ds-color-name">accent-shopify</span>
            <span class="ds-color-hex">#96BF48</span>
          </div>
        </div>

        <h3 class="ds-subsection-title">Neutralní</h3>
        <div class="ds-color-row">
          <div class="ds-color-chip ds-color-light" style="background: #F8F9F9;">
            <span class="ds-color-name">neutral-100</span>
            <span class="ds-color-hex">#F8F9F9</span>
          </div>
          <div class="ds-color-chip ds-color-light" style="background: #D2D2D2;">
            <span class="ds-color-name">neutral-300</span>
            <span class="ds-color-hex">#D2D2D2</span>
          </div>
          <div class="ds-color-chip ds-color-light" style="background: #A0A3BD;">
            <span class="ds-color-name">neutral-500</span>
            <span class="ds-color-hex">#A0A3BD</span>
          </div>
          <div class="ds-color-chip" style="background: #686868;">
            <span class="ds-color-name">neutral-700</span>
            <span class="ds-color-hex">#686868</span>
          </div>
        </div>

        <h3 class="ds-subsection-title">Sémantické</h3>
        <div class="ds-color-row">
          <div class="ds-color-chip" style="background: #FF5252;">
            <span class="ds-color-name">error</span>
            <span class="ds-color-hex">#FF5252</span>
          </div>
          <div class="ds-color-chip" style="background: #4ECCA3;">
            <span class="ds-color-name">success</span>
            <span class="ds-color-hex">#4ECCA3</span>
          </div>
          <div class="ds-color-chip" style="background: #FFA940;">
            <span class="ds-color-name">warning</span>
            <span class="ds-color-hex">#FFA940</span>
          </div>
          <div class="ds-color-chip" style="background: #5DADE2;">
            <span class="ds-color-name">info</span>
            <span class="ds-color-hex">#5DADE2</span>
          </div>
        </div>
      </section>

      <!-- TYPOGRAPHY -->
      <section class="ds-section" id="typography">
        <h2 class="ds-section-title">Typografie</h2>

        <h3 class="ds-subsection-title">Fonty</h3>
        <div class="ds-font-stack">
          <div class="ds-font-card">
            <span class="ds-font-var"><code>--font-primary</code></span>
            <span class="ds-font-name" style="font-family: var(--font-primary);">Kanit</span>
            <span class="ds-font-weights" style="font-family: var(--font-primary);">
              <span style="font-weight:400;">400 Regular</span>
              <span style="font-weight:500;">500 Medium</span>
              <span style="font-weight:600;">600 SemiBold</span>
              <span style="font-weight:700;">700 Bold</span>
              <span style="font-weight:900;">900 Black</span>
            </span>
            <span class="ds-font-use">Nadpisy, navigace, tlačítka, čísla</span>
          </div>
          <div class="ds-font-card">
            <span class="ds-font-var"><code>--font-secondary</code></span>
            <span class="ds-font-name" style="font-family: var(--font-secondary);">Montserrat</span>
            <span class="ds-font-weights" style="font-family: var(--font-secondary);">
              <span style="font-weight:400;">400 Regular</span>
              <span style="font-weight:500;">500 Medium</span>
              <span style="font-weight:600;">600 SemiBold</span>
            </span>
            <span class="ds-font-use">Body text, popisky, metadata</span>
          </div>
        </div>

        <h3 class="ds-subsection-title">Typografická škála — skutečně používáno</h3>
        <div class="ds-type-specimens">

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>H1 · homepage hero</code>
              <span>var(--font-primary) · 700</span>
              <span>clamp(56px, 7.8vw, 100px)</span>
              <span>lh 1.15 · ls 0</span>
              <em>→ cs/index.astro</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
              <span style="font-family: var(--font-primary); font-size: clamp(40px,5.5vw,80px); font-weight: 700; line-height: 1.15; color: #fff; letter-spacing: 0;">Jsme<br />Shopify<br />specialisté</span>
            </div>
          </div>

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>H1 · app pages</code>
              <span>var(--font-primary) · 700</span>
              <span>clamp(56px, 9vw, 130px)</span>
              <span>lh 1.0 · ls 0</span>
              <em>→ esyncer, ae-translator, co-umime</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
              <span style="font-family: var(--font-primary); font-size: clamp(42px,6vw,90px); font-weight: 700; line-height: 1.0; color: #fff; letter-spacing: 0;">eSyncer</span>
            </div>
          </div>

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>H1 · service pages</code>
              <span>var(--font-primary) · 700</span>
              <span>clamp(40px, 5vw, 64px)</span>
              <span>lh 1.1</span>
              <em>→ ServiceHero.astro</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
              <span style="font-family: var(--font-primary); font-size: clamp(32px,3.8vw,64px); font-weight: 700; line-height: 1.1; color: #fff;">Potřebuji<br />brand</span>
            </div>
          </div>

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>H2 · sekce nadpis</code>
              <span>var(--font-primary) · 700</span>
              <span>clamp(32px, 3.6vw, 52px)</span>
              <span>lh 1.15–1.2</span>
              <em>→ index.astro, service pages</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
              <span style="font-family: var(--font-primary); font-size: clamp(26px,3vw,48px); font-weight: 700; line-height: 1.15; color: #fff;">Reference<br />a případovky</span>
            </div>
          </div>

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>H2 · value prop</code>
              <span>var(--font-primary) · 600</span>
              <span>clamp(26px, 3.5vw, 48px)</span>
              <span>lh 1.2</span>
              <em>→ index.astro .value-heading</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
              <span style="font-family: var(--font-primary); font-size: clamp(22px,2.8vw,44px); font-weight: 600; line-height: 1.2; color: #fff;">Shopify dodá technologii,<br /><span style="color: var(--ds-accent);">aethero</span> strategii.</span>
            </div>
          </div>

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>H3 · service title</code>
              <span>var(--font-primary) · 900</span>
              <span>clamp(24px, 3vw, 40px)</span>
              <span>lh 1.1 · uppercase</span>
              <em>→ index.astro .service-title</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
              <span style="font-family: var(--font-primary); font-size: clamp(20px,2.5vw,36px); font-weight: 900; line-height: 1.1; color: #fff; text-transform: uppercase;">NOVÝ SHOPIFY<br />E-SHOP</span>
            </div>
          </div>

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>Body · section</code>
              <span>var(--font-secondary) · 400</span>
              <span>18–22px</span>
              <span>lh 1.6–1.75</span>
              <em>→ service pages, index</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
              <span style="font-family: var(--font-secondary); font-size: 18px; font-weight: 400; line-height: 1.7; color: rgba(255,255,255,0.75);">Od výběru projektu přes design a vývoj<br />až po první objednávku — a dál.</span>
            </div>
          </div>

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>Nav</code>
              <span>var(--font-primary) · 500</span>
              <span>16px · ls 0</span>
              <em>→ Header.astro</em>
            </div>
            <div class="ds-type-preview ds-bg-dark" style="gap: 0; flex-wrap: nowrap;">
              {['ÚVOD', 'CO UMÍME', 'APLIKACE', 'O NÁS', 'KONTAKT'].map(item => (
                <span style="font-family: var(--font-primary); font-size: 16px; font-weight: 500; letter-spacing: 0; color: #fff; padding: 0 20px; white-space: nowrap;">{item}</span>
              ))}
            </div>
          </div>

          <div class="ds-type-row">
            <div class="ds-type-meta">
              <code>Small / meta</code>
              <span>var(--font-secondary) · 400</span>
              <span>13–14px</span>
              <em>→ footer, labels, notes</em>
            </div>
            <div class="ds-type-preview ds-bg-dark">
              <span style="font-family: var(--font-secondary); font-size: 14px; color: rgba(160,163,189,1);">Česká Shopify agentura. Design, strategie, technologie.</span>
            </div>
          </div>

        </div>
      </section>

      <!-- NEKONZISTENCE -->
      <section class="ds-section ds-section-warn" id="inconsistencies">
        <h2 class="ds-section-title ds-title-warn">⚠ Nekonzistence — nutno sjednotit</h2>

        <!-- 1: H1 ve třech variantách -->
        <h3 class="ds-subsection-title">1 · H1 má 3 různé clamp() hodnoty</h3>
        <div class="ds-incon-grid">
          <div class="ds-incon-card ds-incon-bad">
            <div class="ds-incon-label">Homepage hero <span class="ds-incon-file">cs/index.astro</span></div>
            <div class="ds-incon-preview">
              <span style="font-family: var(--font-primary); font-size: clamp(36px,4.5vw,60px); font-weight: 700; line-height: 1.15; color: #fff;">Héro<br />text</span>
            </div>
            <code>clamp(56px, 7.8vw, 100px)</code>
          </div>
          <div class="ds-incon-card ds-incon-bad">
            <div class="ds-incon-label">App pages <span class="ds-incon-file">esyncer / ae-translator</span></div>
            <div class="ds-incon-preview">
              <span style="font-family: var(--font-primary); font-size: clamp(36px,5vw,70px); font-weight: 700; line-height: 1.0; color: #fff;">eSyncer</span>
            </div>
            <code>clamp(56px, 9vw, 130px)</code>
          </div>
          <div class="ds-incon-card ds-incon-bad">
            <div class="ds-incon-label">Service hero <span class="ds-incon-file">ServiceHero.astro</span></div>
            <div class="ds-incon-preview">
              <span style="font-family: var(--font-primary); font-size: clamp(28px,3.2vw,52px); font-weight: 700; line-height: 1.1; color: #fff;">Potřebuji<br />brand</span>
            </div>
            <code>clamp(40px, 5vw, 64px)</code>
          </div>
        </div>

        <!-- 2: Font-size tokeny nepoužívány -->
        <h3 class="ds-subsection-title">2 · Font-size tokeny v tokens.css — nikde se nepoužívají</h3>
        <div class="ds-token-unused-grid">
          {[
            { token: '--text-h1', val: '100px' },
            { token: '--text-h2', val: '70px' },
            { token: '--text-h2-vp', val: '54px' },
            { token: '--text-h3', val: '40px' },
            { token: '--text-body', val: '16px' },
            { token: '--text-section-body', val: '22px' },
            { token: '--text-label', val: '18px' },
            { token: '--text-small', val: '14px' },
          ].map(t => (
            <div class="ds-unused-token">
              <code>{t.token}</code>
              <span class="ds-unused-val">{t.val}</span>
              <span class="ds-unused-badge">NEPOUŽITO</span>
            </div>
          ))}
        </div>
        <p class="ds-incon-note">Místo těchto tokenů se všude píší hardcoded <code>clamp()</code> hodnoty. Buď tokeny smazat, nebo kód přepsat aby je používal.</p>

        <!-- 3: font-weight outlier -->
        <h3 class="ds-subsection-title">3 · font-weight 900 — osamocený outlier</h3>
        <div class="ds-incon-grid">
          <div class="ds-incon-card ds-incon-bad">
            <div class="ds-incon-label">Service title <span class="ds-incon-file">index.astro .service-title</span></div>
            <div class="ds-incon-preview">
              <span style="font-family: var(--font-primary); font-size: 28px; font-weight: 900; color: #fff; text-transform: uppercase;">NOVÝ E-SHOP</span>
            </div>
            <code>font-weight: 900 ← jediný výskyt</code>
          </div>
          <div class="ds-incon-card">
            <div class="ds-incon-label">Všechny ostatní nadpisy</div>
            <div class="ds-incon-preview">
              <span style="font-family: var(--font-primary); font-size: 28px; font-weight: 700; color: #fff;">Nadpis sekce</span>
            </div>
            <code>font-weight: 700 ← standard</code>
          </div>
        </div>

        <!-- 4: line-height -->
        <h3 class="ds-subsection-title">4 · line-height — stejný element, různá hodnota</h3>
        <div class="ds-incon-grid">
          <div class="ds-incon-card ds-incon-bad">
            <div class="ds-incon-label">H1 v index.astro <span class="ds-incon-file">line-height: 1.15</span></div>
            <div class="ds-incon-preview" style="line-height: 1.15;">
              <span style="font-family: var(--font-primary); font-size: 28px; font-weight: 700; color: #fff; line-height: 1.15;">První řádek<br />Druhý řádek<br />Třetí řádek</span>
            </div>
            <code>line-height: 1.15</code>
          </div>
          <div class="ds-incon-card ds-incon-bad">
            <div class="ds-incon-label">H1 v ServiceHero.astro <span class="ds-incon-file">line-height: 1.1</span></div>
            <div class="ds-incon-preview">
              <span style="font-family: var(--font-primary); font-size: 28px; font-weight: 700; color: #fff; line-height: 1.1;">První řádek<br />Druhý řádek<br />Třetí řádek</span>
            </div>
            <code>line-height: 1.1</code>
          </div>
          <div class="ds-incon-card ds-incon-bad">
            <div class="ds-incon-label">Body text index.astro <span class="ds-incon-file">line-height: 1.6</span></div>
            <div class="ds-incon-preview">
              <span style="font-family: var(--font-secondary); font-size: 15px; color: rgba(255,255,255,0.75); line-height: 1.6;">Od výběru projektu přes design<br />a vývoj až po první objednávku<br />a dál.</span>
            </div>
            <code>line-height: 1.6</code>
          </div>
          <div class="ds-incon-card ds-incon-bad">
            <div class="ds-incon-label">Body text CaseStudy/Blog <span class="ds-incon-file">line-height: 1.8</span></div>
            <div class="ds-incon-preview">
              <span style="font-family: var(--font-secondary); font-size: 15px; color: rgba(255,255,255,0.75); line-height: 1.8;">Od výběru projektu přes design<br />a vývoj až po první objednávku<br />a dál.</span>
            </div>
            <code>line-height: 1.8</code>
          </div>
        </div>

        <!-- 5: hardcoded font-family v design-system -->
        <h3 class="ds-subsection-title">5 · Hardcoded font-family místo tokenů — jen v tomto souboru</h3>
        <div class="ds-code-diff">
          <div class="ds-diff-bad">
            <span class="ds-diff-label">❌ Co tu je (11× výskyt)</span>
            <pre><code>font-family: 'Kanit', sans-serif;
font-family: 'Montserrat', sans-serif;</code></pre>
          </div>
          <div class="ds-diff-good">
            <span class="ds-diff-label">✓ Jak to má být</span>
            <pre><code>font-family: var(--font-primary);
font-family: var(--font-secondary);</code></pre>
          </div>
        </div>
        <p class="ds-incon-note">V komponentách (Header, Footer, ServiceHero) a pages se tokeny používají správně. Tento soubor je výjimka.</p>

      </section>

      <!-- SPACING -->
      <section class="ds-section" id="spacing">
        <h2 class="ds-section-title">Spacing</h2>
        <div class="ds-spacing-grid">
          {[
            { name: '--space-8', val: '8px' },
            { name: '--space-16', val: '16px' },
            { name: '--space-24', val: '24px' },
            { name: '--space-40', val: '40px' },
            { name: '--space-80', val: '80px (mob: 48px)' },
            { name: '--space-120', val: '120px (mob: 64px)' },
          ].map(s => (
            <div class="ds-spacing-item">
              <div class="ds-spacing-bar" style={`width: ${s.val.split('px')[0].replace('(','').trim()}px; max-width: 100%;`}></div>
              <code>{s.name}</code>
              <span class="ds-spacing-val">{s.val}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- COMPONENTS -->
      <section class="ds-section" id="components">
        <h2 class="ds-section-title">Komponenty</h2>

        <!-- Buttons -->
        <h3 class="ds-subsection-title">Tlačítka</h3>
        <div class="ds-component-row ds-bg-dark" style="padding: 40px; gap: 20px; flex-wrap: wrap;">
          <a href="#" class="btn-hero-demo">DO ČEHO SE SPOLU PUSTÍME?</a>
          <a href="#" class="btn-teal-demo">CHCI KONZULTACI</a>
          <a href="#" class="btn-outline-demo">VÍCE O TOM JAK PRACUJEME</a>
          <a href="#" class="btn-ref-demo">PŘEJÍT NA BU1</a>
        </div>
        <div class="ds-component-notes">
          <code>.btn-hero</code> — 22px Kanit 600, border 2px solid white, radius 6px, pad 9px 35px<br />
