<script>
  // DS Lightbox — standalone, nezasahuje do ostatních stránek
  (function () {
    const lb = document.getElementById('ds-lightbox');
    if (!lb) return;
    const lbImg = document.getElementById('ds-lb-img');
    const lbCounter = document.getElementById('ds-lb-counter');
    const items = [...document.querySelectorAll('.ds-gallery-item')];
    const images = items.map(item => ({ src: item.getAttribute('href'), alt: item.querySelector('img')?.alt || '' }));
    let current = 0;

    function show(index) {
      current = (index + images.length) % images.length;
      lbImg.src = images[current].src;
      lbImg.alt = images[current].alt;
      lbCounter.textContent = `${current + 1} / ${images.length}`;
    }
    function open(index) { show(index); lb.classList.add('is-open'); lb.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }
    function close() { lb.classList.remove('is-open'); lb.setAttribute('aria-hidden', 'true'); lbImg.src = ''; document.body.style.overflow = ''; }

    items.forEach((item, i) => item.addEventListener('click', e => { e.preventDefault(); open(i); }));
    lb.querySelector('.ds-lb-close').addEventListener('click', close);
    lb.querySelector('.ds-lb-prev').addEventListener('click', e => { e.stopPropagation(); show(current - 1); });
    lb.querySelector('.ds-lb-next').addEventListener('click', e => { e.stopPropagation(); show(current + 1); });
    lb.addEventListener('click', e => { if (e.target === lb || e.target === lbImg) close(); });
    document.addEventListener('keydown', e => {
      if (!lb.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  })();
</script>
