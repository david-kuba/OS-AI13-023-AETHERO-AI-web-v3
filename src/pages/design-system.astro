---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Design System — aethero web v3.1" lang="cs">
  <div class="ds-page">

    <!-- NAV -->
    <nav class="ds-nav">
      <a href="/" class="ds-nav-logo">← web</a>
      <div class="ds-nav-links">
        <a href="#web-v31">web-v3.1</a>
        <a href="#viewports">Viewport</a>
        <a href="#colors">Barvy</a>
        <a href="#rules">Pravidla</a>
        <a href="#typography">Typografie</a>
        <a href="#spacing">Spacing</a>
        <a href="#components">Tlačítka</a>
        <a href="#pills">Pills</a>
        <a href="#blocks">Bloky</a>
        <a href="#cards">Karty</a>
        <a href="#gallery">Galerie</a>
      </div>
    </nav>

    <!-- HEADER -->
    <header class="ds-header">
      <div class="ds-header-inner">
        <div>
          <p class="ds-label">Design System</p>
          <h1 class="ds-title">aethero web</h1>
          <p class="ds-version" id="web-v31">v3.1</p>
        </div>
        <div class="ds-header-meta">
          <div class="ds-meta-item">
            <span class="ds-meta-label">Fonts</span>
            <span class="ds-meta-val">Kanit + Montserrat</span>
          </div>
          <div class="ds-meta-item">
            <span class="ds-meta-label">Framework</span>
            <span class="ds-meta-val">Astro 6 / SSG</span>
          </div>
          <div class="ds-meta-item">
            <span class="ds-meta-label">Deploy</span>
            <span class="ds-meta-val">Cloudflare Pages</span>
          </div>
        </div>
      </div>
    </header>

    <main class="ds-main">

      <!-- LOGO -->
      <section class="ds-section" id="logo">
        <h2 class="ds-section-title">Logo</h2>
        <div class="ds-logo-grid">
          <div class="ds-logo-swatch ds-bg-dark">
            <img src="/ae-logo.svg" alt="æthero" height="40" />
            <span class="ds-swatch-label">Na tmavém pozadí</span>
          </div>
          <div class="ds-logo-swatch ds-bg-teal">
            <img src="/ae-logo.svg" alt="æthero" height="40" />
            <span class="ds-swatch-label">Na teal pozadí</span>
          </div>
          <div class="ds-logo-swatch ds-bg-white">
            <img src="/ae-logo.svg" alt="æthero" height="40" style="filter: invert(1) brightness(0);" />
            <span class="ds-swatch-label ds-label-dark">Na bílém pozadí</span>
          </div>
          <div class="ds-logo-swatch ds-bg-dark" style="align-items: flex-start; gap: 16px;">
            <img src="/ae-logo.svg" alt="æthero" height="28" />
            <img src="/shopify-plus-badge.svg" alt="Shopify Plus Partner" height="28" style="filter: brightness(0) invert(1);" />
            <span class="ds-swatch-label">Logo + badge (footer)</span>
          </div>
        </div>
      </section>

      <!-- COLORS -->
      <section class="ds-section" id="colors">
        <h2 class="ds-section-title">Barvy</h2>

        <h3 class="ds-subsection-title">Pozadí</h3>
        <div class="ds-color-grid">
          <div class="ds-chip2" style="--chip-bg: #00021A;">
            <div class="ds-chip2-swatch" style="background: #00021A;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--ae-bg-deep</code>
                <span class="ds-chip2-hex">#00021A</span>
              </div>
              <strong class="ds-chip2-name">Deep · darkest</strong>
              <p class="ds-chip2-desc">Nejhlubší vrstva — podklady za gradienty, výjimečné použití.</p>
            </div>
          </div>
          <div class="ds-chip2" style="--chip-bg: #000326;">
            <div class="ds-chip2-swatch"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--ae-bg-primary</code>
                <span class="ds-chip2-hex">#000326</span>
              </div>
              <strong class="ds-chip2-name">Primary · canvas</strong>
              <p class="ds-chip2-desc">Hlavní canvas webu. Většina sekcí, header po scrollu, dropdowny.</p>
            </div>
          </div>
          <div class="ds-chip2" style="--chip-bg: #0C0C42;">
            <div class="ds-chip2-swatch" style="background: #0C0C42;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--ae-bg-raised</code>
                <span class="ds-chip2-hex">#0C0C42</span>
              </div>
              <strong class="ds-chip2-name">Raised · cards</strong>
              <p class="ds-chip2-desc">Karty, inputy, vyvýšené elementy — lehce světlejší než canvas.</p>
            </div>
          </div>
          <div class="ds-chip2" style="--chip-bg: #2F324D;">
            <div class="ds-chip2-swatch" style="background: #2F324D;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--card-button</code>
                <span class="ds-chip2-hex">#2F324D</span>
              </div>
              <strong class="ds-chip2-name">Card / Button</strong>
              <p class="ds-chip2-desc">Šedomodrá — pozadí karet, tlačítek a interaktivních prvků.</p>
            </div>
          </div>
        </div>

        <h3 class="ds-subsection-title">Akcenty</h3>
        <div class="ds-color-grid">
          <div class="ds-chip2 ds-chip2-accent">
            <div class="ds-chip2-swatch" style="background: #16BECF;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--action</code>
                <span class="ds-chip2-hex">#16BECF</span>
              </div>
              <strong class="ds-chip2-name">Primární akcent — cyan</strong>
              <p class="ds-chip2-desc">Výhradně pro klikací prvky: nav linky při hoveru, nadpisy-linky (.t-ac třída), quick-nav, CTA sekce pozadí na app stránkách.</p>
              <span class="ds-chip2-rule ds-rule-link">📌 Cyan = vždy odkaz nebo CTA</span>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #0DD4CD;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--action-hover</code>
                <span class="ds-chip2-hex">#0DD4CD</span>
              </div>
              <strong class="ds-chip2-name">Action hover / Footer CTA bg</strong>
              <p class="ds-chip2-desc">Hover stav action barvy. Zároveň pozadí footer CTA sekce (Máme spolu co probrat?) a teal tlačítek.</p>
            </div>
          </div>
          <div class="ds-chip2 ds-chip2-accent">
            <div class="ds-chip2-swatch" style="background: #A081D1;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--text-secondary</code>
                <span class="ds-chip2-hex">#A081D1</span>
              </div>
              <strong class="ds-chip2-name">Zvýraznění textu / Stats bar</strong>
              <p class="ds-chip2-desc">Tučné zvýraznění klíčových frází v popisech sekcí (třída .ac, font-weight 900). Pozadí stats baru na homepage. Nikdy odkaz.</p>
              <span class="ds-chip2-rule ds-rule-nolink">🚫 Fialová = nikdy odkaz</span>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #552A9F;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--accent-purple</code>
                <span class="ds-chip2-hex">#552A9F</span>
              </div>
              <strong class="ds-chip2-name">Gradient čísel SVG</strong>
              <p class="ds-chip2-desc">Výhradně v gradientu číslovacích SVG souborů sekcí (no-01.svg až no-07.svg). V textu na webu nepoužívat — příliš agresivní.</p>
            </div>
          </div>
          <div class="ds-chip2">
            <div class="ds-chip2-swatch" style="background: #96BF48;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--accent-shopify</code>
                <span class="ds-chip2-hex">#96BF48</span>
              </div>
              <strong class="ds-chip2-name">Shopify zelená</strong>
              <p class="ds-chip2-desc">Pouze pro Shopify branding — badge, ikona, explicitní zmínky o Shopify platformě.</p>
            </div>
          </div>
          <div class="ds-chip2" style="--chip-bg: #092066;">
            <div class="ds-chip2-swatch" style="background: #092066;"></div>
            <div class="ds-chip2-body">
              <div class="ds-chip2-top">
                <code>--ae-straight-blue</code>
                <span class="ds-chip2-hex">#092066</span>
              </div>
              <strong class="ds-chip2-name">Straight Blue</strong>
              <p class="ds-chip2-desc">Text na světlém nebo barevném pozadí — čísla ve stats baru, kontaktní info v cyan CTA bloku. Nikdy jako pozadí.</p>
            </div>
          </div>
        </div>

      </section>

      <!-- PRAVIDLA -->
      <section class="ds-section" id="rules">
        <h2 class="ds-section-title">Pravidla barev</h2>

        <div class="ds-rules">

          <div class="ds-rule-card">
            <div class="ds-rule-pill" style="background: #16BECF; color: #000326;">CYAN</div>
            <div class="ds-rule-body">
              <strong>Cyan je vždy klikací prvek</strong>
              <p>Pokud je něco cyan, musí jít kliknout. Cyan slouží jako vizuální signál interaktivity — uživatel instinktivně ví, že na to může sáhnout.</p>
              <div class="ds-rule-cols">
                <div class="ds-rule-ok">
                  <span class="ds-rule-badge-ok">✓ správně</span>
                  <ul>
                    <li>Nav položka při hoveru</li>
                    <li>Nadpis sekce jako odkaz (.t-ac)</li>
                    <li>Quick-nav sekce</li>
                    <li>Pozadí CTA bloku (celý blok je klikací zóna)</li>
                  </ul>
                </div>
                <div class="ds-rule-bad">
                  <span class="ds-rule-badge-bad">✗ špatně</span>
                  <ul>
                    <li>Zvýraznění klíčového slova v textu</li>
                    <li>Dekorativní label nebo badge</li>
                    <li>Čísla sekcí nebo ikonky</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <div class="ds-rule-card">
            <div class="ds-rule-pill" style="background: #A081D1; color: #000326;">FIALOVÁ</div>
            <div class="ds-rule-body">
              <strong>Fialová je zvýraznění — nikdy odkaz</strong>
              <p>Fialová (--text-secondary) označuje důležité fráze v body textu. Je to ekvivalent tučného písma, jen s barvou navíc. Nesmí být zaměnitelná za odkaz.</p>
              <div class="ds-rule-cols">
                <div class="ds-rule-ok">
                  <span class="ds-rule-badge-ok">✓ správně</span>
                  <ul>
                    <li>&lt;strong class="ac"&gt; v popisech sekcí Co umíme</li>
                    <li>Pozadí stats baru</li>
                  </ul>
                </div>
                <div class="ds-rule-bad">
                  <span class="ds-rule-badge-bad">✗ špatně</span>
                  <ul>
                    <li>&lt;a&gt; tag s fialovou barvou</li>
                    <li>Tlačítko nebo CTA</li>
                    <li>Nav položka</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>


        </div>
      </section>

      <!-- TYPOGRAPHY -->
      <section class="ds-section" id="typography">
        <h2 class="ds-section-title">Typografie</h2>

        <h3 class="ds-subsection-title">Fonty</h3>
        <div class="ds-font-stack">
          <div class="ds-font-card">
            <span class="ds-font-var"><code>--font-primary</code></span>
            <span class="ds-font-name" style="font-family: var(--font-primary);">Kanit</span>
            <span class="ds-font-weights" style="font-family: var(--font-primary);">
              <span style="font-weight:400;">400 Regular</span>
              <span style="font-weight:500;">500 Medium</span>
              <span style="font-weight:600;">600 SemiBold</span>
              <span style="font-weight:700;">700 Bold</span>
              <span style="font-weight:900;">900 Black</span>
            </span>
            <span class="ds-font-use">Nadpisy, navigace, tlačítka, čísla</span>
          </div>
          <div class="ds-font-card">
            <span class="ds-font-var"><code>--font-secondary</code></span>
            <span class="ds-font-name" style="font-family: var(--font-secondary);">Montserrat</span>
            <span class="ds-font-weights" style="font-family: var(--font-secondary);">
              <span style="font-weight:400;">400 Regular</span>
              <span style="font-weight:500;">500 Medium</span>
              <span style="font-weight:600;">600 SemiBold</span>
            </span>
            <span class="ds-font-use">Body text, popisky, metadata</span>
          </div>
        </div>

        <p style="font-size:12px;color:rgba(255,255,255,0.4);line-height:1.6;margin-bottom:24px">
          Definováno v <code style="color:#0DD4CD">global.css</code>. Nikdy nevytvářej lokální heading třídy — použij jednu z těchto.<br />
          Každá třída má 3 varianty: <strong style="color:#fff">-maxi</strong> (větší), <strong style="color:#fff">bez suffixu</strong> (standard), <strong style="color:#fff">-mini</strong> (menší).
        </p>
        <table class="ds-gt-table">
          <thead>
            <tr><th>ID</th><th>Třída</th><th>Specifikace</th><th>Ukázka</th><th>Použití</th></tr>
          </thead>
          <tbody>
            <tr>
              <td class="ds-gt-id">T1a</td>
              <td><code class="ds-gt-class">.h1-maxi</code></td>
              <td class="ds-gt-meta">Kanit 700<br/>clamp(56px, 7.8vw, 100px)<br/>lh 1.15</td>
              <td class="ds-gt-preview"><span class="h1-maxi" style="color:#fff">Jsme specialisté</span></td>
              <td class="ds-gt-use">Homepage, co-umime,<br/>esyncer, ae-translator,<br/>kontakt</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T1b</td>
              <td><code class="ds-gt-class">.h1</code></td>
              <td class="ds-gt-meta">Kanit 700<br/>clamp(40px, 5vw, 64px)<br/>lh 1.1</td>
              <td class="ds-gt-preview"><span class="h1" style="color:#fff">Potřebuji brand</span></td>
              <td class="ds-gt-use">Service subpages<br/>(ServiceHero),<br/>o-nas, groomo</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T1c</td>
              <td><code class="ds-gt-class">.h1-mini</code></td>
              <td class="ds-gt-meta">Kanit 700<br/>clamp(32px, 4.5vw, 56px)<br/>lh 1.1</td>
              <td class="ds-gt-preview"><span class="h1-mini" style="color:#fff">Jak jsme stavěli</span></td>
              <td class="ds-gt-use">Rezerva —<br/>zatím nepoužito</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T2a</td>
              <td><code class="ds-gt-class">.h2-maxi</code></td>
              <td class="ds-gt-meta">Kanit 700<br/>clamp(40px, 5vw, 70px)<br/>lh 1.15</td>
              <td class="ds-gt-preview"><span class="h2-maxi" style="color:#fff">Brand, design</span></td>
              <td class="ds-gt-use">CTA sekce,<br/>velké sekce tituly</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T2b</td>
              <td><code class="ds-gt-class">.h2</code></td>
              <td class="ds-gt-meta">Kanit 700<br/>clamp(32px, 3.6vw, 52px)<br/>lh 1.2</td>
              <td class="ds-gt-preview"><span class="h2" style="color:#fff">Reference a případovky</span></td>
              <td class="ds-gt-use">Standardní<br/>sekce nadpis</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T2c</td>
              <td><code class="ds-gt-class">.h2-mini</code></td>
              <td class="ds-gt-meta">Kanit 600<br/>clamp(26px, 3.5vw, 48px)<br/>lh 1.2</td>
              <td class="ds-gt-preview"><span class="h2-mini" style="color:#fff">Shopify dodá technologii</span></td>
              <td class="ds-gt-use">Value prop,<br/>sekundární nadpisy</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T3a</td>
              <td><code class="ds-gt-class">.h3-maxi</code></td>
              <td class="ds-gt-meta">Kanit 700<br/>clamp(28px, 3.2vw, 46px)<br/>lh 1.15</td>
              <td class="ds-gt-preview"><span class="h3-maxi" style="color:#fff">E-shop pro páníčky</span></td>
              <td class="ds-gt-use">Velký H3<br/>(ne uppercase)</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T3b</td>
              <td><code class="ds-gt-class">.h3</code></td>
              <td class="ds-gt-meta">Kanit 900<br/>clamp(24px, 3vw, 40px)<br/>UPPERCASE · lh 1.1</td>
              <td class="ds-gt-preview"><span class="h3" style="color:#fff">Nový Shopify e-shop</span></td>
              <td class="ds-gt-use">Service titles<br/>(co-umime), tribe</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T3c</td>
              <td><code class="ds-gt-class">.h3-mini</code></td>
              <td class="ds-gt-meta">Kanit 700<br/>clamp(20px, 2.5vw, 30px)<br/>lh 1.2</td>
              <td class="ds-gt-preview"><span class="h3-mini" style="color:#fff">O našem přístupu</span></td>
              <td class="ds-gt-use">Subheading<br/>v textu</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T4a</td>
              <td><code class="ds-gt-class">.body-maxi</code></td>
              <td class="ds-gt-meta">Montserrat 400<br/>clamp(18px, 1.8vw, 22px)<br/>lh 1.65</td>
              <td class="ds-gt-preview"><span class="body-maxi" style="color:rgba(255,255,255,0.8)">Zkušená groomerka, která chtěla rozšířit své služby.</span></td>
              <td class="ds-gt-use">Perex, case study<br/>intro, hero subtitle</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T4b</td>
              <td><code class="ds-gt-class">.body</code></td>
              <td class="ds-gt-meta">Montserrat 400<br/>clamp(16px, 1.4vw, 18px)<br/>lh 1.65</td>
              <td class="ds-gt-preview"><span class="body" style="color:rgba(255,255,255,0.75)">Brand i název nám dal zabrat. Museli jsme se rozhodnout.</span></td>
              <td class="ds-gt-use">Standardní<br/>sekce text</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T4c</td>
              <td><code class="ds-gt-class">.body-mini</code></td>
              <td class="ds-gt-meta">Montserrat 500<br/>14px · lh 1.5</td>
              <td class="ds-gt-preview"><span class="body-mini" style="color:rgba(255,255,255,0.5)">Projekt realizován v Q4 2024 · klient: GROOMO.cz</span></td>
              <td class="ds-gt-use">Caption, meta,<br/>datum</td>
            </tr>
            <tr>
              <td class="ds-gt-id">T5</td>
              <td><code class="ds-gt-class">.label</code></td>
              <td class="ds-gt-meta">Kanit 600<br/>14px · ls 0.08em<br/>UPPERCASE</td>
              <td class="ds-gt-preview"><span class="label" style="color:rgba(255,255,255,0.7)">Brand & Identity</span></td>
              <td class="ds-gt-use">Eyebrow nad<br/>nadpisem, kategorie</td>
            </tr>
          </tbody>
        </table>
        <div class="ds-component-notes" style="margin-top:16px">
          ⚡ Pravidlo: Lokální CSS smí přepsat <code>max-width</code> nebo <code>grid-template</code>, ale NIKDY nesmí lokálně redefinovat <code>font-size</code> na headinzích — to patří výhradně do globální škály.
        </div>
      </section>

      <!-- NEKONZISTENCE - odstraněno, vše sjednoceno -->
      <section class="ds-section" id="inconsistencies" style="display:none">
        <h2 class="ds-section-title">Nekonzistence</h2>

        <!-- 1: H1 varianty -->
        <h3 class="ds-subsection-title">1 · H1 — dvě úrovně (sjednoceno)</h3>
        <div class="ds-incon-grid">
          <div class="ds-incon-card" style="border-color: #4ECCA3;">
            <div class="ds-incon-label" style="color: #4ECCA3;">Hero pages — všechny ✓ <span class="ds-incon-file">index, esyncer, ae-translator, co-umime</span></div>
            <div class="ds-incon-preview">
              <span style="font-family: var(--font-primary); font-size: clamp(36px,4.5vw,60px); font-weight: 700; line-height: 1.15; color: #fff;">Jsme<br />Shopify<br />specialisté</span>
            </div>
            <code style="color: #4ECCA3;">clamp(56px, 7.8vw, 100px) · lh 1.15</code>
          </div>
          <div class="ds-incon-card ds-incon-bad">
            <div class="ds-incon-label">Service hero <span class="ds-incon-file">ServiceHero.astro</span></div>
            <div class="ds-incon-preview">
              <span style="font-family: var(--font-primary); font-size: clamp(28px,3.2vw,52px); font-weight: 700; line-height: 1.1; color: #fff;">Potřebuji<br />brand</span>
            </div>
            <code>clamp(40px, 5vw, 64px) · lh 1.1</code>
          </div>
        </div>
        <p class="ds-incon-note">Dvě úrovně jsou záměrné — velké hero stránky vs. menší servisní hero. Větší varianta sjednocena na jednu hodnotu.</p>

        <!-- 2: Font-size tokeny nepoužívány -->
        <h3 class="ds-subsection-title">2 · Font-size tokeny v tokens.css — nikde se nepoužívají</h3>
        <div class="ds-token-unused-grid">
          {[
            { token: '--text-h1', val: '100px' },
            { token: '--text-h2', val: '70px' },
            { token: '--text-h2-vp', val: '54px' },
            { token: '--text-h3', val: '40px' },
            { token: '--text-body', val: '16px' },
