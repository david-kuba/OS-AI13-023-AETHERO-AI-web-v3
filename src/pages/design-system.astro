<style>
  @import url('https://fonts.googleapis.com/css2?family=Kanit:wght@400;500;600;700&family=Montserrat:wght@400;500;600&display=swap');

  :root {
    --ds-bg: #0A0A1A;
    --ds-surface: #12122A;
    --ds-border: rgba(255,255,255,0.06);
    --ds-text: #fff;
    --ds-muted: rgba(255,255,255,0.45);
    --ds-accent: #0DD4CD;
    --ds-purple: #A081D1;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--ds-bg); color: var(--ds-text); }

  .ds-page {
    min-height: 100vh;
    font-family: 'Montserrat', sans-serif;
    background: var(--ds-bg);
    color: var(--ds-text);
    -webkit-font-smoothing: antialiased;
  }

  /* NAV */
  .ds-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10,10,26,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--ds-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 48px;
    gap: 40px;
  }
  .ds-nav-logo {
    font-size: 13px;
    color: var(--ds-muted);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .ds-nav-logo:hover { color: var(--ds-text); }
  .ds-nav-links {
    display: flex;
    gap: 32px;
  }
  .ds-nav-links a {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--ds-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .ds-nav-links a:hover { color: var(--ds-accent); }

  /* HEADER */
  .ds-header {
    padding: 80px 40px 60px;
    border-bottom: 1px solid var(--ds-border);
    background: linear-gradient(180deg, rgba(13,212,205,0.04) 0%, transparent 100%);
  }
  .ds-header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }
  .ds-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--ds-accent);
    margin-bottom: 12px;
  }
  .ds-title {
    font-family: 'Kanit', sans-serif;
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 700;
    line-height: 1;
    color: #fff;
  }
  .ds-version {
    font-family: 'Kanit', sans-serif;
    font-size: 32px;
    font-weight: 400;
    color: var(--ds-purple);
    margin-top: 8px;
  }
  .ds-header-meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-bottom: 4px;
  }
  .ds-meta-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ds-meta-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--ds-muted);
    min-width: 80px;
  }
  .ds-meta-val {
    font-size: 13px;
    font-family: 'Kanit', sans-serif;
    color: #fff;
  }

  /* MAIN */
  .ds-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px 80px;
  }

  /* SECTIONS */
  .ds-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--ds-border);
  }
  .ds-section-title {
    font-family: 'Kanit', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--ds-accent);
    margin-bottom: 40px;
  }
  .ds-subsection-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--ds-muted);
    margin: 48px 0 16px;
  }
  .ds-subsection-title:first-of-type { margin-top: 0; }

  /* LOGO */
  .ds-logo-grid {
    display: grid;
