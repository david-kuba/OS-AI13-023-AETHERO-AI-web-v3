  }
  .ds-spacing-val {
    font-size: 14px;
    color: var(--ds-muted);
  }

  /* COMPONENTS */
  .ds-component-row {
    display: flex;
    align-items: center;
    border-radius: 10px;
    border: 1px solid var(--ds-border);
