    font-size: 13px;
    color: var(--ds-cyan);
    background: rgba(22,190,207,0.08);
    padding: 2px 7px;
    border-radius: 4px;
  }
  .ds-chip2-hex {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    font-family: monospace;
  }
  .ds-chip2-hex-dark { color: rgba(0,0,0,0.35); }
  .ds-chip2-name {
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
  }
  .ds-chip2-name-dark { color: rgba(0,0,0,0.75); }
  .ds-chip2-desc {
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    line-height: 1.55;
    margin: 0;
  }
  .ds-chip2-desc-dark { color: rgba(0,0,0,0.45); }
  .ds-chip2-rule {
    display: inline-block;
    margin-top: 6px;
    font-size: 13px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    align-self: flex-start;
  }
  .ds-rule-link {
    background: rgba(22,190,207,0.15);
    color: var(--ds-cyan);
  }
  .ds-rule-nolink {
    background: rgba(160,129,209,0.15);
    color: #A081D1;
  }

  /* RULES */
  .ds-rules {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .ds-rule-card {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 20px 24px;
  }
  .ds-rule-pill {
    flex-shrink: 0;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 3px;
  }
  .ds-rule-pill-outline {
    background: transparent;
    border: 2px solid rgba(255,255,255,0.5);
    color: rgba(255,255,255,0.7);
  }
  .ds-rule-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ds-rule-body strong {
    font-size: 17px;
    font-weight: 700;
    color: #fff;
    display: block;
  }
  .ds-rule-body > p {
    font-size: 15px;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    margin: 0;
  }
  .ds-rule-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 4px;
  }
  .ds-rule-ok, .ds-rule-bad {
    background: rgba(255,255,255,0.03);
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 14px;
    line-height: 1.6;
  }
  .ds-rule-ok { border-left: 3px solid #4ECCA3; }
  .ds-rule-bad { border-left: 3px solid #FF5252; }
  .ds-rule-badge-ok, .ds-rule-badge-bad {
    display: block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .ds-rule-badge-ok { color: #4ECCA3; }
  .ds-rule-badge-bad { color: #FF5252; }
  .ds-rule-ok ul, .ds-rule-bad ul {
    margin: 0;
    padding-left: 14px;
    color: rgba(255,255,255,0.55);
  }
  .ds-rule-ok li, .ds-rule-bad li { margin-bottom: 2px; }

  /* TYPOGRAPHY */
  .ds-type-specimens {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .ds-type-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 24px;
    align-items: stretch;
  }
  .ds-type-meta {
    font-size: 14px;
    color: var(--ds-muted);
    line-height: 1.6;
    padding: 24px 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ds-type-meta code {
    font-size: 15px;
    font-weight: 700;
    color: var(--ds-accent);
    font-family: monospace;
  }
  .ds-type-meta em {
    font-style: italic;
    color: var(--ds-muted);
    font-size: 13px;
  }
  .ds-type-preview {
    border-radius: 10px;
    padding: 32px 40px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    border: 1px solid var(--ds-border);
    overflow: hidden;
  }

  /* TEXT DEMO */
  .ds-text-demo-note { font-size: 14px; color: rgba(255,255,255,0.4); font-family: monospace; margin-bottom: 20px; }
  .ds-text-demo-note code { color: rgba(255,255,255,0.6); }
  .ds-text-demo-block { background: var(--ds-surface); border: 1px solid var(--ds-border); border-radius: 10px; padding: 32px 40px; }
  .ds-text-demo { font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 400; line-height: 1.65; color: rgba(255,255,255,0.75); }
  .ds-ac { color: #A081D1; font-weight: 600; font-style: normal; }

  /* SPACING */
  .ds-spacing-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .ds-spacing-item {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .ds-spacing-bar {
    height: 20px;
    background: linear-gradient(90deg, var(--ds-accent), var(--ds-purple));
