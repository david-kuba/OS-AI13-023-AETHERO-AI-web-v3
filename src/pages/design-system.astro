              </div>
            </a>
            <a href="/esyncer-screen-2.png" class="ds-gallery-item" data-ds-idx="1">
              <img src="/esyncer-screen-2.png" alt="eSyncer jobs" loading="lazy" class="ds-gallery-img" />
              <div class="ds-gallery-overlay" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
              </div>
            </a>
            <a href="/esyncer-screen-3.png" class="ds-gallery-item" data-ds-idx="2">
              <img src="/esyncer-screen-3.png" alt="eSyncer mappings" loading="lazy" class="ds-gallery-img" />
              <div class="ds-gallery-overlay" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
              </div>
            </a>
            <a href="/esyncer-screen-4.png" class="ds-gallery-item" data-ds-idx="3">
              <img src="/esyncer-screen-4.png" alt="eSyncer settings" loading="lazy" class="ds-gallery-img" />
              <div class="ds-gallery-overlay" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
              </div>
