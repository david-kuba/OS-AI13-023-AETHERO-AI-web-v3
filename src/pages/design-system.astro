              BG rgba(255,255,255,0.03) · Border 1px rgba(255,255,255,0.08) · Radius var(--radius-md)<br />
              Padding var(--space-24) · ★★★★★ žluté + citát (kurzíva) + autor + role<br />
              Flex column height 100%
            </div>
          </div>

          <div class="ds-incon-card ds-incon-ok">
            <div class="ds-incon-label">K6 — Feature card (co-umime)</div>
            <div class="ds-component-notes" style="margin-top:0;padding:0;border:none;font-size:11px;line-height:1.7">
              BG var(--bg-secondary) · Border 1px rgba(255,255,255,0.08) · Radius var(--radius-md)<br />
              Padding var(--space-24) · Ikona SVG 40px · Title Kanit 700 · Seznam itemů<br />
              Hover: border-color rgba(22,190,207,0.3)
            </div>
          </div>

        </div>
      </section>


      <!-- CITÁT / CITACE -->
      <section class="ds-section" id="quote">
        <h2 class="ds-section-title">Citát / Citace</h2>

        <!-- Varianta A: Inline s levým borderem (body sekce) -->
        <div class="ds-block-label">A — Inline · levý border · uvnitř sekce</div>
        <div class="ds-bg-dark" style="padding:40px 48px;margin-bottom:24px">
          <blockquote class="quote-side">
            <p>„Brand je to, co vám zůstane, když vám shoří továrna."</p>
            <cite>— David Ogilvy</cite>
          </blockquote>
        </div>

        <!-- Varianta B: Centrovaná s oddělovačem (standalone sekce) -->
        <div class="ds-block-label">B — Centrovaná · top border · standalone sekce</div>
        <div class="ds-bg-dark" style="padding:40px 48px;margin-bottom:24px;text-align:center">
          <blockquote class="quote-center">
            <p>„Nikdy jsme nečekali, že přechod proběhne takhle hladce. Výsledek překonal očekávání a zákazníci si změny pochvalují."</p>
            <cite>— Dominika Elliot, GROOMO.cz</cite>
          </blockquote>
        </div>

        <!-- Varianta C: Velká — hero citát (sekce na celou šíři) -->
        <div class="ds-block-label">C — Hero citát · velké písmo · centered</div>
        <div class="ds-bg-dark" style="padding:64px 48px;margin-bottom:24px;text-align:center">
          <blockquote class="quote-hero">
            <p>„Značka je slib. A dobrá značka je slib, který je vždy dodržen."</p>
            <cite>— Muhtar Kent</cite>
          </blockquote>
        </div>

        <div class="ds-spec-grid" style="margin-top:8px">
          <div class="ds-spec-item"><code>quote-side</code><span>border-left cyan 3px · 18–24px italic · cite 14px muted</span></div>
          <div class="ds-spec-item"><code>quote-center</code><span>border-top subtle · centered · 18–24px italic · cite 14px muted</span></div>
          <div class="ds-spec-item"><code>quote-hero</code><span>no border · 24–36px italic · centered · max-width 800px</span></div>
        </div>
      </section>


      <!-- GALERIE & LIGHTBOX -->
      <section class="ds-section" id="gallery">
        <h2 class="ds-section-title">Galerie & Lightbox</h2>
        <p style="font-size:12px;color:rgba(255,255,255,0.4);line-height:1.6;margin-bottom:24px">
          Komponenta s vlastními pravidly. Funkční náhled níže — klikni na obrázek.
        </p>

        <!-- PRAVIDLA -->
        <div class="ds-rule-grid" style="margin-bottom:32px">
          <div class="ds-rule-card">
            <div class="ds-rule-label">Grid</div>
            <div class="ds-rule-body">4 sloupce desktop · 2 tablet · 1+1 mobile<br />Gap 12px · margin-top var(--space-40)</div>
          </div>
          <div class="ds-rule-card">
            <div class="ds-rule-label">Thumbnail</div>
            <div class="ds-rule-body">aspect-ratio 16/10 · object-fit cover<br />border-radius var(--radius-md) · hover scale(1.05)</div>
          </div>
          <div class="ds-rule-card">
            <div class="ds-rule-label">Overlay</div>
            <div class="ds-rule-body">rgba(0,3,38,0.5) · ikona zoom SVG 28px<br />opacity 0 → 1 při hoveru (0.22s)</div>
          </div>
          <div class="ds-rule-card">
            <div class="ds-rule-label">Lightbox</div>
            <div class="ds-rule-body">fixed inset:0 · rgba(0,0,0,0.92) · z-index 9999<br />max 90vw/90vh · border-radius var(--radius-md)</div>
          </div>
          <div class="ds-rule-card">
            <div class="ds-rule-label">Navigace</div>
            <div class="ds-rule-body">← → klávesy · Escape zavřít<br />Prev/Next buttony ⌀ 60px · counter font-size 13px</div>
          </div>
          <div class="ds-rule-card">
            <div class="ds-rule-label">Použití</div>
            <div class="ds-rule-body">esyncer.astro · ae-translator.astro<br />Vždy s JS lightboxem — bez něj nefunguje</div>
          </div>
        </div>

        <!-- FUNKČNÍ NÁHLED -->
        <div class="ds-gallery-preview">
          <div class="ds-gallery-grid">
            <a href="/esyncer-screen-1.png" class="ds-gallery-item" data-ds-idx="0">
