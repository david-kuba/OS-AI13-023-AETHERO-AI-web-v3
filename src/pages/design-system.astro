  }
  .ds-btn-row {
    border-radius: 10px;
    padding: 36px 40px;
    display: flex;
    flex-wrap: wrap;
    gap: 32px;
    align-items: flex-start;
    margin-bottom: 4px;
  }
  .ds-btn-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
  }
  .ds-btn-tag {
    font-family: monospace;
