          </div>
        </div>

        <!-- DS lightbox overlay (scoped, nezasahuje do jiných stránek) -->
        <div id="ds-lightbox" class="ds-lightbox" aria-hidden="true" role="dialog" aria-modal="true">
          <button class="ds-lb-close" aria-label="Zavřít">✕</button>
          <button class="ds-lb-prev" aria-label="Předchozí">&#8249;</button>
          <button class="ds-lb-next" aria-label="Další">&#8250;</button>
          <img id="ds-lb-img" src="" alt="" class="ds-lb-img" />
          <div class="ds-lb-counter" id="ds-lb-counter"></div>
        </div>

        <div class="ds-component-notes" style="margin-top:24px">
          ⚡ Pravidlo: Lightbox JS vždy lokální v příslušné stránce (ne shared component) — každá stránka má svůj vlastní <code>#lightbox</code> overlay s unikátním ID. Galerie bez JS = jen grid bez zoom efektu.
        </div>
      </section>

      <span>aethero web design system · v3.1 · 2026</span>
    </footer>

  </div>
</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Kanit:wght@400;500;600;700&family=Montserrat:wght@400;500;600&display=swap');

  :root {
    --ds-bg: #00021A;
    --ds-surface: #000326;
    --ds-border: rgba(255,255,255,0.06);
    --ds-text: #fff;
    --ds-muted: rgba(255,255,255,0.45);
    --ds-accent: #0DD4CD;
    --ds-purple: #A081D1;
  }

  body { background: var(--ds-bg); color: var(--ds-text); }

  .ds-page {
    min-height: 100vh;
    font-family: 'Montserrat', sans-serif;
    background: var(--ds-bg);
    color: var(--ds-text);
    -webkit-font-smoothing: antialiased;
  }

  /* NAV */
  .ds-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(10,10,26,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--ds-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 48px;
    gap: 40px;
  }
  .ds-nav-logo {
    font-size: 14px;
    color: var(--ds-muted);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .ds-nav-logo:hover { color: var(--ds-text); }
  .ds-nav-links {
    display: flex;
    gap: 32px;
  }
  .ds-nav-links a {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--ds-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .ds-nav-links a:hover { color: var(--ds-accent); }

  /* HEADER */
  .ds-header {
    padding: 80px 40px 60px;
    border-bottom: 1px solid var(--ds-border);
    background: linear-gradient(180deg, rgba(13,212,205,0.04) 0%, transparent 100%);
  }
  .ds-header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }
  .ds-label {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 12px;
  }
  .ds-title {
    font-family: 'Kanit', sans-serif;
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 700;
    line-height: 1;
    color: #fff;
  }
  .ds-version {
    font-family: 'Kanit', sans-serif;
    font-size: 32px;
    font-weight: 400;
    color: var(--ds-purple);
    margin-top: 8px;
  }
  .ds-header-meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-bottom: 4px;
  }
  .ds-meta-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ds-meta-label {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ds-muted);
    min-width: 80px;
  }
  .ds-meta-val {
    font-size: 15px;
    font-family: 'Kanit', sans-serif;
    color: #fff;
  }

  /* MAIN */
  .ds-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px 80px;
  }

  /* SECTIONS */
  .ds-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--ds-border);
  }
  .ds-section-title {
    font-family: 'Kanit', sans-serif;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 40px;
  }
  .ds-subsection-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--ds-muted);
    margin: 48px 0 16px;
  }
  .ds-subsection-title:first-of-type { margin-top: 0; }

  /* LOGO */
  .ds-logo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .ds-logo-swatch {
    border-radius: 10px;
    padding: 32px 24px 16px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    border: 1px solid var(--ds-border);
  }
  .ds-bg-dark { background: #000326; }
  .ds-bg-teal { background: #0DD4CD; }
  .ds-bg-white { background: #fff; }
  .ds-swatch-label {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }
  .ds-label-dark { color: rgba(0,0,0,0.4); }

  /* COLORS */
  .ds-color-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 12px;
    margin-bottom: 8px;
  }
  .ds-color-grid-4 {
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  }
  .ds-chip2 {
    display: flex;
    flex-direction: column;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
  }
  .ds-chip2-swatch {
    height: 120px;
    background: var(--chip-bg, #888);
    flex-shrink: 0;
  }
  .ds-chip2-body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  .ds-chip2-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 2px;
  }
