  .ds-bg-dark { background: #000326; }
  .ds-bg-teal { background: #0DD4CD; }
  .ds-bg-white { background: #fff; }
  .ds-swatch-label {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
  }
  .ds-label-dark { color: rgba(0,0,0,0.4); }

  /* COLORS */
  .ds-color-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 12px;
    margin-bottom: 8px;
  }
  .ds-color-grid-4 {
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  }
  .ds-chip2 {
    display: flex;
    flex-direction: column;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
  }
  .ds-chip2-swatch {
    height: 120px;
    background: var(--chip-bg, #888);
    flex-shrink: 0;
  }
  .ds-chip2-body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }
  .ds-chip2-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 2px;
  }
  .ds-chip2-top code {
    font-size: 11px;
    color: var(--ds-cyan);
    background: rgba(22,190,207,0.08);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .ds-chip2-hex {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
