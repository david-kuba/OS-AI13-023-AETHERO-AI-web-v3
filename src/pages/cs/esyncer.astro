---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceHero from '../../components/layout/ServiceHero.astro';

const features = [
  { title: 'Přesné mapování kategorií', desc: 'Ze zdrojového feedu přímo do struktury vašeho e-shopu.' },
  { title: 'Manuální doplnění bez konfliktu', desc: 'Přidávejte produkty ručně — import je nepřepíše.' },
  { title: 'Kompatibilita s dalšími nástroji', desc: 'Funguje vedle ostatních importních nástrojů bez kolizí.' },
  { title: 'Automatické přiřazování tagů', desc: 'Tagy se přidávají automaticky podle pravidel z feedu.' },
  { title: 'Automatické mazání/deaktivace', desc: 'Produkt chybí v XML? Automaticky se deaktivuje nebo smaže.' },
  { title: 'Aktivace dle skladové zásoby', desc: 'Sklad 0 = produkt offline. Sklad > 0 = produkt online. Automaticky.' },
  { title: 'Plně na míru', desc: 'Každá implementace odpovídá přesně vaší logice a struktuře feedu.' },
];
---

<PageLayout title="eSyncer — import a synchronizace pro Shopify" description="Automatizace importu a synchronizace produktových dat z XML feedů přímo do Shopify." lang="cs">
  <ServiceHero
    label="Aplikace"
    title="eSyncer"
    subtitle="Import, synchronizace & automatizace (nejen) pro Shopify. S naší appkou potečou vaše aktualizovaná data o produktech bez manuální práce."
    ctaLabel="bara@aethero.cz"
    ctaHref="mailto:bara@aethero.cz"
  />

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Co eSyncer umí</h2>
      <div class="features-grid">
        {features.map((f) => (
          <div class="feature-card">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-secondary">
    <div class="container how-inner">
      <div>
        <h2 class="section-title">Jak to funguje</h2>
        <p class="how-text">
          Nepoužíváme generická přednastavená pravidla — specializujeme se na komplexní XML feedy.
          Prohlédneme zdrojový feed a požadovaný výstupní formát, celou strukturu replikujeme v synchronizačním nástroji
          a po integraci dostanete vlastní dashboard pro konfiguraci a monitoring.
        </p>
        <div class="how-ctas">
          <a href="mailto:bara@aethero.cz" class="btn-primary">Napište Báře</a>
          <a href="tel:+420776325440" class="btn-ghost">+420 776 325 440</a>
        </div>
      </div>
      <div class="how-highlight">
        <p class="highlight-label">PRO KOHO</p>
        <ul class="for-list">
          <li>E-shopy s dodavatelskými XML/CSV feedy</li>
          <li>Shopify projekty s komplexní produktovou strukturou</li>
          <li>Klienti potřebující automatizaci bez developerů</li>
          <li>Projekty kde standardní import nestačí</li>
        </ul>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: clamp(32px, 5vw, 70px); font-weight: 600; margin-bottom: var(--space-40); }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .feature-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .feature-card h3 { font-size: 15px; font-weight: 600; color: var(--action); margin-bottom: var(--space-8); }
  .feature-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .how-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); }
  .how-text { font-size: 16px; color: var(--neutral-300); line-height: 1.7; margin-bottom: var(--space-40); }
  .how-ctas { display: flex; gap: var(--space-16); flex-wrap: wrap; }
  .how-highlight { background: var(--bg-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-40); }
  .highlight-label { font-family: var(--font-primary); font-size: 11px; font-weight: 600; letter-spacing: 0; color: var(--action); text-transform: uppercase; margin-bottom: var(--space-16); }
  .for-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .for-list li { font-size: var(--text-small); color: var(--neutral-300); padding-left: 14px; position: relative; }
  .for-list li::before { content: '→'; position: absolute; left: 0; color: var(--action); font-size: 12px; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--bg-elevated); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: background var(--transition-base); }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: border-color var(--transition-base), color var(--transition-base); }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }
  @media (max-width: 1024px) { .features-grid { grid-template-columns: repeat(2, 1fr); } .how-inner { grid-template-columns: 1fr; } }
  @media (max-width: 768px) { .features-grid { grid-template-columns: 1fr; } }
</style>
