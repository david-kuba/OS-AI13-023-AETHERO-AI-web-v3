---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout title="eSyncer — import a synchronizace pro Shopify" description="Automatizace importu a synchronizace produktových dat z XML feedů přímo do Shopify. Specializujeme se na komplikované feedy." lang="cs">

  <!-- HERO -->
  <section class="app-hero">
    <div class="app-hero-bg" style="background-image: url('/header-image-esyncer.webp')"></div>
    <div class="app-hero-overlay"></div>
    <div class="container app-hero-inner">
      <img src="/es-sipky.svg" alt="eSyncer" class="app-hero-logo" />
      <h1>eSyncer</h1>
      <p class="app-hero-sub">Import, synchronizace &amp; automatizace<br />(nejen) pro&nbsp;<strong>SHOPIFY</strong></p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="intro-heading">S naší appkou potečou vaše aktualizovaná data o&nbsp;produktech z&nbsp;feedu dodavatele přesně tam, kam&nbsp;potřebujete!</h2>
      <p class="intro-text">Pokud hledáte způsob jak importovat automatizovaně .xml feed, jste tu správně. Víme jak těžké je to nastavit. Naší specializací jsou komplikované .XML feedy, .csv nebo API zdroje pro e-shopy. Importy vyladíme precizně osobně a dál běžíte automaticky.</p>
    </div>
  </section>

  <!-- BENEFITS + WHY -->
  <section class="section bg-secondary">
    <div class="container two-col">
      <div>
        <h2 class="section-title">Jaké má řešení výhody?</h2>
        <ul class="benefit-list">
          <li>Do vybraných kategorií obchodu se importují přesně vybrané kategorie zdrojů.</li>
          <li>Další produkty můžete přidat ručně, aniž by došlo ke konfliktu s importovanými produkty.</li>
          <li>Modul může dále pracovat s jinými importními aplikacemi a s ručně přidanými produkty.</li>
          <li>Můžete nastavit automatické tagy.</li>
          <li>Automaticky odstraňte/zakažte produkty, které v XML neexistují.</li>
          <li>Aplikace deaktivuje produkty, pokud je množství 0 a aktivuje, při počtu produktů vyšší než 0.</li>
          <li>Řešení lze plně upravit dle vašich dodatečných požadavků.</li>
        </ul>
      </div>
      <div>
        <h2 class="section-title">Proč ne vždy čistě automaticky?</h2>
        <p class="body-text">Existují aplikace s předem nastavenými pravidly pro parsování feedu. Ale co když je ten váš o něco komplikovanější a universální řešení na něj nestačí? Nejlepší způsob, jak vytvořit další funkce synchronizačního nástroje, je ukázat nám zdrojový feed a vzorový produkt, jak chcete, aby ve finále vypadal. Zkopírujeme strukturu a chování takové funkcionality a propojíme ji se synchronizačním nástrojem. Vaše data budou přesně tam, kde je chcete mít.</p>
        <p class="body-text">Po dokončení počáteční integrace vše zkontrolujete a případně zapracujeme vaše další požadavky. K dispozici je vám vlastní dashboard, který nabízí další možnosti konfigurace a mimo jiné umožňuje sledovat činnost aplikace.</p>
      </div>
    </div>
    <div class="container btn-demo-row">
      <a href="https://www.aethero.cz/files/esyncer-shopify-demo.pdf" target="_blank" rel="noopener" class="btn-demo">eSyncer DEMO</a>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="section bg-elevated section-screenshots">
    <div class="container">
      <h2 class="section-title">Náhledy aplikace</h2>
      <div class="gallery">
        <a href="/esyncer-screen-1.png" class="gallery-main" aria-label="Zobrazit větší">
          <img src="/esyncer-screen-1.png" alt="eSyncer dashboard" class="gallery-main-img" />
          <div class="gallery-zoom-hint" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
        </a>
        <div class="gallery-thumbs">
          <button class="gallery-thumb is-active" data-src="/esyncer-screen-1.png" data-alt="eSyncer dashboard" data-href="/esyncer-screen-1.png">
            <img src="/esyncer-screen-1.png" alt="eSyncer dashboard" loading="lazy" />
          </button>
          <button class="gallery-thumb" data-src="/esyncer-screen-2.png" data-alt="eSyncer jobs" data-href="/esyncer-screen-2.png">
            <img src="/esyncer-screen-2.png" alt="eSyncer jobs" loading="lazy" />
          </button>
          <button class="gallery-thumb" data-src="/esyncer-screen-3.png" data-alt="eSyncer mappings" data-href="/esyncer-screen-3.png">
            <img src="/esyncer-screen-3.png" alt="eSyncer mappings" loading="lazy" />
          </button>
          <button class="gallery-thumb" data-src="/esyncer-screen-4.png" data-alt="eSyncer settings" data-href="/esyncer-screen-4.png">
            <img src="/esyncer-screen-4.png" alt="eSyncer settings" loading="lazy" />
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div id="lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="lightbox-close" aria-label="Zavřít">✕</button>
    <img id="lightbox-img" src="" alt="" class="lightbox-img" />
  </div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Máme spolu co probrat?<br />Dejte vědět!</h2>
      <div class="cta-contacts">
        <a href="mailto:bara@aethero.cz" class="cta-contact">bara@aethero.cz</a>
        <a href="tel:+420776325440" class="cta-contact">+420 776 325 440</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* ─── HERO ─── */
  .app-hero {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: clamp(400px, 68vh, 700px);
  }
  .app-hero-bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center bottom;
  }
  .app-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,3,38,0.75) 100%);
  }
  .app-hero-inner {
    position: relative; z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    padding-top: 150px;
    padding-bottom: 48px;
  }
  .app-hero-logo {
    width: clamp(120px, 14vw, 220px);
    height: auto;
    object-fit: contain;
  }
  .app-hero h1 {
    font-family: var(--font-primary);
    font-size: clamp(56px, 7.8vw, 100px);
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
    margin: 0;
  }
  .app-hero-sub {
    font-size: clamp(18px, 2.5vw, 28px);
    color: rgba(255,255,255,0.85);
    line-height: 1.4;
    max-width: 680px;
    margin: 0;
  }
  .app-hero-sub strong { color: var(--action); font-weight: 700; }

  /* ─── SECTIONS ─── */
  .section { padding: 40px 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }

  .intro-heading {
    font-family: var(--font-primary);
    font-size: clamp(26px, 3.5vw, 48px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-32);
    max-width: 900px;
  }
  .intro-text {
    font-size: clamp(16px, 1.4vw, 20px);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    max-width: 800px;
  }

  .section-title {
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 600;
    color: #A081D1;
    margin-bottom: var(--space-32);
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-80);
    align-items: start;
  }

  .benefit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: var(--space-40);
  }
  .benefit-list li {
    font-size: 16px;
    color: rgba(255,255,255,0.8);
    line-height: 1.55;
    padding-left: 20px;
    position: relative;
  }
  .benefit-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--action);
    font-size: 14px;
  }

  .body-text {
    font-size: 16px;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin-bottom: var(--space-24);
  }

  .btn-demo-row { text-align: center; padding-top: var(--space-40); }
  .btn-demo {
    display: inline-flex;
    align-items: center;
    padding: 14px 40px;
    background: #fff;
    border: 2px solid #fff;
    color: var(--brand-dark, #000326);
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    transition: background 0.2s, color 0.2s;
  }
  .btn-demo:hover { background: var(--action); border-color: var(--action); color: #000; }

  /* ─── LIGHTBOX ─── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }
  .lightbox.is-open { display: flex; }
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: 2px solid rgba(255,255,255,0.5);
    color: #fff;
    font-size: 20px;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
    line-height: 1;
  }
  .lightbox-close:hover { border-color: #fff; color: #fff; }
  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    cursor: default;
    box-shadow: 0 20px 80px rgba(0,0,0,0.6);
  }

  /* ─── GALLERY ─── */
  .section-screenshots { padding-bottom: 80px; }
  .gallery { margin-top: var(--space-40); }
  .gallery-main {
    display: block;
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-secondary);
    aspect-ratio: 16 / 9;
    margin-bottom: 10px;
    cursor: zoom-in;
  }
  .gallery-main-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center top;
    display: block;
    transition: transform 0.35s, opacity 0.18s;
  }
  .gallery-main:hover .gallery-main-img { transform: scale(1.015); }
  .gallery-zoom-hint {
    position: absolute;
    bottom: 14px;
    right: 14px;
    width: 40px; height: 40px;
    background: rgba(0,0,0,0.55);
    color: #fff;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }
  .gallery-main:hover .gallery-zoom-hint { opacity: 1; }
  .gallery-thumbs {
    display: flex;
    gap: 10px;
  }
  .gallery-thumb {
    flex: 1;
    border: 2px solid transparent;
    padding: 0;
    background: none;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    opacity: 0.45;
    transition: opacity 0.2s, border-color 0.2s;
  }
  .gallery-thumb:hover { opacity: 0.75; }
  .gallery-thumb.is-active { opacity: 1; border-color: rgba(255,255,255,0.7); }
  .gallery-thumb img { width: 100%; height: auto; display: block; }

  /* ─── CTA ─── */
  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 {
    font-family: var(--font-primary);
    font-size: clamp(40px, 5vw, 70px);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin-bottom: var(--space-40);
  }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact {
    font-family: var(--font-primary);
    font-size: clamp(22px, 3vw, 40px);
    font-weight: 700;
    color: var(--brand-dark);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .screenshots-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; }
    .screenshots-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .app-hero-inner { padding-top: 100px; }
    .gallery-thumbs { flex-wrap: wrap; }
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');

  function openLightbox(src, alt) {
    lbImg.src = src;
    lbImg.alt = alt;
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    lbImg.src = '';
    document.body.style.overflow = '';
  }

  const mainLink = document.querySelector('.gallery-main');
  const mainImg = document.querySelector('.gallery-main-img');
  const thumbs = document.querySelectorAll('.gallery-thumb');

  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      mainImg.style.opacity = '0';
      setTimeout(() => {
        mainImg.src = thumb.dataset.src;
        mainImg.alt = thumb.dataset.alt;
        mainLink.href = thumb.dataset.href;
        mainImg.style.opacity = '1';
      }, 160);
      thumbs.forEach(t => t.classList.remove('is-active'));
      thumb.classList.add('is-active');
    });
  });

  mainLink?.addEventListener('click', e => {
    e.preventDefault();
    openLightbox(mainLink.href, mainImg.alt);
  });

  lb.querySelector('.lightbox-close').addEventListener('click', closeLightbox);
  lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>
