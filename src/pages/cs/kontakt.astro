---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout title="Kontakt | aethero" description="Zavolejte nebo napište. Nekoušeme. info@aethero.cz · +420 776 067 663" lang="cs">

  <section class="kontakt-hero">
    <div class="hero-blob" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-text">
        <h1>Ozvěte<br />se nám</h1>
        <p class="hero-sub">Zavolejte, napište! Nekoušeme.<br />Alespoň se seznámíme.</p>
      </div>
      <div class="hero-img-wrap" aria-hidden="true">
        <img src="/chain.webp" alt="" class="hero-img" loading="eager" />
      </div>
    </div>
    <img src="/a-blob-bgr-v31.webp" alt="" class="hero-bg-img" aria-hidden="true" loading="eager" />
  </section>

  <section class="section bg-primary">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-primary">
          <div class="contact-item">
            <a href="tel:+420776067663" class="contact-value">+420 776 067 663</a>
          </div>
          <div class="contact-item">
            <a href="mailto:info@aethero.cz" class="contact-value">info@aethero.cz</a>
          </div>
        </div>
        <div class="contact-secondary">
          <div class="contact-item">
            <p class="contact-label">SPOLEČNOST</p>
            <p class="contact-address">AETHERO s.r.o. · IČO: 05288762</p>
          </div>
          <div class="contact-item">
            <p class="contact-label">KORESPONDENČNÍ ADRESA</p>
            <address class="contact-address">
              Budovcova 700/14<br />
              370 01 České Budějovice
            </address>
          </div>
          <div class="contact-item">
            <p class="contact-label">FAKTURAČNÍ ADRESA</p>
            <address class="contact-address">
              Kurzova 2222/16<br />
              155 00 Praha
            </address>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div id="contact-map" role="region" aria-label="Mapa sídla aethero"></div>

</PageLayout>

<script is:inline>
  (function () {
    var link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
    document.head.appendChild(link);

    function initMap() {
      var map = L.map('contact-map', {
        center: [50.0481, 14.3104],
        zoom: 4,
        zoomControl: true,
        scrollWheelZoom: false,
      });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 19,
      }).addTo(map);

      var icon = L.divIcon({
        className: '',
        html: '<div style="width:20px;height:20px;background:#16BECF;border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 5px rgba(22,190,207,0.25),0 0 24px rgba(22,190,207,0.6)"></div>',
        iconSize: [20, 20],
        iconAnchor: [10, 10],
        popupAnchor: [0, -16],
      });

      L.marker([50.0481, 14.3104], { icon })
        .addTo(map)
        .bindPopup('æ');

      map.getPanes().tilePane.style.filter = 'sepia(1) hue-rotate(210deg) saturate(3) brightness(0.65)';
    }

    function loadLeaflet() {
      var s = document.createElement('script');
      s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      s.onload = initMap;
      document.head.appendChild(s);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', loadLeaflet);
    } else {
      loadLeaflet();
    }
  })();
</script>

<style>
  /* ── Hero ── */
  .kontakt-hero {
    position: relative;
    padding: 130px 0 100px;
    background: var(--ae-bg-primary-alt);
    overflow: hidden;
  }
  .hero-blob {
    position: absolute;
    top: -15%;
    right: -5%;
    width: 700px;
    height: 700px;
    background: radial-gradient(ellipse, rgba(80, 20, 160, 0.45) 0%, transparent 70%);
    border-radius: 50%;
    filter: blur(90px);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-64);
    align-items: center;
  }
  .hero-text h1 {
    font-size: clamp(56px, 7.8vw, 100px);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: var(--space-32);
  }
  .hero-sub {
    font-size: clamp(18px, 2.5vw, 28px);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.55;
  }
  .hero-img {
    width: clamp(180px, 26vw, 400px);
    height: auto;
    display: block;
  }
  .hero-bg-img {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: auto;
    pointer-events: none;
    z-index: 0;
    display: block;
  }

  /* ── Contact section ── */
  .section { padding: calc(var(--space-120) - 40px) 0 var(--space-120); }
  .bg-primary { background: var(--ae-bg-primary); }
  .section-title {
    font-size: clamp(30px, 4vw, 56px);
    font-weight: 700;
    margin-bottom: var(--space-64);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-80);
    align-items: start;
  }
  .contact-primary { display: flex; flex-direction: column; gap: var(--space-48); }
  .contact-secondary { display: flex; flex-direction: column; gap: var(--space-40); }
  .contact-label {
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-8);
  }
  .contact-value {
    font-family: var(--font-primary);
    font-size: clamp(26px, 3vw, 44px);
    font-weight: 700;
    color: var(--text-primary);
    transition: color var(--transition-base);
    display: block;
    text-decoration: none;
  }
  .contact-value:hover { color: var(--action); }
  .contact-address {
    font-style: normal;
    font-size: 17px;
    color: var(--neutral-300);
    line-height: 1.65;
  }

  /* ── Map ── */
  #contact-map {
    width: 100%;
    height: 800px;
    display: block;
  }

  /* Leaflet dark theme overrides */
  :global(.leaflet-popup-content-wrapper) {
    background: #13132a !important;
    color: #fff !important;
    border-radius: 6px !important;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.6) !important;
    font-size: 14px;
    line-height: 1.5;
  }
  :global(.leaflet-popup-tip) {
    background: #13132a !important;
  }
  :global(.leaflet-popup-close-button) {
    color: rgba(255, 255, 255, 0.5) !important;
  }
  :global(.leaflet-popup-close-button:hover) {
    color: #fff !important;
  }
  :global(.leaflet-control-attribution) {
    background: rgba(0, 0, 0, 0.45) !important;
    color: rgba(255, 255, 255, 0.35) !important;
  }
  :global(.leaflet-control-attribution a) {
    color: rgba(255, 255, 255, 0.45) !important;
  }
  :global(.leaflet-control-zoom a) {
    background: #13132a !important;
    color: #fff !important;
    border-color: rgba(255,255,255,0.1) !important;
  }
  :global(.leaflet-control-zoom a:hover) {
    background: #1e1e40 !important;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: var(--space-48); }
  }
  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-img-wrap { display: none; }
    .kontakt-hero { padding: 90px 0 60px; }
    #contact-map { height: 320px; }
  }
  @media (max-width: 480px) {
    .kontakt-hero { padding: 70px 0 48px; }
    .section { padding: var(--space-80) 0; }
  }
</style>
