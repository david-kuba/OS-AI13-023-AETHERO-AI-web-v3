---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';
import WorkSidebar from '../../../components/layout/WorkSidebar.astro';

const migrationSteps = [
  { icon: '<path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/>', title: 'Start', desc: 'Rozhodli jste se pro přechod na Shopify s námi.' },
  { icon: '<line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="16" x2="16" y1="18" y2="22"/>', title: 'Příprava', desc: 'Společně uděláme přípravu na migraci.' },
  { icon: '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>', title: 'Data & SEO', desc: 'Zkontrolujeme vstupy a nastavíme výstupy dle očekávání.' },
  { icon: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>', title: 'Migrace na Shopify', desc: 'Značka, narativ, barvy, digitální prezence, to vše hraje roli.' },
];


const features = [
  { title: 'Multichannel integrace', desc: 'Prodávejte <strong class="hl">z jedné administrace napříč všemi kanály</strong> — Instagram, TikTok, Google Shopping, Amazon. Jeden sklad, jedna pravda o zásobách, vše ze Shopify adminu.', img: '/shopify-chanels.webp', reverse: false },
  { title: 'Integrace na sociální sítě', desc: '<strong class="hl">Přímý prodej přes Instagram, TikTok, Facebook a YouTube.</strong> Unifikovaná správa kampaní, produktů a objednávek z jednoho místa. Zákazník nakupuje tam, kde je.', img: '/fbandinsta.webp', reverse: true },
  { title: 'Taxonomie a kategorizace', desc: 'Pokročilá organizace produktů s Shopify produktovou taxonomií — přes 10 000 standardizovaných kategorií. <strong class="hl">Lepší vyhledávání, SEO a zákaznická zkušenost.</strong>', img: '/shopify-produkt-taxonomy.webp', reverse: false },
  { title: 'Ukažte to v appce celému světu', desc: '<strong class="hl">Shopify Shop App dává zákazníkům brandovanou mobilní zkušenost.</strong> Notifikace, sledování objednávek, personalizovaný feed — v telefonu každého zákazníka.', img: '/shopapp.webp', reverse: true },
  { title: 'B2B profi řešení', desc: 'Shopify Plus umožňuje <strong class="hl">plnohodnotné B2B funkce — vlastní ceníky, firemní účty, schvalovací procesy, ERP napojení a B2B checkout.</strong> Enterprise funkce bez enterprise ceny.', img: '/b2b.webp', reverse: false },
];

---

<PageLayout title="Přechod na Shopify | aethero" description="Migrujte z Shoptetu, WooCommerce nebo jiné platformy na Shopify bez ztráty SEO, dat a zákazníků." lang="cs">
  <ServiceHero
    label="Migrace"
    title="PŘECHOD<br /><span style='color:#fff'>NA SHOPIFY</span>"
    subtitle="Váháte? Chcete poradit? Nebo už jste rozhodnutí? Tak pojďme na to s vámi."
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#proc-migrace"
    image="/donut.webp"
    imageAlt="Přechod na Shopify"
  />

  <!-- Intro + JAK TO UDĚLÁME sidebar -->
  <section class="section bg-primary">
    <div class="container intro-layout">
      <div class="intro-main">
        <h2 class="h1 intro-h2">Odstartujeme váš<br /><span class="accent-purple">PŘECHOD NA SHOPIFY</span></h2>
        <p class="intro-text">Narážíte na limity Shoptetu nebo WooCommerce? <strong class="hl">Shopify je otevřená globální platforma navržená pro růst</strong> — multi-měna, vícejazyčnost, integrace externích systémů a propojení online i offline prodeje přes POS.</p>
        <p class="intro-text">Pomůžeme vám <strong class="hl">přejít plynule — se zachováním SEO, dat i zákaznické zkušenosti</strong>. Spolupracujeme s e-shopy od startupů po velké hráče a víme, na co si dát pozor a jak neztrácet čas ani peníze.</p>
        <a href="#cta" class="btn-action btn-action--lg">Ano, chceme migraci</a>
      </div>
      <WorkSidebar heading="JAK TO UDĚLÁME" items={migrationSteps} />
    </div>
  </section>

  <!-- Shopify Edition Zima 2026 -->
  <section class="section bg-primary" id="proc-migrace">
    <div class="container edition-split">
      <div class="edition-media">
        <img src="/shopify-update-winter-2026.webp" alt="Shopify Edition Zima 2026" class="edition-img" loading="lazy" />
        <a href="/cs/blog/shopify-editions-zima-2026" class="edition-square">
          <h3 class="edition-square-title">Shopify<br />Edition<br />Zima 26 <span class="edition-arrow">➔</span></h3>
        </a>
      </div>
      <div class="edition-text">
        <p class="section-text body">Nové funkce pro rychlost, automatizaci a mezinárodní růst posouvají Shopify zase o kus dál před lokální platformy. Pokud cítíte, že váš e-shop brzdí technologie, teď je ideální chvíle na změnu. <a href="/cs/blog/shopify-editions-zima-2026" class="text-link">Přečti si náš přehled toho nejdůležitějšího ze Shopify Edition Zima 2026</a> nebo se rovnou podívejte <a href="https://www.shopify.com/editions" target="_blank" rel="noopener noreferrer" class="text-link">co všechno nově umí Shopify přímo na oficiálním webu</a>.</p>
        <a href="tel:+420776067663" class="btn-action btn-action--lg">Ozvěte se nám</a>
      </div>
    </div>
  </section>

  <!-- Feature sections -->
  {features.map((f, i) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}${i === 0 ? ' feature-section--first' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          {i === 0 && (
            <div class="feature-lead">
              <h2 class="h2 feature-section-heading">Funkce co vás potěší:</h2>
              <p class="body-maxi feature-lead-sub">Pokud se okolo standartních e-shopů pohybujete už delší dobu, tak tyto funkce a <strong class="hl">možnosti, které jsou u Shopify rovnou v základu, určitě oceníte</strong></p>
            </div>
          )}
          <h3 class="h3-mini feature-title">{f.title}</h3>
          <p class="body" set:html={f.desc}></p>
        </div>
        <div class="feature-img-wrap">
          <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Je na čase to rozjet?<br />Dejte vědět</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .intro-heading { font-size: var(--fs-52); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-40); max-width: 760px; }
  .intro-h2 { margin-bottom: var(--space-40); }
  /* Intro + JAK TO UDĚLÁME sidebar = 2 sloupce */
  .intro-layout { display: grid; grid-template-columns: 1fr 355px; gap: var(--space-64); align-items: start; }
  .intro-main { min-width: 0; }
  .intro-main .intro-text { max-width: none; }
  @media (max-width: 900px) { .intro-layout { grid-template-columns: 1fr; gap: var(--space-40); } }
  /* .hl (bold lavender) — globální utilita v global.css */
  .intro-text { font-size: var(--fs-20); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .intro-text--spaced { margin-top: var(--space-40); }
  .section { padding: var(--space-120) 0; }
  .section-title { margin-bottom: var(--space-40); }
  .section-text { margin-bottom: var(--space-24); }

  /* Shopify Edition blok — obrázek + fialový štítek vlevo, text+tlačítko vpravo */
  /* obrázek = levá 1/3, čtverec přesahuje doprava až ke středu (1/2), text = pravá půlka */
  .edition-split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: center; }
  .edition-media { position: relative; }
  .edition-img { width: 72%; height: auto; border-radius: var(--radius-md); display: block; }
  /* H3 nadpis ve fialovém čtverci — ukotvený k pravému okraji levé půlky (= střed) */
  .edition-square {
    position: absolute; top: 50%; right: 0; transform: translateY(-50%);
    width: 44%; aspect-ratio: 1 / 1;
    display: flex; align-items: center; justify-content: center;
    background: var(--accent-purple); text-decoration: none;
    padding: var(--space-16);
    box-shadow: 0 16px 40px rgba(0,0,0,0.4);
    transition: background var(--transition-base);
  }
  .edition-square:hover { background: var(--text-secondary); }
  .edition-square-title { margin: 0; color: #fff; font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; line-height: 1.1; }
  .edition-arrow { display: block; margin-top: var(--space-16); }

  .feature-section-heading { margin-bottom: var(--space-16); }
  /* lead text (sekční nadpis + perex) vložený do levého sloupce 1. bloku */
  .feature-lead { margin-bottom: var(--space-40); }
  .feature-lead-sub { margin-bottom: 0; }

  .feature-section { padding: var(--space-120) 0; }
  .feature-section--first { padding-top: var(--space-40); }
  .feature-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: center; }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text,
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-title { font-size: var(--fs-36); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }
  .feature-img { width: 100%; max-width: 560px; height: auto; border-radius: var(--radius-md); display: block; }


  @media (max-width: 1024px) {
    .edition-split { grid-template-columns: 1fr; gap: var(--space-40); }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
