---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const checkItems = [
  'Multi-měna a vícejazyčnost bez pluginů',
  'Integrace ERP, CRM a logistiky',
  'Zachování SEO a URL struktury',
  'Online + offline přes Shopify POS',
  'Automatizace procesů přes Shopify Flow',
  'Mezinárodní expanze bez migrace platformy',
];

const features = [
  { title: 'Multichannel integrace', desc: 'Prodávejte z jedné administrace napříč všemi kanály — Instagram, TikTok, Google Shopping, Amazon. Jeden sklad, jedna pravda o zásobách, vše ze Shopify adminu.', img: '/shopify-chanels.webp', reverse: false },
  { title: 'Integrace na sociální sítě', desc: 'Přímý prodej přes Instagram, TikTok, Facebook a YouTube. Unifikovaná správa kampaní, produktů a objednávek z jednoho místa. Zákazník nakupuje tam, kde je.', img: '/fbandinsta.webp', reverse: true },
  { title: 'Shopify App Store', desc: 'Přes 10 000 aplikací pro každou potřebu — od recenzí a věrnostních programů po fulfilment a B2B. Hotové integrace, které fungují okamžitě.', img: '/aplikace.webp', reverse: false },
  { title: 'Taxonomie a kategorizace', desc: 'Pokročilá organizace produktů s Shopify produktovou taxonomií — přes 10 000 standardizovaných kategorií. Lepší vyhledávání, SEO a zákaznická zkušenost.', img: '/shopify-produkt-taxonomy.webp', reverse: true },
  { title: 'Ukažte to v appce celému světu', desc: 'Shopify Shop App dává zákazníkům brandovanou mobilní zkušenost. Notifikace, sledování objednávek, personalizovaný feed — v telefonu každého zákazníka.', img: '/shopapp.webp', reverse: false },
  { title: 'B2B profi řešení', desc: 'Shopify Plus umožňuje plnohodnotné B2B funkce — vlastní ceníky, firemní účty, schvalovací procesy, ERP napojení a B2B checkout. Enterprise funkce bez enterprise ceny.', img: '/b2b.webp', reverse: true },
];

const relatedServices = [
  { href: '/cs/co-umime/potrebuji-brand', label: 'Potřebuji brand' },
  { href: '/cs/co-umime/novy-shopify-e-shop', label: 'Nový Shopify e-shop' },
  { href: '/cs/co-umime/expanze-do-zahranici', label: 'Expanze do zahraničí' },
  { href: '/cs/co-umime/rozvoj-a-podpora', label: 'Rozvoj a podpora' },
  { href: '/cs/co-umime/analyza-a-strategie', label: 'Analýza a strategie' },
  { href: '/cs/co-umime/custom-vyvoj-a-aplikace', label: 'Custom vývoj a aplikace' },
];
---

<PageLayout title="Přechod na Shopify | aethero" description="Migrujte z Shoptetu, WooCommerce nebo jiné platformy na Shopify bez ztráty SEO, dat a zákazníků." lang="cs">
  <ServiceHero
    label="Migrace"
    title="PŘECHOD<br /><span style='color:var(--action)'>NA SHOPIFY</span>"
    subtitle="Váháte? Chcete poradit? Nebo už jste rozhodnutí? Tak pojďme na to s vámi."
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#proc-migrace"
    image="/donut.webp"
    imageAlt="Přechod na Shopify"
  />

  <!-- Intro -->
  <section class="section-intro bg-elevated">
    <div class="container">
      <h2 class="intro-heading">Odstartujeme váš<br /><span class="text-action">PŘECHOD NA SHOPIFY</span></h2>
      <p class="intro-text">Narážíte na limity Shoptetu nebo WooCommerce? Shopify je otevřená globální platforma navržená pro růst — multi-měna, vícejazyčnost, integrace externích systémů a propojení online i offline prodeje přes POS.</p>
      <p class="intro-text">Pomůžeme vám přejít plynule — se zachováním SEO, dat i zákaznické zkušenosti.</p>
      <a href="tel:+420776067663" class="btn-action">Zavolejme si zdarma</a>
      <p class="intro-text intro-text--spaced">Spolupracujeme s e-shopy od startupů po velké hráče. Přecházíme z různých platforem — Shoptet, WooCommerce, Magento nebo custom řešení. Víme, na co si dát pozor a jak neztrácet čas ani peníze.</p>
      <a href="#proc-migrace" class="intro-link">Ano, chceme migrovat →</a>
    </div>
  </section>

  <!-- 2-col: text + checklist -->
  <section class="section bg-secondary" id="proc-migrace">
    <div class="container two-col-check">
      <div>
        <h2 class="section-title">Shopify Edition Zima 2026</h2>
        <p class="section-text">Shopify vydává velké funkční updaty 2× ročně. Každé vydání přináší nové funkce pro obchodníky, vývojáře i zákazníky — a Shopify vás neúčtuje zvlášť za upgrade. Na to jste s jinými platformami zvyklí?</p>
        <div class="edition-img-wrap">
          <img src="/shopify-update-winter-2026.webp" alt="Shopify Edition Zima 2026" class="edition-img" loading="lazy" />
        </div>
        <p class="section-text">Jako Shopify partner dostáváme přístup k novinkám dřív než ostatní — a přenášíme je přímo do vašeho e-shopu. <a href="https://www.shopify.com/editions" target="_blank" rel="noopener" class="section-link">Shopify Editions Zima 2026</a> nám na to nové nabídku dáváme přímo do vašeho projektu.</p>
      </div>
      <div>
        <h2 class="section-title">Jak to začít</h2>
        <ul class="check-list">
          {checkItems.map((c) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{c}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="container" style="margin-top: var(--space-64); text-align: center;">
      <a href="tel:+420776067663" class="btn-action">Ozvěte se nám</a>
    </div>
  </section>

  <!-- Feature heading -->
  <section class="section-heading bg-elevated">
    <div class="container">
      <h2 class="feature-section-heading">Funkce co vás potěší:</h2>
      <p class="section-text">Pokud se chcete standardních e-shopů pohybujete ze světa dat, tak tyto funkce a možnosti, které jsou rovnou v základu, určitě oceníte</p>
    </div>
  </section>

  <!-- Feature sections -->
  {features.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          <h2 class="feature-title">{f.title}</h2>
          <p class="feature-desc">{f.desc}</p>
        </div>
        <div class="feature-img-wrap">
          <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />
        </div>
      </div>
    </section>
  ))}

  <!-- Related -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Další služby</h2>
      <ul class="related-services">
        {relatedServices.map((s) => (
          <li>
            <a href={s.href} class="related-link">
              <span>{s.label}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Je na čase to rozjet?<br />Dejte vědět</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading { font-size: clamp(32px, 4vw, 52px); font-weight: 700; line-height: 1.15; margin-bottom: var(--space-40); max-width: 760px; }
  .text-action { color: var(--action); }
  .intro-text { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.75; max-width: 720px; margin-bottom: var(--space-16); }
  .intro-text--spaced { margin-top: var(--space-40); }
  .btn-action { display: inline-flex; padding: 16px 40px; background: var(--action); color: #000; font-family: var(--font-primary); font-size: 15px; font-weight: 700; border-radius: var(--radius-md); text-decoration: none; margin: var(--space-32) 0; transition: background var(--transition-base); }
  .btn-action:hover { background: var(--action-hover); }
  .intro-link { display: inline-block; margin-top: var(--space-24); color: var(--action); font-size: 16px; font-weight: 600; text-decoration: none; }
  .intro-link:hover { opacity: 0.75; }

  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-40); }
  .section-text { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: var(--space-24); }
  .section-link { color: var(--action); text-decoration: none; font-weight: 600; }
  .section-link:hover { opacity: 0.75; }

  .two-col-check { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .edition-img-wrap { margin-bottom: var(--space-24); }
  .edition-img { width: 100%; max-width: 400px; height: auto; border-radius: var(--radius-md); display: block; }
  .check-list { list-style: none; display: flex; flex-direction: column; gap: 16px; padding-top: var(--space-8); }
  .check-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 15px; color: rgba(255,255,255,0.8); line-height: 1.5; }
  .check-list svg { flex-shrink: 0; margin-top: 2px; }

  .section-heading { padding: var(--space-80) 0 var(--space-40); }
  .feature-section-heading { font-size: clamp(24px, 3vw, 40px); font-weight: 700; margin-bottom: var(--space-16); }

  .feature-section { padding: var(--space-120) 0; }
  .feature-section:nth-child(odd) { background: var(--bg-elevated); }
  .feature-section:nth-child(even) { background: var(--bg-secondary); }
  .feature-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: center; }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text,
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-title { font-size: clamp(24px, 3vw, 36px); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); }
  .feature-desc { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.75; }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }
  .feature-img { width: 100%; max-width: 560px; height: auto; border-radius: var(--radius-md); display: block; }

  .related-services { list-style: none; display: flex; flex-direction: column; }
  .related-link { display: flex; align-items: center; justify-content: space-between; padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 15px; color: var(--neutral-300); transition: color var(--transition-base); text-decoration: none; }
  .related-link:hover { color: var(--action); }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: clamp(28px, 4vw, 48px); font-weight: 700; color: #000; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: 20px; font-weight: 700; color: #000; text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { opacity: 0.7; }

  @media (max-width: 1024px) {
    .two-col-check { grid-template-columns: 1fr; }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
