---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';
import WorkSidebar from '../../../components/layout/WorkSidebar.astro';

const processItems = [
  { icon: '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>', title: 'Rychlý audit & zadání', desc: 'Co přesně má být výsledkem a jak poznáme, že to funguje.' },
  { icon: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>', title: 'Návrh řešení', desc: 'Varianty: appka vs. úprava vs. integrace (a proč).' },
  { icon: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>', title: 'MVP', desc: 'První verze, co už přináší hodnotu (a je bezpečná pro provoz).' },
  { icon: '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>', title: 'Iterace & škálování', desc: 'Doladíme hrany, přidáme automatizace, zrychlíme.' },
  { icon: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"/><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"/><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"/><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"/>', title: 'Podpora', desc: 'Ať to žije i za 3 měsíce, ne jen v den spuštění.' },
];

const whenCustom = [
  'potřebujete napojení na ERP / sklad / dodavatele, ale data jsou „jinačí"',
  'chcete vlastní logiku v košíku / dopravě / slevách / B2B, kterou univerzální appky neumí',
  'řešíte lokální požadavky (CZ/SK i širší zahraničí) a nechcete další „lepení páskou"',
  'potřebujete automatizace, které šetří čas každý den',
];

const deliverables = [
  'Shopify theme úpravy (Liquid, UX/CRO drobnosti, výkon)',
  'Shopify Functions & checkout logika (slevy, doprava, B2B pravidla – tam, kde to Shopify dovolí)',
  'Integrace přes API (ERP, CRM, WMS, dopravci, fakturace, PIM…)',
  'Custom aplikace (private/public), admin nástroje, dashboardy',
  'Datové toky (importy/exporty, validace, mapování polí, automatizace)',
];


const hardCases = [
  { title: 'Dodavatelské feedy a importy', desc: 'Když „univerzální" parser nestačí a potřebujete vlastní mapování, pravidla, validaci a dohled.' },
  { title: 'B2B logika', desc: 'Ceny po přihlášení, individuální ceníky, schvalování objednávek, platební limity.' },
  { title: 'Doprava & platby', desc: 'Lokálně i mezinárodně: pravidla, která se mění podle země, košíku, skladu, marže.' },
  { title: 'ERP/WMS integrace', desc: 'Skladové pohyby, fakturace, vratky, stav objednávek – aby data seděla všude.' },
  { title: 'Admin nástroje', desc: 'Interní dashboardy, které zrychlí práci týmu (a sníží chybovost).' },
];

const whyUs = [
  { title: 'Shopify-first přístup', desc: 'Využít maximum z platformy, a custom jen tam, kde to dává smysl.' },
  { title: 'Poměr cena/výkon', desc: 'Radši chytré řešení než drahá stavba pro stavbu.' },
  { title: 'E-commerce v DNA', desc: 'Řešíme nejen kód, ale i UX, data a dopady do provozu.' },
  { title: 'Udržitelnost', desc: 'Ať to není „one-off", ale věc, kterou umíte rozvíjet.' },
];

const faq = [
  { q: 'Kolik to stojí?', a: 'To záleží. Jedna drobná úprava může být rychlovka, aplikace je už ale projekt. Po krátkém ujasnění zadání vám dáme varianty a doporučení, co má nejlepší poměr cena/výkon.' },
  { q: 'Děláte i „jen" konzultaci?', a: 'Ano. Někdy stačí 60–90 minut a máme všichni jasno, co stavět, co koupit jako appku a čemu se vyhnout a proč.' },
  { q: 'Umíte napojit i něco, co „nemá integraci"?', a: 'Pokud má služba API (nebo aspoň rozumný export/import), většinou se cesta najde.' },
];

---

<PageLayout title="Custom vývoj a aplikace | aethero" description="Vlastní Shopify aplikace, integrace a úpravy šablon přesně pro vaše potřeby." lang="cs">
  <ServiceHero
    label="Custom vývoj"
    title="APLIKACE &<br /><span style='color:#fff'>CUSTOM VÝVOJ</span>"
    subtitle="Máte pocit, jste vyčerpali všechny možnosti okolo aplikací nebo máte něco atypického? OK, tak pojďme na to!"
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#jak-to-delame"
    image="/infinity.webp"
    imageAlt="Custom vývoj a aplikace pro Shopify"
  />

  <!-- Potřebujete APPKU nebo <span class="accent-purple">CUSTOM ÚPRAVU</span>? -->
  <section class="section bg-primary" id="jak-to-delame">
    <div class="container intro-layout">
      <div class="intro-main">
        <h2 class="h1 intro-h2">Potřebujete <span class="accent-purple">APPKU</span><br />nebo <span class="accent-purple">CUSTOM ÚPRAVU</span>?</h2>
        <p class="intro-text">Tato část naší práce je, na straně jedné, úžasně jednoduchá — na vysvětlování, ale také <strong class="hl">dosti nepředvídatelná na straně druhé — při realizaci</strong>. V ideálním případě za námi přijdete s definicí problému a odcházíte od nás s řešením. Je to srozumitelné?</p>
        <h3 class="h3-mini intro-subhead">Nejdřív porozumět, pak řešit.</h3>
        <p class="intro-text">Aby custom řešení nespálila váš rozpočet ani nervy, držíme se jednoduché logiky: nejprve pochopit problém, pak teprve něco stavět.</p>
        <p class="intro-text">Zkontrolujeme zda opravdu někde není nějaké řešení hotové a pak společně rozebereme váš problém na kousky, abychom ho mohli vyřešit. Někdy je to jedna drobná úprava, která zvedne konverze. Jindy je to napojení, které vám <strong class="hl">srovná data v celém provozu</strong>. A občas je to aplikace, bez které to prostě nepůjde.</p>
        <a href="#cta" class="btn-action btn-action--lg">Super, sem s tím</a>
      </div>
      <WorkSidebar heading="JAK TO DĚLÁME" items={processItems} />
    </div>
  </section>

  <!-- Kdy je čas na custom + Úpravy/integrace (2-col) -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h2 section-title">Kdy už je čas na „custom" ?</h2>
      <p class="section-text body">Shopify App Store je super. Občas ale narazíte na hranici: lokální specifika, netypická data, složitější proces, nebo máte prostě potřebu, která je „jen vaše", kvůli zboží či službě. A tehdy dává smysl něco postavit: rychle, čistě a tak, aby to šlo dlouhodobě udržet.</p>
      <div class="custom-2col">
        <div>
          <h3 class="when-subhead">Appka občas nestačí když</h3>
          <ul class="arrow-list">
            {whenCustom.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a href="tel:+420776067663" class="btn-action btn-action--lg">Super, sem s tím.</a>
        </div>
        <div>
          <h3 class="when-subhead">Úpravy, integrace i vlastní aplikace</h3>
          <ul class="arrow-list">
            {deliverables.map((d) => (
              <li>{d}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Typické složitější oříšky -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h2 section-title">Typické „složitější oříšky"</h2>
      <ul class="arrow-list">
        {hardCases.map((h) => (
          <li><span><strong class="hl">{h.title}</strong>: {h.desc}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Proč s námi -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h2 section-title">Proč s námi</h2>
      <ul class="arrow-list">
        {whyUs.map((w) => (
          <li><span><strong class="hl">{w.title}</strong>: {w.desc}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h2 section-title">FAQ (rychle a bez omáčky)</h2>
      <div class="faq-list">
        {faq.map((f) => (
          <div class="faq-item">
            <p class="faq-q">Otázka: {f.q}</p>
            <p class="body">Odpověď: {f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Naše současné aplikace -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h2 section-title">Naše současné aplikace</h2>
      <div class="apps-grid">
        <a href="/cs/esyncer" class="app-card">
          <div class="app-card-header" style="background-image: url('/header-image-esyncer.webp')">
            <img src="/es-sipky.svg" alt="eSyncer" class="app-logo" />
          </div>
          <div class="app-card-body">
            <h3 class="h3-mini">eSyncer</h3>
            <p>Import, synchronizace & automatizace produktových dat (nejen) pro Shopify.</p>
            <span class="btn-action btn-action--lg app-cta">Více o eSynceru</span>
          </div>
        </a>
        <a href="/cs/ae-translator" class="app-card">
          <div class="app-card-header" style="background-image: url('/ae-translator-hero.webp')">
            <img src="/ae-translate-znak.svg" alt="AE Translator" class="app-logo" />
          </div>
          <div class="app-card-body">
            <h3 class="h3-mini">AE Translator</h3>
            <p>AI překlad obsahu Shopify e-shopu. DeepL, Claude nebo DeepSeek — na výběr.</p>
            <span class="btn-action btn-action--lg app-cta">Více o AE Translatoru</span>
          </div>
        </a>
        <a href="/cs/kontakt" class="app-card app-card--teaser">
          <div class="app-card-header app-card-header--teaser">
            <svg class="app-logo" width="84" height="84" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
          </div>
          <div class="app-card-body">
            <h3 class="h3-mini">A co vaše aplikace</h3>
            <p>Máte nápad na vlastní appku nebo potřebujete něco na míru? Zkontaktujte nás a můžeme začít.</p>
            <span class="btn-action btn-action--lg app-cta">Zkontaktujte nás</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Jdeme spolu něco vytvořit?<br />Dejte vědět</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }
  .intro-h2 { margin-bottom: var(--space-40); }
  .intro-subhead { margin-top: var(--space-16); color: #fff; }
  /* Intro + sidebar = 2 sloupce */
  .intro-layout { display: grid; grid-template-columns: 1fr 355px; gap: var(--space-64); align-items: start; }
  .intro-main { min-width: 0; }
  .intro-main .intro-text { max-width: none; }
  @media (max-width: 900px) { .intro-layout { grid-template-columns: 1fr; gap: var(--space-40); } }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-text { font-size: var(--fs-20); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .section-title { margin-bottom: var(--space-40); }
  .section-text { margin-bottom: var(--space-24); max-width: 760px; }

  .intro-wrap { max-width: 800px; }

  .when-subhead { font-size: 18px; font-weight: 600; color: #fff; margin-bottom: var(--space-24); }
  /* „Kdy je čas na custom" = 2 sloupce; seznamy → globální .arrow-list */
  .custom-2col { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-64); align-items: start; }
  .custom-2col .arrow-list { margin-bottom: var(--space-40); }
  /* tlačítka → globální .btn-action--lg (global.css); zde jen odskok od seznamu v 2-col sekci */
  .custom-2col .btn-action--lg { margin-top: 30px; }
  @media (max-width: 900px) { .custom-2col { grid-template-columns: 1fr; gap: var(--space-40); } }


  .hard-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .hard-card { background: var(--ae-bg-primary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .hard-title { font-size: 16px; font-weight: 600; color: #fff; margin-bottom: var(--space-12); }
  .hard-desc { font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.6; }

  .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-24); max-width: 800px; }
  .why-card { background: var(--ae-bg-primary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .why-title { font-size: 16px; font-weight: 600; color: #fff; margin-bottom: var(--space-8); }
  .why-desc { font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.6; }

  .faq-list { display: flex; flex-direction: column; gap: var(--space-32); max-width: 760px; }
  .faq-item { border-left: 2px solid var(--action); padding-left: var(--space-24); }
  .faq-q { font-size: 16px; font-weight: 600; margin-bottom: var(--space-8); }

  /* Aplikace — 3-kartový grid (port z co-umime) */
  .apps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .app-card { background: rgba(255,255,255,0.08); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); overflow: hidden; display: flex; flex-direction: column; transition: border-color 0.2s, transform 0.2s; text-decoration: none; }
  .app-card:hover { border-color: rgba(13,212,205,0.3); transform: translateY(-2px); }
  .app-card-header { position: relative; height: 260px; background-size: cover; background-position: center top; }
  .app-card-header.app-card-header--teaser { background-image: url('/a-multitvar-bgr-v33.webp'); background-size: 200%; background-position: right -50px top -50px; }
  .app-card-header--teaser .app-logo { color: #fff; }
  .app-logo { position: absolute; left: 28px; bottom: 20px; width: 84px; height: 84px; object-fit: contain; z-index: 2; filter: drop-shadow(0 4px 14px rgba(0,0,0,0.5)); }
  .app-card-body { padding: 28px 32px 36px; flex: 1; display: flex; flex-direction: column; }
  .app-card-body h3 { margin-bottom: 10px; }
  .app-card-body p { font-size: 16px; color: var(--neutral-300); line-height: 1.6; margin-bottom: 20px; flex: 1; }
  .app-cta { align-self: flex-start; }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: var(--fs-70); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 1024px) {
    .hard-grid { grid-template-columns: repeat(2, 1fr); }
    .why-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .hard-grid { grid-template-columns: 1fr; }
    .apps-grid { grid-template-columns: 1fr; }
  }
</style>
