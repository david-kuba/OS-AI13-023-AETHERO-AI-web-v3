---
import PageLayout from '../../../layouts/PageLayout.astro';

const services = [
  {
    num: '01',
    numImg: '/no-01.svg',
    anchor: 'brand',
    title: 'Design dýcháme! Vytváříme <span class="t-ac">SHOPIFY&nbsp;BRANDY</span> s&nbsp;DX, na&nbsp;které zákazníci nezapomínají!',
    desc: '<strong class="ac">BRAND E-SHOPU</strong> osobitost, příběh, emoce a slib s vámi spojený a <strong class="ac">Digital Experience,</strong> vše, co o vás svět zjistí, až vás vyhledá na internetu. A je jedno, zda to bude reklama, video, banner, fotka na LinkedIn anebo zapomenutý tweet. To celé s vámi umíme vytvořit a sladit.',
    cta: 'Chci vědět víc',
    href: '/cs/co-umime/potrebuji-brand',
  },
  {
    num: '02',
    numImg: '/no-02.svg',
    anchor: 'novy-eshop',
    title: 'Stavíme parádní <a href="/cs/co-umime/novy-shopify-e-shop" class="t-ac">E-SHOPY NA&nbsp;SHOPIFY</a> od vzhledu, nastavení, přes spuštění, až&nbsp;po dlouhodobou podporu.',
    desc: '<strong class="ac">Vyberte si Shopify – ten nejlepší nástroj.</strong> Bez omezení toho, kde prodáváte a v kolika měnách. Platformu s neskutečnou škálovatelností, podporou a drivem. Shopify je nastaveno tak, aby s vámi rostlo od&nbsp;StartUpu až po mezinárodní mega projekt!',
    cta: 'Dobře, chci vědět víc',
    href: '/cs/co-umime/novy-shopify-e-shop',
  },
  {
    num: '03',
    numImg: '/no-03.svg',
    anchor: 'prechod',
    title: 'Odstartujeme vaši <span class="t-ac">MIGRACI NA&nbsp;SHOPIFY</span>. Uvědomujeme si, že&nbsp;je&nbsp;to velké rozhodnutí a&nbsp;nic se nesmí pokazit.',
    desc: '<strong class="ac">Jasně, čím lépe na tom jste nyní, tím větší je to riziko.</strong> Ale nebojte, máme pro vás vícero způsobů jak vše bezpečně vyřešit. A stojí to za prozkoumání. Od SEO analýzy přes mapu redirektů, UX design, až po data a propojení na další systémy včetně přímé linky na Shopify.',
    cta: 'Tak ukažte',
    href: '/cs/co-umime/prechod-na-shopify',
  },
  {
    num: '04',
    numImg: '/no-04.svg',
    anchor: 'expanze',
    title: 'Chystáte <span class="t-ac">EXPANZI DO&nbsp;ZAHRANIČÍ</span>? A máte plán? Můžeme ho spolu odladit a&nbsp;opřít se o&nbsp;možnosti Shopify.',
    desc: 'To, že v Česku jede e-commerce pořádně, je celkem známá věc. Méně se ví, že máme nejvíc e-shopů na obyvatele v celé Evropě — přes 63 000 obchodů na 10,7 milionu lidí. A přesto jsme dlouho obchodovali hlavně sami sobě. Slovensko bylo druhý krok, zahraničí vzdálený sen. To se mění — cross-border e-commerce roste 18&nbsp;% ročně. <strong class="ac">Pokud vám domácí trh a Slovensko nestačí, pojďte s námi expandovat</strong> díky Shopify.',
    cta: 'Tak ukažte',
    href: '/cs/co-umime/expanze-do-zahranici',
  },
  {
    num: '05',
    numImg: '/no-05.svg',
    anchor: 'rozvoj',
    title: '<span class="t-ac">ROZVOJ A&nbsp;PODPORA</span> — ať&nbsp;už potřebujete technickou pomoc, plán anebo jen&nbsp;další ruce, jsme tady.',
    desc: 'Víme, že ne každý problém má řešení v tutoriálu nebo videu – občas je potřeba hlubší technický vhled, zkušenost z vícero reálných projektů, abyste získali šanci najít další souvislosti. <strong class="ac">Dejte vědět a najdeme řešení spolu.</strong>',
    cta: 'OK, chci pomoci',
    href: '/cs/co-umime/rozvoj-a-podpora',
  },
  {
    num: '06',
    numImg: '/no-06.svg',
    anchor: 'analyza',
    title: '<span class="t-ac">ANALÝZA A&nbsp;STRATEGIE</span> — přestaňte hádat, zjistěte proč.',
    desc: 'Data vašeho e-shopu říkají víc, než si myslíte. Analyzujeme GA4, reklamy, emaily a dodáme strategii s konkrétními kroky. <strong class="ac">Jasná čísla, jasné priority, jasný plán.</strong>',
    cta: 'Chci analýzu',
    href: '/cs/co-umime/analyza-a-strategie',
  },
  {
    num: '07',
    numImg: '/no-07.svg',
    anchor: 'custom',
    title: '<span class="t-ac">CUSTOM ÚPRAVY A&nbsp;APLIKACE</span> — když potřebujete něco nového, lokálního či&nbsp;složitějšího, co zrovna neřeší aplikace.',
    desc: 'Tahle část naší práce je, na straně jedné, úžasně jednoduchá na vysvětlení, ale také dosti nepředvídatelná na straně druhé. <strong class="ac">V ideálním případě za námi přijdete s definicí problému a odcházíte od nás s řešením&nbsp;:o)</strong> A někde mezitím my to řešení najdeme nebo vytvoříme a vy zaplatíte.',
    cta: 'Super, pojďme na to',
    href: '/cs/co-umime/custom-vyvoj-a-aplikace',
  },
];

---

<PageLayout title="Co umíme" description="Komplexní Shopify služby od brandingu přes vývoj až po mezinárodní expanzi." lang="cs">

  <!-- HERO -->
  <section class="co-hero">
    <div class="co-hero-bg"></div>
    <div class="co-hero-overlay"></div>
    <div class="container co-hero-inner">
      <h1>Co umíme</h1>
      <a href="#brand" class="co-hero-cta">A do čeho se pustíme spolu?</a>
    </div>
  </section>

  <!-- SERVICES -->
  {services.map((s, i) => (
    <section class={`svc-section ${i % 2 === 0 ? 'svc-even' : 'svc-odd'}`} id={s.anchor}>
      <div class="container svc-grid">
        <div class="svc-num-col">
          {s.numImg
            ? <img src={s.numImg} alt={`${s.num}`} class="svc-num-img" width="470" height="212" loading="lazy" />
            : <span class="svc-num-text">{s.num}</span>
          }
        </div>
        <div class="svc-text-col">
          <h2 class="svc-title" set:html={s.title} />
          <p class="svc-desc" set:html={s.desc} />
          <a href={s.href} class="svc-cta">{s.cta}</a>
        </div>
      </div>
    </section>
  ))}

  <!-- APPS -->
  <section class="apps-section">
    <div class="container">
      <h2 class="section-label">APLIKACE</h2>
      <div class="apps-grid">
        <a href="/cs/esyncer" class="app-card">
          <div class="app-card-header" style="background-image: url('/header-image-esyncer.webp')"></div>
          <div class="app-card-body">
            <img src="/es-sipky.svg" alt="eSyncer" class="app-logo" />
            <h3>eSyncer</h3>
            <p>Import, synchronizace & automatizace produktových dat (nejen) pro Shopify.</p>
            <span class="app-link">Více o eSyncer →</span>
          </div>
        </a>
        <a href="/cs/ae-translator" class="app-card">
          <div class="app-card-header" style="background-image: url('/ae-translator-hero.webp')"></div>
          <div class="app-card-body">
            <img src="/ae-translate-znak.svg" alt="AE Translator" class="app-logo" />
            <h3>AE Translator</h3>
            <p>AI překlad obsahu Shopify e-shopu. DeepL, Claude nebo DeepSeek — na výběr.</p>
            <span class="app-link">Více o AE Translator →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Máme spolu co probrat?<br />Dejte vědět.</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* ─── HERO ─── */
  .co-hero {
    position: relative;
    min-height: 68vh;
    overflow: hidden;
    background: #171a1c;
  }
  .co-hero-bg {
    position: absolute; inset: 0;
    background-image: url('/a-multitvar-bgr-v33.webp');
    background-size: cover;
    background-position: 52% 100%;
  }
  .co-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(1,0,19,0) 60%, #000326 95%);
  }
  .co-hero-inner {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
  }
  .co-hero h1 {
    font-size: clamp(56px, 7.8vw, 100px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 40px;
  }
  .co-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: var(--radius-sm);
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #fff;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 4px 24px rgba(0,0,0,0.2);
    transition: background 0.2s, border-color 0.2s;
  }
  .co-hero-cta:hover {
    background: rgba(255,255,255,0.18);
    border-color: rgba(255,255,255,0.5);
  }


  /* ─── SERVICE SECTIONS ─── */
  .co-hero + .svc-section { padding-top: 24px; }
  .svc-section {
    padding: 100px 0;
  }
  .svc-section:nth-child(odd) { background: var(--bg-primary); }
  .svc-section:nth-child(even) { background: #000326; }

  .svc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  /* Even index (0,2,4,6…) = num left, text right */
  .svc-even .svc-num-col { order: 1; }
  .svc-even .svc-text-col { order: 2; }
  /* Odd index (1,3,5…) = text left, num right */
  .svc-odd .svc-num-col { order: 2; }
  .svc-odd .svc-text-col { order: 1; }

  .svc-num-img {
    width: 100%;
    max-width: 470px;
    height: auto;
    display: block;
  }
  .svc-even .svc-num-img { margin-left: auto; }
  .svc-odd .svc-num-img { margin-right: auto; }
  #custom .svc-num-img { max-width: 423px; }

  .svc-num-text {
    font-family: var(--font-primary);
    font-size: clamp(80px, 12vw, 160px);
    font-weight: 700;
    line-height: 1;
    color: rgba(255,255,255,0.12);
    display: block;
  }

  .svc-title {
    font-family: var(--font-primary);
    font-size: clamp(26px, 3.5vw, 48px);
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
    margin-bottom: 24px;
  }
  .svc-title :global(.t-ac) {
    color: var(--action);
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 2px;
  }
  .svc-desc {
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255,255,255,0.75);
    margin-bottom: 32px;
  }
  .svc-desc :global(.ac) {
    color: var(--text-secondary);
    font-weight: 900;
  }
  .svc-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 28px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(13,212,205,0.4);
    color: var(--action);
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 300;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    text-decoration: none;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: background 0.25s, border-color 0.25s, color 0.25s, box-shadow 0.25s;
  }
  .svc-cta:hover {
    background: rgba(13,212,205,0.33);
    border-color: rgba(13,212,205,0.75);
    color: #fff;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.1), 0 0 10px rgba(13,212,205,0.12);
  }

  /* ─── APPS ─── */
  .apps-section {
    background: var(--bg-secondary);
    padding: 100px 0;
  }
  .section-label {
    font-family: var(--font-primary);
    font-size: clamp(26px, 3.5vw, 48px);
    font-weight: 600;
    color: #fff;
    line-height: 1.2;
    text-align: center;
    margin-bottom: 40px;
  }
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .app-card {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
  }
  .app-card:hover { border-color: rgba(13,212,205,0.3); transform: translateY(-2px); }
  .app-card-header {
    height: 260px;
    background-size: cover;
    background-position: center top;
  }
  .app-logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
    display: block;
    margin-bottom: 16px;
  }
  .app-card-body { padding: 28px 32px 36px; flex: 1; display: flex; flex-direction: column; }
  .app-card-body h3 { font-size: clamp(20px, 2.5vw, 30px); font-weight: 600; margin-bottom: 10px; }
  .app-card-body p { font-size: 16px; color: var(--neutral-300); line-height: 1.6; margin-bottom: 20px; flex: 1; }
  .app-link { color: var(--action); font-size: 15px; font-weight: 500; }

  /* ─── CTA ─── */
  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--brand-dark); text-decoration: none; transition: opacity 0.2s; }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }
  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .svc-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .svc-even .svc-num-col,
    .svc-odd .svc-num-col { order: 1; }
    .svc-even .svc-text-col,
    .svc-odd .svc-text-col { order: 2; }
    .svc-num-img { max-width: 280px; }
    .svc-section { padding: 60px 0; }
    .apps-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .co-hero { min-height: 60vh; }
    .co-hero-inner { padding-bottom: 48px; }
    .svc-num-img { max-width: 200px; }
    .svc-section { padding: 48px 0; }
  }
</style>
