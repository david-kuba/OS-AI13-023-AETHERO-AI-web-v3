---
import PageLayout from '../../../layouts/PageLayout.astro';

const services = [
  {
    num: '01',
    numImg: '/no-01.svg',
    anchor: 'brand',
    title: 'Design dýcháme! Vytváříme <a href="/cs/co-umime/potrebuji-brand" class="t-ac">SHOPIFY&nbsp;BRANDY</a> s&nbsp;DX, na&nbsp;které zákazníci nezapomínají!',
    desc: '<strong class="ac">BRAND E-SHOPU</strong> osobitost, příběh, emoce a slib s vámi spojený a <strong class="ac">Digital Experience,</strong> vše, co o vás svět zjistí, až vás vyhledá na internetu. A je jedno, zda to bude reklama, video, banner, fotka na LinkedIn anebo zapomenutý tweet. To celé s vámi umíme vytvořit a sladit.',
    cta: 'Chci vědět víc',
    href: '/cs/co-umime/potrebuji-brand',
  },
  {
    num: '02',
    numImg: '/no-02.svg',
    anchor: 'novy-eshop',
    title: 'Stavíme parádní <a href="/cs/co-umime/novy-shopify-e-shop" class="t-ac">E-SHOPY NA&nbsp;SHOPIFY</a> od vzhledu, nastavení, přes spuštění, až&nbsp;po dlouhodobou podporu.',
    desc: '<strong class="ac">Vyberte si Shopify – ten nejlepší nástroj.</strong> Bez omezení toho, kde prodáváte a v kolika měnách. Platformu s neskutečnou škálovatelností, podporou a drivem. Shopify je nastaveno tak, aby s vámi rostlo od&nbsp;StartUpu až po mezinárodní mega projekt!',
    cta: 'Dobře, chci vědět víc',
    href: '/cs/co-umime/novy-shopify-e-shop',
  },
  {
    num: '03',
    numImg: '/no-03.svg',
    anchor: 'prechod',
    title: 'Odstartujeme vaši <a href="/cs/co-umime/prechod-na-shopify" class="t-ac">MIGRACI NA&nbsp;SHOPIFY</a>. Uvědomujeme si, že&nbsp;je&nbsp;to velké rozhodnutí a&nbsp;nic se nesmí pokazit.',
    desc: '<strong class="ac">Jasně, čím lépe na tom jste nyní, tím větší je to riziko.</strong> Ale nebojte, máme pro vás vícero způsobů jak vše bezpečně vyřešit. A stojí to za prozkoumání. Od SEO analýzy přes mapu redirektů, UX design, až po data a propojení na další systémy včetně přímé linky na Shopify.',
    cta: 'Tak ukažte',
    href: '/cs/co-umime/prechod-na-shopify',
  },
  {
    num: '04',
    numImg: '/no-04.svg',
    anchor: 'expanze',
    title: 'Chystáte <a href="/cs/co-umime/expanze-do-zahranici" class="t-ac">EXPANZI DO&nbsp;ZAHRANIČÍ</a>? A máte plán? Můžeme ho spolu odladit a&nbsp;opřít se o&nbsp;možnosti Shopify.',
    desc: 'To, že v Česku jede e-commerce pořádně, je celkem známá věc. Méně se ví, že máme nejvíc e-shopů na obyvatele v celé Evropě — přes 63 000 obchodů na 10,7 milionu lidí. A přesto jsme dlouho obchodovali hlavně sami sobě. Slovensko bylo druhý krok, zahraničí vzdálený sen. To se mění — cross-border e-commerce roste 18&nbsp;% ročně. <strong class="ac">Pokud vám domácí trh a Slovensko nestačí, pojďte s námi expandovat</strong> díky Shopify.',
    cta: 'Tak ukažte',
    href: '/cs/co-umime/expanze-do-zahranici',
  },
  {
    num: '05',
    numImg: '/no-05.svg',
    anchor: 'rozvoj',
    title: '<a href="/cs/co-umime/rozvoj-a-podpora" class="t-ac">ROZVOJ A&nbsp;PODPORA</a> — ať&nbsp;už potřebujete technickou pomoc, plán anebo jen&nbsp;další ruce, jsme tady.',
    desc: 'Víme, že ne každý problém má řešení v tutoriálu nebo videu – občas je potřeba hlubší technický vhled, zkušenost z vícero reálných projektů, abyste získali šanci najít další souvislosti. <strong class="ac">Dejte vědět a najdeme řešení spolu.</strong>',
    cta: 'OK, chci pomoci',
    href: '/cs/co-umime/rozvoj-a-podpora',
  },
  {
    num: '06',
    numImg: '/no-06.svg',
    anchor: 'analyza',
    title: '<a href="/cs/co-umime/analyza-a-strategie" class="t-ac">ANALÝZA A&nbsp;STRATEGIE</a> — přestaňte hádat, zjistěte proč.',
    desc: 'Data vašeho e-shopu říkají víc, než si myslíte. Analyzujeme GA4, reklamy, emaily a dodáme strategii s konkrétními kroky. <strong class="ac">Jasná čísla, jasné priority, jasný plán.</strong>',
    cta: 'Chci analýzu',
    href: '/cs/co-umime/analyza-a-strategie',
  },
  {
    num: '07',
    numImg: '/no-07.svg',
    anchor: 'custom',
    title: '<a href="/cs/co-umime/custom-vyvoj-a-aplikace" class="t-ac">CUSTOM ÚPRAVY A&nbsp;APLIKACE</a> — když potřebujete něco nového, lokálního či&nbsp;složitějšího, co zrovna neřeší aplikace.',
    desc: 'Tahle část naší práce je, na straně jedné, úžasně jednoduchá na vysvětlení, ale také dosti nepředvídatelná na straně druhé. <strong class="ac">V ideálním případě za námi přijdete s definicí problému a odcházíte od nás s řešením&nbsp;:o)</strong> A někde mezitím my to řešení najdeme nebo vytvoříme a vy zaplatíte.',
    cta: 'Super, pojďme na to',
    href: '/cs/co-umime/custom-vyvoj-a-aplikace',
  },
];

---

<PageLayout title="Co umíme" description="Komplexní Shopify služby od brandingu přes vývoj až po mezinárodní expanzi." lang="cs">

  <!-- HERO -->
  <section class="co-hero">
    <div class="co-hero-bg"></div>
    <div class="co-hero-overlay"></div>
    <div class="container co-hero-inner">
      <h1>Co umíme</h1>
      <p class="co-hero-sub">Vyberte si oblast která vás zajímá, zkontaktujte nás.</p>
      <a href="#cta" class="btn-hero">A můžeme začít</a>
    </div>
  </section>

  <!-- SERVICES -->
  {services.map((s, i) => (
    <section class={`svc-section ${i % 2 === 0 ? 'svc-even' : 'svc-odd'}`} id={s.anchor}>
      <div class="container svc-grid">
        <div class="svc-num-col">
          {s.numImg
            ? <img src={s.numImg} alt={`${s.num}`} class="svc-num-img" width="470" height="212" loading="lazy" />
            : <span class="svc-num-text">{s.num}</span>
          }
        </div>
        <div class="svc-text-col">
          <h2 class="svc-title" set:html={s.title} />
          <p class="svc-desc body" set:html={s.desc} />
          <a href={s.href} class="btn-action btn-action--lg">{s.cta}</a>
        </div>
      </div>
    </section>
  ))}

  <!-- APPS -->
  <section class="apps-section">
    <div class="container">
      <h3 class="h3 section-label">Aplikace</h3>
      <div class="apps-grid">
        <a href="/cs/esyncer" class="app-card">
          <div class="app-card-header" style="background-image: url('/header-image-esyncer.webp')">
            <img src="/es-sipky.svg" alt="eSyncer" class="app-logo" />
          </div>
          <div class="app-card-body">
            <h3 class="h3-mini">eSyncer</h3>
            <p>Import, synchronizace & automatizace produktových dat (nejen) pro Shopify.</p>
            <span class="btn-action btn-action--lg app-cta">Více o eSynceru</span>
          </div>
        </a>
        <a href="/cs/ae-translator" class="app-card">
          <div class="app-card-header" style="background-image: url('/ae-translator-hero.webp')">
            <img src="/ae-translate-znak.svg" alt="AE Translator" class="app-logo" />
          </div>
          <div class="app-card-body">
            <h3 class="h3-mini">AE Translator</h3>
            <p>AI překlad obsahu Shopify e-shopu. DeepL, Claude nebo DeepSeek — na výběr.</p>
            <span class="btn-action btn-action--lg app-cta">Více o AE Translatoru</span>
          </div>
        </a>
        <a href="/cs/kontakt" class="app-card app-card--teaser">
          <div class="app-card-header app-card-header--teaser">
            <svg class="app-logo" width="84" height="84" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
          </div>
          <div class="app-card-body">
            <h3 class="h3-mini">A co vaše aplikace</h3>
            <p>Máte nápad na vlastní appku nebo potřebujete něco na míru? Zkontaktujte nás a můžeme začít.</p>
            <span class="btn-action btn-action--lg app-cta">Zkontaktujte nás</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Máme spolu co probrat?<br />Dejte vědět.</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* ─── HERO ─── */
  .co-hero {
    position: relative;
    min-height: 68vh;
    overflow: hidden;
    background: #000326;
  }
  .co-hero-bg {
    position: absolute; inset: 0;
    background-image: url('/a-multitvar-bgr-v33.webp');
    background-size: cover;
    background-position: 52% 100%;
  }
  .co-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(1,0,19,0) 60%, #000326 95%);
  }
  .co-hero-inner {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
  }
  .co-hero h1 {
    font-size: var(--fs-100);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 20px;
  }
  .co-hero-sub {
    font-family: var(--font-secondary);
    font-size: var(--fs-22);
    font-weight: 400;
    color: rgba(255,255,255,0.85);
    line-height: 1.5;
    margin-bottom: 36px;
  }

  /* ─── SERVICE SECTIONS ─── */
  .co-hero + .svc-section { padding-top: 24px; }
  .svc-section {
    padding: 100px 0;
  }
  .svc-section:nth-child(odd) { background: var(--ae-bg-primary); }
  .svc-section:nth-child(even) { background: #000326; }

  .svc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  /* Even index (0,2,4,6…) = num left, text right */
  .svc-even .svc-num-col { order: 1; }
  .svc-even .svc-text-col { order: 2; }
  /* Odd index (1,3,5…) = text left, num right */
  .svc-odd .svc-num-col { order: 2; }
  .svc-odd .svc-text-col { order: 1; }

  .svc-num-img {
    width: 100%;
    max-width: 470px;
    height: auto;
    display: block;
  }
  .svc-even .svc-num-img { margin-left: auto; }
  .svc-odd .svc-num-img { margin-right: auto; }
  #custom .svc-num-img { max-width: 423px; }

  .svc-num-text {
    font-family: var(--font-primary);
    font-size: var(--fs-160);
    font-weight: 700;
    line-height: 1;
    color: rgba(255,255,255,0.12);
    display: block;
  }

  .svc-title {
    font-family: var(--font-primary);
    font-size: var(--fs-48);
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
    margin-bottom: 24px;
  }
  .svc-title :global(.t-ac) {
    color: #fff;
    text-decoration: none;
  }
  .svc-title :global(a.t-ac) {
    color: var(--action);
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 2px;
  }
  .svc-desc {
    margin-bottom: 32px;
  }
  .svc-desc :global(.ac) {
    color: var(--text-secondary);
    font-weight: 900;
  }
  /* ─── APPS ─── */
  .apps-section {
    background: var(--ae-bg-primary);
    padding: 100px 0;
  }
  /* section-label = jen centrování + margin; velikost/řez řídí .h3 */
  .section-label {
    color: #fff;
    text-align: center;
    margin-bottom: 40px;
  }
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  /* teaser karta — gradient místo fotky + bílá plus ikona */
  .app-card-header.app-card-header--teaser {
    background-image: url('/a-multitvar-bgr-v33.webp');
    background-size: 200%;          /* ~2× za hranici fitu = zoom */
    background-position: right -50px top -50px;  /* fokus na pravý horní roh */
  }
  .app-card-header--teaser .app-logo { color: #fff; }
  .app-card {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
  }
  .app-card:hover { border-color: rgba(13,212,205,0.3); transform: translateY(-2px); }
  .app-card-header {
    position: relative;
    height: 260px;
    background-size: cover;
    background-position: center top;
  }
  /* logo přes obrázek (vlevo dole), zvětšené */
  .app-logo {
    position: absolute;
    left: 28px;
    bottom: 20px;
    width: 84px;
    height: 84px;
    object-fit: contain;
    z-index: 2;
    filter: drop-shadow(0 4px 14px rgba(0,0,0,0.5));
  }
  .app-card-body { padding: 28px 32px 36px; flex: 1; display: flex; flex-direction: column; }
  .app-card-body h3 { margin-bottom: 10px; }
  .app-card-body p { font-size: 16px; color: var(--neutral-300); line-height: 1.6; margin-bottom: 20px; flex: 1; }
  /* CTA = tlačítko místo odkazu (span uvnitř card-anchoru), hugne vlevo */
  .app-cta { align-self: flex-start; }

  /* ─── CTA ─── */
  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: var(--fs-70); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity 0.2s; }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }
  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .svc-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .svc-even .svc-num-col,
    .svc-odd .svc-num-col { order: 1; }
    .svc-even .svc-text-col,
    .svc-odd .svc-text-col { order: 2; }
    .svc-num-img { max-width: 280px; }
    .svc-section { padding: 60px 0; }
    .apps-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .co-hero { min-height: 60vh; }
    .co-hero-inner { padding-bottom: 48px; }
    .svc-num-img { max-width: 200px; }
    .svc-section { padding: 48px 0; }
  }
</style>
