---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const analyzeItems = [
  'E-mail marketing — Leadhub, Klaviyo, Mailchimp, Ecomail a další. Kampaně, automations, segmenty, open rate, CTR, revenue na email.',
  'E-shopová platforma — Shoptet, Shopify, WooCommerce — objednávky, zákazníci, produkty, sezónnost, retence, AOV.',
  'Google Analytics / GA4 — Zdroje návštěvnosti, konverzní cesty, atribuční model, výkon kanálů, chování uživatelů.',
  'Google Ads — Výkon kampaní, ROAS, search terms, ztracená imprese, příležitosti pro škálování nebo úsporu.',
  'Meta Ads — Facebook & Instagram — dosah, frekvence, CPM, ROAS, audience overlap, funnel analýza.',
  'Crawling webu — Pokud data nejsou v exportu — projdeme e-shop nebo web automaticky a vytěžíme produktový katalog, ceny, kategorie, UX vzory.',
];

const deliverables = [
  'Přehled klíčových metrik — 24měsíční horizont, meziroční srovnání, identifikace trendů',
  'Analýza příčin robotu nebo poklesu — co funguje, co nefunguje a proč',
  'Přehled výkonu kampaní a automatizací — cross-sell příležitosti, segmentace zákazníků',
  'Cross-sell příležitosti a analýza nákupních košíků — co a kdy zákazníci kupují',
  'Cross-sell mapování / CRM — email kampaně, flowSy, Klavia vs zákazníci, kompetitivní metriky',
  'Segmentační doporučení — RFM modely, retence zákazníků, churn prevention',
  'SEO a integrace — email kampaně, flowSy, Klaviyo vs zákazníci, kompetitivní metriky',
  'Marketingová strategie nad rámec emailu — 40 konkrétních úkolů, které přinesou výsledky',
];

const forWho = [
  'Váš e-shop generuje data, ale nemáte kapacitu nebo know-how je správně přečíst',
  'Tušíte, že e-maily, reklamy nebo flows fungují lépe — ale nevíte jak to udělat',
  'Potřebujete konkrétní akční plán s jasnou prioritizací, ne obecná doporučení',
  'Rozhodujete se, kam investovat marketingový rozpočet v příštím roce',
];

const steps = [
  { num: '1. Napojení dat', desc: 'Pošlete nám exporty nebo API přístup k vašim platformám. Bez přístupu? Pomůžeme — pošleme vám CSV soubory nebo data vytáhneme sami. Vše se udělá diskrétně.' },
  { num: '2. Analýza', desc: 'Projdeme data do hloubky: objednávky, kampaně, zákazníci. Typicky 1–3 dny podle rozsahu dat.' },
  { num: '3. Živá spolupráce', desc: 'Projdeme výsledky s vámi v reálném čase. Vy doplňujete kontext, my zodpovídáme otázky — výsledkem je strategie šitá na míru, na nic navíc — žádné šablony.' },
  { num: '4. Strategický dokument + plán', desc: 'Dostanete přehledný online strateg. dokument s kompletní analýzou a klikacím 365denním plánem. Připravený online, kdykoli přístupný.' },
];

---

<PageLayout title="Analýza a strategie | aethero" description="Přestaňte hádat — zjistěte proč váš e-shop neroste. Propojíme vaše data a dodáme strategii, která rovnou funguje." lang="cs">
  <ServiceHero
    label="Analýza a strategie"
    title="ANALÝZA<br /><span style='color:#fff'>A STRATEGIE</span>"
    subtitle="Víte, proč váš e-shop roste? A proč někdy neroste? Propojíme vaše data, zapojíme AI + kontext — a výsledky jsou opravdu působivé."
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#jak-to-funguje"
    image="/aethero-gradient-222.png"
    imageAlt="Analýza a strategie pro e-shop"
  />

  <!-- Přestaňte hádat -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h1 intro-h2">Přestaňte hádat,<br /><span class="accent-purple">ZJISTĚTE PROČ</span></h2>
      <p class="intro-text">Váš e-shop vám totiž něco říká. <strong class="hl">Posloucháte ho?</strong> Každý e-shop má v sobě a v datech schovaný příběh — kde vydělává, kde krvácí, proč někteří zákazníci zůstávají a jiní zmizí po prvním nákupu. <strong class="hl">Ta data už dávno máte, jen je nikdo nečte.</strong> A měl by.</p>
      <p class="intro-text">Chce to zkušenost a trochu technického voo-doo, ale pak se s vašimi daty, plány a ochočenou AI posadíme, propojíme je s čím je potřeba: Google Ads, Analytics, Metou i s mailovým klientem a <strong class="hl">vrátíme vám strategii, která má čísla u každého doporučení</strong>: kolik to vydělá, kolik ušetří, kdy to zapnout.</p>
      <a href="#cta" class="btn-secondary">Chcete analýzu? Zavolejte</a>
    </div>
  </section>

  <!-- Vaše data říkají víc -->
  <section class="section bg-primary">
    <div class="container">
      <div class="two-col-analyze">
        <div>
          <h2 class="h2 section-title">Vaše data říkají víc,<br />než si myslíte</h2>
          <p class="section-text">API přístup, CSV exporty nebo crawling webu — dokážeme napojit téměř jakýkoliv zdroj dat. Propojíme data z vašeho e-shopu, emailové kampaně, GAds, Analytiku i sociální sítě. A vy pak dostanete konkrétní strategii s kvantifikovaným přínosem každého doporučení — žádné obecné rady.</p>
          <p class="section-text"><strong>Nejčastěji pracujeme s e-shopy od 3M Kč ročního obratu na Shoptetu, Shopify a WooCommerce.</strong></p>
          <a href="#jak-to-funguje" class="text-link">Co to jsou?</a>
        </div>
        <div>
          <h3 class="analyze-label">CO ANALYZUJEME</h3>
          <ul class="analyze-list">
            {analyzeItems.map((a) => (
              <li>{a}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h3-mini testimonials-label">Reference majitelů e-shopů</h2>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-top">
            <a href="https://www.fleppi.cz" target="_blank" rel="noopener" class="testimonial-logo-link">
              <img src="/ref-fleppi-logo.jpg" alt="fleppi" class="testimonial-logo testimonial-logo--light" />
            </a>
          </div>
          <p class="testimonial-text">„Výstup byl kvalitně zpracovaný, přehledný a hlavně plný konkrétních podnětů, které můžeme rovnou využít pro další růst našeho e-shopu. Žádná obecná doporučení, ale řešení šitá nám na míru."</p>
          <div class="testimonial-footer">
            <img src="/ref-lucie.jpg" alt="Lucie" class="testimonial-avatar" />
            <div class="testimonial-person">
              <span>Lucie, majitelka</span>
              <a href="https://www.fleppi.cz" target="_blank" rel="noopener" class="text-link">Fleppi.cz</a>
            </div>
            <div class="google-review">
              <svg class="google-g-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="Google">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              <div class="google-stars">★★★★★</div>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-top">
            <a href="https://bu1.cz" target="_blank" rel="noopener" class="testimonial-logo-link">
              <img src="/ref-bu1-logo.svg" alt="BU1" class="testimonial-logo" />
            </a>
          </div>
          <p class="testimonial-text">„Jsem z toho nadšený, protože poprvé mám ucelený obraz o všem, co se v e-shopu děje, na jednom místě. Ta největší pecka je v tom, jak se ty data mezi sebou propojují. Vidím jestli je ten obsah na webu skutečně zaujal a k tomu si přihodím info z mailingu — na co nám lidi nejlépe reagují v e-mailech. Právě tyhle přesahy, kdy vidím celou cestu zákazníka od vyhledávání až po nákup, mi dovolují dělat v Shopify úpravy, které mají hlavu a patu."</p>
          <div class="testimonial-footer">
            <img src="/ref-petr.png" alt="Petr" class="testimonial-avatar" />
            <div class="testimonial-person">
              <span>Petr, majitel</span>
              <a href="https://bu1.cz" target="_blank" rel="noopener" class="text-link">BU1.cz</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Výstup / Case study -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h2-mini section-title-center">Výstup, <span class="text-action">který rovnou použijete.</span></h2>
      <div class="output-col">
        <div>
          <p class="section-text">Žádné tabulky v Excelu, které si nikdo neotevře. Výsledkem je živý strategický dokument dostupný online — přehledný, konkrétní, s klikacím akčním plánem.</p>
          <ul class="deliverables-list">
            {deliverables.map((d) => (
              <li>{d}</li>
            ))}
          </ul>
          <a href="/cs/groomo-cz-na-shopify" class="text-link">OK, zkuste si příklady</a>
        </div>
        <div class="case-study-wrap">
          <div class="case-study-card">
            <img src="/fleppi-study-v2.webp" alt="Mailingová strategie pro fleppi.cz" class="case-study-img" loading="lazy" />
            <a href="/cs/pripadova-studie-email-marketing-fleppi-cz" class="case-study-cta">Přečtěte si<br/>případovou studii</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4 kroky -->
  <section class="section bg-primary" id="jak-to-funguje">
    <div class="container">
      <h2 class="h2-mini section-title-center"><strong>4 kroky</strong> k hotové strategii</h2>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card">
            <h3 class="step-num">{s.num}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pro koho -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h2-mini section-title-center">Služba je pro vás, <span class="text-action">pokud...</span></h2>
      <ul class="for-who-list">
        {forWho.map((f) => (
          <li>{f}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Zjistěte kde -->
  <section class="section-mid bg-primary">
    <div class="container">
      <h2 class="h2-mini section-title-center">Zjistěte kde váš e-shop ztrácí zákazníky<br />a jak to otočit</h2>
      <p class="section-text-center">Napište nám co chcete pochopit, a na čem jedete. Zbytek nechte na nás.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Chci analýzu —<br />volám, píši!</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading { font-size: clamp(32px, 4vw, 52px); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-40); }
  .text-action { color: #fff; }
  .intro-h2 { margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-text { font-size: clamp(16px, 1.4vw, 20px); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .section { padding: var(--space-120) 0; }
  .section-mid { padding: var(--space-80) 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }
  .section-title { margin-bottom: var(--space-40); }
  .section-title-center { margin-bottom: var(--space-40); text-align: center; }
  .section-text { font-size: 18px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: var(--space-24); }
  .section-text-center { font-size: 18px; color: rgba(255,255,255,0.75); line-height: 1.7; text-align: center; max-width: 600px; margin: 0 auto; }

  .two-col-analyze { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .analyze-label { font-family: var(--font-primary); font-size: 14px; font-weight: 700; letter-spacing: 0; color: rgba(255,255,255,0.55); text-transform: uppercase; margin-bottom: var(--space-24); }
  .analyze-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .analyze-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 16px; color: rgba(255,255,255,0.7); line-height: 1.55; }
  .analyze-list li::before { content: '→'; color: var(--text-secondary); flex-shrink: 0; line-height: 1.55; }

  .output-col { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .deliverables-list { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: var(--space-32); }
  .deliverables-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 16px; color: rgba(255,255,255,0.7); line-height: 1.55; }
  .deliverables-list li::before { content: '→'; color: var(--text-secondary); flex-shrink: 0; line-height: 1.55; }

  .case-study-wrap { display: flex; }
  .case-study-card { position: relative; border-radius: var(--radius-md); overflow: hidden; }
  .case-study-img { display: block; width: 100%; height: auto; }
  .case-study-cta {
    position: absolute; bottom: 20px; left: 20px; right: 20px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center; padding: 14px 20px;
    background: rgba(255,255,255,0.18); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.45);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 24px rgba(0,0,0,0.2);
    color: #000326; font-family: var(--font-primary); font-size: 16px; font-weight: 600;
    text-transform: uppercase; text-align: center; line-height: 1.4; text-decoration: none;
    transition: background var(--transition-base), border-color var(--transition-base);
  }
  .case-study-cta:hover { background: rgba(255,255,255,0.28); border-color: rgba(255,255,255,0.65); }
  .case-tag { font-size: 14px; font-weight: 700; letter-spacing: 0; color: rgba(255,255,255,0.55); text-transform: uppercase; }

  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-24); }
  .step-card { background: var(--ae-bg-primary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .step-num { font-size: 16px; font-weight: 700; color: var(--text-primary); margin-bottom: var(--space-12); }
  .step-card p { font-size: 14px; color: var(--neutral-300); line-height: 1.6; }

  .for-who-list { list-style: none; display: flex; flex-direction: column; gap: 16px; max-width: 640px; margin: 0 auto; }
  .for-who-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.8); line-height: 1.55; }
  .for-who-list li::before { content: '→'; color: var(--text-secondary); flex-shrink: 0; line-height: 1.55; }

  .testimonials-label { margin-bottom: var(--space-40); text-align: center; }
  .testimonials-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: stretch; }
  .testimonial-card {
    background: var(--card-button);
    border-radius: var(--radius-md);
    padding: 48px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .testimonial-header { display: flex; align-items: center; gap: 20px; }
  .testimonial-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top center;
    flex-shrink: 0;
    border: 3px solid rgba(255,255,255,0.15);
  }
  .testimonial-person { min-width: 0; }
  .testimonial-person span { display: block; font-size: 16px; color: rgba(255,255,255,0.5); margin-top: 4px; }
  .testimonial-person .text-link { display: block; font-size: 16px; margin-top: 4px; }
  .testimonial-text {
    font-size: 18px;
    color: rgba(255,255,255,0.85);
    line-height: 1.75;
    font-style: italic;
    font-family: var(--font-secondary);
    margin: 0;
    flex: 1;
  }
  .testimonial-top { display: flex; align-items: center; gap: 16px; padding-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .testimonial-footer { display: flex; align-items: center; gap: 20px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08); }
  .google-review { display: flex; flex-direction: column; align-items: center; gap: 4px; margin-left: auto; flex-shrink: 0; }
  .google-g-icon { width: 28px; height: 28px; display: block; }
  .google-stars { color: #FABB05; font-size: 18px; letter-spacing: 1px; line-height: 1; }
  .testimonial-logo-link { display: inline-flex; flex-shrink: 0; }
  .testimonial-logo { height: 67px; width: auto; max-width: 194px; object-fit: contain; flex-shrink: 0; }
  .testimonial-logo--light { background: rgba(255,255,255,0.95); border-radius: 8px; padding: 0; width: 160px; height: 120px; object-fit: cover; object-position: center; }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 1024px) {
    .two-col-analyze { grid-template-columns: 1fr; }
    .output-col { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .case-study-wrap { display: none; }
    .testimonials-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
