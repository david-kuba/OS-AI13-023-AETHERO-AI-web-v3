---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const analyzeItems = [
  'E-mail marketing — Leadhub, Klaviyo, Mailchimp, Ecomail a další. Kampaně, automations, segmenty, open rate, CTR, revenue na email.',
  'E-shopová platforma — Shoptet, Shopify, WooCommerce — objednávky, zákazníci, produkty, sezónnost, retence, AOV.',
  'Google Analytics / GA4 — Zdroje návštěvnosti, konverzní cesty, atribuční model, výkon kanálů, chování uživatelů.',
  'Google Ads — Výkon kampaní, ROAS, search terms, ztracená imprese, příležitosti pro škálování nebo úsporu.',
  'Meta Ads — Facebook & Instagram — dosah, frekvence, CPM, ROAS, audience overlap, funnel analýza.',
  'Crawling webu — Pokud data nejsou v exportu — projdeme e-shop nebo web automaticky a vytěžíme produktový katalog, ceny, kategorie, UX vzory.',
];

const deliverables = [
  'Přehled klíčových metrik — 24měsíční horizont, meziroční srovnání, identifikace trendů',
  'Analýza příčin robotu nebo poklesu — co funguje, co nefunguje a proč',
  'Přehled výkonu kampaní a automatizací — cross-sell příležitosti, segmentace zákazníků',
  'Cross-sell příležitosti a analýza nákupních košíků — co a kdy zákazníci kupují',
  'Cross-sell mapování / CRM — email kampaně, flowSy, Klavia vs zákazníci, kompetitivní metriky',
  'Segmentační doporučení — RFM modely, retence zákazníků, churn prevention',
  'SEO a integrace — email kampaně, flowSy, Klaviyo vs zákazníci, kompetitivní metriky',
  'Marketingová strategie nad rámec emailu — 40 konkrétních úkolů, které přinesou výsledky',
];

const forWho = [
  'Váš e-shop generuje data, ale nemáte kapacitu nebo know-how je správně přečíst',
  'Tušíte, že e-maily, reklamy nebo flows fungují lépe — ale nevíte jak to udělat',
  'Potřebujete konkrétní akční plán s jasnou prioritizací, ne obecná doporučení',
  'Rozhodujete se, kam investovat marketingový rozpočet v příštím roce',
];

const steps = [
  { num: '1. Napojení dat', desc: 'Pošlete nám exporty nebo API přístup k vašim platformám. Bez přístupu? Pomůžeme — pošleme vám CSV soubory nebo data vytáhneme sami. Vše se udělá diskrétně.' },
  { num: '2. Analýza', desc: 'Projdeme data do hloubky: objednávky, kampaně, zákazníci. Typicky 1–3 dny podle rozsahu dat.' },
  { num: '3. Živá spolupráce', desc: 'Projdeme výsledky s vámi v reálném čase. Vy doplňujete kontext, my zodpovídáme otázky — výsledkem je strategie šitá na míru, na nic navíc — žádné šablony.' },
  { num: '4. Strategický dokument + plán', desc: 'Dostanete přehledný online strateg. dokument s kompletní analýzou a klikacím 365denním plánem. Připravený online, kdykoli přístupný.' },
];

const relatedServices = [
  { href: '/cs/co-umime/potrebuji-brand', label: 'Potřebuji brand' },
  { href: '/cs/co-umime/novy-shopify-e-shop', label: 'Nový Shopify e-shop' },
  { href: '/cs/co-umime/prechod-na-shopify', label: 'Přechod na Shopify' },
  { href: '/cs/co-umime/expanze-do-zahranici', label: 'Expanze do zahraničí' },
  { href: '/cs/co-umime/rozvoj-a-podpora', label: 'Rozvoj a podpora' },
  { href: '/cs/co-umime/custom-vyvoj-a-aplikace', label: 'Custom vývoj a aplikace' },
];
---

<PageLayout title="Analýza a strategie | aethero" description="Přestaňte hádat — zjistěte proč váš e-shop neroste. Propojíme vaše data a dodáme strategii, která rovnou funguje." lang="cs">
  <ServiceHero
    label="Analýza a strategie"
    title="ANALÝZA<br /><span style='color:var(--action)'>A STRATEGIE</span>"
    subtitle="Víte, proč váš e-shop roste? A proč někdy neroste? Propojíme vaše data, zapojíme AI + kontext — a výsledky jsou opravdu působivé."
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#jak-to-funguje"
    image="/aethero-gradient-222.png"
    imageAlt="Analýza a strategie pro e-shop"
  />

  <!-- Přestaňte hádat -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="intro-h2">Přestaňte hádat,<br /><span class="accent-purple">ZJISTĚTE PROČ</span></h2>
      <p class="intro-text">Váš e-shop vám totiž něco říká. <strong class="hl">Posloucháte ho?</strong> Každý e-shop má v sobě a v datech schovaný příběh — kde vydělává, kde krvácí, proč někteří zákazníci zůstávají a jiní zmizí po prvním nákupu. <strong class="hl">Ta data už dávno máte, jen je nikdo nečte.</strong> A měl by.</p>
      <p class="intro-text">Chce to zkušenost a trochu technického voo-doo, ale pak se s vašimi daty, plány a ochočenou AI posadíme, propojíme je s čím je potřeba: Google Ads, Analytics, Metou i s mailovým klientem a <strong class="hl">vrátíme vám strategii, která má čísla u každého doporučení</strong>: kolik to vydělá, kolik ušetří, kdy to zapnout.</p>
      <a href="#cta" class="intro-btn">Chcete analýzu? Zavolejte →</a>
    </div>
  </section>

  <!-- Vaše data říkají víc -->
  <section class="section bg-secondary">
    <div class="container">
      <div class="two-col-analyze">
        <div>
          <h2 class="section-title">Vaše data říkají víc,<br />než si myslíte</h2>
          <p class="section-text">API přístup, CSV exporty nebo crawling webu — dokážeme napojit téměř jakýkoliv zdroj dat. Propojíme data z vašeho e-shopu, emailové kampaně, GAds, Analytiku i sociální sítě. A vy pak dostanete konkrétní strategii s kvantifikovaným přínosem každého doporučení — žádné obecné rady.</p>
          <p class="section-text"><strong>Nejčastěji pracujeme s e-shopy od 3M Kč ročního obratu na Shoptetu, Shopify a WooCommerce.</strong></p>
          <a href="#jak-to-funguje" class="section-link">Co to jsou? →</a>
        </div>
        <div>
          <h3 class="analyze-label">CO ANALYZUJEME</h3>
          <ul class="analyze-list">
            {analyzeItems.map((a) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section bg-secondary">
    <div class="container">
      <h4 class="testimonials-label">Co na tuhle službu říkají majitelé e-shopů?</h4>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <p class="testimonial-text">„Výstup byl kvalitně zpracovaný, přehledný a hlavně plný konkrétních podnětů, které můžeme rovnou využít pro další růst našeho e-shopu. Žádná obecná doporučení, ale řešení šitá nám na míru."</p>
          <p class="testimonial-author">— <strong>Lucie, majitelka fleppi.cz</strong> · ⭐⭐⭐⭐⭐ Google</p>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-text">„Jsem z toho nadšený, protože poprvé mám ucelený obraz o všem, co se v e-shopu děje, na jednom místě. Ta největší pecka je v tom, jak se ty data mezi sebou propojují. Vidím jestli je ten obsah na webu skutečně zaujal a k tomu si přihodím info z mailingu — na co nám lidi nejlépe reagují v e-mailech. Právě tyhle přesahy, kdy vidím celou cestu zákazníka od vyhledávání až po nákup, mi dovolují dělat v Shopify úpravy, které mají hlavu a patu."</p>
          <p class="testimonial-author">— <strong>Petr, majitel BU1.cz</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Výstup / Case study -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title-center">Výstup, <span class="text-action">který rovnou použijete.</span></h2>
      <div class="output-col">
        <div>
          <p class="section-text">Žádné tabulky v Excelu, které si nikdo neotevře. Výsledkem je živý strategický dokument dostupný online — přehledný, konkrétní, s klikacím akčním plánem.</p>
          <ul class="deliverables-list">
            {deliverables.map((d) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <a href="/cs/zkusenosti" class="section-link">OK, zkuste si příklady →</a>
        </div>
        <div class="case-study-wrap">
          <a href="/cs/zkusenosti" class="case-study-card">
            <img src="/fleppi-study-v2.webp" alt="Mailingová strategie pro fleppi.cz" class="case-study-img" loading="lazy" />
            <div class="case-study-label">
              <span class="case-tag">PŘÍPADOVÁ STUDIE</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4 kroky -->
  <section class="section bg-secondary" id="jak-to-funguje">
    <div class="container">
      <h2 class="section-title-center"><strong>4 kroky</strong> k hotové strategii</h2>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card">
            <h3 class="step-num">{s.num}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pro koho -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title-center">Služba je pro vás, <span class="text-action">pokud...</span></h2>
      <ul class="for-who-list">
        {forWho.map((f) => (
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Zjistěte kde -->
  <section class="section-mid bg-secondary">
    <div class="container">
      <h2 class="section-title-center">Zjistěte kde váš e-shop ztrácí zákazníky<br />a jak to otočit</h2>
      <p class="section-text-center">Napište nám co chcete pochopit, a na čem jedete. Zbytek nechte na nás.</p>
    </div>
  </section>

  <!-- Related -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Další služby</h2>
      <ul class="related-services">
        {relatedServices.map((s) => (
          <li>
            <a href={s.href} class="related-link">
              <span>{s.label}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Chci analýzu —<br />volám, píši!</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading { font-size: clamp(32px, 4vw, 52px); font-weight: 700; line-height: 1.15; margin-bottom: var(--space-40); }
  .text-action { color: var(--action); }
  .intro-h2 { font-size: clamp(40px, 6vw, 80px); font-weight: 700; line-height: 1.1; margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-btn { display: inline-flex; align-items: center; padding: 14px 32px; background: #fff; color: var(--brand-dark); font-family: var(--font-primary); font-size: 15px; font-weight: 700; text-transform: uppercase; border-radius: var(--radius-md); transition: background var(--transition-base), transform var(--transition-base); margin-top: var(--space-16); }
  .intro-btn:hover { background: rgba(255,255,255,0.88); transform: translateY(-1px); }
  .intro-text { font-size: clamp(16px, 1.4vw, 20px); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .btn-action { display: inline-flex; padding: 16px 40px; background: var(--action); color: #000; font-family: var(--font-primary); font-size: 15px; font-weight: 700; border-radius: var(--radius-md); text-decoration: none; margin-top: var(--space-32); transition: background var(--transition-base); }
  .btn-action:hover { background: var(--action-hover); }

  .section { padding: var(--space-120) 0; }
  .section-mid { padding: var(--space-80) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: clamp(32px, 5vw, 70px); font-weight: 600; margin-bottom: var(--space-40); }
  .section-title-center { font-size: clamp(24px, 3vw, 40px); font-weight: 600; margin-bottom: var(--space-40); text-align: center; }
  .section-text { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: var(--space-24); }
  .section-text-center { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; text-align: center; max-width: 600px; margin: 0 auto; }
  .section-link { color: var(--action); font-size: 15px; font-weight: 600; text-decoration: none; }
  .section-link:hover { opacity: 0.75; }

  .two-col-analyze { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .analyze-label { font-family: var(--font-primary); font-size: 12px; font-weight: 700; letter-spacing: 0; color: var(--action); text-transform: uppercase; margin-bottom: var(--space-24); }
  .analyze-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .analyze-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.5; }
  .analyze-list svg { flex-shrink: 0; margin-top: 2px; }

  .output-col { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .deliverables-list { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: var(--space-32); }
  .deliverables-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.5; }
  .deliverables-list svg { flex-shrink: 0; margin-top: 2px; }

  .case-study-wrap { display: flex; }
  .case-study-card { display: block; text-decoration: none; border-radius: var(--radius-md); overflow: hidden; background: var(--bg-secondary); transition: transform var(--transition-base); }
  .case-study-card:hover { transform: translateY(-4px); }
  .case-study-img { display: block; width: 100%; height: auto; }
  .case-study-label { padding: var(--space-16); }
  .case-tag { font-size: 11px; font-weight: 700; letter-spacing: 0; color: var(--action); text-transform: uppercase; }

  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-24); }
  .step-card { background: var(--bg-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .step-num { font-size: 15px; font-weight: 700; color: var(--text-primary); margin-bottom: var(--space-12); }
  .step-card p { font-size: 14px; color: var(--neutral-300); line-height: 1.6; }

  .for-who-list { list-style: none; display: flex; flex-direction: column; gap: 16px; max-width: 640px; margin: 0 auto; }
  .for-who-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.8); line-height: 1.5; }
  .for-who-list svg { flex-shrink: 0; margin-top: 2px; }

  .related-services { list-style: none; display: flex; flex-direction: column; }
  .related-link { display: flex; align-items: center; justify-content: space-between; padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 15px; color: var(--neutral-300); transition: color var(--transition-base); text-decoration: none; }
  .related-link:hover { color: var(--action); }

  .testimonials-label { font-size: clamp(18px, 2vw, 24px); font-weight: 600; margin-bottom: var(--space-40); text-align: center; }
  .testimonials-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-40); }
  .testimonial-card { background: rgb(232, 222, 255); border-radius: var(--radius-md); padding: var(--space-32); }
  .testimonial-text { font-size: 15px; color: #1a1a2e; line-height: 1.7; margin-bottom: var(--space-16); font-style: italic; }
  .testimonial-author { font-size: 14px; color: #1a1a2e; opacity: 0.85; }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.1; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--brand-dark); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 1024px) {
    .two-col-analyze { grid-template-columns: 1fr; }
    .output-col { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .case-study-wrap { display: none; }
    .testimonials-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
