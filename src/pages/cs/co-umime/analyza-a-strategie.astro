---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const steps = [
  { step: '01', title: 'Datový audit', desc: 'GA4, Google Ads, Meta Ads, emailová platforma — sbíráme vše na jednom místě.' },
  { step: '02', title: 'Analýza a segmentace', desc: 'RFM analýza zákazníků, crawl produktů, identifikace problémových oblastí.' },
  { step: '03', title: 'Strategie a priority', desc: '365denní akční plán s prioritizovanými úkoly a jasnou odpovědností.' },
  { step: '04', title: 'Implementace a měření', desc: 'Zapracování doporučení, sledování výsledků a iterace.' },
];

const tools = [
  'Klaviyo, Mailchimp, Ecomail',
  'Google Analytics 4',
  'Google Ads a Meta Ads',
  'Shopify, Shoptet, WooCommerce',
  'Crawl produktů a obsahová analýza',
  'Zákaznická segmentace (RFM)',
];

const deliverables = [
  'Přehled klíčových metrik (24měsíční horizont)',
  'Analýza příčin růstu a poklesu',
  'Přehled výkonu kampaní a automatizací',
  'Mapa cross-sell příležitostí',
  'Segmentační doporučení (RFM)',
  'Marketingová strategie nad rámec emailu',
  '365denní akční plán s 40+ úkoly a odhadem ROI',
];

const forWho = [
  'E-shop s obratem minimálně 3 miliony Kč ročně',
  'Cítíte, že data nevyužíváte naplno',
  'Kampaně běží, ale výsledky stagnují',
  'Nemáte interní analytický tým',
  'Chcete konkrétní doporučení, ne obecné rady',
];

const relatedServices = [
  { href: '/cs/co-umime/potrebuji-brand', label: 'Potřebuji brand' },
  { href: '/cs/co-umime/novy-shopify-e-shop', label: 'Nový Shopify e-shop' },
  { href: '/cs/co-umime/prechod-na-shopify', label: 'Přechod na Shopify' },
  { href: '/cs/co-umime/expanze-do-zahranici', label: 'Expanze do zahraničí' },
  { href: '/cs/co-umime/rozvoj-a-podpora', label: 'Rozvoj a podpora' },
  { href: '/cs/co-umime/custom-vyvoj-a-aplikace', label: 'Custom vývoj a aplikace' },
];
---

<PageLayout title="Analýza a strategie" description="Přestaňte hádat — zjistěte proč váš e-shop neroste. Propojíme vaše data a dodáme strategii, která rovnou funguje." lang="cs">
  <ServiceHero
    label="Analýza a strategie"
    title="ANALÝZA A STRATEGIE"
    subtitle="Víte, proč váš e-shop roste? A proč někdy neroste? Propojíme vaše data a dodáme strategii, která rovnou funguje."
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#jak-to-funguje"
  />

  <!-- Section 1: Přestaňte hádat -->
  <section class="section bg-elevated">
    <div class="container">
      <div class="intro-block">
        <h2 class="section-title">Přestaňte hádat, <span class="title-accent">ZJISTĚTE PROČ</span></h2>
        <p class="section-text">Každý e-shop skrývá ve svých datech příběh — kde jsou zóny ziskovosti, proč zákazníci odcházejí nebo zůstávají. Kombinujeme zkušenosti, technické know-how a AI, abychom propojili data z Google Ads, Analytics, Meta a emailových platforem. Výsledky jsou měřitelné od prvního dne.</p>
        <p class="section-text">Cílíme na e-shopy s obratem od 3 milionů Kč ročně na Shoptetu, Shopify nebo WooCommerce.</p>
      </div>
    </div>
  </section>

  <!-- Section 2: 4 kroky -->
  <section id="jak-to-funguje" class="section bg-secondary">
    <div class="container">
      <h2 class="section-title">4 kroky k hotové strategii</h2>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card">
            <span class="step-num">{s.step}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3: Co analyzujeme / Co dostanete -->
  <section class="section bg-elevated">
    <div class="container two-col">
      <div>
        <h2 class="section-title">Co analyzujeme</h2>
        <ul class="tools-list">
          {tools.map((t) => (
            <li>{t}</li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="section-title">Co dostanete</h2>
        <ul class="check-list">
          {deliverables.map((d) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {d}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Section 4: Pro koho je služba -->
  <section class="section bg-secondary">
    <div class="container for-who-block">
      <h2 class="section-title">Služba je pro vás, pokud…</h2>
      <ul class="check-list for-who-list">
        {forWho.map((f) => (
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {f}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Related services -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Další služby</h2>
      <ul class="related-services">
        {relatedServices.map((s) => (
          <li>
            <a href={s.href} class="related-link">
              <span>{s.label}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Výstup, který rovnou použijete</h2>
      <p>Zavolejme si a zjistíme, co vaše data prozrazují.</p>
      <div class="cta-links">
        <a href="mailto:info@aethero.cz" class="btn-primary">Zavolejme si</a>
        <a href="tel:+420776067663" class="btn-ghost">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-40); }
  .title-accent { color: var(--action); }
  .section-text { font-size: 18px; color: rgba(255,255,255,0.8); line-height: 1.7; margin-bottom: var(--space-24); }
  .intro-block { max-width: 780px; }

  /* Steps */
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-24); }
  .step-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .step-num { display: block; font-family: var(--font-primary); font-size: 13px; font-weight: 600; color: var(--action); margin-bottom: var(--space-16); }
  .step-card h3 { font-size: 16px; font-weight: 600; margin-bottom: var(--space-8); }
  .step-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }

  /* Two-col layout */
  .two-col { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-80); }

  /* Tools list */
  .tools-list { list-style: none; display: flex; flex-direction: column; gap: 12px; padding: 0; }
  .tools-list li { font-size: var(--text-small); color: var(--neutral-300); padding-left: 20px; position: relative; line-height: 1.6; }
  .tools-list li::before { content: '—'; position: absolute; left: 0; color: var(--text-secondary); }

  /* Check list */
  .check-list { list-style: none; display: flex; flex-direction: column; gap: 12px; padding: 0; }
  .check-list li { display: flex; align-items: flex-start; gap: var(--space-8); font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .check-list li svg { flex-shrink: 0; margin-top: 2px; }

  /* For who */
  .for-who-block { max-width: 640px; }
  .for-who-list { }

  /* Related services */
  .related-services { list-style: none; display: flex; flex-direction: column; padding: 0; }
  .related-link { display: flex; align-items: center; justify-content: space-between; padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 15px; color: var(--neutral-300); transition: color var(--transition-base); text-decoration: none; }
  .related-link:hover { color: var(--action); }

  /* CTA */
  .cta-section { padding: var(--space-120) 0; background: var(--bg-primary-alt); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-16); }
  .cta-inner p { color: var(--neutral-300); margin-bottom: var(--space-40); }
  .cta-links { display: flex; gap: var(--space-16); justify-content: center; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--bg-elevated); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: background var(--transition-base); text-decoration: none; }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: border-color var(--transition-base), color var(--transition-base); text-decoration: none; }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }

  /* Responsive */
  @media (max-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .two-col { grid-template-columns: 1fr; gap: var(--space-40); }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .steps-grid { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr; }
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
