---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const features = [
  {
    title: 'AI parťák, přímo v e-shopu',
    logo: '/shopify-sidekick-logo2.webp',
    desc: 'Sidekick je AI asistent integrovaný do adminu e-shopu a výrazně vám urychlí práci v Shopify. Dokáže provádět operativní úkoly (vytvořit produkt, upravovat kolekce, analyzovat prodeje, připraví reporty), pomůže s marketingem (psaní popisků, e-mailů, SEO doporučení), umí navrhovat a aplikovat úpravy storefrontu včetně změn vzhledu nebo upravovat téma podle zadání včetně tvorby Liquid kódu. Sidekick umí vysvětlit, jak fungují nastavení v adminu, doporučit kroky pro růst e-shopu, automatizovat procesy a navrhovat best practices. Odpovědi personalizuje podle prodejů, zákazníků a specifické konfigurace vašeho obchodu.',
    img: '/shopify-premium-story.webp',
    reverse: false,
  },
  {
    title: 'Přehledná a moderní administrace',
    logo: null,
    desc: 'Administrační prostředí, ve kterém se zorientuješ během chvíle – i bez technických znalostí. Produkty, objednávky, platby i obsah se spravuje z jednoho místa, jednoduše a logicky. Místo složitého systému dostanete nástroj, který dává kontrolu nad e-shopem hned od prvního dne. A nebojte, můžete ji používat i v češtině.',
    img: null,
    reverse: true,
  },
  {
    title: 'Správa e-shopu v appce',
    logo: null,
    desc: 'Shopify mobile app umožňuje spravovat celý e-shop z telefonu. Sledujte tržby v reálném čase, zpracovávejte objednávky, reagujte na zákazníky a monitorujte výkon odkudkoli na světě.',
    img: '/appka.webp',
    reverse: false,
  },
  {
    title: 'Možnost prodávat tam, kde to žije',
    logo: null,
    desc: 'Instagram, TikTok, Facebook, Google Shopping, Amazon — vše napojené na jediný Shopify admin. Jeden sklad, jedna pravda o zásobách, jedno centrum pro všechny objednávky.',
    img: '/prodej-kdekoliv.webp',
    reverse: true,
  },
  {
    title: 'Analytika, marketing',
    logo: null,
    desc: 'Přehledné dashboardy, sledování trendů a chytrá segmentace zákazníků. Shopify Email, SMS marketing a integrace s Google Analytics, Meta Ads nebo Klaviyo — vše bez složitého nastavování.',
    img: '/data-marketing.webp',
    reverse: false,
  },
  {
    title: 'Automatizace',
    logo: null,
    desc: 'Shopify Flow reaguje na chování zákazníků automaticky. Tagování objednávek, e-mailové sekvence, slevy, upozornění skladníků — jednou nastavíte, pak to funguje bez vás.',
    img: '/flow-automation.webp',
    reverse: true,
  },
  {
    title: 'Shopify App Store',
    logo: null,
    desc: 'Apps.shopify.com — ekosystém, do kterého už někdo investoval miliony hodin. Shopify App Store není „jen seznam doplňků". Je to jeden z největších e-commerce ekosystémů na světě — místo, kde vývojáři, technologické firmy a samotné Shopify posledních více než 15 let systematicky řeší problémy, které by vás jinak stály měsíce vývoje, testování a ladění. Najdete tu přes deset tisíc aplikací, které rozšiřují Shopify prakticky o cokoliv, co vás napadne.',
    img: '/aplikace.webp',
    reverse: false,
  },
];

const reasons = [
  'Jedna z 3 nejpoužívanějších e-commerce platforem na světě',
  'Rok napřed před evropskou konkurencí v aktualizacích a funkcích',
  'Velká mezinárodní firma — nezávislost na jediném lokálním dodavateli',
  'Mezinárodní škálování bez nutnosti migrace platforem',
  'PCI DSS certifikace a špičkové zabezpečení v základu',
  'Shopify Plus pro enterprise s dedikovaným supportem',
  'Komunita partnerů a agentur po celém světě',
];

const capabilities = [
  'Správa produktů, kolekcí a cen',
  'Objednávky, zásoby a dopravci',
  'Zákazníci a CRM',
  'Platební brány a checkout',
  'SEO a marketing nástroje',
  'Analytika a reporty',
  'Aplikace a integrace',
  'Multi-jazyk a multi-měna',
];

---

<PageLayout title="Nový Shopify e-shop | aethero" description="Spustíme váš nový e-shop na Shopify — od návrhu přes vývoj až po první objednávku. Přeskočíme slepé uličky a rovnou spustíme e-shop, který vydělává." lang="cs">
  <ServiceHero
    label="Nový e-shop"
    title="NOVÝ E-SHOP<br /><span style='color:#fff'>NA SHOPIFY</span>"
    subtitle="Spusťte váš e-commerce projekt na mezinárodní superplatformě. Přeskočíme slepé uličky a rovnou spustíme e-shop, který vydělává."
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#shopify-proc"
    image="/infinity.webp"
    imageAlt="Shopify e-shop na aethero"
  />

  <!-- Pojďme rozběhnout -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h1 intro-h2">Pojďme rozběhnout váš<br /><span class="accent-purple">NOVÝ E-SHOP</span> na Shopify</h2>
      <p class="intro-text">Všechno začíná stejně — skvělý nápad, mlhavá představa o tom, jak ho spustit. Budete stavět sami, nebo s námi? <strong class="hl">Pokud si myslíte Shopify je pro vás velký, přesvědčíme vás o opaku.</strong></p>
      <p class="intro-text">Pokud váš projekt myslíte vážně, <strong class="hl">víme, jak na to</strong>. Rádi spolupracujeme s lidmi, kteří přicházejí s plány — ne s otázkami, jestli to vůbec půjde. Zkušenosti a intuici přineseme my. Přijdete s cílem a my najdeme cestu.</p>
      <a href="#cta" class="btn-secondary">Tak pojďme na to</a>
    </div>
  </section>

  <!-- Co spolu se Shopify dostaneme -->
  <section class="section bg-primary" id="shopify-proc">
    <div class="container">
      <div class="two-col-capabilities">
        <div>
          <h2 class="h2 section-title">Ptáte se, co spolu s Shopify dostaneme?</h2>
          <p class="section-text">Moderní e-commerce platforma, která má za sebou desítky milionů obchodníků a roky vývoje — technologická infrastruktura, globální distribuce, PCI DSS compliance a více než 10 000 aplikací.</p>
          <p class="section-text">Shopify investuje desítky miliard dolarů ročně do infrastruktury. Tím pádem, že se vás netýkají výpadky, bezpečnostní incidenty nebo zaostávání za konkurencí.</p>
          <a href="#features" class="text-link">Co to jsou?</a>
        </div>
        <ul class="capability-list" id="features">
          {capabilities.map((c) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{c}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Feature sections - alternating image/text -->
  {features.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          {f.logo && <img src={f.logo} alt={f.title} class="feature-logo" loading="lazy" />}
          <h2 class="h3-mini feature-title">{f.title}</h2>
          <p class="feature-desc">{f.desc}</p>
        </div>
        {f.img && (
          <div class="feature-img-wrap">
            <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />
          </div>
        )}
        {!f.img && (
          <div class="feature-img-wrap feature-img-wrap--empty"></div>
        )}
      </div>
    </section>
  ))}

  <!-- Proč Shopify + Groomo -->
  <section class="section bg-primary">
    <div class="container two-col-groomo">
      <div>
        <h2 class="h2 section-title">PROČ začít na platformě Shopify?</h2>
        <p class="section-text">Pojď nám říct proč nejpopulárnější e-commerce platforma na světě je ideální volbou pro vaše podnikání — bez ohledu na velikost ani produkty.</p>
        <ul class="reasons-list">
          {reasons.map((r) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="groomo-wrap">
        <div class="groomo-card">
          <img src="/groomo-ref-na-vysku.webp" alt="Groomo — případová studie" class="groomo-img" loading="lazy" />
          <a href="/cs/groomo-cz-na-shopify" class="groomo-cta">Přečtěte si<br/>případovou studii</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Už jste rozhodnutí?<br />Tak se ozvěte:</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* Intro section */
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-40);
    max-width: 760px;
  }
  .text-action { color: #fff; }
  .intro-h2 { margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-text {
    font-size: clamp(16px, 1.4vw, 20px);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    max-width: 860px;
    margin-bottom: var(--space-24);
  }
  .intro-text--spaced { margin-top: var(--space-40); }
  /* Capabilities section */
  .section { padding: var(--space-120) 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }
  .section-title { margin-bottom: var(--space-40); }
  .section-text { font-size: 18px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: var(--space-24); }
  .two-col-capabilities { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .capability-list { list-style: none; display: flex; flex-direction: column; gap: 16px; padding-top: var(--space-8); }
  .capability-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.8); line-height: 1.5; }
  .capability-list svg { flex-shrink: 0; margin-top: 1px; }

  /* Feature sections */
  .feature-section { padding: var(--space-120) 0; }
  .feature-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-80);
    align-items: center;
  }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text { direction: ltr; }
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-logo { display: block; height: 32px; width: auto; margin-bottom: var(--space-24); }
  .feature-title { margin-bottom: var(--space-24); }
  .feature-desc { font-size: 18px; color: rgba(255,255,255,0.75); line-height: 1.6; }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }
  .feature-img-wrap--empty { min-height: 200px; }
  .feature-img {
    width: 100%;
    max-width: 560px;
    height: auto;
    border-radius: var(--radius-md);
    display: block;
  }

  /* Proč Shopify + Groomo */
  .two-col-groomo { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .reasons-list { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-top: var(--space-24); }
  .reasons-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.75); line-height: 1.5; }
  .reasons-list svg { flex-shrink: 0; margin-top: 2px; }
  .groomo-wrap { display: flex; justify-content: center; }
  .groomo-card { position: relative; max-width: 340px; width: 100%; border-radius: 6px; overflow: hidden; }
  .groomo-img { display: block; width: 100%; height: auto; }
  .groomo-cta {
    position: absolute; bottom: 20px; left: 20px; right: 20px;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    padding: 14px 20px;
    background: rgba(255,255,255,0.18);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.45);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 24px rgba(0,0,0,0.2);
    color: #000326;
    font-family: var(--font-primary); font-size: 16px; font-weight: 600;
    text-transform: uppercase; text-align: center; line-height: 1.4;
    text-decoration: none;
    transition: background var(--transition-base), border-color var(--transition-base);
  }
  .groomo-cta:hover { background: rgba(255,255,255,0.28); border-color: rgba(255,255,255,0.65); }

  /* CTA */
  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  /* Responsive */
  @media (max-width: 1024px) {
    .two-col-capabilities { grid-template-columns: 1fr; }
    .two-col-groomo { grid-template-columns: 1fr; }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
