---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';
import WorkSidebar from '../../../components/layout/WorkSidebar.astro';

const startSteps = [
  { icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>', title: 'Vaše plány a požadavky', desc: 'Řekněte nám, jak si projekt představujete a jaké máte potřeby.' },
  { icon: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>', title: 'Naše analýza, doporučení', desc: 'Projdeme podrobnosti, vyjasníme neznámé a vytvoříme doporučení rozsahu a možností.' },
  { icon: '<path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"/>', title: 'Nabídka → Smlouva', desc: 'Po zpřesnění z obou stran vzniká nabídka a z té pak smlouva.' },
  { icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>', title: 'Projekt', desc: 'Rozbíháme projekt, společně s vámi nastavujeme, propojujeme a vytváříme.' },
  { icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>', title: 'Správa a rozvoj', desc: 'Po spuštění práce nekončí, spíše začíná. Jste na cestě k úspěšnému e-commerce projektu.' },
];

const features = [
  {
    title: 'AI parťák, přímo v e-shopu',
    logo: '/shopify-sidekick-logo2.webp',
    logoText: 'Shopify<br />Sidekick',
    desc: 'Sidekick je <strong class="hl">AI asistent integrovaný do adminu e-shopu a výrazně vám urychlí práci v Shopify.</strong> Dokáže provádět operativní úkoly (vytvořit produkt, upravovat kolekce, analyzovat prodeje, připraví reporty), pomůže s marketingem (psaní popisků, e-mailů, SEO doporučení), umí navrhovat a aplikovat úpravy storefrontu včetně změn vzhledu nebo upravovat téma podle zadání včetně tvorby Liquid kódu. <strong class="hl">Sidekick umí vysvětlit, jak fungují nastavení v adminu, doporučit kroky pro růst e-shopu, automatizovat procesy a navrhovat best practices.</strong> Odpovědi personalizuje podle prodejů, zákazníků a specifické konfigurace vašeho obchodu.',
    img: '/shopify-premium-story.webp',
    reverse: false,
  },
  {
    title: 'Přehledná a moderní administrace',
    logo: null,
    desc: '<strong class="hl">Administrační prostředí, ve kterém se zorientuješ během chvíle – i bez technických znalostí.</strong> Produkty, objednávky, platby i obsah se spravuje z jednoho místa, jednoduše a logicky. Místo složitého systému dostanete nástroj, který dává kontrolu nad e-shopem hned od prvního dne. <strong class="hl">A nebojte, můžete ji používat i v češtině.</strong>',
    img: '/shopify-admin.png',
    reverse: true,
  },
  {
    title: 'Správa e-shopu v appce',
    logo: null,
    desc: '<strong class="hl">Shopify má nativní mobilní aplikaci, která vám dá plnou kontrolu nad e-shopem odkudkoliv.</strong> Sledujte tržby v reálném čase, spravujte objednávky, přidávejte produkty nebo komunikujte se zákazníky — přímo z telefonu. <strong class="hl">Ať jste na cestách, na schůzce nebo prostě nejste u počítače, e-shop běží dál a vy ho máte v kapse.</strong>',
    img: '/appka.webp',
    reverse: false,
  },
  {
    title: 'Možnost prodávat tam, kde to žije',
    logo: null,
    desc: 'Shopify vám umožňuje prodávat nejen přes vlastní e-shop, ale přímo tam, kde zákazníci tráví čas — <strong class="hl">na Instagramu, TikToku, Facebooku, v Google Shopping nebo přes Amazon. Všechny kanály se spravují z jednoho místa,</strong> objednávky, sklad i analytika jsou propojené. Místo aby zákazník musel přijít k vám, jdete vy za ním.',
    img: '/prodej-kdekoliv.webp',
    reverse: true,
  },
  {
    title: 'Analytika, marketing',
    logo: null,
    desc: 'Analytika v Shopify vám dá <strong class="hl">jasný přehled o tom, co v marketingu skutečně funguje.</strong> Díky přehledným dashboardům a chytrým reportům lze jednoduše sledovat vývoj tržeb, chování zákazníků i výkon jednotlivých kampaní. Propojení s nástroji jako Google Analytics, reklamními systémy nebo s e-mailovými službami umožňuje vidět celý nákupní proces v souvislostech. Správně nastavené měření <strong class="hl">pomáhá rychle reagovat na změny, optimalizovat rozpočty a soustředit energii tam, kde má marketing největší dopad.</strong>',
    img: '/data-marketing.webp',
    reverse: false,
  },
  {
    title: 'Automatizace',
    logo: null,
    desc: 'Automatizace uvnitř e-shopu, postavená zejména na Shopify Flow a event-driven architektuře, umožňuje reagovat na data v reálném čase. Pomáhá je převádět do konkrétních akcí bez nutnosti manuálních zásahů. <strong class="hl">Pomocí přednastavených nebo vlastních workflow lze automaticky reagovat na chování zákazníků, změny v objednávkách či výkonnost kampaní.</strong> Výsledkem je úspora času, méně chyb a marketing, který funguje plynule i ve chvíli, kdy tým řeší jiné priority.',
    img: '/flow-automation.webp',
    reverse: true,
  },
  {
    title: 'Shopify App Store',
    logo: null,
    desc: '<a href="https://apps.shopify.com/" target="_blank" rel="noopener noreferrer" class="text-link">Apps.shopify.com</a> — <strong class="hl">ekosystém, do kterého už někdo investoval miliony hodin. Shopify App Store není „jen seznam doplňků". Je to jeden z největších e-commerce ekosystémů na světě</strong> — místo, kde vývojáři, technologické firmy a samotné Shopify posledních více než 15 let systematicky řeší problémy, které by vás jinak stály měsíce vývoje, testování a ladění. Najdete tu přes deset tisíc aplikací, které rozšiřují Shopify prakticky o cokoliv, co vás napadne… a často i o to, co vás zatím ještě nenapadlo, že budete potřebovat.',
    img: '/aplikace.webp',
    reverse: false,
  },
];

const appStore = features[features.length - 1];
const featuresMain = features.slice(0, -1);

const reasons = [
  '<strong class="hl">Patří mezi tři světově nejpoužívanější systémy pro e-commerce</strong>, takže má určitě dostatečnou variabilitu i pro vaše produkty a váš projekt.',
  '<strong class="hl">Změny v e-commerce jsou extrémně rychlé</strong>, to je bez diskuze. <strong class="hl">Potřebuje mít platformu která má před evropskou konkurencí spíše roční náskok</strong> a ne 2 roky zpoždění a technický dluh.',
  '<strong class="hl">Nejde o relativně malou, lokální českou firmu</strong> s cílením na e-commerce prodej v Čechách a Slovensku (a možná trochu v Polsku a Maďarsku).',
  'Pravděpodobně <strong class="hl">nechcete být závislí na jediné servisní firmě</strong>, když se něco pokazí - ( a tím myslíme, že ani na nás ne)',
  'Protože na začátku si možná umíte s lecčím poradit i sami, takže <strong class="hl">ušetříte a za dva roky pak máte možnost mít mezinárodní firmu na stejném systému</strong> a k tomu výběr z aplikací i firem, co o vás budou pečovat. Bez migrace.',
];

const capabilities = [
  'Správa produktů, kolekcí a cen',
  'Objednávky, zásoby a dopravci',
  'Zákazníci a CRM',
  'Platební brány a checkout',
  'SEO a marketing nástroje',
  'Analytika a reporty',
  'Aplikace a integrace',
  'Multi-jazyk a multi-měna',
];

---

<PageLayout title="Nový Shopify e-shop | aethero" description="Spustíme váš nový e-shop na Shopify — od návrhu přes vývoj až po první objednávku. Přeskočíme slepé uličky a rovnou spustíme e-shop, který vydělává." lang="cs">
  <ServiceHero
    label="Nový e-shop"
    title="NOVÝ E-SHOP<br /><span style='color:#fff'>NA SHOPIFY</span>"
    subtitle="Spusťte váš e-commerce projekt na mezinárodní superplatformě. Přeskočíme slepé uličky a rovnou spustíme e-shop, který vydělává."
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#shopify-proc"
    image="/infinity.webp"
    imageAlt="Shopify e-shop na aethero"
  />

  <!-- Pojďme rozběhnout -->
  <section class="section bg-primary">
    <div class="container intro-layout">
      <div class="intro-main">
        <h2 class="h1 intro-h2">Pojďme rozběhnout váš<br /><span class="accent-purple">NOVÝ E-SHOP</span> na Shopify</h2>
        <p class="intro-text">Všechno začíná stejně — skvělý nápad, mlhavá představa o tom, jak ho spustit. Budete stavět sami, nebo s námi? <strong class="hl">Pokud si myslíte Shopify je pro vás velký, přesvědčíme vás o opaku.</strong></p>
        <p class="intro-text">Pokud váš projekt myslíte vážně, <strong class="hl">víme, jak na to</strong>. Rádi spolupracujeme s lidmi, kteří přicházejí s plány — ne s otázkami, jestli to vůbec půjde. Zkušenosti a intuici přineseme my. Přijdete s cílem a my najdeme cestu.</p>
        <a href="#cta" class="btn-action btn-action--lg">Tak pojďme na to</a>
      </div>
      <WorkSidebar heading="JAK ZAČNEME" items={startSteps} />
    </div>
  </section>

  <!-- Co spolu se Shopify dostaneme -->
  <section class="section bg-primary" id="shopify-proc">
    <div class="container">
      <h2 class="h2 section-title">Ptáte se, co spolu<br />s Shopify dostanete?</h2>
      <div class="two-col-capabilities">
        <ul class="plus-list" id="features">
          {capabilities.map((c) => (
            <li>{c}</li>
          ))}
        </ul>
        <div>
          <p class="section-text body-maxi">Moderní e-commerce platformu, která má <strong class="hl">rychlost, stabilitu a bezpečnost v základu</strong>, možnost globálního prodeje bez technických kompromisů, připravenost na více jazyků, měn i trhů. <strong class="hl">Na Shopify můžete fungovat od prvních objednávek až po mezinárodní brand – bez přepisování e-shopu každé dva roky.</strong></p>
          <p class="section-text body">Tohle vychvalování bychom asi měli trochu něčím „podepřít”, že? Tak se na to koukneme. Vybrali jsme pro vás některé z funkcí, které považujeme za zásadní a často překvapivě nejsou zcela běžné.</p>
          <p class="section-text body">Na konci stránky jsme pro vás shrnuli proč začít právě na platformě Shopify</p>
          <a href="#proc-zacit" class="btn-action btn-action--ghost">Proč začít na Shopify</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature sections - alternating image/text -->
  {featuresMain.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          <h2 class="h3-mini feature-title">{f.title}</h2>
          <p class="body" set:html={f.desc}></p>
        </div>
        {f.img && (
          <div class="feature-img-wrap">
            {f.logo && (
              <div class="feature-logo-lockup">
                <img src={f.logo} alt={f.title} class="feature-logo" loading="lazy" />
                {f.logoText && <span class="feature-logo-text" set:html={f.logoText}></span>}
              </div>
            )}
            <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />
          </div>
        )}
        {!f.img && (
          <div class="feature-img-wrap feature-img-wrap--empty"></div>
        )}
      </div>
    </section>
  ))}

  <!-- Shopify App Store — nadpis + text nahoře, mřížka ikon full-width dole -->
  <section class="section bg-primary appstore-section">
    <div class="container">
      <div class="appstore-head">
        <h2 class="appstore-title">Shopify<br />App Store</h2>
        <p class="body appstore-text" set:html={appStore.desc}></p>
      </div>
      <div class="appstore-grid">
        <img src={appStore.img} alt="Shopify App Store — ekosystém aplikací" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Proč Shopify + Groomo -->
  <section class="section bg-primary" id="proc-zacit">
    <div class="container">
      <h2 class="h2 section-title">PROČ začít<br />na platformě Shopify?</h2>
      <div class="two-col-groomo">
        <div>
          <p class="section-text body">Najděte si svoje vlastní důvody proč zkusit Shopify s námi</p>
          <ul class="reasons-list">
            {reasons.map((r) => (
              <li>
                <span class="reason-arrow" aria-hidden="true">➔</span>
                <span set:html={r}></span>
              </li>
            ))}
          </ul>
        </div>
        <div class="groomo-wrap">
          <div class="groomo-card">
            <img src="/groomo-ref-na-vysku.webp" alt="Groomo — případová studie" class="groomo-img" loading="lazy" />
            <a href="/cs/groomo-cz-na-shopify" class="groomo-cta">Přečtěte si<br/>případovou studii</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Už jste rozhodnutí?<br />Tak se ozvěte:</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* Intro section */
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading {
    font-size: var(--fs-52);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-40);
    max-width: 760px;
  }
  .text-action { color: #fff; }
  .intro-h2 { margin-bottom: var(--space-40); }
  /* Intro + JAK ZAČNEME sidebar = 2 sloupce */
  .intro-layout { display: grid; grid-template-columns: 1fr 355px; gap: var(--space-64); align-items: start; }
  .intro-main { min-width: 0; }
  .intro-main .intro-text { max-width: none; }
  @media (max-width: 900px) { .intro-layout { grid-template-columns: 1fr; gap: var(--space-40); } }
  .accent-purple { color: var(--text-secondary); }
  /* .hl (bold lavender) — globální utilita v global.css */
  .intro-text {
    font-size: var(--fs-20);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    max-width: 860px;
    margin-bottom: var(--space-24);
  }
  .intro-text--spaced { margin-top: var(--space-40); }
  /* Capabilities section */
  .section { padding: var(--space-120) 0; }
  #shopify-proc { padding-top: calc(var(--space-120) - var(--space-40)); }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }
  .section-title { margin-bottom: var(--space-40); }
  .section-text { margin-bottom: var(--space-24); }
  .two-col-capabilities { display: grid; grid-template-columns: 1fr 2fr; gap: var(--space-80); align-items: start; }
  /* plus-list — odrážky „+" 22px levandule (lokální varianta check-listu) */
  .plus-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-16); }
  .plus-list li { display: flex; align-items: flex-start; gap: 12px; font-family: var(--font-secondary); font-size: var(--text-body); color: rgba(255,255,255,0.8); line-height: 1.6; }
  .plus-list li::before { content: '+'; color: var(--text-secondary); font-size: 24px; font-weight: 700; line-height: 1.3; flex-shrink: 0; }

  /* Feature sections */
  .feature-section { padding: var(--space-120) 0; }
  .feature-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-80);
    align-items: center;
  }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text { direction: ltr; }
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-logo-lockup { display: flex; align-items: center; align-self: flex-start; gap: var(--space-16); }
  .feature-logo { display: block; height: 64px; width: auto; transform: translateX(2px); }
  .feature-logo-text { font-family: var(--font-primary); font-size: var(--fs-30); font-weight: 700; color: #fff; line-height: 1.05; }
  .feature-title { margin-bottom: var(--space-24); }
  .feature-img-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--space-24); }
  .feature-img-wrap--empty { min-height: 200px; }
  .feature-img {
    width: 100%;
    max-width: 560px;
    height: auto;
    border-radius: var(--radius-md);
    display: block;
  }

  /* Proč Shopify + Groomo */
  /* Shopify App Store — nadpis + text nahoře, mřížka ikon full-width dole */
  .appstore-head { display: grid; grid-template-columns: 280px 1fr; gap: var(--space-64); align-items: start; margin-bottom: var(--space-64); }
  .appstore-title { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: #fff; line-height: 1.05; margin: 0; }
  .appstore-text { max-width: 900px; }
  .appstore-grid img { width: 100%; height: auto; display: block; border-radius: var(--radius-md); }
  @media (max-width: 900px) { .appstore-head { grid-template-columns: 1fr; gap: var(--space-24); } }

  .two-col-groomo { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .reasons-list { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-top: var(--space-24); }
  .reasons-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.5; }
  .reason-arrow { flex-shrink: 0; color: var(--text-secondary); }
  .groomo-wrap { display: flex; justify-content: center; align-self: end; }
  .groomo-card { position: relative; max-width: 340px; width: 100%; border-radius: 6px; overflow: hidden; }
  .groomo-img { display: block; width: 100%; height: auto; }
  .groomo-cta {
    position: absolute; bottom: 20px; left: 20px; right: 20px;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    padding: 14px 20px;
    background: rgba(255,255,255,0.18);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.45);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 24px rgba(0,0,0,0.2);
    color: #000326;
    font-family: var(--font-primary); font-size: 16px; font-weight: 600;
    text-transform: uppercase; text-align: center; line-height: 1.4;
    text-decoration: none;
    transition: background var(--transition-base), border-color var(--transition-base);
  }
  .groomo-cta:hover { background: rgba(255,255,255,0.28); border-color: rgba(255,255,255,0.65); }

  /* CTA */
  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: var(--fs-70); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  /* Responsive */
  @media (max-width: 1024px) {
    .two-col-capabilities { grid-template-columns: 1fr; }
    .two-col-groomo { grid-template-columns: 1fr; }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
