---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const workCards = [
  { title: 'Brand, Identita, DX', desc: 'Značka, barvy, fonty, celá digitální zkušenost, souhra která dává smysl lidem i e-shopu.' },
  { title: 'Šablona — Theme', desc: 'Profesionální výběr a nastavení Shopify šablony. Rychlost, CTA, layouty, bloky, varianty a propojení s brandem.' },
  { title: 'Obsah & prezentace', desc: 'Vizuální a obsahové podklady. Brandové šablony, produktový obsah, launch vizuály s návazností na e-shop.' },
  { title: 'Funkčnost & konverze', desc: 'Produktové stránky, kolekce, upsell, cross-sell a UX logika. Navrhujeme Shopify tak, aby prodával, ne jen vypadal dobře.' },
  { title: 'Růst skrze marketing', desc: 'Příprava pro výkonové kampaně a expanzi. SEO, analytika, lokalizace, napojení na marketingové nástroje a další růst.' },
];

const relatedServices = [
  { href: '/cs/co-umime/novy-shopify-e-shop', label: 'Nový Shopify e-shop' },
  { href: '/cs/co-umime/prechod-na-shopify', label: 'Přechod na Shopify' },
  { href: '/cs/co-umime/expanze-do-zahranici', label: 'Expanze do zahraničí' },
  { href: '/cs/co-umime/rozvoj-a-podpora', label: 'Rozvoj a podpora' },
  { href: '/cs/co-umime/analyza-a-strategie', label: 'Analýza a strategie' },
  { href: '/cs/co-umime/custom-vyvoj-a-aplikace', label: 'Custom vývoj a aplikace' },
];
---

<PageLayout title="Potřebuji brand | aethero" description="Budujeme brandy, které rezonují napříč kulturami. Značka, vizuální identita a digitální zkušenost pro váš Shopify e-shop." lang="cs">
  <ServiceHero
    label="Brand & Identity"
    title="Potřebuji <span style='color:var(--action)'>BRAND</span>"
    subtitle="A skrze něj i místo v myslích a srdcích zákazníků"
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    image="/triangle.webp"
    imageAlt="Brand a vizuální identita"
  />

  <!-- Intro hero text -->
  <section class="section bg-elevated">
    <div class="container intro-wrap">
      <h2 class="section-title">Budujeme BRANDY, které rezonují napříč kulturami</h2>
      <h3 class="intro-sub">Ultimátním řešením které nabízíme, je společná příprava dotaženého brandu. Nejde ani o snadné ani levné řešení, ale je to ověřená a fungující cesta.</h3>
      <a href="tel:+420776067663" class="intro-link">Tak pojďme na to ➝</a>
    </div>
  </section>

  <!-- Brand pillar -->
  <section class="section bg-secondary">
    <div class="container">
      <h3 class="pillar-heading">BRAND, je prvním pilířem vašeho úspěchu.</h3>
      <div class="brand-text-col">
        <p class="section-text">Ptáte se proč tu řešíme takovou obyčejnou a zdálo by se možná i základní věc, jako je BRAND? Protože ho můžete záměrně stvořit malý a prostinký, ale nesmíte ho postavit špatně a pak ho ukázat světu. Zde naplno platí, že nedostanete druhou šanci učinit první dojem.</p>
        <p class="section-text">Váš BRAND je energií celého e-commerce stroje. A stejně jako například elektřina, vám neodpustí hrubou chybu. BRAND je naprosto zásadní ingrediencí a musíte ho brát vážně, chcete-li mít úspěch.</p>
        <p class="section-text">Název, znak — logo, doména, typografie, barvy... To je ta část, o které se snadno mluví, ale o to je těžší je ji nastavit správně. A pak je tu ta druhá oblast, kde jsou části brandu, které se dají vznosně popisovat, ale vznikají na základě hlubšího vhledu, pocitů a je nutné je skrze konzistentní přístup k brandu zakódovat do firmy: komunikace, hodnoty, vize, vnitřní kultura firmy, motivace lidí (ta která se odrazí na dlouhodobém záři firmy) a mnoho dalších částí.</p>
      </div>
      <blockquote class="ogilvy-quote">„ Brand je to, co vám zůstane, když vám shoří továrna... " <cite>— David Ogilvy</cite></blockquote>
    </div>
  </section>

  <!-- Na čem můžeme spolu pracovat -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="work-heading">NA ČEM MŮŽEME SPOLU — PRACOVAT</h2>
      <div class="work-grid">
        {workCards.map((c) => (
          <div class="work-card">
            <h3 class="work-card-title">{c.title}</h3>
            <p class="work-card-desc">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- A proč si myslíme -->
  <section class="section bg-secondary">
    <div class="container brand-analogy">
      <h3 class="analogy-heading">A proč si myslíme, že v tom určitě nemáte být sami?</h3>
      <p class="section-text">Tvorba brandu, je jako stavba nového domu. Na první pohled je všem všechno jasné. Každý přece ví, že budete mít kuchyň i koupelnu. Ale až teprve ve chvíli, kdy začnete zjišťovat „jak tu kuchyň vybavit, propojit s jídelnou a k tomu zkoušíte najít správný styl obložení koupelny i vhodný typ vany...", tak tehdy to začne být doopravdy náročné... A pak si přejete mít pomoc nadosah!</p>
      <p class="section-text"><strong>No a od toho tu jsme my.</strong></p>
      <a href="tel:+420776067663" class="intro-link">ozvěte se nám ➝</a>
    </div>
  </section>

  <!-- Muhtar Kent quote -->
  <section class="section bg-elevated quote-section">
    <div class="container">
      <blockquote class="kent-quote">„Značka je slib. A dobrá značka je slib, který je vždy dodržen"<cite>— Muhtar Kent</cite></blockquote>
    </div>
  </section>

  <!-- Related services -->
  <section class="section bg-secondary">
    <div class="container">
      <h2 class="section-title">Co pro vás okolo Shopify můžeme udělat?</h2>
      <ul class="related-services">
        {relatedServices.map((s) => (
          <li>
            <a href={s.href} class="related-link">
              <span>{s.label}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Brand, design, máme co probrat?<br />Dejte vědět</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-40); }
  .section-text { font-size: 17px; color: rgba(255,255,255,0.8); line-height: 1.75; margin-bottom: var(--space-24); max-width: 760px; }

  .intro-wrap { max-width: 800px; }
  .intro-sub { font-size: clamp(18px, 2vw, 24px); font-weight: 400; color: rgba(255,255,255,0.7); line-height: 1.5; margin-bottom: var(--space-32); }
  .intro-link { display: inline-block; color: var(--action); font-size: 16px; font-weight: 600; text-decoration: none; }
  .intro-link:hover { opacity: 0.75; }

  .pillar-heading { font-size: clamp(24px, 3vw, 40px); font-weight: 700; margin-bottom: var(--space-40); color: var(--action); }
  .brand-text-col { max-width: 760px; }

  .ogilvy-quote { margin-top: var(--space-64); font-size: clamp(18px, 2vw, 24px); font-style: italic; color: rgba(255,255,255,0.9); border-left: 3px solid var(--action); padding-left: var(--space-32); line-height: 1.5; }
  .ogilvy-quote cite { display: block; font-size: 14px; font-style: normal; color: rgba(255,255,255,0.5); margin-top: var(--space-16); }

  .work-heading { font-size: clamp(20px, 2.5vw, 32px); font-weight: 700; letter-spacing: 0.05em; margin-bottom: var(--space-48); color: var(--action); text-transform: uppercase; }
  .work-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .work-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .work-card-title { font-size: 16px; font-weight: 700; color: var(--action); margin-bottom: var(--space-12); }
  .work-card-desc { font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.6; }

  .brand-analogy { max-width: 760px; }
  .analogy-heading { font-size: clamp(22px, 2.5vw, 32px); font-weight: 700; margin-bottom: var(--space-32); }

  .quote-section { padding: var(--space-80) 0; }
  .kent-quote { font-size: clamp(20px, 2.5vw, 32px); font-style: italic; color: rgba(255,255,255,0.9); text-align: center; line-height: 1.5; max-width: 720px; margin: 0 auto; }
  .kent-quote cite { display: block; font-size: 16px; font-style: normal; color: rgba(255,255,255,0.5); margin-top: var(--space-24); }

  .related-services { list-style: none; display: flex; flex-direction: column; }
  .related-link { display: flex; align-items: center; justify-content: space-between; padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 15px; color: var(--neutral-300); transition: color var(--transition-base); text-decoration: none; }
  .related-link:hover { color: var(--action); }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.1; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--brand-dark); text-decoration: underline; text-underline-offset: 4px; transition: opacity var(--transition-base); }
  .cta-contact:hover { opacity: 0.7; }

  @media (max-width: 1024px) {
    .work-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .work-grid { grid-template-columns: 1fr; }
  }
</style>
