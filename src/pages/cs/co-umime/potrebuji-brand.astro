---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const workCards = [
  { icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>', title: 'Brand, Identita, DX', desc: 'Značka, barvy, fonty, celá digitální zkušenost, souhra která dává smysl lidem i e-shopu.' },
  { icon: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>', title: 'Šablona — Theme', desc: 'Profesionální výběr a nastavení Shopify šablony. Rychlost, CTA, layouty, bloky, varianty a propojení s brandem.' },
  { icon: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>', title: 'Obsah & prezentace', desc: 'Vizuální a obsahové podklady. Brandové šablony, produktový obsah, launch vizuály s návazností na e-shop.' },
  { icon: '<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>', title: 'Funkčnost & konverze', desc: 'Produktové stránky, kolekce, upsell, cross-sell a UX logika. Navrhujeme Shopify tak, aby prodával, ne jen vypadal dobře.' },
  { icon: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>', title: 'Růst skrze marketing', desc: 'Příprava pro výkonové kampaně a expanzi. SEO, analytika, lokalizace, napojení na marketingové nástroje a další růst.' },
];

---

<PageLayout title="Potřebuji brand | aethero" description="Budujeme brandy, které rezonují napříč kulturami. Značka, vizuální identita a digitální zkušenost pro váš Shopify e-shop." lang="cs">
  <ServiceHero
    label="Brand & Identity"
    title="Potřebuji <span style='color:#fff'>BRAND</span>"
    subtitle="A skrze něj získat místo v myslích a srdcích zákazníků"
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    ctaLower={true}
    image="/triangle.webp"
    imageAlt="Brand a vizuální identita"
  />

  <!-- Intro hero text -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h1 intro-h2">Budujeme <span class="accent-purple">BRANDY</span>, které <br />rezonují napříč kulturami</h2>
      <p class="intro-text">Stavíte e-commerce firmu, <strong class="hl">stvořte svou značku a rozjeďte to na plno</strong>. Jděte s kůží na trh! Brand bude v budoucnu vaším štítem i brněním. V době hyperkonkurence <strong class="hl">máte okolo 2 vteřin zákazníkovy pozornosti</strong>. Musíte <strong>zaujmout „na první dobrou"</strong> a pak být přímočaří, srozumitelní, konzistentní a zapamatovatelní.</p>
      <p class="intro-text"><strong class="hl">Ultimátním řešením které nabízíme, je vytvoření dotaženého brandu se kterým bude umět pracovat i vaše AI.</strong> Nejde ani o snadné ani levné řešení, ale je to jediná dlouhodobě fungující cesta.</p>
      <a href="#cta" class="btn-action btn-action--lg">Jdeme vytvořit brand</a>
    </div>
  </section>

  <!-- Brand pillar + work sidebar -->
  <section class="section bg-primary">
    <div class="container brand-layout">
      <div class="brand-main">
        <h3 class="h2 pillar-heading">BRAND, je prvním pilířem vašeho úspěchu.</h3>
        <div class="brand-text-col">
          <p class="section-text body">Ptáte se proč tu řešíme takovou obyčejnou a zdálo by se možná i základní věc, jako je BRAND? Protože ho můžete záměrně stvořit malý a prostinký, ale nesmíte ho postavit špatně a pak ho ukázat světu. Zde naplno platí, že nedostanete druhou šanci učinit první dojem.</p>
          <p class="section-text body">Váš BRAND je energií celého e-commerce stroje. A stejně jako například elektřina, vám neodpustí hrubou chybu. BRAND je naprosto zásadní ingrediencí a musíte ho brát vážně, chcete-li mít úspěch.</p>
          <p class="section-text body">Název, znak — logo, doména, typografie, barvy... To je ta část, o které se snadno mluví, ale o to je těžší je ji nastavit správně. A pak je tu ta druhá oblast, kde jsou části brandu, které se dají vznosně popisovat, ale vznikají na základě hlubšího vhledu, pocitů a je nutné je skrze konzistentní přístup k brandu zakódovat do firmy: komunikace, hodnoty, vize, vnitřní kultura firmy, motivace lidí (ta která se odrazí na dlouhodobém záři firmy) a mnoho dalších částí.</p>
        </div>
        {/* Ogilvy citát — dočasně schováno na přání, připraveno k vrácení:
        <blockquote class="quote ogilvy-quote">„ Brand je to, co vám zůstane, když vám shoří továrna... " <cite>— David Ogilvy</cite></blockquote>
        */}
      </div>
      <aside class="work-aside">
        <h2 class="h2-mini work-heading">NA ČEM MŮŽEME SPOLU — PRACOVAT</h2>
        <div class="work-list">
          {workCards.map((c) => (
            <div class="work-item">
              <div class="work-item-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon}></svg></div>
              <div class="work-item-text">
                <h3 class="work-item-title">{c.title}</h3>
                <p class="work-item-desc">{c.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <!-- Muhtar Kent quote -->
  <section class="section bg-primary quote-section">
    <div class="container">
      <blockquote class="quote-display">„Značka je slib.<br />A dobrá značka je slib,<br />který je vždy dodržen"<cite>— Muhtar Kent</cite></blockquote>
    </div>
  </section>

  <!-- A proč si myslíme -->
  <section class="section bg-primary">
    <div class="container analogy-split">
      <div class="analogy-ref">
        <div class="ref-card">
          <img src="/groomo-ref-na-vysku.webp" alt="GROOMO — reference aethero" class="ref-img" loading="lazy" />
          <a href="/cs/groomo-cz-na-shopify" class="ref-card-cta">Přečtěte si<br/>případovou studii</a>
        </div>
      </div>
      <div class="analogy-text">
        <h3 class="h2-mini analogy-heading">A proč si myslíme, že v tom určitě<br />nemáte být sami?</h3>
        <p class="section-text body">Tvorba brandu, je jako stavba nového domu. Na první pohled je všem všechno jasné. Každý přece ví, že budete mít kuchyň i koupelnu. Ale až teprve ve chvíli, kdy začnete zjišťovat „jak tu kuchyň vybavit, propojit s jídelnou a k tomu zkoušíte najít správný styl obložení koupelny i vhodný typ vany...", tak tehdy to začne být doopravdy náročné... A pak si přejete mít pomoc nadosah!</p>
        <p class="section-text body"><strong>No a od toho tu jsme my.</strong></p>
        <a href="tel:+420776067663" class="btn-action">Ozvěte se nám</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Brand, design, máme co probrat?<br />Dejte vědět</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }
  .section-title { font-size: var(--fs-70); font-weight: 600; margin-bottom: var(--space-40); }
  .section-text { margin-bottom: var(--space-24); max-width: 760px; }

  .intro-h2 { margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .intro-text { font-size: var(--fs-20); color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: var(--space-24); max-width: 860px; }
  /* .hl (bold lavender) — globální utilita v global.css */
  .pillar-heading { margin-bottom: var(--space-40); color: #fff; }
  .brand-text-col { max-width: 760px; }

  .ogilvy-quote { margin-top: var(--space-64); }

  /* Brand pilíř + work sidebar = 2 sloupce */
  .brand-layout { display: grid; grid-template-columns: 1fr 355px; gap: var(--space-64); align-items: start; }
  .brand-main { min-width: 0; }
  .work-aside {
    background: var(--ae-bg-deep);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: var(--radius-md); padding: var(--space-32);
  }
  .work-heading { font-size: var(--fs-18); font-weight: 700; letter-spacing: 0.08em; margin-bottom: var(--space-24); color: #fff; text-transform: uppercase; line-height: 1.3; padding-left: calc(42px + var(--space-16)); }
  .work-list { display: flex; flex-direction: column; gap: var(--space-32); }
  .work-item { display: flex; gap: var(--space-16); align-items: flex-start; }
  .work-item-icon {
    flex-shrink: 0; width: 42px; height: 42px;
    display: grid; place-items: center; border-radius: 10px;
    color: var(--text-secondary);
    background: rgba(160,129,209,0.12);
    border: 1px solid rgba(160,129,209,0.28);
  }
  .work-item-icon svg { width: 22px; height: 22px; display: block; }
  .work-item-title { font-size: 15px; font-weight: 700; color: var(--text-secondary); margin-bottom: var(--space-8); }
  .work-item-desc { font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.55; }

  .analogy-split { display: grid; grid-template-columns: 420px 1fr; gap: 60px; align-items: center; }
  .analogy-text { max-width: 700px; }
  .analogy-heading { font-size: var(--fs-32); font-weight: 700; margin-bottom: var(--space-32); }
  .analogy-ref { display: flex; justify-content: center; }
  .ref-card { position: relative; max-width: 380px; width: 100%; border-radius: 6px; overflow: hidden; }
  .ref-img { width: 100%; display: block; }
  .ref-card-cta {
    position: absolute; bottom: 30px; left: 30px; right: 30px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    padding: 18px 24px;
    background: rgba(255,255,255,0.18);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.45);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 24px rgba(0,0,0,0.2);
    color: #000326;
    font-family: var(--font-primary); font-size: 16px; font-weight: 600;
    text-transform: uppercase; text-align: center; line-height: 1.4;
    text-decoration: none;
    transition: background var(--transition-base), border-color var(--transition-base);
  }
  .ref-card-cta:hover { background: rgba(255,255,255,0.28); border-color: rgba(255,255,255,0.65); color: #000326; }
  @media (max-width: 900px) {
    .analogy-split { grid-template-columns: 1fr; gap: var(--space-40); }
    .ref-img { max-width: 300px; margin: 0 auto; }
  }

  .quote-section { padding: var(--space-40) 0; margin-top: calc(-1 * var(--space-80)); }
  /* kontrastní citát: styl z globálního .quote-display */

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: var(--fs-70); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 900px) {
    .brand-layout { grid-template-columns: 1fr; gap: var(--space-40); }
  }
</style>
