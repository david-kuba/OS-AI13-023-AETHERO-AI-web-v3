---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const features = [
  { title: 'AI parťák pro lokalizaci obsahu', logo: '/sidekick.png', desc: 'Shopify Sidekick generuje lokalizované popisy produktů, marketingové texty a obsah v jazyce cílového trhu. Méně manuální práce, více relevance pro místní zákazníky.', img: null, reverse: false },
  { title: 'Shopify Markets — jeden admin, celý svět', desc: 'Správa všech trhů z jediného adminu — ceny v lokálních měnách, subdomény, jazykové varianty, DPH a zákonné požadavky pro každý trh. Bez nutnosti duplicitních e-shopů.', img: '/shopify-premium-story.webp', reverse: true },
  { title: 'Mezinárodní prodej se Shopify', desc: 'Shopify je od základu navržen pro cross-border commerce. Nativní podpora vícejazyčnosti, multi-měny, lokálních platebních metod a regionálních fulfilment center — vše pod jednou střechou.', img: '/international-sale-shopify.webp', reverse: false },
  { title: 'Benchmarking výkonu oproti trhu', desc: 'Shopify Store Benchmarks porovnává váš e-shop s podobnými obchody na globálním trhu. Zjistíte kde skutečně stojíte a kde jsou největší příležitosti pro růst na nových trzích.', img: '/store-benchmark.webp', reverse: true },
  { title: 'B2B expanze bez kompromisů', desc: 'Shopify Plus přináší plnohodnotné B2B funkce pro mezinárodní trhy — vlastní ceníky pro firemní zákazníky, schvalovací procesy, ERP napojení a B2B checkout v každém jazyce a měně.', img: '/b2b-1.webp', reverse: false },
  { title: 'Měření marketingu napříč trhy', desc: 'Přehled výkonu kampaní na každém trhu zvlášť — Google Ads, Meta, email. Víte přesně, které kanály přinášejí ROI na DE, SK nebo PL trhu a kde optimalizovat rozpočet.', img: '/marketing-measurement.webp', reverse: true },
  { title: 'Shopify Shop App — v telefonu zákazníků', desc: 'Brandovaná přítomnost v mobilním zařízení zákazníků po celém světě. Notifikace o objednávkách, personalizovaný feed a sledování zásilek — vše bez nutnosti vlastní mobilní aplikace.', img: '/shopify-shop-app.webp', reverse: false },
  { title: 'Real-time analytika pro každý trh', desc: 'Živá data o výkonu jednotlivých trhů bez denního zpracování — okamžitý přehled konverzí, průměrné hodnoty košíku a chování zákazníků na každém trhu zvlášť.', img: '/analytika.webp', reverse: true },
];

const relatedServices = [
  { href: '/cs/co-umime/potrebuji-brand', label: 'Potřebuji brand' },
  { href: '/cs/co-umime/novy-shopify-e-shop', label: 'Nový Shopify e-shop' },
  { href: '/cs/co-umime/prechod-na-shopify', label: 'Přechod na Shopify' },
  { href: '/cs/co-umime/rozvoj-a-podpora', label: 'Rozvoj a podpora' },
  { href: '/cs/co-umime/analyza-a-strategie', label: 'Analýza a strategie' },
  { href: '/cs/co-umime/custom-vyvoj-a-aplikace', label: 'Custom vývoj a aplikace' },
];
---

<PageLayout title="Expanze do zahraničí | aethero" description="Jeden Shopify e-shop, celý svět. Pomůžeme vám s expanzí na zahraniční trhy pomocí Shopify Markets." lang="cs">
  <ServiceHero
    label="Mezinárodní expanze"
    title="EXPANZE<br /><span style='color:var(--action)'>DO ZAHRANIČÍ</span>"
    subtitle="Je čas rozjet to naplno — Evropa? Celý svět? Shopify Markets vám umožní spravovat všechny trhy z jednoho adminu."
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#expanze-proc"
    image="/chain.webp"
    imageAlt="Expanze do zahraničí"
  />

  <!-- Intro -->
  <section class="section-intro bg-elevated">
    <div class="container">
      <h2 class="intro-heading">Prodávejte<br /><span class="text-action">GLOBÁLNĚ</span></h2>
      <p class="intro-text">Shopify je od základu navržen pro mezinárodní prodej. Jedna platforma s podporou více měn, jazyků, B2B integracemi a propojením fyzických prodejen. Vše z jednoho adminu — bez nutnosti duplikovat e-shop pro každý trh.</p>
      <p class="intro-text">V aethero jsme pomohli klientům rozjet prodej v desítkách zemí. Víme, co funguje a co zbytečně prodražuje čas i peníze.</p>
      <a href="tel:+420776067663" class="btn-action">Jdeme expandovat?</a>
    </div>
  </section>

  <!-- Stats -->
  <section class="section bg-secondary" id="expanze-proc">
    <div class="container two-col">
      <div>
        <h2 class="section-title">Máte plán na expanzi do zahraničí?</h2>
        <p class="section-text">Shopify je od základu navržen pro mezinárodní prodej. Získáte jednu globální platformu s podporou více měn, jazyků, B2B integracemi a propojením fyzických prodejen. Vše z jednoho adminu.</p>
        <p class="section-text">V aethero jsme pomohli klientům rozjet prodej v desítkách zemí. Víme, co funguje a co zbytečně prodražuje čas i peníze.</p>
      </div>
      <div class="intro-highlights">
        <div class="highlight-item">
          <span class="highlight-num">30+</span>
          <span class="highlight-label">zemí dostupných přes Shopify Markets z jednoho adminu</span>
        </div>
        <div class="highlight-item">
          <span class="highlight-num">1</span>
          <span class="highlight-label">platforma pro celý svět — bez migrace při škálování</span>
        </div>
        <div class="highlight-item">
          <span class="highlight-num">100%</span>
          <span class="highlight-label">lokalizace — jazyk, měna, platby, daně pro každý trh</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature sections -->
  {features.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          {f.logo && <img src={f.logo} alt={f.title} class="feature-logo" loading="lazy" />}
          <h2 class="feature-title">{f.title}</h2>
          <p class="feature-desc">{f.desc}</p>
        </div>
        <div class="feature-img-wrap">
          {f.img && <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />}
        </div>
      </div>
    </section>
  ))}

  <!-- Related -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Další služby</h2>
      <ul class="related-services">
        {relatedServices.map((s) => (
          <li>
            <a href={s.href} class="related-link">
              <span>{s.label}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Jdeme<br />EXPANDOVAT?</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading { font-size: clamp(32px, 4vw, 52px); font-weight: 700; line-height: 1.15; margin-bottom: var(--space-40); }
  .text-action { color: var(--action); }
  .intro-text { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.75; max-width: 720px; margin-bottom: var(--space-24); }
  .btn-action { display: inline-flex; padding: 16px 40px; background: var(--action); color: #000; font-family: var(--font-primary); font-size: 15px; font-weight: 700; border-radius: var(--radius-md); text-decoration: none; margin-top: var(--space-16); transition: background var(--transition-base); }
  .btn-action:hover { background: var(--action-hover); }

  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: clamp(24px, 3vw, 36px); font-weight: 700; margin-bottom: var(--space-40); }
  .section-text { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: var(--space-24); }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .intro-highlights { display: flex; flex-direction: column; gap: var(--space-40); padding-top: var(--space-8); }
  .highlight-item { display: flex; flex-direction: column; gap: var(--space-8); border-left: 2px solid var(--action); padding-left: var(--space-24); }
  .highlight-num { font-size: 48px; font-weight: 700; color: var(--action); line-height: 1; font-family: var(--font-primary); }
  .highlight-label { font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.5; }

  .feature-section { padding: var(--space-120) 0; }
  .feature-section:nth-child(odd) { background: var(--bg-elevated); }
  .feature-section:nth-child(even) { background: var(--bg-secondary); }
  .feature-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: center; }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text,
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-logo { height: 48px; width: auto; display: block; margin-bottom: var(--space-24); object-fit: contain; }
  .feature-title { font-size: clamp(20px, 2.5vw, 30px); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); color: var(--action); }
  .feature-desc { font-size: 16px; color: rgba(255,255,255,0.75); line-height: 1.75; }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }
  .feature-img { width: 100%; max-width: 560px; height: auto; border-radius: var(--radius-md); display: block; }

  .related-services { list-style: none; display: flex; flex-direction: column; }
  .related-link { display: flex; align-items: center; justify-content: space-between; padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 15px; color: var(--neutral-300); transition: color var(--transition-base); text-decoration: none; }
  .related-link:hover { color: var(--action); }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: clamp(28px, 4vw, 48px); font-weight: 700; color: #000; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: 20px; font-weight: 700; color: #000; text-decoration: none; }
  .cta-contact:hover { opacity: 0.7; }

  @media (max-width: 1024px) {
    .two-col { grid-template-columns: 1fr; }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
