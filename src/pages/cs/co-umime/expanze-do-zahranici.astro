---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const features = [
  { title: 'Shopify Sidekick AI přímo v e-shopu', logo: '/sidekick.png', desc: 'Sidekick je AI asistent integrovaný do adminu e-shopu a výrazně vám urychlí práci v Shopify. Dokáže provádět operativní úkoly (vytvořit produkt, upravovat kolekce, analyzovat prodeje, připravit reporty), pomůže s marketingem (psaní popisků, e-mailů) a poradí na základě vašich vlastních dat i obecných zkušeností z trhu.', img: null, reverse: false },
  { title: 'Nabušený „admin"', desc: 'Nebudeme vám nic lakovat na růžovo... postavit e-shop dá práci a ani pak není cesta k úspěchu snadná. Takže v „adminu" budete trávit spoustu času. A hodí se, když je přehledný a drží s vámi krok. Shopify admin umí: analytika, nápovědy, AI která vidí na vaše data a dokáže i poradit podle obecných zkušeností odjinud. A to je jen začátek.', img: '/analytika.webp', reverse: true },
  { title: 'Postaveno pro mezinárodní prodej', desc: 'Trhy neboli Markets řeší v Shopify nastavení místní měny, platebních metod, jazyků. Další funkce vám pomohou poskytnout globálním zákazníkům důvěrně známé nákupní prostředí, které prokazatelně zvyšuje konverze. Podle trhu lze naladit šablonu, obsah, vybrat výrobky, nastavit ceny. S Shop Pay jim můžete nabídnout jejich platební metody a přizpůsobit i adresy dle zvyklostí.', img: '/international-sale-shopify.webp', reverse: false },
  { title: 'Možnost sofistikovaného porovnání se s ostatními', desc: 'Shopify vám skrze AI a také díky zabudovaným benchmarkům ukáže jak jsou na tom podobné obchody ve světě. Takže svou výkonnost můžete lépe měřit a využít informace ve svůj prospěch.', img: '/store-benchmark.webp', reverse: true },
  { title: 'Multichannel marketing', desc: 'Přehledně si organizujte marketingové aktivity napříč e-mailem, sociálními sítěmi, reklamou i organickou návštěvností do ucelených kampaní. Díky přehledným reportům jednotlivých kanálů lépe porozumíte tomu, odkud přichází zákazníci, kolik stojí jejich získání a jaká je návratnost marketingových investic.', img: '/marketing-measurement.webp', reverse: false },
  { title: 'Real-time přehled o datech e-shopu', desc: 'S Shopify máte okamžitý přehled o tom, jak si váš e-shop skutečně vede – bez čekání na denní přepočty nebo omezené přehledy. Data se aktualizují v reálném čase napříč celým dashboardem i reporty. Přizpůsobte si přehled přesně podle toho, co je pro vás rozhodující, a sledujte klíčové metriky na první pohled.', img: '/real-time-monitoring.png', reverse: true },
  { title: 'B2B ready', desc: 'Ve verzi Shopify Plus najdete nativní B2B funkcionalitu navrženou pro firmy s vysokým objemem objednávek, složitou cenotvorbou a individuálními obchodními vztahy. Umožňuje pracovat s firemními účty, vlastními ceníky, schvalovacími procesy i opakovanými nákupy v jednom sjednoceném řešení. Chcete menší B2B řešení? To vyřeší aplikace nebo custom vývoj.', img: '/b2b-1.webp', reverse: false },
  { title: 'Shopify SHOP aplikace, u zákazníka v mobilu', desc: 'Díky Shop aplikaci se vaše značka dostává přímo do mobilních zařízení zákazníků a to po celém světě. Ideální uživatelská zkušenost. Zákazníci mohou jednoduše sledovat objednávky, vracet se k oblíbeným produktům a opakovaně nakupovat bez nutnosti znovu procházet celý nákupní proces.', img: '/shopify-shop-app.webp', reverse: true },
  { title: 'Automatizace', desc: 'S rostoucím objemem objednávek nedává ruční správa smysl. Automatizace umožňuje převést klíčové procesy — od práce s objednávkami a zákazníky, přes cenotvorbu a zásoby až po marketingové scénáře — do řízených, předvídatelných toků. Výsledkem je menší závislost na manuálních zásazích, nižší chybovost a schopnost škálovat bez neustálého navyšování týmu.', img: '/flow-automation.webp', reverse: false },
];

const relatedServices = [
  { href: '/cs/co-umime/potrebuji-brand', label: 'Potřebuji brand' },
  { href: '/cs/co-umime/novy-shopify-e-shop', label: 'Nový Shopify e-shop' },
  { href: '/cs/co-umime/prechod-na-shopify', label: 'Přechod na Shopify' },
  { href: '/cs/co-umime/rozvoj-a-podpora', label: 'Rozvoj a podpora' },
  { href: '/cs/co-umime/analyza-a-strategie', label: 'Analýza a strategie' },
  { href: '/cs/co-umime/custom-vyvoj-a-aplikace', label: 'Custom vývoj a aplikace' },
];
---

<PageLayout title="Expanze do zahraničí | aethero" description="Jeden Shopify e-shop, celý svět. Pomůžeme vám s expanzí na zahraniční trhy pomocí Shopify Markets." lang="cs">
  <ServiceHero
    label="Mezinárodní expanze"
    title="EXPANZE<br /><span style='color:var(--action)'>DO ZAHRANIČÍ</span>"
    subtitle="Je čas rozjet to naplno, Evropa? Celý svět? No jasně, jdeme do toho s vámi."
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#expanze-proc"
    image="/chain.webp"
    imageAlt="Expanze do zahraničí"
  />

  <!-- Intro -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="intro-h2">Máte plán na<br /><span class="accent-purple">EXPANZI DO ZAHRANIČÍ</span>?</h2>
      <p class="intro-text">S Shopify vám otevřeme cestu k růstu, <strong class="hl">který na lokálních platformách jednoduše není možný</strong>. Udělejte rozhodný krok vpřed na mezinárodní trhy a do globálního e-commerce.</p>
      <p class="intro-text">Získáte <strong class="hl">jednu globální platformu postavenou od základu pro mezinárodní prodej</strong> — více měn, jazyků a lokalizovaná zákaznická zkušenost.</p>
      <a href="#cta" class="intro-btn">Jdeme expandovat →</a>
    </div>
  </section>

  <!-- Stats -->
  <section class="section bg-secondary" id="expanze-proc">
    <div class="container two-col">
      <div>
        <h2 class="section-title">Co vám expanze s Shopify přinese?</h2>
        <p class="section-text">K dispozici máte vše, co potřebujete proto, abyste svůj e-shop proměnili ve skutečnou globální značku. Zde je jen částečný výčet funkcí, které by vás mohly zaujmout.</p>
      </div>
      <div class="intro-highlights">
        <div class="highlight-item">
          <span class="highlight-num">30+</span>
          <span class="highlight-label">zemí dostupných přes Shopify Markets z jednoho adminu</span>
        </div>
        <div class="highlight-item">
          <span class="highlight-num">1</span>
          <span class="highlight-label">platforma pro celý svět — bez migrace při škálování</span>
        </div>
        <div class="highlight-item">
          <span class="highlight-num">100%</span>
          <span class="highlight-label">lokalizace — jazyk, měna, platby, daně pro každý trh</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature sections -->
  {features.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          {f.logo && <img src={f.logo} alt={f.title} class="feature-logo" loading="lazy" />}
          <h2 class="feature-title">{f.title}</h2>
          <p class="feature-desc">{f.desc}</p>
        </div>
        <div class="feature-img-wrap">
          {f.img && <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />}
        </div>
      </div>
    </section>
  ))}

  <!-- Tady jste na správném místě -->
  <section class="section bg-secondary">
    <div class="container" style="text-align: center; max-width: 720px; margin: 0 auto;">
      <h3 class="tady-heading">Tady jste na správném místě!</h3>
      <p class="tady-text">U globální expanze není otázkou jestli, ale spíše kdy. Shopify vám dodá technologický základ, díky kterému se budete moci soustředit na růst místo řešení limitů platformy. Je teď ten správný čas a chcete s námi posunout svůj e-shop dál?</p>
    </div>
  </section>

  <!-- Related -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Další služby</h2>
      <ul class="related-services">
        {relatedServices.map((s) => (
          <li>
            <a href={s.href} class="related-link">
              <span>{s.label}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Jdeme EXPANDOVAT?<br />Dejte vědět</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading { font-size: clamp(32px, 4vw, 52px); font-weight: 700; line-height: 1.15; margin-bottom: var(--space-40); }
  .text-action { color: var(--action); }
  .intro-h2 { font-size: clamp(40px, 6vw, 80px); font-weight: 700; line-height: 1.1; margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-btn { display: inline-flex; align-items: center; padding: 14px 32px; background: #fff; color: var(--brand-dark); font-family: var(--font-primary); font-size: 15px; font-weight: 700; text-transform: uppercase; border-radius: var(--radius-md); transition: background var(--transition-base), transform var(--transition-base); margin-top: var(--space-16); }
  .intro-btn:hover { background: rgba(255,255,255,0.88); transform: translateY(-1px); }
  .intro-text { font-size: clamp(16px, 1.4vw, 20px); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .btn-action { display: inline-flex; padding: 16px 40px; background: var(--action); color: #000; font-family: var(--font-primary); font-size: 15px; font-weight: 700; border-radius: var(--radius-md); text-decoration: none; margin-top: var(--space-16); transition: background var(--transition-base); }
  .btn-action:hover { background: var(--action-hover); }

  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: clamp(24px, 3vw, 36px); font-weight: 700; margin-bottom: var(--space-40); }
  .section-text { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: var(--space-24); }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .intro-highlights { display: flex; flex-direction: column; gap: var(--space-40); padding-top: var(--space-8); }
  .highlight-item { display: flex; flex-direction: column; gap: var(--space-8); border-left: 2px solid var(--action); padding-left: var(--space-24); }
  .highlight-num { font-size: 48px; font-weight: 700; color: var(--action); line-height: 1; font-family: var(--font-primary); }
  .highlight-label { font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.5; }

  .feature-section { padding: var(--space-120) 0; }
  .feature-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: center; }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text,
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-logo { height: 48px; width: auto; display: block; margin-bottom: var(--space-24); object-fit: contain; }
  .feature-title { font-size: clamp(20px, 2.5vw, 30px); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); color: var(--action); }
  .feature-desc { font-size: 16px; color: rgba(255,255,255,0.75); line-height: 1.75; }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }
  .feature-img { width: 100%; max-width: 560px; height: auto; border-radius: var(--radius-md); display: block; }

  .tady-heading { font-size: clamp(24px, 3vw, 40px); font-weight: 700; margin-bottom: var(--space-24); }
  .tady-text { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.75; }

  .related-services { list-style: none; display: flex; flex-direction: column; }
  .related-link { display: flex; align-items: center; justify-content: space-between; padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 15px; color: var(--neutral-300); transition: color var(--transition-base); text-decoration: none; }
  .related-link:hover { color: var(--action); }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.1; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--brand-dark); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 1024px) {
    .two-col { grid-template-columns: 1fr; }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
