---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const steps = [
  { step: '01', title: 'Strategie vstupu na trh', desc: 'Výběr prioritních zemí, validace potenciálu a business case.' },
  { step: '02', title: 'Architektura řešení', desc: 'Návrh Shopify struktury, integrace a technická architektura.' },
  { step: '03', title: 'Lokalizace a compliance', desc: 'Obsah, platební metody, daně, legislativa a jazykové mutace.' },
  { step: '04', title: 'Launch a škálování', desc: 'Uvedení na trh a systematický growth.' },
];

const capabilities = [
  'Shopify Markets pro správu všech trhů z jednoho adminu',
  'Multicurrency a multilanguage nativně',
  'B2B řešení pro enterprise klienty (Shopify Plus)',
  'Lokalizace platebních metod dle země',
  'AI Sidekick pro lokalizaci obsahu',
  'Shopify Shop App pro mobilní zákazníky',
  'Reálná analytika a dashboardy',
  'Automatizace procesů přes Shopify Flow',
];
---

<PageLayout title="Expanze do zahraničí" description="Jeden Shopify e-shop, celý svět. Pomůžeme vám s expanzí na zahraniční trhy." lang="cs">
  <ServiceHero
    label="Mezinárodní expanze"
    title="EXPANZE<br /><span style='color:var(--action)'>DO ZAHRANIČÍ</span>"
    subtitle="Je čas rozjet to naplno — Evropa, celý svět? Shopify Markets umožňuje spravovat všechny trhy z jednoho adminu. Postaráme se o techniku, vy o byznys."
  />

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">4 kroky k expanzi</h2>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card">
            <span class="step-num">{s.step}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-secondary">
    <div class="container">
      <h2 class="section-title">Co pro vás zajistíme</h2>
      <ul class="cap-list">
        {capabilities.map((c) => (
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {c}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Máte plán na expanzi?</h2>
      <p>Zavolejte nebo napište — probereme váš trh a navrhneme postup.</p>
      <div class="cta-links">
        <a href="mailto:info@aethero.cz" class="btn-primary">info@aethero.cz</a>
        <a href="tel:+420776067663" class="btn-ghost">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-40); }
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-24); }
  .step-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .step-num { display: block; font-family: var(--font-primary); font-size: 13px; font-weight: 600; color: var(--action); margin-bottom: var(--space-16); }
  .step-card h3 { font-size: 16px; font-weight: 600; margin-bottom: var(--space-8); }
  .step-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .cap-list { list-style: none; display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-16); }
  .cap-list li { display: flex; align-items: flex-start; gap: var(--space-8); font-size: var(--text-small); color: var(--neutral-300); }
  .cta-section { padding: var(--space-120) 0; background: var(--bg-primary-alt); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-16); }
  .cta-inner p { color: var(--neutral-300); margin-bottom: var(--space-40); }
  .cta-links { display: flex; gap: var(--space-16); justify-content: center; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--bg-elevated); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: background var(--transition-base); }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: border-color var(--transition-base), color var(--transition-base); }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }
  @media (max-width: 1024px) { .steps-grid { grid-template-columns: repeat(2, 1fr); } .cap-list { grid-template-columns: 1fr; } }
  @media (max-width: 768px) { .steps-grid { grid-template-columns: 1fr; } }
</style>
