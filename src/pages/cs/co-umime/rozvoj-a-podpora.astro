---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const services = [
  { title: 'Technická podpora', desc: 'Řešení chyb v Liquid šablonách, vlastních aplikacích a integraci třetích stran.' },
  { title: 'Rozšiřování funkcí', desc: 'Nové funkcionality na míru — přesně to, co váš e-shop potřebuje.' },
  { title: 'Systémové integrace', desc: 'ERP, CRM, logistické platformy a fakturační systémy napojené bez problémů.' },
  { title: 'Shopify Markets', desc: 'Nastavení a správa mezinárodních trhů z jednoho adminu.' },
  { title: 'Výkonová optimalizace', desc: 'Rychlost, Core Web Vitals a škálování e-shopu pro rostoucí provoz.' },
  { title: 'Design a UX podpora', desc: 'Technická implementace designových změn a UX vylepšení.' },
  { title: 'Long-term konzultace', desc: 'Code reviews, architektonické poradenství a strategické plánování.' },
];
---

<PageLayout title="Rozvoj a podpora" description="Dlouhodobý technický partner pro váš Shopify projekt. Spuštění je jen začátek." lang="cs">
  <ServiceHero
    label="Rozvoj a podpora"
    title="ROZVOJ<br /><span style='color:var(--action)'>A PODPORA</span>"
    subtitle="Rozvoj Shopify projektů nekončí spuštěním e-shopu — začíná. Jsme tu pro vás jako technický partner na dlouhou cestu."
  />

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">S čím vám pomůžeme</h2>
      <div class="services-grid">
        {services.map((s) => (
          <div class="service-card">
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="highlight-section">
    <div class="container highlight-inner">
      <div class="highlight-text">
        <h2>Pomůžeme?<br /><span style="color:var(--action)">Dejte vědět.</span></h2>
        <p>Nemáte čas, lidi nebo know-how? Přesně pro to jsme tu. Přinášíme hloubkové technické znalosti podložené skutečnými projekty.</p>
        <div class="cta-links">
          <a href="mailto:info@aethero.cz" class="btn-primary">info@aethero.cz</a>
          <a href="tel:+420776067663" class="btn-ghost">+420 776 067 663</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .section-title { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-40); }
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .service-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .service-card h3 { font-size: 16px; font-weight: 600; color: var(--action); margin-bottom: var(--space-8); }
  .service-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .highlight-section { padding: var(--space-120) 0; background: var(--bg-secondary); }
  .highlight-inner { max-width: 640px; }
  .highlight-text h2 { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-24); }
  .highlight-text p { font-size: 18px; color: var(--neutral-300); line-height: 1.7; margin-bottom: var(--space-40); }
  .cta-links { display: flex; gap: var(--space-16); flex-wrap: wrap; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--bg-elevated); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: background var(--transition-base); }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: border-color var(--transition-base), color var(--transition-base); }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }
  @media (max-width: 1024px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .services-grid { grid-template-columns: 1fr; } }
</style>
