---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';
import WorkSidebar from '../../../components/layout/WorkSidebar.astro';

// TODO: placeholder — obsah dovymyslíme
const placeholderItems = [
  { icon: '<circle cx="12" cy="12" r="10"/>', title: 'Doplnit', desc: 'Obsah doplníme.' },
  { icon: '<circle cx="12" cy="12" r="10"/>', title: 'Doplnit', desc: 'Obsah doplníme.' },
  { icon: '<circle cx="12" cy="12" r="10"/>', title: 'Doplnit', desc: 'Obsah doplníme.' },
  { icon: '<circle cx="12" cy="12" r="10"/>', title: 'Doplnit', desc: 'Obsah doplníme.' },
];

const features = [
  { title: 'Technický support & troubleshooting', desc: 'Řešíme komplexní technické problémy v Liquid šablonách, custom aplikacích, Shopify Functions, checkoutu i napojených službách. Identifikujeme příčiny chyb, ne jen jejich symptomy.', img: '/support.jpg', reverse: false },
  { title: 'Rozšiřování funkcionalit & custom vývoj', desc: 'Vyvíjíme custom úpravy na míru – pokročilá práce s produkty, cenotvorbou, checkoutem, logikou dopravy a plateb, včetně vlastních aplikací.', img: '/custom.webp', reverse: true },
  { title: 'Integrace & systémová architektura', desc: 'Navrhujeme a realizujeme robustní integrace na ERP, CRM, skladové a logistické systémy. Automatizujeme datové toky a nastavujeme škálovatelnou architekturu bez vendor locku.', img: '/system1.webp', reverse: false },
  { title: 'Nastavení Shopify Markets pro mezinárodní expanzi', desc: 'Technické nastavení více trhů, měn, jazyků, domén, daňových pravidel, dopravy a lokálních plateb. Připravíme e-shop na provoz napříč zemí bez duplikace řešení.', img: '/shopify-international.webp', reverse: true },
  { title: 'Výkon, stabilita & škálování', desc: 'Výkon šablon, zátěž aplikací, Core Web Vitals a celkovou stabilitu e-shopu udržíme ve stavu, aby zvládal vysokou návštěvnost i špičky v prodeji.', img: '/vykon.webp', reverse: false },
  { title: 'Design & UX podpora s technickým přesahem', desc: 'Pomůžeme s úpravami designu, UX optimalizací a implementací design systému přímo v Shopify – od práce s existující šablonou až po custom řešení, to vše v souladu s brandem i technickými best practices.', img: '/ux-we-do.webp', reverse: true },
  { title: 'Technické konzultace i dlouhodobý support', desc: 'Jsme váš technický partner pro kontinuální rozvoj – od auditů a code review až po strategická rozhodnutí o dalším směřování Shopify řešení.', img: '/longtime-support.jpg', reverse: false },
];

---

<PageLayout title="Rozvoj a podpora | aethero" description="Dlouhodobý technický partner pro váš Shopify projekt. Jsme tu pro support, rozvoj, integrace i strategii." lang="cs">
  <ServiceHero
    label="Rozvoj a podpora"
    title="ROZVOJ<br /><span style='color:#fff'>A PODPORA</span>"
    subtitle="Shopify projekt? Jsme připraveni, kde je třeba pomoci? Chybí vám lidé, čas, znalosti? Napište, zavolejte."
    ctaLabel="Zavolejme si"
    ctaHref="tel:+420776067663"
    cta2Label="Zjistěte jak"
    cta2Href="#co-udelame"
    image="/lifebuoy.webp"
    imageAlt="Rozvoj a podpora Shopify"
  />

  <!-- Intro + sidebar (placeholder) -->
  <section class="section bg-primary">
    <div class="container intro-layout">
      <div class="intro-main">
        <h2 class="h1 intro-h2"><span class="accent-purple">S ČÍM CHCETE POMOCI</span><br />na Shopify projektu?</h2>
        <p class="intro-text"><strong class="hl">Někdy hledání videí k řešení problému prostě nestačí</strong> a je potřeba hlubší technický vhled, zkušenost z více reálných projektů a tím možnost najít širší souvislosti.</p>
        <p class="intro-text">Chceme abyste věděli, že ani po pár letech <strong class="hl">nemáme nos nahoru a když to půjde pomůžeme vám</strong>. Rozvoj a podpora Shopify projektů nekončí spuštěním e-shopu.</p>
        <a href="#cta" class="btn-action btn-action--lg">Tak pojďme na to</a>
      </div>
      <WorkSidebar heading="JAK ZAČNEME" items={placeholderItems} />
    </div>
  </section>

  <!-- Co pro vás uděláme -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h2-mini section-title" id="co-udelame">Co pro vás můžeme v rámci<br />naší technické podpory udělat</h2>
    </div>
  </section>

  <!-- Feature sections -->
  {features.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          <h3 class="h3-mini feature-title">{f.title}</h3>
          <p class="body">{f.desc}</p>
        </div>
        <div class="feature-img-wrap">
          <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Pomůžeme?<br />Dejte vědět</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .intro-heading { font-size: var(--fs-52); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-40); max-width: 760px; }
  .intro-h2 { margin-bottom: var(--space-40); }
  /* Intro + sidebar = 2 sloupce */
  .intro-layout { display: grid; grid-template-columns: 1fr 355px; gap: var(--space-64); align-items: start; }
  .intro-main { min-width: 0; }
  .intro-main .intro-text { max-width: none; }
  @media (max-width: 900px) { .intro-layout { grid-template-columns: 1fr; gap: var(--space-40); } }
  /* .hl (bold lavender) — globální utilita v global.css */
  .intro-text { font-size: var(--fs-20); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .section-title { text-align: center; }

  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text,
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-title { margin-bottom: var(--space-24); color: #fff; }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }


  @media (max-width: 1024px) {
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
