  { icon: '/icons/zamerovac.svg', label: 'Metapole, metatagy, filtrace', desc: 'Zajistíme správnou strukturu dat a SEO značení produktů' },
  { icon: '/icons/pocitac.svg', label: 'Konverze', desc: 'Zvýšíme výkonnost e-shopu optimalizací nákupního procesu, CTA prvků a UX směrem k nákupu' },
  { icon: '/icons/cas.svg', label: 'Rychlost', desc: 'Rychlejší e-shop znamená vyšší konverze i lepší SEO' },
  { icon: '/icons/taska.svg', label: 'Cesta zákazníka', desc: 'Každý dotek se značkou musí dávat smysl = zmapujeme a vylepšíme' },
  { icon: '/icons/cena.svg', label: 'Výkonnostní marketing', desc: 'Strategie a kampaně, které přinášejí skutečný výkon a GTM setup pro přesné měření' },
