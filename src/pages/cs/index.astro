  { title: 'AI SEO — nová tvrdá realita vyhledávání pro e-shopy (2026)', time: '7', ago: 'před 5 měsíci', href: '/cs/blog/ai-seo-2026', img: '/blog-02.webp' },
  { title: 'Shopify Edition — Zima 2026', time: '6', ago: 'před 6 měsíci', href: '/cs/blog/shopify-editions-zima-2026', img: '/blog-03.webp' },
  { title: 'Překlad platební metody v Shopify, když Translate & Adapt nepomáhá', time: '3', ago: 'před 8 měsíci', href: '/cs/blog/preklad-platebni-metody-shopify', img: '/blog-04.webp' },
  { title: 'Jakou e-commerce platformu zvolit? Shopify versus Shoptet', time: '18', ago: 'před rokem', href: '/cs/blog/shopify-vs-shoptet', img: '/blog-05.webp' },
