<script>
  const track = document.getElementById('services-track') as HTMLElement | null;

  if (track) {
    const DUR = 900;
    const EASE = `transform ${DUR}ms cubic-bezier(0.4, 0, 0.2, 1)`;
    const INTERVAL = 5000;

    const originals = Array.from(track.children) as HTMLElement[];
    const N = originals.length;

    // Prepend clones of all items (reversed) — umožní drag vlevo za začátek
    [...originals].reverse().forEach(el => track.insertBefore(el.cloneNode(true), track.firstChild));
    // Append clones pro auto-advance za konec
    originals.forEach(el => track.appendChild(el.cloneNode(true)));
    // Pořadí: [N start-clones] + [N originals] + [N end-clones]

    const itemW = () => (track.children[N] as HTMLElement).offsetWidth;

    let pos = N * itemW();
    track.style.transition = 'none';
    track.style.transform = `translateX(-${pos}px)`;
    track.offsetWidth; // force reflow
    track.style.transition = EASE;

    const moveTo = (p: number, animated: boolean) => {
      pos = p;
      if (!animated) {
        track.style.transition = 'none';
        track.style.transform = `translateX(-${p}px)`;
        track.offsetWidth;
        track.style.transition = EASE;
      } else {
        track.style.transform = `translateX(-${p}px)`;
      }
    };

    const normalize = () => {
      const w = itemW();
      if (pos >= 2 * N * w) moveTo(pos - N * w, false);
      else if (pos < N * w) moveTo(pos + N * w, false);
    };

    const advance = () => {
      moveTo(pos + itemW(), true);
      setTimeout(normalize, DUR + 50);
    };

    let timer = setInterval(advance, INTERVAL);

    let dragStartX = 0;
    let dragStartY = 0;
    let dragStartPos = 0;
    let dragging = false;
    let dragMoved = false;
    let dragLocked = false; // true = potvrzeno horizontální, pointer zachycen

    track.addEventListener('pointerdown', (e: PointerEvent) => {
      dragging = true;
      dragMoved = false;
      dragLocked = false;
      dragStartX = e.clientX;
      dragStartY = e.clientY;
      dragStartPos = pos;
      // Pointer zatím NEZACHYCUJEME — čekáme na potvrzení směru
      clearInterval(timer);
    });

    track.addEventListener('pointermove', (e: PointerEvent) => {
      if (!dragging) return;
      const dx = Math.abs(e.clientX - dragStartX);
      const dy = Math.abs(e.clientY - dragStartY);

      if (!dragLocked) {
        if (dx < 6 && dy < 6) return; // příliš malý pohyb, čekej
        if (dy > dx) {
          // Vertikální scroll — předáme prohlížeči
          dragging = false;
          timer = setInterval(advance, INTERVAL);
          return;
        }
        // Horizontální drag potvrzeno — teprve teď zachytíme pointer
        dragLocked = true;
        track.style.transition = 'none';
        track.setPointerCapture(e.pointerId);
        track.classList.add('is-dragging');
      }

      const delta = dragStartX - e.clientX;
      if (Math.abs(delta) > 5) dragMoved = true;
      pos = dragStartPos + delta;
      track.style.transform = `translateX(-${pos}px)`;
    });

    const finishDrag = () => {
      if (!dragging) return;
      dragging = false;
      if (!dragLocked) {
        // Žádný pohyb nebo vertikální — žádný snap
        timer = setInterval(advance, INTERVAL);
        return;
      }
      track.classList.remove('is-dragging');
      const w = itemW();
      pos = Math.round(pos / w) * w;
      track.style.transition = EASE;
      track.style.transform = `translateX(-${pos}px)`;
      setTimeout(() => {
        normalize();
        timer = setInterval(advance, INTERVAL);
      }, DUR + 50);
    };

    track.addEventListener('pointerup', finishDrag);
    track.addEventListener('pointercancel', finishDrag);

    // Zablokuj klik na odkaz po dragu
    track.addEventListener('click', (e: MouseEvent) => {
      if (dragMoved) e.preventDefault();
    }, true);
  }
</script>

