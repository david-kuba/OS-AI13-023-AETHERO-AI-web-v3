    .features { padding: 60px 0; }
    .stats-inner { gap: 16px; }
    .stat-num { font-size: 28px; }
    .stat-label { font-size: 16px; }
    .ae-services { padding: 60px 0; }
    .ae-services-title { font-size: 20px; }
    .references { padding: 60px 0; }
    .ref-card { padding: 24px 20px; }
    .zkusenosti { padding: 60px 0; }
    .zk-logos { gap: 20px; }
    .zk-logo-text { font-size: 16px; }
    .blog-section { padding: 60px 0; }
    .blog-card { flex: 0 0 calc(100vw - 48px); }
    .footer-cta { padding: 60px 0; }
    .footer-cta-contacts { gap: 12px; }
  }
</style>

<script>
(function() {
  const track = document.getElementById('blog-track');
  const prevBtn = document.getElementById('blog-prev');
  const nextBtn = document.getElementById('blog-next');
  if (!track || !prevBtn || !nextBtn) return;
  const cards = Array.from(track.querySelectorAll('.blog-card'));
  const GAP = 16;
  let current = 0;

  function visibleCount() {
    const w = window.innerWidth;
    if (w <= 480) return 1;
    if (w <= 768) return 2;
    if (w <= 1100) return 3;
    return 4;
  }
  function maxStep() { return Math.max(0, cards.length - visibleCount()); }
  function update() {
    if (!cards[0]) return;
    const step = cards[0].offsetWidth + GAP;
    track.style.transform = 'translateX(-' + (current * step) + 'px)';
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current >= maxStep();
  }
  prevBtn.addEventListener('click', () => { if (current > 0) { current--; update(); } });
  nextBtn.addEventListener('click', () => { if (current < maxStep()) { current++; update(); } });
  window.addEventListener('resize', () => { current = Math.min(current, maxStep()); update(); });

  // Touch swipe
  const hint = document.getElementById('blog-swipe-hint');
  let tsX = 0, tsY = 0;
  track.addEventListener('touchstart', e => { tsX = e.touches[0].clientX; tsY = e.touches[0].clientY; }, { passive: true });
  track.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - tsX;
    const dy = e.changedTouches[0].clientY - tsY;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
      if (dx < 0 && current < maxStep()) { current++; update(); }
      else if (dx > 0 && current > 0) { current--; update(); }
    }
  }, { passive: true });

  // Hint visibility
  const origUpdate = update;
  function updateWithHint() {
    origUpdate();
    if (hint) hint.style.opacity = current >= maxStep() ? '0' : '';
  }
  // replace all future calls
  prevBtn.onclick = () => { if (current > 0) { current--; updateWithHint(); } };
  nextBtn.onclick = () => { if (current < maxStep()) { current++; updateWithHint(); } };
  track.addEventListener('touchend', () => { if (hint) hint.style.opacity = current >= maxStep() ? '0' : ''; }, { passive: true });

  update();
})();
</script>
