const allServices = [
  { icon: '/icons/blesk.svg', label: 'Brand, Identita, DX', desc: 'Značka, narativ, barvy, digitální prezence, to vše hraje roli.' },
  { icon: '/icons/analyza.svg', label: 'Strategické analýzy', desc: 'Analýza trhů a konkurence, analýza SEO a klíč. slov + vyhledávacích trendů a další' },
  { icon: '/icons/nastroje.svg', label: 'Shopify aplikace', desc: 'Výběr a detailní nastavení aplikací doprava, platby, reference, maily' },
  { icon: '/icons/vrstvy.svg', label: 'Šablona - Theme', desc: 'Profesionální pomoc s výběrem a nastavením šablony, kontrola rychlosti, custom úpravy...' },
  { icon: '/icons/world-point.svg', label: 'Mezinárodní setup e-shopu', desc: 'Příprava mezinárodního nastavení kombinací trhů, měn, jazyků atd.' },
  { icon: '/icons/magic.svg', label: 'Překlady', desc: 'Nastavení překladů a jejich opakované přeložení při změnách pro multijazyčné projekty' },
