---

<PageLayout
  title="Jsme Shopify specialisté"
  description="Česká Shopify agentura. Design, strategie a technologie pro váš e-commerce úspěch."
  lang="cs"
>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-inner">
      <div class="hero-left">
        <h1 class="hero-heading">
          Jsme<br />
          Shopify<br />
          <span class="hero-rotate-wrapper" aria-live="polite">
            <span class="hero-rotate">specialisté</span>
          </span>
        </h1>
        <a href="/cs/kontakt" class="btn-hero">Do čeho se spolu pustíme?</a>
      </div>
      <div class="hero-right" aria-hidden="true">
        <img src="/hero-glass.webp" alt="" width="704" height="630" class="hero-shape" loading="eager" />
      </div>
    </div>
  </section>

  <!-- SERVICE SELECTOR CAROUSEL -->
  <section class="services-section">
    <div class="services-track-wrap" id="services-track-wrap">
      <div class="services-track">
        {services.map((s) => (
          <a href={s.href} class="service-item">
            <div class="service-content">
              <span class="service-num">{s.num}</span>
              <p class="service-text">{s.pre}</p>
              <h3 class="service-title">{s.title}</h3>
              <span class="service-link">{s.label}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
    <div class="services-controls">
      <button class="ctrl-btn ctrl-prev" id="ctrl-prev" aria-label="Předchozí">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 4l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="ctrl-btn ctrl-next" id="ctrl-next" aria-label="Další">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </section>

  <!-- VALUE PROP -->
  <section class="value-prop">
    <div class="container value-inner">
      <p class="value-heading">
        <span class="val-shopify">Shopify</span> dodá technologii,<br />
        <span class="val-aethero">aethero</span> strategii.
      </p>
      <p class="value-body">
        Od výběru projektu přes design a vývoj až po první objednávku — a dál.
        Staráme se o celý životní cyklus vašeho e-shopu tak,<br />
        <span class="value-purple">aby technologie nikdy nebyla překážka, ale nástroj růstu.</span>
      </p>
      <img src="/icons/shopify-monotone-white.svg" alt="Shopify" class="shopify-icon" width="60" height="64" loading="lazy" />
    </div>
  </section>

  <!-- FEATURES 4-COL -->
  <section class="features">
    <div class="container">
      <div class="features-grid">
        {features.map((col) => (
          <div class="feature-col">
            <h3 class="feature-col-title">{col.title}</h3>
            <ul class="feature-list">
              {col.items.map((item) => (
                <li class="feature-item">
                  <img src={item.icon} alt="" width="36" height="36" loading="lazy" class="feature-icon" />
                  <div>
                    <strong class="feature-label">{item.label}</strong>
                    <span class="feature-desc">{item.desc}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="stats-bar">
    <div class="container stats-inner">
      <div class="stat">
        <span class="stat-num">4,8 mil</span>
        <span class="stat-label">e-shopů fungujících ve světě</span>
      </div>
      <div class="stat">
        <span class="stat-num">175 zemí</span>
        <span class="stat-label">kde můžete prodávat</span>
      </div>
      <div class="stat">
        <span class="stat-num">3 500 vývojářů</span>
        <span class="stat-label">z celkových cca 8 000 zaměstnanců</span>
      </div>
      <img src="/shopify-white.png" alt="Shopify" class="shopify-stats-logo" width="140" height="40" loading="lazy" />
    </div>
  </section>

  <!-- AE SERVICES SECTION -->
  <section class="ae-services">
    <div class="container">
      <div class="ae-services-header">
        <img src="/ae-znak.svg" alt="aethero" class="ae-znak" width="64" height="64" loading="lazy" />
        <h2 class="ae-services-title">KOMPLEXNÍ POMOC PŘI TVORBĚ SHOPIFY E-SHOPU<br />NA VŠECH ÚROVNÍCH</h2>
      </div>
      <div class="ae-services-grid">
        {allServices.map((s) => (
          <div class="ae-service-item">
            <img src={s.icon} alt="" width="36" height="36" loading="lazy" class="ae-service-icon" />
            <div>
              <strong class="ae-service-label">{s.label}</strong>
              <span class="ae-service-desc">{s.desc}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="ae-services-ctas">
        <a href="/cs/kontakt" class="btn-teal">Chci konzultaci</a>
        <a href="/cs/co-umime" class="btn-outline">Více o tom jak pracujeme</a>
      </div>
    </div>
  </section>

  <!-- REFERENCES -->
  <section class="references">
    <div class="container">
      <h2 class="section-heading">Reference</h2>
      <div class="ref-grid">
        <div class="ref-card">
          <p class="ref-desc">Pro značku <a href="https://bu1.cz" target="_blank" rel="noopener" class="ref-link-inline">BU1.cz</a> jsme vytvořili mezinárodní moderní Shopify obchod s novým designem a důrazem na uživatelský zážitek. Řešení podporuje vícejazyčný prodej a je připravené na rychlý růst.</p>
          <div class="ref-img-wrap">
            <img src="/ref-bu1.webp" alt="BU1 – Brankářské rukavice a oblečení" width="800" height="450" loading="lazy" class="ref-img" />
            <div class="ref-img-overlay">
              <span class="ref-img-label">Brankářské rukavice<br />a oblečení</span>
            </div>
          </div>
          <a href="https://bu1.cz" target="_blank" rel="noopener" class="btn-outline ref-cta">Přejít na BU1</a>
        </div>
        <div class="ref-card">
          <p class="ref-desc">GROOMO vzniklo jako kompletní projekt v naší produkci — od tvorby značky až po vývoj Shopify e-shopu. Celý ekosystém značky stojí na touze i schopnosti pomoci, lásce ke psům a profesionalitě.</p>
          <div class="ref-img-wrap">
            <img src="/ref-groomo.webp" alt="GROOMO – Pro groomery, profi páníčky a paničky" width="800" height="450" loading="lazy" class="ref-img" />
            <div class="ref-img-overlay">
              <span class="ref-img-label">Pro groomery,<br />profi páníčky a paničky</span>
            </div>
          </div>
          <a href="/cs/groomo-cz-na-shopify" class="btn-outline ref-cta">Případová studie GROOMO.cz</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ZKUŠENOSTI -->
  <section class="zkusenosti">
    <div class="container zk-inner">
      <h2 class="zk-heading">Zkušenosti</h2>
      <p class="zk-body">Za dobu, kdy pracujeme v tomto oboru, jsme společně nashromáždili působivou sbírku klientů a tím i zkušeností. Pracovali jsme na mnoha na různých projektech, takže veselé historky o spolupráci s nadnárodními a jinými firmami, spolu můžem klidně probrat u kafe ;-D</p>
      <div class="zk-logos">
        <span class="zk-logo-text">Genkia</span>
        <span class="zk-logo-text">BU1</span>
        <span class="zk-logo-text">GROOMO</span>
        <span class="zk-logo-text">Havana Club</span>
        <span class="zk-logo-text">e·on</span>
        <span class="zk-logo-text">Jan Becher</span>
        <span class="zk-logo-text">air/bank</span>
      </div>
    </div>
  </section>

  <!-- BLOG -->
  <section class="blog-section">
    <div class="container">
      <h2 class="section-heading">Blog</h2>
      <div class="blog-grid">
        {blogPosts.map((post) => (
          <a href={post.href} class="blog-card">
            <div class="blog-card-img">
              <img src={post.img} alt={post.title} width="837" height="450" loading="lazy" />
              <span class="blog-time">⏱{post.time} min.</span>
            </div>
            <div class="blog-card-body">
              <span class="blog-ago">{post.ago}</span>
              <h3 class="blog-title">{post.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER CTA -->
  <section class="footer-cta">
    <div class="container footer-cta-inner">
      <h2 class="footer-cta-heading">Máme spolu co probrat? Dejte vědět</h2>
      <div class="footer-cta-contacts">
        <a href="mailto:info@aethero.cz" class="footer-cta-link">info@aethero.cz</a>
        <a href="tel:+420776067663" class="footer-cta-link">+420 776 067 663</a>
      </div>
    </div>
  </section>

</PageLayout>

<script>
  // Hero rotating text
  const words = ['specialisté', 'stratégové', 'vývojáři', 'partneři'];
  const rotEl = document.querySelector('.hero-rotate');
  if (rotEl) {
    let i = 0;
    setInterval(() => {
      i = (i + 1) % words.length;
      rotEl.classList.add('fade-out');
      setTimeout(() => {
        rotEl.textContent = words[i];
        rotEl.classList.remove('fade-out');
      }, 300);
    }, 2800);
  }

  // Service carousel scroll
  const trackWrap = document.getElementById('services-track-wrap');
  const prevBtn = document.getElementById('ctrl-prev');
  const nextBtn = document.getElementById('ctrl-next');
  if (trackWrap && nextBtn && prevBtn) {
    const scrollAmt = 360;
    nextBtn.addEventListener('click', () => trackWrap.scrollBy({ left: scrollAmt, behavior: 'smooth' }));
    prevBtn.addEventListener('click', () => trackWrap.scrollBy({ left: -scrollAmt, behavior: 'smooth' }));
  }
</script>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    background-color: #171A1C;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/hero-bg.webp');
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    z-index: 0;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 40px;
    padding-top: 120px;
    padding-bottom: 80px;
  }
  .hero-left { display: flex; flex-direction: column; align-items: flex-start; }
  .hero-heading {
    font-family: var(--font-primary);
    font-size: clamp(56px, 7.8vw, 100px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: 0.4px;
    color: #fff;
    margin-bottom: 40px;
  }
  .hero-rotate-wrapper { display: block; overflow: hidden; }
  .hero-rotate {
    display: inline-block;
    color: var(--action);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .hero-rotate.fade-out { opacity: 0; transform: translateY(8px); }
  .btn-hero {
    display: inline-flex;
    align-items: center;
    padding: 9px 35px;
    border: 2px solid #fff;
    color: #fff;
    font-family: var(--font-primary);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 6px;
    transition: border-color 0.2s, background 0.2s;
    white-space: nowrap;
  }
  .btn-hero:hover { background: rgba(255,255,255,0.1); }
  .hero-right { display: flex; justify-content: center; align-items: center; }
  .hero-shape {
    width: 100%;
    max-width: 600px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 60px rgba(120,50,220,0.3));
  }

  /* SERVICES CAROUSEL */
  .services-section {
    background: #000326;
    padding: 80px 0;
    position: relative;
  }
  .services-track-wrap {
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0 40px;
  }
  .services-track-wrap::-webkit-scrollbar { display: none; }
  .services-track {
    display: flex;
    gap: 0;
    width: max-content;
  }
  .service-item {
    display: flex;
    flex-direction: column;
    min-width: 340px;
    scroll-snap-align: start;
    border-right: 1px solid rgba(255,255,255,0.08);
    padding: 40px 40px 40px 0;
    color: #fff;
    transition: opacity 0.2s;
  }
  .service-item:first-child { padding-left: 0; }
  .service-item:hover { opacity: 0.85; }
  .service-content { display: flex; flex-direction: column; gap: 8px; }
  .service-num {
    font-family: var(--font-primary);
    font-size: clamp(60px, 8vw, 100px);
    font-weight: 700;
    color: var(--text-secondary);
    line-height: 1;
  }
  .service-text {
    font-size: 14px;
    font-weight: 500;
    color: rgba(255,255,255,0.8);
    line-height: 1.4;
    margin: 0;
  }
  .service-title {
    font-family: var(--font-primary);
    font-size: 40px;
    font-weight: 600;
    line-height: 1.1;
    color: var(--action);
    margin: 4px 0 8px;
  }
  .service-link {
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: #fff;
    text-transform: uppercase;
  }
  .services-controls {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    padding: 24px 40px 0;
  }
  .ctrl-btn {
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    background: transparent;
    color: #fff;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
