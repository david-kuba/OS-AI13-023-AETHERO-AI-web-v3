      </p>
      <img src="/shopify-white.png" alt="Shopify" class="shopify-icon" loading="lazy" />
    </div>
  </section>

  <!-- FEATURES 4-COL -->
  <section class="features">
    <div class="container">
      <div class="features-grid">
        {features.map((col) => (
          <div class="feature-col">
            <h3 class="h3-mini feature-col-title">{col.title}</h3>
            <ul class="feature-list">
              {col.items.map((item) => (
                <li class="feature-item">
                  <img src={item.icon} alt="" width="36" height="36" loading="lazy" class="feature-icon" />
                  <div>
                    <strong class="feature-label">{item.label}</strong>
                    <span class="feature-desc">{item.desc}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="stats-bar">
    <div class="stats-inner">
      <div class="stat">
        <span class="stat-num">4,8 mil</span>
        <span class="stat-label">e-shopů fungujících ve světě</span>
      </div>
      <div class="stat">
        <span class="stat-num">175 zemí</span>
        <span class="stat-label">kde můžete prodávat</span>
      </div>
      <div class="stat">
        <span class="stat-num">3 500 vývojářů</span>
        <span class="stat-label">z celkových cca 8 000 zaměstnanců</span>
      </div>
      <img src="/icons/shopify-monotone-white.svg" alt="Shopify" class="shopify-stats-logo" loading="lazy" />
    </div>
  </section>

  <!-- AE SERVICES SECTION -->
  <section class="ae-services">
    <div class="container">
      <div class="ae-services-header">
        <img src="/ae-znak.svg" alt="aethero" class="ae-znak" width="120" height="120" loading="lazy" />
        <h5 class="ae-services-title">KOMPLEXNÍ POMOC PŘI TVORBĚ, SPRÁVĚ A ROZVOJI SHOPIFY E-SHOPU</h5>
      </div>
      <div class="ae-services-grid">
        {allServices.map((s) => (
          <div class="ae-service-item">
            <img src={s.icon} alt="" width="36" height="36" loading="lazy" class="ae-service-icon" />
            <div>
              <strong class="ae-service-label">{s.label}</strong>
              <span class="ae-service-desc">{s.desc}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="ae-services-ctas">
        <a href="/cs/kontakt" class="btn-teal">Chci konzultaci</a>
        <a href="/cs/co-umime" class="btn-outline">Více o tom jak pracujeme</a>
      </div>
    </div>
  </section>

  <!-- REFERENCES -->
  <section class="references">
    <div class="container">
      <h2 class="h2-maxi section-heading">Reference</h2>
      <div class="ref-grid">
        <div class="ref-card">
          <h3 class="ref-title"><a href="https://bu1.cz" target="_blank" rel="noopener">BU1.cz, BU1sport.com</a></h3>
          <p class="ref-desc body">Pro značku <a href="https://bu1.cz" target="_blank" rel="noopener" class="text-link">BU1.cz</a> jsme vytvořili mezinárodní moderní Shopify obchod s novým designem a důrazem na uživatelský zážitek. Řešení podporuje vícejazyčný prodej a je připravené na rychlý růst.</p>
          <div class="ref-img-wrap">
            <img src="/ref-bu1.webp" alt="BU1 – Brankářské rukavice a oblečení" width="800" height="450" loading="lazy" class="ref-img" />
            <div class="ref-img-overlay">
              <span class="ref-img-label">Brankářské rukavice<br />a oblečení</span>
            </div>
          </div>
          <a href="https://bu1.cz" target="_blank" rel="noopener" class="btn-outline ref-cta">Přejít na BU1</a>
        </div>
        <div class="ref-card">
          <h3 class="ref-title"><a href="/cs/groomo-cz-na-shopify">GROOMO.cz</a></h3>
          <p class="ref-desc body">GROOMO vzniklo jako kompletní projekt v naší produkci — od tvorby značky až po vývoj Shopify e-shopu. Celý ekosystém značky stojí na touze i schopnosti pomoci, lásce ke psům a profesionalitě.</p>
          <div class="ref-img-wrap">
            <img src="/ref-groomo.webp" alt="GROOMO – Pro groomery, profi páníčky a paničky" width="800" height="450" loading="lazy" class="ref-img" />
            <div class="ref-img-overlay">
