const { title, readTime, date, perex, content } = Astro.props;
const dateFormatted = new Date(date).toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' });

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": perex,
  "datePublished": date,
  "inLanguage": "cs-CZ",
  "publisher": {
    "@type": "Organization",
    "name": "AETHERO s.r.o.",
    "url": "https://aethero.agency"
  },
  "author": {
    "@type": "Organization",
    "name": "AETHERO s.r.o."
  }
};
---

<PageLayout {title} description={perex} lang="cs" jsonLd={articleSchema}>

  <section class="blog-hero">
    <div class="container blog-hero-inner">
      <div class="blog-meta">
        <span>{dateFormatted}</span>
        <span class="dot" aria-hidden="true">·</span>
        <span>{readTime} čtení</span>
      </div>
      <h1>{title}</h1>
      <p class="blog-perex">{perex}</p>
    </div>
  </section>

  <article class="section bg-primary">
    <div class="container article-inner">
      <div class="article-body">
        <p>{content}</p>
      </div>
    </div>
  </article>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Máme spolu co probrat?</h2>
      <div class="cta-links">
        <a href="mailto:info@aethero.cz" class="btn-primary">info@aethero.cz</a>
        <a href="/cs/kontakt" class="btn-ghost">Kontakt</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .blog-hero { background: var(--ae-bg-primary); padding: 160px 0 80px; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .blog-hero-inner { max-width: 760px; }
  .blog-meta { display: flex; align-items: center; gap: var(--space-8); font-size: var(--text-small); color: var(--neutral-500); margin-bottom: var(--space-24); }
  .dot { opacity: 0.4; }
  .blog-hero h1 { font-size: var(--fs-72); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); }
  .blog-perex { font-size: var(--fs-24); color: var(--text-secondary); line-height: 1.6; }
  .section { padding: var(--space-120) 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .article-inner { max-width: 760px; }
  .article-body { font-size: 18px; color: var(--neutral-300); line-height: 1.6; }
  .cta-section { padding: var(--space-80) 0; background: var(--ae-bg-primary); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: var(--fs-70); font-weight: 600; margin-bottom: var(--space-40); }
  .cta-links { display: flex; gap: var(--space-16); justify-content: center; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--ae-bg-primary); font-family: var(--font-primary); font-size: 16px; font-weight: 600; border-radius: var(--radius-sm); transition: background var(--transition-base); }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 16px; font-weight: 600; border-radius: var(--radius-sm); transition: border-color var(--transition-base), color var(--transition-base); }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }
  @media (max-width: 768px) {
    .blog-hero { padding: 120px 0 60px; }
  }
  @media (max-width: 480px) {
    .blog-hero { padding: 90px 0 48px; }
  }
</style>
