---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceHero from '../../components/layout/ServiceHero.astro';

const steps = [
  { step: '01', title: 'Export z Shopify', desc: 'Exportujte produkty, kolekce nebo stránky do CSV nebo ZIP formátu.' },
  { step: '02', title: 'Nahrání do AE Translator', desc: 'Soubor nahrajete do aplikace — bez kódování, bez nastavení.' },
  { step: '03', title: 'Hromadný AI překlad', desc: 'Zvolíte AI engine a spustíte překlad. DeepL, Claude nebo Deep Seek.' },
  { step: '04', title: 'Import zpět do Shopify', desc: 'Stáhnete přeložený soubor a reimportujete do Shopify adminu.' },
];

const features = [
  { title: 'Výběr AI enginu', desc: 'DeepL, Claude nebo Deep Seek — volíte dle kvality a ceny.' },
  { title: 'Pay-per-token', desc: 'Platíte jen za tokeny zvoleného AI poskytovatele. Bez předplatného.' },
  { title: 'Vlastní prompty', desc: 'Nastavíte instrukce pro překlad — tone of voice, terminologie, výjimky.' },
  { title: 'Vícejazyčný slovník', desc: 'Definujete výrazy, které se nikdy nepřekládají nebo překládají jinak.' },
  { title: 'Výběrové vynechání', desc: 'Vyloučíte konkrétní hodnoty z překladu — kódy produktů, SKU, URLs.' },
  { title: 'Automatický překlad URL', desc: 'Handle se automaticky přeloží z přeloženého názvu produktu.' },
];

const engines = [
  { name: 'DeepL', desc: 'Nejlepší kvalita pro evropské jazyky. Rychlý a přesný.' },
  { name: 'Claude', desc: 'Pokročilé instrukce a nuance. Skvělý pro marketing a copywriting.' },
  { name: 'Deep Seek', desc: 'Cenově nejefektivnější možnost pro velké objemy.' },
];
---

<PageLayout title="AE Translator — AI překlad Shopify e-shopu" description="Hromadný AI překlad produktů, kolekcí a stránek v Shopify za zlomek ceny klasických překladačů." lang="cs">
  <ServiceHero
    label="Aplikace"
    title="AE Translator"
    subtitle="Hromadný AI překlad Shopify obsahu za zlomek ceny. Exportujte, přeložte, reimportujte — bez vývojáře, bez čekání."
    ctaLabel="Napište Báře"
    ctaHref="mailto:bara@aethero.cz"
  />

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Jak to funguje</h2>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card">
            <span class="step-num">{s.step}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-secondary">
    <div class="container">
      <h2 class="section-title">Podporované AI enginy</h2>
      <div class="engines-grid">
        {engines.map((e) => (
          <div class="engine-card">
            <h3>{e.name}</h3>
            <p>{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Funkce aplikace</h2>
      <div class="features-grid">
        {features.map((f) => (
          <div class="feature-card">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Máme spolu co probrat?</h2>
      <p>Demo připravujeme. Napište Báře — probereme váš projekt a objem překladu.</p>
      <div class="cta-links">
        <a href="mailto:bara@aethero.cz" class="btn-primary">bara@aethero.cz</a>
        <a href="tel:+420776325440" class="btn-ghost">+420 776 325 440</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: clamp(32px, 5vw, 70px); font-weight: 600; margin-bottom: var(--space-40); }
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-24); }
  .step-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .step-num { display: block; font-family: var(--font-primary); font-size: 13px; font-weight: 600; color: var(--action); margin-bottom: var(--space-16); }
  .step-card h3 { font-size: 16px; font-weight: 600; margin-bottom: var(--space-8); }
  .step-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .engines-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .engine-card { background: var(--bg-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-40); }
  .engine-card h3 { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 600; color: var(--action); margin-bottom: var(--space-16); }
  .engine-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .feature-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .feature-card h3 { font-size: 15px; font-weight: 600; color: var(--action); margin-bottom: var(--space-8); }
  .feature-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .cta-section { padding: var(--space-120) 0; background: var(--bg-secondary); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: clamp(32px, 5vw, 70px); font-weight: 600; margin-bottom: var(--space-16); }
  .cta-inner p { color: var(--neutral-300); margin-bottom: var(--space-40); }
  .cta-links { display: flex; gap: var(--space-16); justify-content: center; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--bg-elevated); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: background var(--transition-base); }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: border-color var(--transition-base), color var(--transition-base); }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }
  @media (max-width: 1024px) { .steps-grid { grid-template-columns: repeat(2, 1fr); } .engines-grid { grid-template-columns: 1fr; } .features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .steps-grid { grid-template-columns: 1fr; } .features-grid { grid-template-columns: 1fr; } }
</style>
