---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout title="AE Translator — AI překlad Shopify e-shopu" description="Hromadný AI překlad produktů, kolekcí a stránek v Shopify za zlomek ceny klasických překladačů. DeepL, Claude nebo DeepSeek." lang="cs">

  <!-- HERO -->
  <section class="app-hero">
    <div class="app-hero-bg" style="background-image: url('/ae-translator-hero.webp')"></div>
    <div class="app-hero-overlay"></div>
    <div class="container app-hero-inner">
      <img src="/ae-translate-znak.svg" alt="AE Translator" class="app-hero-logo" />
      <h1>AE TRANSLATOR</h1>
      <p class="app-hero-sub"><span class="app-hero-sub-hi">Překladač textů nativně exportovaných z Shopify</span><br />s možností napojení na vlastní AI a vytvořením pravidel</p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h2 intro-heading">Překládejte s&nbsp;pomocí AI za&nbsp;zlomek&nbsp;ceny.</h2>
      <p class="intro-text">Shopify App Store nabízí velké množství překladových aplikací, některé z nich dokonce využívají AI nebo nabízí propojení s překladateli, ovšem cena takového překladu se může blížit vyšším tisícům i desetitisícům, pokud má váš e-shop stovky či tisíce produktů.</p>
      <p class="intro-text process-text">Naše aplikace využívá nativní Shopify export a import: <strong>exportujete produkty, kolekce nebo stránky do formátu CSV či ZIP, nahrajete soubor a vše hromadně přeložíte pomocí AI</strong> (DeepL, Claude nebo DeepSeek). <strong>Přeložený soubor stáhnete a naimportujete jej zpět do administrace.</strong></p>
    </div>
  </section>

  <!-- BENEFITS + WHY -->
  <section class="section bg-primary">
    <div class="container two-col">
      <div>
        <h2 class="h3 section-title">Jaké má naše řešení výhody?</h2>
        <ul class="arrow-list" style="margin-bottom: var(--space-40)">
          <li>Využívá možnosti exportovat obsah celého webu do csv, který vložením do aplikace projde překladem AI</li>
          <li>Vyberete si model, který chcete na překlad využít</li>
          <li>Za překlad platíte pouze za cenu tokenu od vámi vybrané služby</li>
          <li>Vyladíte si uživatelský prompt přesně pro vaše potřeby</li>
          <li>Snadno v exportovaném souboru hromadně zkontrolujete přeložené hodnoty</li>
          <li>Jednoduše si nastavíte slovník pro různé jazyky</li>
          <li>Snadno zakážete překlad určitých hodnot</li>
          <li>Můžete si zvolit překlad url handles, které se automaticky vytvoří z přeloženého názvu</li>
        </ul>
        <p class="extra-note">Pokud chcete použít model, který není v současné nabídce aplikace, ozvěte se nám — přidáme ho.</p>
      </div>
      <div>
        <h2 class="h3 section-title">Proč ne pouze automaticky?</h2>
        <p class="body-text body">AE Translator aplikace si na nic nehraje. Je to šikovná vychytávka, která vám za málo peněz pomůže dosáhnout velkého výsledku. Odladili jsme za vás problémy, které by AI mohlo při překladech způsobovat. Na vás už je doladit si prompt tak, aby odpovídal vašim očekáváním. Dodejte kontext a pravidla, a můžete překládat.</p>
      </div>
    </div>
    <div class="container btn-demo-row">
      <a href="#" class="btn-demo">AE Translator DEMO</a>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="section bg-primary section-screenshots">
    <div class="container">
      <h2 class="h2-mini section-title-large">Náhledy aplikace</h2>
      <div class="gallery-grid">
        <a href="/aet-screen-1.png" class="gallery-item" data-index="0">
          <img src="/aet-screen-1.png" alt="AE Translator — přehled překladů" loading="lazy" class="gallery-img" />
          <div class="gallery-overlay" aria-hidden="true"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></div>
        </a>
        <a href="/aet-screen-2.png" class="gallery-item" data-index="1">
          <img src="/aet-screen-2.png" alt="AE Translator — nastavení" loading="lazy" class="gallery-img" />
          <div class="gallery-overlay" aria-hidden="true"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></div>
        </a>
        <a href="/aet-screen-3.png" class="gallery-item" data-index="2">
          <img src="/aet-screen-3.png" alt="AE Translator — slovník" loading="lazy" class="gallery-img" />
          <div class="gallery-overlay" aria-hidden="true"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></div>
        </a>
      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div id="lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Galerie snímků">
    <button class="lightbox-close" aria-label="Zavřít">✕</button>
    <button class="lightbox-prev" aria-label="Předchozí">&#8249;</button>
    <button class="lightbox-next" aria-label="Další">&#8250;</button>
    <img id="lightbox-img" src="" alt="" class="lightbox-img" />
    <div class="lightbox-counter" id="lightbox-counter"></div>
  </div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Máme spolu co probrat?<br />Dejte vědět!</h2>
      <div class="cta-contacts">
        <a href="mailto:bara@aethero.cz" class="cta-contact">bara@aethero.cz</a>
        <a href="tel:+420776325440" class="cta-contact">+420 776 325 440</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* ─── HERO ─── */
  .app-hero {
    position: relative;
    display: block;
    overflow: hidden;
  }
  .app-hero-bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center bottom;
  }
  .app-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,3,38,0.75) 100%);
  }
  .app-hero-inner {
    position: relative; z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    padding-top: 150px;
    padding-bottom: 100px;
  }
  .app-hero-logo {
    width: 220px;
    height: auto;
    object-fit: contain;
  }
  .app-hero h1 {
    font-family: var(--font-primary);
    font-size: var(--fs-100);
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
    margin: 0;
  }
  .app-hero-sub {
    font-size: var(--fs-22);
    color: rgba(255,255,255,0.85);
    line-height: 1.5;
    max-width: 640px;
    margin: 0;
  }
  .app-hero-sub-hi { color: #A081D1; }

  /* ─── SECTIONS ─── */
  .section { padding: 40px 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }

  .intro-heading {
    margin-bottom: var(--space-32);
  }
  .intro-text {
    font-size: var(--fs-20);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    max-width: 800px;
    margin: 0 0 var(--space-24);
  }
  .process-text strong { color: #fff; }

  .section-title {
    color: #A081D1;
    margin-bottom: var(--space-32);
  }
  .section-title-large {
    margin-bottom: var(--space-40);
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-80);
    align-items: start;
  }

  .benefit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: var(--space-32);
  }
  .benefit-list li {
    font-size: 16px;
    color: rgba(255,255,255,0.8);
    line-height: 1.55;
    padding-left: 20px;
    position: relative;
  }
  .benefit-list li::before {
    content: '➔';
    position: absolute;
    left: 0;
    color: rgba(255,255,255,0.55);
    font-size: 14px;
  }

  .extra-note {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
    margin-bottom: var(--space-24);
    font-style: italic;
  }

  .body-text {
    margin-bottom: var(--space-24);
  }

  .btn-demo-row { text-align: center; padding-top: var(--space-40); }
  .btn-demo {
    display: inline-flex;
    align-items: center;
    padding: 14px 40px;
    background: #fff;
    border: 2px solid #fff;
    color: var(--ae-straight-blue, #000326);
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    transition: background 0.2s, color 0.2s;
  }
  .btn-demo:hover { background: var(--action); border-color: var(--action); color: #000; }

  /* ─── GALLERY ─── */
  .section-screenshots { padding-bottom: 80px; }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: var(--space-40);
  }
  .gallery-item {
    display: block;
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    cursor: zoom-in;
  }
  .gallery-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .gallery-item:hover .gallery-img { transform: scale(1.05); }
  .gallery-overlay {
    position: absolute; inset: 0;
    background: rgba(0,3,38,0.5);
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    opacity: 0;
    transition: opacity 0.22s;
  }
  .gallery-item:hover .gallery-overlay { opacity: 1; }

  /* ─── LIGHTBOX NAV ─── */
  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,0.12);
    border: none; color: #fff;
    font-size: 44px; line-height: 1;
    width: 60px; height: 60px;
    border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
    z-index: 1;
  }
  .lightbox-prev { left: 24px; }
  .lightbox-next { right: 24px; }
  .lightbox-prev:hover, .lightbox-next:hover { background: rgba(255,255,255,0.28); }
  .lightbox-counter {
    position: absolute;
    bottom: 20px; left: 50%; transform: translateX(-50%);
    color: rgba(255,255,255,0.55);
    font-family: var(--font-primary);
    font-size: 13px; letter-spacing: 0.08em;
  }

  /* ─── CTA ─── */
  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 {
    font-family: var(--font-primary);
    font-size: var(--fs-70);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin-bottom: var(--space-40);
  }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact {
    font-family: var(--font-primary);
    font-size: var(--fs-40);
    font-weight: 700;
    color: var(--ae-straight-blue);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .intro-heading { text-align: left; }
    .intro-text { text-align: left; margin-left: 0; margin-right: 0; }
    .app-hero-logo { width: 120px; }
    .app-hero { min-height: auto; }
    .app-hero h1 { font-size: var(--fs-56); }
    .app-hero-inner { padding-bottom: 48px; }
  }
  @media (max-width: 480px) {
    .app-hero-inner { padding-top: 100px; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ─── LIGHTBOX ─── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }
  .lightbox.is-open { display: flex; }
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: 2px solid rgba(255,255,255,0.5);
    color: #fff;
    font-size: 20px;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
    line-height: 1;
  }
  .lightbox-close:hover { border-color: #fff; color: #fff; }
  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    cursor: default;
    box-shadow: 0 20px 80px rgba(0,0,0,0.6);
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');
  const lbCounter = document.getElementById('lightbox-counter');
  const items = [...document.querySelectorAll('.gallery-item')];
  const images = items.map(item => ({
    src: item.href,
    alt: item.querySelector('img')?.alt || ''
  }));
  let current = 0;

  function show(index) {
    current = (index + images.length) % images.length;
    lbImg.src = images[current].src;
    lbImg.alt = images[current].alt;
    lbCounter.textContent = `${current + 1} / ${images.length}`;
  }
  function openLightbox(index) {
    show(index);
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    lbImg.src = '';
    document.body.style.overflow = '';
  }

  items.forEach((item, i) => {
    item.addEventListener('click', e => { e.preventDefault(); openLightbox(i); });
  });

  lb.querySelector('.lightbox-close').addEventListener('click', closeLightbox);
  lb.querySelector('.lightbox-prev').addEventListener('click', e => { e.stopPropagation(); show(current - 1); });
  lb.querySelector('.lightbox-next').addEventListener('click', e => { e.stopPropagation(); show(current + 1); });
  lb.addEventListener('click', e => { if (e.target === lb || e.target === lbImg) closeLightbox(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('is-open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>
