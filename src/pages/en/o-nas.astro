---
import PageLayout from '../../layouts/PageLayout.astro';

const team = [
  {
    name: 'David',
    role: 'Design & Business Development',
    desc: 'Primary contact for new projects. Handles design, strategy and new client relationships.',
    email: 'david@aethero.cz',
    phone: '+420 776 067 663',
  },
  {
    name: 'Bára',
    role: 'Coding, UX/UI & Project Management',
    desc: 'Makes sure everything makes sense. Combines development, user experience and project coordination with a consistently great attitude.',
    email: 'bara@aethero.cz',
  },
  {
    name: 'Tom',
    role: 'Design, Video & Motion',
    desc: 'Graphics, video, 3D and motion design. Responsible for the visual side of products and premium aesthetic experience.',
  },
];
---

<PageLayout title="About Us" description="We are a small team with broad experience. We met on projects and decided to make it official." lang="en">

  <section class="o-nas-hero">
    <div class="hero-blob" aria-hidden="true"></div>
    <div class="container">
      <h1>About Us</h1>
      <p class="hero-sub">
        A team that met on projects and decided to make it official.
        We bring decades of industry experience — and do only what we love.
      </p>
    </div>
  </section>

  <section class="section bg-primary">
    <div class="container">
      <h2 class="section-title">Team</h2>
      <div class="team-grid">
        {team.map((member) => (
          <div class="team-card">
            <div class="team-avatar" aria-hidden="true">
              <span>{member.name[0]}</span>
            </div>
            <h3 class="team-name">{member.name}</h3>
            <p class="team-role">{member.role}</p>
            <p class="team-desc">{member.desc}</p>
            {member.email && (
              <a href={`mailto:${member.email}`} class="team-contact">{member.email}</a>
            )}
            {member.phone && (
              <a href={`tel:${member.phone.replace(/\s/g,'')}`} class="team-contact">{member.phone}</a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-primary">
    <div class="container mission-inner">
      <div>
        <h2 class="section-title">What drives us</h2>
        <p class="mission-text">
          We have been in e-commerce long enough to know what works and what does not.
          We do not sell hours — we deliver results. Each of us brings a different perspective,
          but we all share the same goal: your store should grow.
        </p>
      </div>
      <div class="mission-values">
        <div class="value-item">
          <h3>Honest</h3>
          <p>We say what we think, including when something is not a good idea.</p>
        </div>
        <div class="value-item">
          <h3>Long-term</h3>
          <p>Most of our clients are with us for years, not months.</p>
        </div>
        <div class="value-item">
          <h3>Shopify-first</h3>
          <p>We focus on one platform and do it properly.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Call, write!<br />We don't bite.</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-link">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-link">+420 776 067 663</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; justify-content: center; gap: var(--space-40); flex-wrap: wrap; }
  .cta-link { font-size: clamp(22px, 3vw, 40px); color: var(--ae-straight-blue); font-family: var(--font-primary); font-weight: 700; text-decoration: none; transition: opacity var(--transition-base); }
  .cta-link:hover { text-decoration: underline; text-underline-offset: 4px; }

  .o-nas-hero {
    position: relative; overflow: hidden;
    background: var(--ae-bg-primary-alt);
    padding: 130px 0 80px;
  }
  .hero-blob {
    position: absolute; top: -20%; right: -5%;
    width: 500px; height: 500px;
    background: radial-gradient(ellipse, rgba(203,0,215,0.15) 0%, transparent 70%);
    border-radius: 50%; filter: blur(60px);
    pointer-events: none;
  }
  .o-nas-hero h1 { font-size: clamp(40px, 5vw, 64px); font-weight: 700; margin-bottom: 24px; }
  .hero-sub { font-size: 22px; color: rgba(255,255,255,0.75); max-width: 600px; line-height: 1.5; }

  .section { padding: var(--space-120) 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }
  .section-title { font-size: clamp(32px, 5vw, 70px); font-weight: 600; margin-bottom: var(--space-40); }

  .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .team-card {
    background: var(--ae-bg-primary); border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md); padding: var(--space-40);
    display: flex; flex-direction: column; gap: 8px;
  }
  .team-avatar {
    width: 80px; height: 80px; border-radius: 50%;
    background: linear-gradient(135deg, var(--text-secondary), var(--action));
    display: flex; align-items: center; justify-content: center;
    margin-bottom: var(--space-16);
  }
  .team-avatar span { font-size: 32px; font-weight: 700; color: #fff; }
  .team-name { font-size: 24px; font-weight: 700; }
  .team-role { font-size: 14px; color: rgba(255,255,255,0.6); font-weight: 500; letter-spacing: 0; }
  .team-desc { font-size: 16px; color: var(--neutral-300); line-height: 1.6; flex: 1; }
  .team-contact { font-size: 14px; color: var(--text-secondary); transition: color var(--transition-base); }
  .team-contact:hover { color: var(--action); }

  .mission-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .mission-text { font-size: 18px; color: rgba(255,255,255,0.8); line-height: 1.7; }
  .mission-values { display: flex; flex-direction: column; gap: var(--space-24); }
  .value-item { padding: var(--space-24); background: rgba(13,212,205,0.08); border: 1px solid rgba(13,212,205,0.22); border-radius: var(--radius-md); }
  .value-item h3 { font-size: 20px; font-weight: 700; color: #fff; margin-bottom: 8px; }
  .value-item p { font-size: 16px; color: var(--neutral-300); }

  @media (max-width: 768px) {
    .team-grid { grid-template-columns: 1fr; }
    .mission-inner { grid-template-columns: 1fr; }
    .o-nas-hero { padding: 90px 0 60px; }
  }
  @media (max-width: 480px) {
    .o-nas-hero { padding: 70px 0 48px; }
    .o-nas-hero h1 { font-size: clamp(32px, 9vw, 48px); }
    .section { padding: var(--space-80) 0; }
  }
</style>
