---
import PageLayout from '../../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  // TODO: Connect to Storyblok in Milestone 2.x
  return [
    {
      params: { slug: 'shopify-mandatory-button' },
      props: { title: 'Mandatory Button in Shopify: Don\'t Wait Until It Becomes a Problem', readTime: '7 min', date: '2026-05-01', perex: 'How to correctly set up the mandatory button in Shopify and avoid compliance issues.', content: 'Article content will be added. Storyblok CMS integration in Milestone 2.x.' },
    },
    {
      params: { slug: 'ai-seo-2026' },
      props: { title: 'AI SEO — The New Hard Reality of Search for E-shops (2026)', readTime: '7 min', date: '2026-01-15', perex: 'How artificial intelligence is changing SEO and what it means for your e-shop.', content: 'Article content will be added. Storyblok CMS integration in Milestone 2.x.' },
    },
    {
      params: { slug: 'shopify-editions-winter-2026' },
      props: { title: 'Shopify Editions — Winter 2026', readTime: '5 min', date: '2025-12-10', perex: 'Overview of the most important updates from Shopify Editions Winter 2026.', content: 'Article content will be added. Storyblok CMS integration in Milestone 2.x.' },
    },
    {
      params: { slug: 'translating-payment-methods-shopify' },
      props: { title: "Translating Payment Methods in Shopify When Translate & Adapt Doesn't Help", readTime: '3 min', date: '2025-10-05', perex: 'A practical guide to translating payment methods in Shopify outside of standard tools.', content: 'Article content will be added. Storyblok CMS integration in Milestone 2.x.' },
    },
    {
      params: { slug: 'shopify-vs-shoptet' },
      props: { title: 'Which E-commerce Platform to Choose? Shopify vs Shoptet', readTime: '18 min', date: '2025-06-01', perex: 'Detailed comparison of Shopify and Shoptet for the Central European market.', content: 'Article content will be added. Storyblok CMS integration in Milestone 2.x.' },
    },
  ];
}

const { title, readTime, date, perex, content } = Astro.props;
const dateFormatted = new Date(date).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": perex,
  "datePublished": date,
  "inLanguage": "en-US",
  "publisher": {
    "@type": "Organization",
    "name": "AETHERO s.r.o.",
    "url": "https://aethero.agency"
  },
  "author": {
    "@type": "Organization",
    "name": "AETHERO s.r.o."
  }
};
---

<PageLayout {title} description={perex} lang="en" jsonLd={articleSchema}>

  <article class="blog-article">
    <header class="article-hero">
      <div class="hero-blob" aria-hidden="true"></div>
      <div class="container article-hero-inner">
        <div class="article-meta">
          <time datetime={date}>{dateFormatted}</time>
          <span class="read-time">{readTime} read</span>
        </div>
        <h1>{title}</h1>
        <p class="article-perex">{perex}</p>
      </div>
    </header>

    <section class="article-body">
      <div class="container article-content">
        <p class="placeholder-note">{content}</p>
      </div>
    </section>
  </article>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Something to discuss?</h2>
      <div class="cta-links">
        <a href="mailto:info@aethero.cz" class="btn-primary">info@aethero.cz</a>
        <a href="/en/kontakt" class="btn-ghost">Contact</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  .article-hero {
    position: relative; overflow: hidden;
    background: var(--ae-bg-primary);
    padding: 160px 0 80px;
  }
  .hero-blob {
    position: absolute; top: -100px; right: -100px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(160,129,209,0.15) 0%, transparent 70%);
    border-radius: 50%; pointer-events: none;
  }
  .article-hero-inner { max-width: 760px; }
  .article-meta { display: flex; gap: 16px; margin-bottom: 24px; font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.7); }
  .read-time::before { content: '·'; margin-right: 16px; }
  .article-hero h1 { font-size: var(--fs-72); font-weight: 700; line-height: 1.2; margin-bottom: 24px; }
  .article-perex { font-size: var(--fs-24); color: rgba(255,255,255,0.85); line-height: 1.5; }
  .article-body { padding: var(--space-120) 0; background: var(--ae-bg-primary); }
  .article-content { max-width: 800px; }
  .placeholder-note { font-size: 18px; color: var(--neutral-500); font-style: italic; }
  .cta-section { padding: var(--space-80) 0; background: var(--ae-bg-primary); }
  .cta-inner h2 { font-size: var(--fs-70); font-weight: 600; margin-bottom: var(--space-40); }
  .cta-links { display: flex; gap: var(--space-16); justify-content: center; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--ae-bg-primary); font-family: var(--font-primary); font-size: 16px; font-weight: 600; border-radius: var(--radius-sm); transition: background var(--transition-base); }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 16px; font-weight: 600; border-radius: var(--radius-sm); transition: border-color var(--transition-base), color var(--transition-base); }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }
  @media (max-width: 768px) {
    .blog-hero { padding: 120px 0 60px; }
  }
  @media (max-width: 480px) {
    .blog-hero { padding: 90px 0 48px; }
  }
</style>
