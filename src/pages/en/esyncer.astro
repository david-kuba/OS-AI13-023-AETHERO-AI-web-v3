---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout title="eSyncer — Product Import & Sync for Shopify" description="Automate product data import and synchronisation from XML feeds directly into Shopify." lang="en">

  <!-- HERO -->
  <section class="app-hero">
    <div class="app-hero-bg" style="background-image: url('/header-image-esyncer.webp')"></div>
    <div class="app-hero-overlay"></div>
    <div class="container app-hero-inner">
      <img src="/es-sipky.svg" alt="eSyncer" class="app-hero-logo" />
      <h1>eSyncer</h1>
      <p class="app-hero-sub">Import, synchronisation &amp; automation<br />(not only) for&nbsp;<strong>SHOPIFY</strong></p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="intro-heading">With our app, your up-to-date product data flows from your supplier's feed exactly where&nbsp;you&nbsp;need&nbsp;it!</h2>
      <p class="intro-text">If you're looking for a way to automate XML feed imports, you're in the right place. We know how difficult it is to set up. We specialise in complex XML feeds, CSV files and API sources for e-commerce. We fine-tune every import personally — and then you run on autopilot.</p>
    </div>
  </section>

  <!-- BENEFITS + WHY -->
  <section class="section bg-secondary">
    <div class="container two-col">
      <div>
        <h2 class="section-title">What are the advantages?</h2>
        <ul class="benefit-list">
          <li>Only selected source categories are imported into the relevant store categories.</li>
          <li>You can add products manually without conflicting with imported products.</li>
          <li>The module works alongside other import apps and manually added products.</li>
          <li>Automatic tags can be set up.</li>
          <li>Automatically remove or disable products that no longer exist in the XML feed.</li>
          <li>The app deactivates products when stock reaches 0 and reactivates them when stock goes above 0.</li>
          <li>The solution can be fully customised to your additional requirements.</li>
        </ul>
      </div>
      <div>
        <h2 class="section-title">Why not fully automatic?</h2>
        <p class="body-text">Some apps come with preset feed parsing rules. But what if your feed is a bit more complex and a universal solution just doesn't cut it? The best approach is to show us the source feed and a sample of how you want the final product to look. We replicate the exact structure and behaviour and connect it to the sync tool. Your data will be exactly where you want it.</p>
        <p class="body-text">After the initial integration is complete, you review everything and we incorporate any further requirements. You get your own dashboard offering additional configuration options and the ability to monitor the app's activity.</p>
      </div>
    </div>
    <div class="container btn-demo-row">
      <a href="https://www.aethero.cz/files/esyncer-shopify-demo.pdf" target="_blank" rel="noopener" class="btn-demo">DEMO</a>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">App screenshots</h2>
      <div class="screenshots-grid">
        <a href="/esyncer-screen-1.png" class="screenshot-link">
          <img src="/esyncer-screen-1.png" alt="eSyncer dashboard" loading="lazy" class="screenshot-img" />
        </a>
        <a href="/esyncer-screen-2.png" class="screenshot-link">
          <img src="/esyncer-screen-2.png" alt="eSyncer jobs" loading="lazy" class="screenshot-img" />
        </a>
        <a href="/esyncer-screen-3.png" class="screenshot-link">
          <img src="/esyncer-screen-3.png" alt="eSyncer mappings" loading="lazy" class="screenshot-img" />
        </a>
        <a href="/esyncer-screen-4.png" class="screenshot-link">
          <img src="/esyncer-screen-4.png" alt="eSyncer settings" loading="lazy" class="screenshot-img" />
        </a>
      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div id="lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="lightbox-close" aria-label="Close">✕</button>
    <img id="lightbox-img" src="" alt="" class="lightbox-img" />
  </div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Got something to discuss?<br />Get in touch!</h2>
      <div class="cta-contacts">
        <a href="mailto:bara@aethero.cz" class="cta-contact">bara@aethero.cz</a>
        <a href="tel:+420776325440" class="cta-contact">+420 776 325 440</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* ─── HERO ─── */
  .app-hero {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: clamp(400px, 68vh, 700px);
  }
  .app-hero-bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center bottom;
  }
  .app-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,3,38,0.75) 100%);
  }
  .app-hero-inner {
    position: relative; z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    padding-top: 150px;
    padding-bottom: 48px;
  }
  .app-hero-logo {
    width: clamp(120px, 14vw, 220px);
    height: auto;
    object-fit: contain;
  }
  .app-hero h1 {
    font-family: var(--font-primary);
    font-size: clamp(56px, 7.8vw, 100px);
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
    margin: 0;
  }
  .app-hero-sub {
    font-size: clamp(18px, 2.5vw, 28px);
    color: rgba(255,255,255,0.85);
    line-height: 1.4;
    max-width: 680px;
    margin: 0;
  }

  /* ─── SECTIONS ─── */
  .section { padding: 40px 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }

  .intro-heading {
    font-family: var(--font-primary);
    font-size: clamp(30px, 4vw, 56px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-32);
  }
  .intro-text {
    font-size: clamp(16px, 1.4vw, 20px);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    max-width: 800px;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-80);
  }
  .section-title {
    font-size: clamp(22px, 3vw, 36px);
    font-weight: 600;
    line-height: 1.2;
    color: #A081D1;
    margin-bottom: var(--space-32);
  }
  .benefit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: var(--space-40);
  }
  .benefit-list li {
    font-size: 18px;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    padding-left: 24px;
    position: relative;
  }
  .benefit-list li::before { content: '→'; position: absolute; left: 0; color: var(--action); }
  .btn-demo-row { text-align: center; padding-top: var(--space-40); }
  .btn-demo {
    display: inline-flex;
    align-items: center;
    padding: 14px 40px;
    background: #fff;
    border: 2px solid #fff;
    color: var(--brand-dark, #000326);
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    transition: background 0.2s, color 0.2s;
  }
  .btn-demo:hover { background: var(--action); border-color: var(--action); color: #000; }
  .body-text {
    font-size: 18px;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin-bottom: var(--space-24);
  }

  .screenshots-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-24);
    margin-top: var(--space-40);
  }
  .screenshot-link { display: block; border-radius: var(--radius-md); overflow: hidden; }
  .screenshot-img { width: 100%; height: auto; display: block; transition: opacity 0.2s; }
  .screenshot-link:hover .screenshot-img { opacity: 0.85; }

  /* ─── LIGHTBOX ─── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }
  .lightbox.is-open { display: flex; }
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: 2px solid rgba(255,255,255,0.5);
    color: #fff;
    font-size: 20px;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
    line-height: 1;
  }
  .lightbox-close:hover { border-color: #fff; color: #fff; }
  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    cursor: default;
    box-shadow: 0 20px 80px rgba(0,0,0,0.6);
  }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 {
    font-family: var(--font-primary);
    font-size: clamp(40px, 5vw, 70px);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin-bottom: var(--space-40);
  }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact {
    font-family: var(--font-primary);
    font-size: clamp(22px, 3vw, 40px);
    font-weight: 700;
    color: var(--brand-dark);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; gap: var(--space-40); }
    .screenshots-grid { grid-template-columns: 1fr; }
    .app-hero-inner { padding-top: 100px; }
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');

  function openLightbox(src, alt) {
    lbImg.src = src;
    lbImg.alt = alt;
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    lbImg.src = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.screenshot-link').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const img = link.querySelector('img');
      openLightbox(link.href, img ? img.alt : '');
    });
  });

  lb.querySelector('.lightbox-close').addEventListener('click', closeLightbox);
  lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>
