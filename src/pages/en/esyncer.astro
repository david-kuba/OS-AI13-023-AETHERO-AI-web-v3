---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout title="eSyncer — Product Import & Sync for Shopify" description="Automate product data import and synchronisation from XML feeds directly into Shopify." lang="en">

  <!-- HERO -->
  <section class="app-hero">
    <div class="app-hero-bg" style="background-image: url('/header-image-esyncer.webp')"></div>
    <div class="app-hero-overlay"></div>
    <div class="container app-hero-inner">
      <img src="/es-sipky.svg" alt="eSyncer" class="app-hero-logo" />
      <h1>eSyncer</h1>
      <p class="app-hero-sub">Import, synchronisation &amp; automation<br />(not only) for&nbsp;<strong>SHOPIFY</strong></p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="intro-heading">With our app, your up-to-date product data flows from your supplier's feed exactly where&nbsp;you&nbsp;need&nbsp;it!</h2>
      <p class="intro-text">If you're looking for a way to automate XML feed imports, you're in the right place. We know how difficult it is to set up. We specialise in complex XML feeds, CSV files and API sources for e-commerce. We fine-tune every import personally — and then you run on autopilot.</p>
    </div>
  </section>

  <!-- BENEFITS + WHY -->
  <section class="section bg-primary">
    <div class="container two-col">
      <div>
        <h2 class="h3 section-title">What are the advantages?</h2>
        <ul class="arrow-list" style="margin-bottom: var(--space-40)">
          <li>Only selected source categories are imported into the relevant store categories.</li>
          <li>You can add products manually without conflicting with imported products.</li>
          <li>The module works alongside other import apps and manually added products.</li>
          <li>Automatic tags can be set up.</li>
          <li>Automatically remove or disable products that no longer exist in the XML feed.</li>
          <li>The app deactivates products when stock reaches 0 and reactivates them when stock goes above 0.</li>
          <li>The solution can be fully customised to your additional requirements.</li>
        </ul>
      </div>
      <div>
        <h2 class="h3 section-title">Why not fully automatic?</h2>
        <p class="body-text body">Some apps come with preset feed parsing rules. But what if your feed is a bit more complex and a universal solution just doesn't cut it? The best approach is to show us the source feed and a sample of how you want the final product to look. We replicate the exact structure and behaviour and connect it to the sync tool. Your data will be exactly where you want it.</p>
        <p class="body-text body">After the initial integration is complete, you review everything and we incorporate any further requirements. You get your own dashboard offering additional configuration options and the ability to monitor the app's activity.</p>
      </div>
    </div>
    <div class="container btn-demo-row">
      <a href="https://www.aethero.cz/files/esyncer-shopify-demo.pdf" target="_blank" rel="noopener noreferrer" class="btn-demo">eSyncer DEMO</a>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="section bg-primary section-screenshots">
    <div class="container">
      <h2 class="h3 section-title">App screenshots</h2>
      <div class="gallery-grid">
        <a href="/esyncer-screen-1.png" class="gallery-item" data-index="0">
          <img src="/esyncer-screen-1.png" alt="eSyncer dashboard" loading="lazy" class="gallery-img" />
          <div class="gallery-overlay" aria-hidden="true"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></div>
        </a>
        <a href="/esyncer-screen-2.png" class="gallery-item" data-index="1">
          <img src="/esyncer-screen-2.png" alt="eSyncer jobs" loading="lazy" class="gallery-img" />
          <div class="gallery-overlay" aria-hidden="true"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></div>
        </a>
        <a href="/esyncer-screen-3.png" class="gallery-item" data-index="2">
          <img src="/esyncer-screen-3.png" alt="eSyncer mappings" loading="lazy" class="gallery-img" />
          <div class="gallery-overlay" aria-hidden="true"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></div>
        </a>
        <a href="/esyncer-screen-4.png" class="gallery-item" data-index="3">
          <img src="/esyncer-screen-4.png" alt="eSyncer settings" loading="lazy" class="gallery-img" />
          <div class="gallery-overlay" aria-hidden="true"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg></div>
        </a>
      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div id="lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Screenshot gallery">
    <button class="lightbox-close" aria-label="Close">✕</button>
    <button class="lightbox-prev" aria-label="Previous">&#8249;</button>
    <button class="lightbox-next" aria-label="Next">&#8250;</button>
    <img id="lightbox-img" src="" alt="" class="lightbox-img" />
    <div class="lightbox-counter" id="lightbox-counter"></div>
  </div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Got something to discuss?<br />Get in touch!</h2>
      <div class="cta-contacts">
        <a href="mailto:bara@aethero.cz" class="cta-contact">bara@aethero.cz</a>
        <a href="tel:+420776325440" class="cta-contact">+420 776 325 440</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* ─── HERO ─── */
  .app-hero {
    position: relative;
    display: block;
    overflow: hidden;
    min-height: 700px;
  }
  .app-hero-bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center bottom;
  }
  .app-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,3,38,0.75) 100%);
  }
  .app-hero-inner {
    position: relative; z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    padding-top: 150px;
    padding-bottom: 48px;
  }
  .app-hero-logo {
    width: 220px;
    height: auto;
    object-fit: contain;
  }
  .app-hero h1 {
    font-family: var(--font-primary);
    font-size: var(--fs-100);
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
    margin: 0;
  }
  .app-hero-sub {
    font-size: var(--fs-28);
    color: rgba(255,255,255,0.85);
    line-height: 1.4;
    max-width: 680px;
    margin: 0;
  }

  /* ─── SECTIONS ─── */
  .section { padding: 40px 0; }

  .intro-heading {
    font-family: var(--font-primary);
    font-size: var(--fs-56);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-32);
    max-width: 800px;
  }
  .intro-text {
    font-size: var(--fs-20);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    max-width: 800px;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-80);
  }
  .section-title { color: #A081D1; margin-bottom: var(--space-32); }
  .benefit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: var(--space-40);
  }
  .benefit-list li {
    font-size: 18px;
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    padding-left: 24px;
    position: relative;
  }
  .benefit-list li::before { content: '➔'; position: absolute; left: 0; color: rgba(255,255,255,0.55); }
  .btn-demo-row { text-align: center; padding-top: var(--space-40); }
  .btn-demo {
    display: inline-flex;
    align-items: center;
    padding: 14px 40px;
    background: #fff;
    border: 2px solid #fff;
    color: var(--ae-straight-blue, #000326);
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    transition: background 0.2s, color 0.2s;
  }
  .btn-demo:hover { background: var(--action); border-color: var(--action); color: #000; }
  .body-text {
    margin-bottom: var(--space-24);
  }

  /* ─── GALLERY ─── */
  .section-screenshots { padding-bottom: 80px; }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-top: var(--space-40);
  }
  .gallery-item {
    display: block;
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 16 / 10;
    cursor: zoom-in;
  }
  .gallery-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .gallery-item:hover .gallery-img { transform: scale(1.05); }
  .gallery-overlay {
    position: absolute; inset: 0;
    background: rgba(0,3,38,0.5);
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    opacity: 0;
    transition: opacity 0.22s;
  }
  .gallery-item:hover .gallery-overlay { opacity: 1; }

  /* ─── LIGHTBOX NAV ─── */
  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,0.12);
    border: none; color: #fff;
    font-size: 44px; line-height: 1;
    width: 60px; height: 60px;
    border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
    z-index: 1;
  }
  .lightbox-prev { left: 24px; }
  .lightbox-next { right: 24px; }
  .lightbox-prev:hover, .lightbox-next:hover { background: rgba(255,255,255,0.28); }
  .lightbox-counter {
    position: absolute;
    bottom: 20px; left: 50%; transform: translateX(-50%);
    color: rgba(255,255,255,0.55);
    font-family: var(--font-primary);
    font-size: 13px; letter-spacing: 0.08em;
  }

  /* ─── LIGHTBOX ─── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }
  .lightbox.is-open { display: flex; }
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: 2px solid rgba(255,255,255,0.5);
    color: #fff;
    font-size: 20px;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
    line-height: 1;
  }
  .lightbox-close:hover { border-color: #fff; color: #fff; }
  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    cursor: default;
    box-shadow: 0 20px 80px rgba(0,0,0,0.6);
  }

  .cta-inner h2 {
    font-family: var(--font-primary);
    font-size: var(--fs-70);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin-bottom: var(--space-40);
  }
  .cta-contact {
    font-family: var(--font-primary);
    font-size: var(--fs-40);
    font-weight: 700;
    color: var(--ae-straight-blue);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; gap: var(--space-40); }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .app-hero-inner { padding-top: 100px; }
    .app-hero { min-height: auto; }
    .app-hero-logo { width: 120px; }
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');
  const lbCounter = document.getElementById('lightbox-counter');
  const items = [...document.querySelectorAll('.gallery-item')];
  const images = items.map(item => ({
    src: item.href,
    alt: item.querySelector('img')?.alt || ''
  }));
  let current = 0;

  function show(index) {
    current = (index + images.length) % images.length;
    lbImg.src = images[current].src;
    lbImg.alt = images[current].alt;
    lbCounter.textContent = `${current + 1} / ${images.length}`;
  }
  function openLightbox(index) {
    show(index);
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    lbImg.src = '';
    document.body.style.overflow = '';
  }

  items.forEach((item, i) => {
    item.addEventListener('click', e => { e.preventDefault(); openLightbox(i); });
  });

  lb.querySelector('.lightbox-close').addEventListener('click', closeLightbox);
  lb.querySelector('.lightbox-prev').addEventListener('click', e => { e.stopPropagation(); show(current - 1); });
  lb.querySelector('.lightbox-next').addEventListener('click', e => { e.stopPropagation(); show(current + 1); });
  lb.addEventListener('click', e => { if (e.target === lb || e.target === lbImg) closeLightbox(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('is-open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>
