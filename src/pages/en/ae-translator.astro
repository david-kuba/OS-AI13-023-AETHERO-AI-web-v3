---
import PageLayout from '../../layouts/PageLayout.astro';

const steps = [
  { step: '01', title: 'Export from Shopify', desc: 'Export products, collections or pages to CSV or ZIP format.' },
  { step: '02', title: 'Upload to AE Translator', desc: 'Upload the file to the app — no coding, no configuration.' },
  { step: '03', title: 'Bulk AI Translation', desc: 'Choose your AI engine and run the translation. DeepL, Claude or DeepSeek.' },
  { step: '04', title: 'Import Back to Shopify', desc: 'Download the translated file and reimport into Shopify admin.' },
];

const features = [
  { title: 'AI Engine Selection', desc: 'DeepL, Claude or DeepSeek — choose based on quality and cost.' },
  { title: 'Pay-per-Token', desc: 'Pay only for tokens of the chosen AI provider. No subscription.' },
  { title: 'Custom Prompts', desc: 'Set translation instructions — tone of voice, terminology, exceptions.' },
  { title: 'Multilingual Glossary', desc: 'Define terms that should never be translated or are translated differently.' },
  { title: 'Selective Exclusion', desc: 'Exclude specific values from translation — product codes, SKUs, URLs.' },
  { title: 'Automatic URL Translation', desc: 'Handle is automatically translated from the translated product name.' },
];

const engines = [
  { name: 'DeepL', desc: 'Best quality for European languages. Fast and accurate.' },
  { name: 'Claude', desc: 'Advanced instructions and nuance. Great for marketing and copywriting.' },
  { name: 'DeepSeek', desc: 'Most cost-effective option for large volumes.' },
];
---

<PageLayout title="AE Translator — AI Translation for Shopify" description="Bulk AI translation of products, collections and pages in Shopify for a fraction of the cost." lang="en">

  <!-- HERO -->
  <section class="app-hero">
    <div class="app-hero-bg" style="background-image: url('/ae-translator-hero.webp')"></div>
    <div class="app-hero-overlay"></div>
    <div class="container app-hero-inner">
      <img src="/ae-translate-znak.svg" alt="AE Translator" class="app-hero-logo" />
      <h1>AE<br />TRANSLATOR</h1>
      <p class="app-hero-sub"><span class="app-hero-sub-hi">AI-powered bulk translation of Shopify content</span><br />for a fraction of the cost.</p>
    </div>
  </section>

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">How it works</h2>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card">
            <span class="step-num">{s.step}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-secondary">
    <div class="container">
      <h2 class="section-title">Features</h2>
      <div class="features-grid">
        {features.map((f) => (
          <div class="feature-card">
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Available AI engines</h2>
      <div class="engines-grid">
        {engines.map((e) => (
          <div class="engine-card">
            <h3>{e.name}</h3>
            <p>{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Want to try it?</h2>
      <p>Contact Bára — she will set it up for your store.</p>
      <div class="cta-links">
        <a href="mailto:bara@aethero.cz" class="btn-primary">bara@aethero.cz</a>
        <a href="tel:+420776325440" class="btn-ghost">+420 776 325 440</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* ─── HERO ─── */
  .app-hero {
    position: relative;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
  }
  .app-hero-bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
  }
  .app-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,3,38,0.75) 100%);
  }
  .app-hero-inner {
    position: relative; z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    padding-top: 120px;
    padding-bottom: 80px;
  }
  .app-hero-logo {
    width: clamp(120px, 14vw, 220px);
    height: auto;
    object-fit: contain;
  }
  .app-hero h1 {
    font-family: var(--font-primary);
    font-size: clamp(56px, 7.8vw, 100px);
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
    margin: 0;
  }
  .app-hero-sub {
    font-size: clamp(16px, 2vw, 22px);
    color: rgba(255,255,255,0.85);
    line-height: 1.5;
    max-width: 640px;
    margin: 0;
  }
  .app-hero-sub-hi { color: var(--action); }

  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: clamp(32px, 5vw, 70px); font-weight: 600; margin-bottom: var(--space-40); }
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-24); }
  .step-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .step-num { font-size: 48px; font-weight: 700; color: var(--text-secondary); line-height: 1; display: block; margin-bottom: var(--space-16); }
  .step-card h3 { font-size: 16px; font-weight: 600; margin-bottom: var(--space-8); }
  .step-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .feature-card { background: var(--bg-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-40); }
  .feature-card h3 { font-size: 18px; font-weight: 600; color: var(--action); margin-bottom: var(--space-8); }
  .feature-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .engines-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .engine-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-40); }
  .engine-card h3 { font-size: 24px; font-weight: 700; color: var(--action); margin-bottom: var(--space-16); }
  .engine-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .cta-section { padding: var(--space-120) 0; background: var(--bg-secondary); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: clamp(32px, 5vw, 70px); font-weight: 600; margin-bottom: var(--space-16); }
  .cta-inner p { color: var(--neutral-300); margin-bottom: var(--space-40); }
  .cta-links { display: flex; gap: var(--space-16); justify-content: center; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--bg-elevated); font-family: var(--font-primary); font-size: 16px; font-weight: 600; border-radius: var(--radius-sm); transition: background var(--transition-base); }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 16px; font-weight: 600; border-radius: var(--radius-sm); transition: border-color var(--transition-base); }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }
  @media (max-width: 768px) { .steps-grid { grid-template-columns: 1fr; } .features-grid { grid-template-columns: 1fr; } .engines-grid { grid-template-columns: 1fr; } }
</style>
