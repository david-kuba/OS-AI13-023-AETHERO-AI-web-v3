---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout title="AE Translator — AI Translation for Shopify" description="Bulk AI translation of products, collections and pages in Shopify for a fraction of the cost." lang="en">

  <!-- HERO -->
  <section class="app-hero">
    <div class="app-hero-bg" style="background-image: url('/ae-translator-hero.webp')"></div>
    <div class="app-hero-overlay"></div>
    <div class="container app-hero-inner">
      <img src="/ae-translate-znak.svg" alt="AE Translator" class="app-hero-logo" />
      <h1>AE TRANSLATOR</h1>
      <p class="app-hero-sub"><span class="app-hero-sub-hi">AI-powered bulk translation of Shopify content</span><br />for a fraction of the cost.</p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="intro-heading">Translate with&nbsp;AI for&nbsp;a&nbsp;fraction&nbsp;of&nbsp;the&nbsp;cost.</h2>
      <p class="intro-text">The Shopify App Store offers a large number of translation apps — some even use AI or connect to translation services. But the cost can easily reach thousands, especially if your store has hundreds or thousands of products.</p>
      <p class="intro-text process-text">Our app uses Shopify's native export and import: <strong>export your products, collections or pages to CSV or ZIP, upload the file and bulk-translate everything with AI</strong> (DeepL, Claude or DeepSeek). <strong>Download the translated file and reimport it back into Shopify admin.</strong></p>
    </div>
  </section>

  <!-- BENEFITS + WHY -->
  <section class="section bg-secondary">
    <div class="container two-col">
      <div>
        <h2 class="section-title">What are the advantages?</h2>
        <ul class="benefit-list">
          <li>Export your entire store content to CSV and run it through AI translation in one go</li>
          <li>Choose the AI model you want to use for translation</li>
          <li>Pay only the token cost of your chosen AI provider — no subscription</li>
          <li>Fine-tune the user prompt exactly to your needs</li>
          <li>Easily review all translated values in the exported file before importing</li>
          <li>Set up a glossary for different languages</li>
          <li>Exclude specific values from translation — product codes, SKUs, URLs</li>
          <li>Optionally translate URL handles, auto-generated from the translated product name</li>
        </ul>
        <p class="extra-note">If you need a model not currently in the app — let us know and we'll add it.</p>
        <a href="#" class="btn-demo">DEMO COMING SOON</a>
      </div>
      <div>
        <h2 class="section-title">Why not fully automatic?</h2>
        <p class="body-text">AE Translator does exactly what it says. It's a practical tool that helps you achieve great results at a low cost. We've solved the common AI translation pitfalls for you. All you need to do is tune the prompt to match your expectations — add context and rules, and you're ready to translate.</p>
      </div>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title-large">App screenshots</h2>
      <div class="screenshots-grid">
        <a href="/aet-screen-1.png" class="screenshot-link">
          <img src="/aet-screen-1.png" alt="AE Translator — translation overview" loading="lazy" class="screenshot-img" />
        </a>
        <a href="/aet-screen-2.png" class="screenshot-link">
          <img src="/aet-screen-2.png" alt="AE Translator — settings" loading="lazy" class="screenshot-img" />
        </a>
        <a href="/aet-screen-3.png" class="screenshot-link">
          <img src="/aet-screen-3.png" alt="AE Translator — glossary" loading="lazy" class="screenshot-img" />
        </a>
      </div>
    </div>
  </section>

  <!-- LIGHTBOX -->
  <div id="lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="lightbox-close" aria-label="Close">✕</button>
    <img id="lightbox-img" src="" alt="" class="lightbox-img" />
  </div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Got something to discuss?<br />Get in touch!</h2>
      <div class="cta-contacts">
        <a href="mailto:bara@aethero.cz" class="cta-contact">bara@aethero.cz</a>
        <a href="tel:+420776325440" class="cta-contact">+420 776 325 440</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* ─── HERO ─── */
  .app-hero {
    position: relative;
    display: block;
    overflow: hidden;
  }
  .app-hero-bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center bottom;
  }
  .app-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,3,38,0.75) 100%);
  }
  .app-hero-inner {
    position: relative; z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    padding-top: 150px;
    padding-bottom: 100px;
  }
  .app-hero-logo {
    width: clamp(120px, 14vw, 220px);
    height: auto;
    object-fit: contain;
  }
  .app-hero h1 {
    font-family: var(--font-primary);
    font-size: clamp(56px, 7.8vw, 100px);
    font-weight: 700;
    line-height: 1.2;
    color: #fff;
    margin: 0;
  }
  .app-hero-sub {
    font-size: clamp(16px, 2vw, 22px);
    color: rgba(255,255,255,0.85);
    line-height: 1.5;
    max-width: 640px;
    margin: 0;
  }
  .app-hero-sub-hi { color: var(--action); }

  /* ─── SECTIONS ─── */
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }

  .intro-heading {
    font-family: var(--font-primary);
    font-size: clamp(30px, 4vw, 56px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-32);
  }
  .intro-text {
    font-size: clamp(16px, 1.4vw, 20px);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    max-width: 800px;
    margin: 0 0 var(--space-24);
  }
  .process-text strong { color: var(--action); }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-80);
  }
  .section-title {
    font-size: clamp(22px, 3vw, 36px);
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: var(--space-32);
  }
  .benefit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: var(--space-24);
  }
  .benefit-list li {
    font-size: 18px;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    padding-left: 24px;
    position: relative;
  }
  .benefit-list li::before { content: '→'; position: absolute; left: 0; color: var(--action); }
  .extra-note {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin-bottom: var(--space-32);
    font-style: italic;
  }
  .btn-demo {
    display: block;
    width: fit-content;
    margin: var(--space-40) auto 0;
    padding: 14px 40px;
    background: #fff;
    border: 2px solid #fff;
    color: var(--brand-dark, #000326);
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    transition: background 0.2s, color 0.2s;
  }
  .btn-demo:hover { background: var(--action); border-color: var(--action); color: #000; }
  .body-text {
    font-size: 18px;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin-bottom: var(--space-24);
  }

  .section-title-large {
    font-family: var(--font-primary);
    font-size: clamp(26px, 3.5vw, 48px);
    font-weight: 600;
    color: #fff;
    line-height: 1.2;
    margin-bottom: var(--space-40);
  }
  .screenshots-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-24);
  }
  .screenshot-link { display: block; border-radius: var(--radius-md); overflow: hidden; }
  .screenshot-img { width: 100%; height: auto; display: block; transition: transform 0.3s; }
  .screenshot-link:hover .screenshot-img { transform: scale(1.03); }

  /* ─── LIGHTBOX ─── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
  }
  .lightbox.is-open { display: flex; }
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: 2px solid rgba(255,255,255,0.5);
    color: #fff;
    font-size: 20px;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
    line-height: 1;
  }
  .lightbox-close:hover { border-color: #fff; color: #fff; }
  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    cursor: default;
    box-shadow: 0 20px 80px rgba(0,0,0,0.6);
  }

  /* ─── CTA ─── */
  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 {
    font-family: var(--font-primary);
    font-size: clamp(40px, 5vw, 70px);
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    margin-bottom: var(--space-40);
  }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact {
    font-family: var(--font-primary);
    font-size: clamp(22px, 3vw, 40px);
    font-weight: 700;
    color: var(--brand-dark);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; }
    .screenshots-grid { grid-template-columns: 1fr 1fr; }
    .intro-heading { text-align: left; }
    .intro-text { text-align: left; margin-left: 0; margin-right: 0; }
  }
  @media (max-width: 480px) {
    .app-hero-inner { padding-top: 100px; }
    .screenshots-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');

  function openLightbox(src, alt) {
    lbImg.src = src;
    lbImg.alt = alt;
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    lbImg.src = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.screenshot-link').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const img = link.querySelector('img');
      openLightbox(link.href, img ? img.alt : '');
    });
  });

  lb.querySelector('.lightbox-close').addEventListener('click', closeLightbox);
  lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>
