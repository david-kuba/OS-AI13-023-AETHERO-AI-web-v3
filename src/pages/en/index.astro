<script>
  const track = document.getElementById('services-track') as HTMLElement | null;
  const trackWrap = document.getElementById('services-track-wrap') as HTMLElement | null;
  if (track && trackWrap) {
    const STEP = 600;
    const INTERVAL = 5000;
    let offset = 0;

    setInterval(() => {
      const maxOffset = track.scrollWidth - trackWrap.clientWidth;
      offset += STEP;
      if (offset > maxOffset) {
        offset = 0;
        track.style.transition = 'none';
        track.style.transform = 'translateX(0)';
        track.offsetWidth;
        requestAnimationFrame(() => { track.style.transition = ''; });
      } else {
        track.style.transform = `translateX(-${offset}px)`;
      }
    }, INTERVAL);
  }
</script>

<style>
  /* HERO */
  .hero {
    position: relative;
    background-color: #000326;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('/hero-bg.webp');
