                    <strong class="feature-label">{item.label}</strong>
                    <span class="feature-desc">{item.desc}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="stats-bar">
    <div class="stats-inner">
      <div class="stat">
        <span class="stat-num">4.8M</span>
        <span class="stat-label">stores operating worldwide</span>
      </div>
      <div class="stat">
        <span class="stat-num">175 countries</span>
        <span class="stat-label">where you can sell</span>
      </div>
      <div class="stat">
        <span class="stat-num">3,500 devs</span>
        <span class="stat-label">out of ~8,000 Shopify employees</span>
      </div>
      <img src="/icons/shopify-monotone-white.svg" alt="Shopify" class="shopify-stats-logo" loading="lazy" />
