---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const steps = [
  { step: '01', title: 'Data Audit', desc: 'GA4, Google Ads, Meta Ads, email platform — we bring everything to one place.' },
  { step: '02', title: 'Analysis & Segmentation', desc: 'RFM customer analysis, product crawl, identifying problem areas.' },
  { step: '03', title: 'Strategy & Priorities', desc: '365-day action plan with prioritised tasks and clear ownership.' },
  { step: '04', title: 'Implementation & Measurement', desc: 'Applying recommendations, tracking results and iterating.' },
];

const forWho = [
  'E-shop with at least €120k annual revenue',
  'You feel you are not making full use of your data',
  'Campaigns are running but results are stagnating',
  'You do not have an internal analytics team',
  'You want specific recommendations, not generic advice',
];
---

<PageLayout title="Strategy & Analytics" description="Stop guessing — find out why your e-shop is not growing. Your data says more than you think." lang="en">
  <ServiceHero lang="en"
    label="Strategy & Analytics"
    title="STOP GUESSING,<br /><span style='color:var(--action)'>FIND OUT WHY</span>"
    subtitle="Your data says more than you think. We analyse GA4, ads, email marketing and customer data — and deliver a strategy that works from day one."
  />

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">4 steps to a finished strategy</h2>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card">
            <span class="step-num">{s.step}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-secondary">
    <div class="container two-col">
      <div>
        <h2 class="section-title">What we analyse</h2>
        <ul class="tools-list">
          <li>Klaviyo, Mailchimp, Ecomail</li>
          <li>Google Analytics 4 / GA4</li>
          <li>Google Ads and Meta Ads</li>
          <li>Shopify, Shoptet, WooCommerce</li>
          <li>Product crawl and content analysis</li>
          <li>Customer segmentation (RFM)</li>
        </ul>
      </div>
      <div>
        <h2 class="section-title">Is this for you?</h2>
        <ul class="for-who-list">
          {forWho.map((f) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Ready to find out?</h2>
      <p>Let's start with a free intro call about your data situation.</p>
      <div class="cta-links">
        <a href="mailto:info@aethero.cz" class="btn-primary">info@aethero.cz</a>
        <a href="tel:+420776067663" class="btn-ghost">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-40); }
  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-24); }
  .step-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .step-num { display: block; font-family: var(--font-primary); font-size: 13px; font-weight: 600; color: var(--action); margin-bottom: var(--space-16); }
  .step-card h3 { font-size: 16px; font-weight: 600; margin-bottom: var(--space-8); }
  .step-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .two-col { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-80); }
  .tools-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .tools-list li { font-size: var(--text-small); color: var(--neutral-300); padding-left: 12px; position: relative; }
  .tools-list li::before { content: '—'; position: absolute; left: 0; color: var(--text-secondary); }
  .for-who-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .for-who-list li { display: flex; align-items: flex-start; gap: var(--space-8); font-size: var(--text-small); color: var(--neutral-300); }
  .cta-section { padding: var(--space-120) 0; background: var(--bg-primary-alt); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-16); }
  .cta-inner p { color: var(--neutral-300); margin-bottom: var(--space-40); }
  .cta-links { display: flex; gap: var(--space-16); justify-content: center; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--bg-elevated); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: background var(--transition-base); }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: border-color var(--transition-base), color var(--transition-base); }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }
  @media (max-width: 1024px) { .steps-grid { grid-template-columns: repeat(2, 1fr); } .two-col { grid-template-columns: 1fr; } }
  @media (max-width: 768px) { .steps-grid { grid-template-columns: 1fr; } }
</style>
