---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const analyzeItems = [
  'Email marketing — Leadhub, Klaviyo, Mailchimp, Ecomail and others. Campaigns, automations, segments, open rate, CTR, revenue per email.',
  'E-commerce platform — Shoptet, Shopify, WooCommerce — orders, customers, products, seasonality, retention, AOV.',
  'Google Analytics / GA4 — Traffic sources, conversion paths, attribution model, channel performance, user behaviour.',
  'Google Ads — Campaign performance, ROAS, search terms, lost impressions, opportunities to scale or save.',
  'Meta Ads — Facebook & Instagram — reach, frequency, CPM, ROAS, audience overlap, funnel analysis.',
  'Web crawling — If the data is not in an export — we crawl the store or website automatically and extract the product catalogue, prices, categories, UX patterns.',
];

const deliverables = [
  'Key metrics overview — 24-month horizon, year-on-year comparison, trend identification',
  'Root cause analysis of growth or decline — what works, what does not and why',
  'Campaign and automation performance overview — cross-sell opportunities, customer segmentation',
  'Cross-sell opportunities and shopping basket analysis — what customers buy and when',
  'Cross-sell mapping / CRM — email campaigns, flows, Klaviyo vs customers, competitive metrics',
  'Segmentation recommendations — RFM models, customer retention, churn prevention',
  'SEO and integrations — email campaigns, flows, Klaviyo vs customers, competitive metrics',
  'Marketing strategy beyond email — 40 specific tasks that will deliver results',
];

const forWho = [
  'Your store generates data but you lack the capacity or know-how to read it properly',
  'You suspect your emails, ads or flows could perform better — but do not know how to do it',
  'You need a specific action plan with clear prioritisation, not generic recommendations',
  'You are deciding where to invest your marketing budget in the next year',
];

const steps = [
  { num: '1. Data connection', desc: 'Send us exports or API access to your platforms. No access? We will help — we can send you CSV files or pull the data ourselves. Everything is handled discreetly.' },
  { num: '2. Analysis', desc: 'We go through the data in depth: orders, campaigns, customers. Typically 1–3 days depending on data volume.' },
  { num: '3. Live collaboration', desc: 'We go through the results with you in real time. You add context, we answer questions — the result is a bespoke strategy with nothing superfluous, no templates.' },
  { num: '4. Strategy document + plan', desc: 'You receive a clear online strategy document with a complete analysis and a clickable 365-day plan. Prepared online, accessible any time.' },
];

const relatedServices = [
  { href: '/en/co-umime/potrebuji-brand', label: 'I need a brand' },
  { href: '/en/co-umime/novy-shopify-e-shop', label: 'New Shopify store' },
  { href: '/en/co-umime/prechod-na-shopify', label: 'Migration to Shopify' },
  { href: '/en/co-umime/expanze-do-zahranici', label: 'International expansion' },
  { href: '/en/co-umime/rozvoj-a-podpora', label: 'Development & support' },
  { href: '/en/co-umime/custom-vyvoj-a-aplikace', label: 'Custom development & apps' },
];
---

<PageLayout title="Strategy & Analytics | aethero" description="Stop guessing — find out why your store is not growing. We connect your data and deliver a strategy that works right away." lang="en">
  <ServiceHero
    lang="en"
    label="Strategy & Analytics"
    title="STRATEGY<br /><span style='color:var(--action)'>& ANALYTICS</span>"
    subtitle="Do you know why your store is growing? And why it sometimes is not? We connect your data, apply AI + context — and the results are truly impressive."
    ctaLabel="Let's talk"
    ctaHref="tel:+420776067663"
    cta2Label="Find out how"
    cta2Href="#how-it-works"
    image="/aethero-gradient-222.png"
    imageAlt="Strategy and analytics for an e-shop"
  />

  <!-- Stop guessing -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="intro-h2">Stop guessing,<br /><span class="accent-purple">FIND OUT WHY</span></h2>
      <p class="intro-text">Your store is telling you something. <strong class="hl">Are you listening?</strong> Every store has a story hidden inside its data — where it earns, where it bleeds, why some customers stay and others disappear after the first purchase. <strong class="hl">You already have that data — nobody is reading it.</strong> And someone should.</p>
      <p class="intro-text">It takes experience and a bit of technical voodoo, but then we sit down with your data, plans and a tamed AI, connect them to what is needed: Google Ads, Analytics, Meta and your email client — and <strong class="hl">hand you back a strategy with numbers against every recommendation</strong>: how much it will earn, how much it will save, when to switch it on.</p>
      <a href="#cta" class="intro-btn">Want an analysis? Call or write →</a>
    </div>
  </section>

  <!-- Your data says more -->
  <section class="section bg-secondary">
    <div class="container">
      <div class="two-col-analyze">
        <div>
          <h2 class="section-title">Your data says more<br />than you think</h2>
          <p class="section-text">API access, CSV exports or web crawling — we can connect almost any data source. We combine data from your store, email campaigns, Google Ads, Analytics and social media. And you then receive a specific strategy with the quantified benefit of each recommendation — no generic advice.</p>
          <p class="section-text"><strong>We most often work with stores from €120k annual revenue on Shoptet, Shopify and WooCommerce.</strong></p>
          <a href="#how-it-works" class="section-link">What are those? →</a>
        </div>
        <div>
          <h3 class="analyze-label">WHAT WE ANALYSE</h3>
          <ul class="analyze-list">
            {analyzeItems.map((a) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section bg-secondary">
    <div class="container">
      <h4 class="testimonials-label">What do store owners say about this service?</h4>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <p class="testimonial-text">"The output was well-crafted, clear and above all full of specific insights we can immediately use to drive further growth for our store. No generic recommendations — solutions tailored specifically to us."</p>
          <p class="testimonial-author">— <strong>Lucie, owner of fleppi.cz</strong> · ⭐⭐⭐⭐⭐ Google</p>
        </div>
        <div class="testimonial-card">
          <p class="testimonial-text">"I am thrilled, because for the first time I have a complete picture of everything happening in the store, all in one place. The biggest thing is how the data connects with each other. I can see whether the content on the site actually engaged people and add info from the mailing — what people respond to best in emails. These overlaps, where I see the entire customer journey from search to purchase, allow me to make changes in Shopify that actually make sense."</p>
          <p class="testimonial-author">— <strong>Petr, owner of BU1.cz</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Output / Case study -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title-center">Output <span class="text-action">you can use straight away.</span></h2>
      <div class="output-col">
        <div>
          <p class="section-text">No Excel tables that nobody opens. The result is a live strategy document available online — clear, specific, with a clickable action plan.</p>
          <ul class="deliverables-list">
            {deliverables.map((d) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <a href="/en/zkusenosti" class="section-link">OK, check out the examples →</a>
        </div>
        <div class="case-study-wrap">
          <a href="/en/zkusenosti" class="case-study-card">
            <img src="/fleppi-study-v2.webp" alt="Email strategy for fleppi.cz" class="case-study-img" loading="lazy" />
            <div class="case-study-label">
              <span class="case-tag">CASE STUDY</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4 steps -->
  <section class="section bg-secondary" id="how-it-works">
    <div class="container">
      <h2 class="section-title-center"><strong>4 steps</strong> to a finished strategy</h2>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card">
            <h3 class="step-num">{s.num}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- For whom -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title-center">This service is for you, <span class="text-action">if...</span></h2>
      <ul class="for-who-list">
        {forWho.map((f) => (
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Find out where -->
  <section class="section-mid bg-secondary">
    <div class="container">
      <h2 class="section-title-center">Find out where your store is losing customers<br />and how to turn it around</h2>
      <p class="section-text-center">Tell us what you want to understand and what you are working with. Leave the rest to us.</p>
    </div>
  </section>

  <!-- Related -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Other services</h2>
      <ul class="related-services">
        {relatedServices.map((s) => (
          <li>
            <a href={s.href} class="related-link">
              <span>{s.label}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>I want an analysis —<br />calling, writing!</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading { font-size: clamp(32px, 4vw, 52px); font-weight: 700; line-height: 1.15; margin-bottom: var(--space-40); }
  .text-action { color: var(--action); }
  .intro-h2 { font-size: clamp(40px, 6vw, 80px); font-weight: 700; line-height: 1.1; margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-text { font-size: clamp(16px, 1.4vw, 20px); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .intro-btn { display: inline-flex; align-items: center; padding: 14px 32px; background: #fff; color: var(--brand-dark); font-family: var(--font-primary); font-size: 15px; font-weight: 700; text-transform: uppercase; border-radius: var(--radius-md); transition: background var(--transition-base), transform var(--transition-base); margin-top: var(--space-16); }
  .intro-btn:hover { background: rgba(255,255,255,0.88); transform: translateY(-1px); }
  .btn-action { display: inline-flex; padding: 16px 40px; background: var(--action); color: #000; font-family: var(--font-primary); font-size: 15px; font-weight: 700; border-radius: var(--radius-md); text-decoration: none; margin-top: var(--space-32); transition: background var(--transition-base); }
  .btn-action:hover { background: var(--action-hover); }

  .section { padding: var(--space-120) 0; }
  .section-mid { padding: var(--space-80) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: clamp(32px, 5vw, 70px); font-weight: 600; margin-bottom: var(--space-40); }
  .section-title-center { font-size: clamp(24px, 3vw, 40px); font-weight: 600; margin-bottom: var(--space-40); text-align: center; }
  .section-text { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: var(--space-24); }
  .section-text-center { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; text-align: center; max-width: 600px; margin: 0 auto; }
  .section-link { color: var(--action); font-size: 15px; font-weight: 600; text-decoration: none; }
  .section-link:hover { opacity: 0.75; }

  .two-col-analyze { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .analyze-label { font-family: var(--font-primary); font-size: 12px; font-weight: 700; letter-spacing: 0; color: var(--action); text-transform: uppercase; margin-bottom: var(--space-24); }
  .analyze-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .analyze-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.5; }
  .analyze-list svg { flex-shrink: 0; margin-top: 2px; }

  .output-col { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .deliverables-list { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: var(--space-32); }
  .deliverables-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.5; }
  .deliverables-list svg { flex-shrink: 0; margin-top: 2px; }

  .case-study-wrap { display: flex; }
  .case-study-card { display: block; text-decoration: none; border-radius: var(--radius-md); overflow: hidden; background: var(--bg-secondary); transition: transform var(--transition-base); }
  .case-study-card:hover { transform: translateY(-4px); }
  .case-study-img { display: block; width: 100%; height: auto; }
  .case-study-label { padding: var(--space-16); }
  .case-tag { font-size: 11px; font-weight: 700; letter-spacing: 0; color: var(--action); text-transform: uppercase; }

  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-24); }
  .step-card { background: var(--bg-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .step-num { font-size: 15px; font-weight: 700; color: var(--text-primary); margin-bottom: var(--space-12); }
  .step-card p { font-size: 14px; color: var(--neutral-300); line-height: 1.6; }

  .for-who-list { list-style: none; display: flex; flex-direction: column; gap: 16px; max-width: 640px; margin: 0 auto; }
  .for-who-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.8); line-height: 1.5; }
  .for-who-list svg { flex-shrink: 0; margin-top: 2px; }

  .related-services { list-style: none; display: flex; flex-direction: column; }
  .related-link { display: flex; align-items: center; justify-content: space-between; padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 15px; color: var(--neutral-300); transition: color var(--transition-base); text-decoration: none; }
  .related-link:hover { color: var(--action); }

  .testimonials-label { font-size: clamp(18px, 2vw, 24px); font-weight: 600; margin-bottom: var(--space-40); text-align: center; }
  .testimonials-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-40); }
  .testimonial-card { background: rgb(232, 222, 255); border-radius: var(--radius-md); padding: var(--space-32); }
  .testimonial-text { font-size: 15px; color: #1a1a2e; line-height: 1.7; margin-bottom: var(--space-16); font-style: italic; }
  .testimonial-author { font-size: 14px; color: #1a1a2e; opacity: 0.85; }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.1; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--brand-dark); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 1024px) {
    .two-col-analyze { grid-template-columns: 1fr; }
    .output-col { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .case-study-wrap { display: none; }
    .testimonials-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
