---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const analyzeItems = [
  'Email marketing — Leadhub, Klaviyo, Mailchimp, Ecomail and others. Campaigns, automations, segments, open rate, CTR, revenue per email.',
  'E-commerce platform — Shoptet, Shopify, WooCommerce — orders, customers, products, seasonality, retention, AOV.',
  'Google Analytics / GA4 — Traffic sources, conversion paths, attribution model, channel performance, user behaviour.',
  'Google Ads — Campaign performance, ROAS, search terms, lost impressions, opportunities to scale or save.',
  'Meta Ads — Facebook & Instagram — reach, frequency, CPM, ROAS, audience overlap, funnel analysis.',
  'Web crawling — If the data is not in an export — we crawl the store or website automatically and extract the product catalogue, prices, categories, UX patterns.',
];

const deliverables = [
  'Key metrics overview — 24-month horizon, year-on-year comparison, trend identification',
  'Root cause analysis of growth or decline — what works, what does not and why',
  'Campaign and automation performance overview — cross-sell opportunities, customer segmentation',
  'Cross-sell opportunities and shopping basket analysis — what customers buy and when',
  'Cross-sell mapping / CRM — email campaigns, flows, Klaviyo vs customers, competitive metrics',
  'Segmentation recommendations — RFM models, customer retention, churn prevention',
  'SEO and integrations — email campaigns, flows, Klaviyo vs customers, competitive metrics',
  'Marketing strategy beyond email — 40 specific tasks that will deliver results',
];

const forWho = [
  'Your store generates data but you lack the capacity or know-how to read it properly',
  'You suspect your emails, ads or flows could perform better — but do not know how to do it',
  'You need a specific action plan with clear prioritisation, not generic recommendations',
  'You are deciding where to invest your marketing budget in the next year',
];

const steps = [
  { num: '1. Data connection', desc: 'Send us exports or API access to your platforms. No access? We will help — we can send you CSV files or pull the data ourselves. Everything is handled discreetly.' },
  { num: '2. Analysis', desc: 'We go through the data in depth: orders, campaigns, customers. Typically 1–3 days depending on data volume.' },
  { num: '3. Live collaboration', desc: 'We go through the results with you in real time. You add context, we answer questions — the result is a bespoke strategy with nothing superfluous, no templates.' },
  { num: '4. Strategy document + plan', desc: 'You receive a clear online strategy document with a complete analysis and a clickable 365-day plan. Prepared online, accessible any time.' },
];

---

<PageLayout title="Analytics & Strategy | aethero" description="Stop guessing — find out why your store is not growing. We connect your data and deliver a strategy that works right away." lang="en">
  <ServiceHero
    lang="en"
    label="Analytics & Strategy"
    title="ANALYTICS<br /><span style='color:#fff'>& STRATEGY</span>"
    subtitle="Do you know why your store is growing? And why it sometimes is not? We connect your data, apply AI + context — and the results are truly impressive."
    ctaLabel="Let's talk"
    ctaHref="tel:+420776067663"
    cta2Label="Find out how"
    cta2Href="#how-it-works"
    image="/aethero-gradient-222.png"
    imageAlt="Strategy and analytics for an e-shop"
  />

  <!-- Stop guessing -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="intro-h2">Stop guessing,<br /><span class="accent-purple">FIND OUT WHY</span></h2>
      <p class="intro-text">Your store is telling you something. <strong class="hl">Are you listening?</strong> Every store has a story hidden inside its data — where it earns, where it bleeds, why some customers stay and others disappear after the first purchase. <strong class="hl">You already have that data — nobody is reading it.</strong> And someone should.</p>
      <p class="intro-text">It takes experience and a bit of technical voodoo, but then we sit down with your data, plans and a tamed AI, connect them to what is needed: Google Ads, Analytics, Meta and your email client — and <strong class="hl">hand you back a strategy with numbers against every recommendation</strong>: how much it will earn, how much it will save, when to switch it on.</p>
      <a href="#cta" class="btn-secondary">Want an analysis? Call or write</a>
    </div>
  </section>

  <!-- Your data says more -->
  <section class="section bg-primary">
    <div class="container">
      <div class="two-col-analyze">
        <div>
          <h2 class="section-title">Your data says more<br />than you think</h2>
          <p class="section-text body">API access, CSV exports or web crawling — we can connect almost any data source. We combine data from your store, email campaigns, Google Ads, Analytics and social media. And you then receive a specific strategy with the quantified benefit of each recommendation — no generic advice.</p>
          <p class="section-text body"><strong>We most often work with stores from €120k annual revenue on Shoptet, Shopify and WooCommerce.</strong></p>
          <a href="#how-it-works" class="text-link">What are those?</a>
        </div>
        <div>
          <h3 class="analyze-label">WHAT WE ANALYSE</h3>
          <ul class="analyze-list">
            {analyzeItems.map((a) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="testimonials-label">References from e-shop owners</h2>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-top">
            <a href="https://www.fleppi.cz" target="_blank" rel="noopener noreferrer" class="testimonial-logo-link">
              <img src="/ref-fleppi-logo.jpg" alt="fleppi" class="testimonial-logo testimonial-logo--light" />
            </a>
          </div>
          <p class="testimonial-text">"The output was well-crafted, clear and above all full of specific insights we can immediately use to drive further growth for our store. No generic recommendations — solutions tailored specifically to us."</p>
          <div class="testimonial-footer">
            <img src="/ref-lucie.jpg" alt="Lucie" class="testimonial-avatar" />
            <div class="testimonial-person">
              <strong>Lucie</strong>
              <span>Owner · <a href="https://www.fleppi.cz" target="_blank" rel="noopener noreferrer" class="text-link">fleppi.cz</a></span>
            </div>
            <div class="google-review">
              <svg class="google-g-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="Google">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              <div class="google-stars">★★★★★</div>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-top">
            <a href="https://bu1.cz" target="_blank" rel="noopener noreferrer" class="testimonial-logo-link">
              <img src="/ref-bu1-logo.svg" alt="BU1" class="testimonial-logo" />
            </a>
          </div>
          <p class="testimonial-text">"I am thrilled, because for the first time I have a complete picture of everything happening in the store, all in one place. The biggest thing is how the data connects with each other. I can see whether the content on the site actually engaged people and add info from the mailing — what people respond to best in emails. These overlaps, where I see the entire customer journey from search to purchase, allow me to make changes in Shopify that actually make sense."</p>
          <div class="testimonial-footer">
            <img src="/ref-petr.png" alt="Petr" class="testimonial-avatar" />
            <div class="testimonial-person">
              <strong>Petr</strong>
              <span>Owner · <a href="https://bu1.cz" target="_blank" rel="noopener noreferrer" class="text-link">BU1.cz</a></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Output / Case study -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="section-title-center">Output <span class="text-action">you can use straight away.</span></h2>
      <div class="output-col">
        <div>
          <p class="section-text body">No Excel tables that nobody opens. The result is a live strategy document available online — clear, specific, with a clickable action plan.</p>
          <ul class="deliverables-list">
            {deliverables.map((d) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{d}</span>
              </li>
            ))}
          </ul>
          <a href="/en/groomo-cz-na-shopify" class="text-link">OK, check out the examples</a>
        </div>
        <div class="case-study-wrap">
          <div class="case-study-card">
            <img src="/fleppi-study-v2.webp" alt="Email strategy for fleppi.cz" class="case-study-img" loading="lazy" />
            <a href="/en/pripadova-studie-email-marketing-fleppi-cz" class="case-study-cta">Read the<br/>case study</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4 steps -->
  <section class="section bg-primary" id="how-it-works">
    <div class="container">
      <h2 class="section-title-center"><strong>4 steps</strong> to a finished strategy</h2>
      <div class="steps-grid">
        {steps.map((s) => (
          <div class="step-card">
            <h3 class="step-num">{s.num}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- For whom -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="section-title-center">This service is for you, <span class="text-action">if...</span></h2>
      <ul class="for-who-list">
        {forWho.map((f) => (
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Find out where -->
  <section class="section-mid bg-primary">
    <div class="container">
      <h2 class="section-title-center">Find out where your store is losing customers<br />and how to turn it around</h2>
      <p class="section-text-center body">Tell us what you want to understand and what you are working with. Leave the rest to us.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>I want an analysis —<br />calling, writing!</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading { font-size: var(--fs-52); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-40); }
  .text-action { color: #fff; }
  .intro-h2 { font-size: var(--fs-80); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-text { font-size: var(--fs-20); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .section { padding: var(--space-120) 0; }
  .section-mid { padding: var(--space-80) 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }
  .section-title { font-size: var(--fs-70); font-weight: 600; margin-bottom: var(--space-40); }
  .section-title-center { font-size: var(--fs-48); font-weight: 600; margin-bottom: var(--space-40); text-align: center; }
  .section-text { margin-bottom: var(--space-24); }
  .section-text-center { text-align: center; max-width: 600px; margin: 0 auto; }

  .two-col-analyze { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .analyze-label { font-family: var(--font-primary); font-size: 14px; font-weight: 700; letter-spacing: 0; color: rgba(255,255,255,0.55); text-transform: uppercase; margin-bottom: var(--space-24); }
  .analyze-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .analyze-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.5; }
  .analyze-list svg { flex-shrink: 0; margin-top: 2px; }

  .output-col { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .deliverables-list { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: var(--space-32); }
  .deliverables-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.5; }
  .deliverables-list svg { flex-shrink: 0; margin-top: 2px; }

  .case-study-wrap { display: flex; }
  .case-study-card { position: relative; border-radius: var(--radius-md); overflow: hidden; }
  .case-study-img { display: block; width: 100%; height: auto; }
  .case-study-cta {
    position: absolute; bottom: 20px; left: 20px; right: 20px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center; padding: 14px 20px;
    background: rgba(255,255,255,0.18); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.45);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 24px rgba(0,0,0,0.2);
    color: #000326; font-family: var(--font-primary); font-size: 16px; font-weight: 600;
    text-transform: uppercase; text-align: center; line-height: 1.4; text-decoration: none;
    transition: background var(--transition-base), border-color var(--transition-base);
  }
  .case-study-cta:hover { background: rgba(255,255,255,0.28); border-color: rgba(255,255,255,0.65); }
  .case-tag { font-size: 14px; font-weight: 700; letter-spacing: 0; color: rgba(255,255,255,0.55); text-transform: uppercase; }

  .steps-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-24); }
  .step-card { background: var(--ae-bg-primary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .step-num { font-size: 16px; font-weight: 700; color: var(--text-primary); margin-bottom: var(--space-12); }
  .step-card p { font-size: 14px; color: var(--neutral-300); line-height: 1.6; }

  .for-who-list { list-style: none; display: flex; flex-direction: column; gap: 16px; max-width: 640px; margin: 0 auto; }
  .for-who-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.5; }
  .for-who-list svg { flex-shrink: 0; margin-top: 2px; }

  .testimonials-label { font-size: var(--fs-24); font-weight: 600; margin-bottom: var(--space-40); text-align: center; }
  .testimonials-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: stretch; }
  .testimonial-card {
    background: var(--card-button);
    border-radius: var(--radius-md);
    padding: 48px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .testimonial-top { display: flex; align-items: center; gap: 16px; padding-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .testimonial-footer { display: flex; align-items: center; gap: 20px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08); }
  .google-review { display: flex; flex-direction: column; align-items: center; gap: 4px; margin-left: auto; flex-shrink: 0; }
  .google-g-icon { width: 28px; height: 28px; display: block; }
  .google-stars { color: #FABB05; font-size: 18px; letter-spacing: 1px; line-height: 1; }
  .testimonial-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top center;
    flex-shrink: 0;
    border: 3px solid rgba(255,255,255,0.15);
  }
  .testimonial-person { min-width: 0; }
  .testimonial-person strong { display: block; font-size: 22px; font-weight: 700; color: #fff; line-height: 1.3; }
  .testimonial-person span { display: block; font-size: 16px; color: rgba(255,255,255,0.5); margin-top: 6px; }
  .testimonial-text {
    font-size: 18px;
    color: rgba(255,255,255,0.85);
    line-height: 1.75;
    font-style: italic;
    font-family: var(--font-secondary);
    margin: 0;
    flex: 1;
  }
  .testimonial-logo-link { display: inline-flex; flex-shrink: 0; }
  .testimonial-logo { height: 67px; width: auto; max-width: 194px; object-fit: contain; flex-shrink: 0; }
  .testimonial-logo--light { background: rgba(255,255,255,0.95); border-radius: 8px; padding: 0; width: 160px; height: 120px; object-fit: cover; object-position: center; }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: var(--fs-70); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 1024px) {
    .two-col-analyze { grid-template-columns: 1fr; }
    .output-col { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: repeat(2, 1fr); }
    .case-study-wrap { display: none; }
    .testimonials-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
