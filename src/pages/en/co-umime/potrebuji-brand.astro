---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const workCards = [
  { icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>', title: 'Brand, Identity, DX', desc: 'Brand, colours, fonts, the entire digital experience — a coherent whole that makes sense to people and to your store.' },
  { icon: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>', title: 'Theme', desc: 'Professional selection and configuration of a Shopify theme. Speed, CTAs, layouts, blocks, variants and brand alignment.' },
  { icon: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>', title: 'Content & presentation', desc: 'Visual and content foundations. Brand templates, product content and launch visuals tied to the store.' },
  { icon: '<polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>', title: 'Functionality & conversion', desc: 'Product pages, collections, upsell, cross-sell and UX logic. We design Shopify to sell — not just to look good.' },
  { icon: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>', title: 'Growth through marketing', desc: 'Preparation for performance campaigns and expansion. SEO, analytics, localisation, marketing tool integration and further growth.' },
];

---

<PageLayout title="I need a brand | aethero" description="We build brands that resonate across cultures. Brand, visual identity and digital experience for your Shopify store." lang="en">
  <ServiceHero
    lang="en"
    label="Brand & Identity"
    title="I need a <span style='color:#fff'>BRAND</span>"
    subtitle="And through it — a place in the minds and hearts of customers"
    ctaLabel="Let's talk"
    ctaHref="tel:+420776067663"
    ctaLower={true}
    image="/triangle.webp"
    imageAlt="Brand and visual identity"
  />

  <!-- Intro hero text -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="h1 intro-h2">We build <span class="accent-purple">BRANDS</span> that<br />resonate across cultures</h2>
      <p class="intro-text">Building an e-commerce business? <strong class="hl">Create your brand and go all in.</strong> Put yourself out there! Your brand will be your shield and armour. In an age of hyper-competition, <strong class="hl">you have around 2 seconds of your customer's attention.</strong> You need to <strong>captivate right from the start</strong> — then be straightforward, clear, consistent, and memorable.</p>
      <p class="intro-text"><strong class="hl">The ultimate solution we offer is building a rock-solid brand together.</strong> It's neither easy nor cheap — but it's a proven path that works.</p>
      <a href="#cta" class="btn-action btn-action--lg">Let's do it</a>
    </div>
  </section>

  <!-- Brand pillar + work sidebar -->
  <section class="section bg-primary">
    <div class="container brand-layout">
      <div class="brand-main">
        <h3 class="h2 pillar-heading">BRAND is the first pillar of your success.</h3>
        <div class="brand-text-col">
          <p class="section-text body">You might wonder why we are talking about something that seems so ordinary, even basic — BRAND? Because you can intentionally build it small and simple, but you must never build it wrong and then show it to the world. Here, the rule applies in full: you will not get a second chance to make a first impression.</p>
          <p class="section-text body">Your BRAND is the energy of the entire e-commerce machine. And just like electricity, it will not forgive a serious mistake. BRAND is an absolutely essential ingredient — you need to take it seriously if you want to succeed.</p>
          <p class="section-text body">Name, symbol — logo, domain, typography, colours... That is the part that is easy to talk about, yet so much harder to get right. And then there is the second area — the parts of the brand that can be described in lofty terms, but which emerge from deeper insight and feeling, and must be encoded into the company through a consistent approach to the brand: communication, values, vision, internal culture, people's motivation (the kind that will shine through in the long-term success of the company) and much more.</p>
        </div>
        {/* Ogilvy quote — temporarily hidden on request, ready to restore:
        <blockquote class="quote ogilvy-quote">"A brand is what remains when the factory burns down..." <cite>— David Ogilvy</cite></blockquote>
        */}
      </div>
      <aside class="work-aside">
        <h2 class="h2-mini work-heading">WHAT WE CAN — WORK ON TOGETHER</h2>
        <div class="work-list">
          {workCards.map((c) => (
            <div class="work-item">
              <div class="work-item-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon}></svg></div>
              <div class="work-item-text">
                <h3 class="work-item-title">{c.title}</h3>
                <p class="work-item-desc">{c.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <!-- Muhtar Kent quote -->
  <section class="section bg-primary quote-section">
    <div class="container">
      <blockquote class="quote-display">"A brand is a promise.<br />And a great brand<br />is a promise kept."<cite>— Muhtar Kent</cite></blockquote>
    </div>
  </section>

  <!-- Why you should not do it alone -->
  <section class="section bg-primary">
    <div class="container analogy-split">
      <div class="analogy-ref">
        <div class="ref-card">
          <img src="/groomo-ref-na-vysku.webp" alt="GROOMO — aethero reference" class="ref-img" loading="lazy" />
          <a href="/en/groomo-cz-na-shopify" class="ref-card-cta">Read the<br/>case study</a>
        </div>
      </div>
      <div class="analogy-text">
        <h3 class="h2-mini analogy-heading">And why do we think you definitely should not do this alone?</h3>
        <p class="section-text body">Building a brand is like building a new house. At first glance, everything seems obvious to everyone. After all, everyone knows there will be a kitchen and a bathroom. But it is only when you start figuring out "how to fit out that kitchen, connect it to the dining room, and at the same time find the right tile style for the bathroom and the right type of bathtub..." — that is when it really gets demanding. And then you wish you had help at hand!</p>
        <p class="section-text body"><strong>And that is exactly why we are here.</strong></p>
        <a href="tel:+420776067663" class="btn-action">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Brand, design — shall we talk?<br />Get in touch</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }
  .section-title { font-size: var(--fs-70); font-weight: 600; margin-bottom: var(--space-40); }
  .section-text { margin-bottom: var(--space-24); max-width: 760px; }

  .intro-h2 { margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .intro-text { font-size: var(--fs-20); color: rgba(255,255,255,0.85); line-height: 1.6; margin-bottom: var(--space-24); max-width: 860px; }
  /* .hl (bold lavender) — globální utilita v global.css */
  .pillar-heading { margin-bottom: var(--space-40); color: #fff; }
  .brand-text-col { max-width: 760px; }

  .ogilvy-quote { margin-top: var(--space-64); }

  /* Brand pillar + work sidebar = 2 columns */
  .brand-layout { display: grid; grid-template-columns: 1fr 355px; gap: var(--space-64); align-items: start; }
  .brand-main { min-width: 0; }
  .work-aside {
    background: var(--ae-bg-deep);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: var(--radius-md); padding: var(--space-32);
  }
  .work-heading { font-size: var(--fs-18); font-weight: 700; letter-spacing: 0.08em; margin-bottom: var(--space-24); color: #fff; text-transform: uppercase; line-height: 1.3; padding-left: calc(42px + var(--space-16)); }
  .work-list { display: flex; flex-direction: column; gap: var(--space-32); }
  .work-item { display: flex; gap: var(--space-16); align-items: flex-start; }
  .work-item-icon {
    flex-shrink: 0; width: 42px; height: 42px;
    display: grid; place-items: center; border-radius: 10px;
    color: var(--text-secondary);
    background: rgba(160,129,209,0.12);
    border: 1px solid rgba(160,129,209,0.28);
  }
  .work-item-icon svg { width: 22px; height: 22px; display: block; }
  .work-item-title { font-size: 15px; font-weight: 700; color: var(--text-secondary); margin-bottom: var(--space-8); }
  .work-item-desc { font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.55; }

  .analogy-split { display: grid; grid-template-columns: 420px 1fr; gap: 60px; align-items: center; }
  .analogy-text { max-width: 700px; }
  .analogy-heading { font-size: var(--fs-32); font-weight: 700; margin-bottom: var(--space-32); }
  .analogy-ref { display: flex; justify-content: center; }
  .ref-card { position: relative; max-width: 380px; width: 100%; border-radius: 6px; overflow: hidden; }
  .ref-img { width: 100%; display: block; }
  .ref-card-cta {
    position: absolute; bottom: 30px; left: 30px; right: 30px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    padding: 18px 24px;
    background: rgba(255,255,255,0.18);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.45);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 24px rgba(0,0,0,0.2);
    color: #000326;
    font-family: var(--font-primary); font-size: 16px; font-weight: 600;
    text-transform: uppercase; text-align: center; line-height: 1.4;
    text-decoration: none;
    transition: background var(--transition-base), border-color var(--transition-base);
  }
  .ref-card-cta:hover { background: rgba(255,255,255,0.28); border-color: rgba(255,255,255,0.65); color: #000326; }
  @media (max-width: 900px) {
    .analogy-split { grid-template-columns: 1fr; gap: var(--space-40); }
    .ref-img { max-width: 300px; margin: 0 auto; }
  }

  .quote-section { padding: var(--space-40) 0; margin-top: calc(-1 * var(--space-80)); }
  /* kontrastní citát: styl z globálního .quote-display */

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: var(--fs-70); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 900px) {
    .brand-layout { grid-template-columns: 1fr; gap: var(--space-40); }
  }
</style>
