---
import PageLayout from '../../../layouts/PageLayout.astro';

const services = [
  {
    num: '01',
    numImg: '/no-01.svg',
    anchor: 'brand',
    title: 'We breathe design! We create <span class="t-ac">SHOPIFY&nbsp;BRANDS</span> with&nbsp;DX that customers never forget!',
    desc: '<strong class="ac">YOUR STORE\'S BRAND</strong> — personality, story, emotion and promise connected to you, and <strong class="ac">Digital Experience:</strong> everything the world discovers when it looks you up online. Whether that\'s an ad, a video, a banner, a LinkedIn photo or a forgotten tweet — we can create and align it all.',
    cta: 'I want to know more',
    href: '/en/co-umime/potrebuji-brand',
  },
  {
    num: '02',
    numImg: '/no-02.svg',
    anchor: 'new-store',
    title: 'We build great <a href="/en/co-umime/novy-shopify-e-shop" class="t-ac">SHOPIFY STORES</a> — from design and setup, through launch, to long-term support.',
    desc: '<strong class="ac">Choose Shopify – the best tool available.</strong> No limits on where you sell or in how many currencies. A platform with incredible scalability, support and momentum. Shopify is built to grow with you from&nbsp;StartUp to international mega-project.',
    cta: 'Alright, tell me more',
    href: '/en/co-umime/novy-shopify-e-shop',
  },
  {
    num: '03',
    numImg: '/no-03.svg',
    anchor: 'migration',
    title: 'We\'ll kick off your <span class="t-ac">SHOPIFY&nbsp;MIGRATION</span>. We understand it\'s a big decision and nothing can go wrong.',
    desc: '<strong class="ac">Sure, the better you\'re doing now, the bigger the risk.</strong> But don\'t worry — we have multiple ways to handle everything safely. And it\'s worth exploring. From SEO analysis through redirect maps, UX design, all the way to data and system integrations including a direct line to Shopify.',
    cta: 'Show me how',
    href: '/en/co-umime/prechod-na-shopify',
  },
  {
    num: '04',
    numImg: '/no-04.svg',
    anchor: 'expansion',
    title: 'Planning <span class="t-ac">INTERNATIONAL&nbsp;EXPANSION</span>? Got a plan? Let\'s refine it together and leverage what Shopify offers.',
    desc: 'Cross-border e-commerce is growing 18&nbsp;% annually. The fact that your home market is doing well is great — but why stop there? <strong class="ac">If your domestic market isn\'t enough, let\'s expand together</strong> with Shopify Markets — one admin for all markets, currencies, languages and taxes.',
    cta: 'Show me how',
    href: '/en/co-umime/expanze-do-zahranici',
  },
  {
    num: '05',
    numImg: '/no-05.svg',
    anchor: 'support',
    title: '<span class="t-ac">DEVELOPMENT &amp; SUPPORT</span> — whether you need technical help, a plan, or just extra hands, we\'re here.',
    desc: 'We know not every problem has a solution in a tutorial or a video — sometimes you need deeper technical insight and experience from multiple real projects to find the right path forward. <strong class="ac">Get in touch and we\'ll find the solution together.</strong>',
    cta: 'OK, I need help',
    href: '/en/co-umime/rozvoj-a-podpora',
  },
  {
    num: '06',
    numImg: '/no-06.svg',
    anchor: 'analytics',
    title: '<span class="t-ac">ANALYTICS &amp; STRATEGY</span> — stop guessing. Find out why.',
    desc: 'Your store\'s data tells you more than you think. We analyse GA4, ads, emails and deliver a strategy with concrete next steps. <strong class="ac">Clear numbers, clear priorities, clear plan.</strong>',
    cta: 'I want an audit',
    href: '/en/co-umime/analyza-a-strategie',
  },
  {
    num: '07',
    numImg: '/no-07.svg',
    anchor: 'custom',
    title: '<span class="t-ac">CUSTOM DEVELOPMENT &amp; APPS</span> — when you need something new, local, or complex that no app currently solves.',
    desc: 'This part of our work is, on one hand, wonderfully simple to explain — and quite unpredictable on the other. <strong class="ac">In an ideal scenario you come to us with a problem definition and leave with a solution&nbsp;:o)</strong> Somewhere in between, we find or build that solution and you pay.',
    cta: 'Let\'s go',
    href: '/en/co-umime/custom-vyvoj-a-aplikace',
  },
];

---

<PageLayout
  title="What We Do — Shopify Services"
  description="Full-cycle Shopify services: brand, new store, migration, international expansion, support, custom development."
  lang="en"
>

  <!-- HERO -->
  <section class="co-hero">
    <div class="co-hero-bg"></div>
    <div class="co-hero-overlay"></div>
    <div class="container co-hero-inner">
      <h1>What we do</h1>
      <p class="co-hero-sub">Choose an area that interests you, get in touch.</p>
      <a href="#cta" class="btn-hero">Let's get started</a>
    </div>
  </section>

  <!-- SERVICES -->
  {services.map((s, i) => (
    <section class={`svc-section ${i % 2 === 0 ? 'svc-even' : 'svc-odd'}`} id={s.anchor}>
      <div class="container svc-grid">
        <div class="svc-num-col">
          {s.numImg
            ? <img src={s.numImg} alt={`${s.num}`} class="svc-num-img" width="470" height="212" loading="lazy" />
            : <span class="svc-num-text">{s.num}</span>
          }
        </div>
        <div class="svc-text-col">
          <h2 class="svc-title" set:html={s.title} />
          <p class="svc-desc body" set:html={s.desc} />
          <a href={s.href} class="btn-secondary">{s.cta}</a>
        </div>
      </div>
    </section>
  ))}

  <!-- APPS -->
  <section class="apps-section">
    <div class="container">
      <h2 class="section-label">APPS</h2>
      <div class="apps-grid">
        <a href="/en/esyncer" class="app-card">
          <div class="app-card-header" style="background-image: url('/header-image-esyncer.webp')"></div>
          <div class="app-card-body">
            <img src="/es-sipky.svg" alt="eSyncer" class="app-logo" />
            <h3>eSyncer</h3>
            <p>Product data import, sync & automation for Shopify and beyond.</p>
            <span class="app-link">Learn more about eSyncer →</span>
          </div>
        </a>
        <a href="/en/ae-translator" class="app-card">
          <div class="app-card-header" style="background-image: url('/ae-translator-hero.webp')"></div>
          <div class="app-card-body">
            <img src="/ae-translate-znak.svg" alt="AE Translator" class="app-logo" />
            <h3>AE Translator</h3>
            <p>AI-powered Shopify content translation. DeepL, Claude or DeepSeek — your choice.</p>
            <span class="app-link">Learn more about AE Translator →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Have something to discuss?<br />Get in touch.</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* ─── HERO ─── */
  .co-hero {
    position: relative;
    min-height: 68vh;
    overflow: hidden;
    background: #000326;
  }
  .co-hero-bg {
    position: absolute; inset: 0;
    background-image: url('/a-multitvar-bgr-v33.webp');
    background-size: cover;
    background-position: 52% 100%;
  }
  .co-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(1,0,19,0) 60%, #000326 95%);
  }
  .co-hero-inner {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
  }
  .co-hero h1 {
    font-size: clamp(56px, 7.8vw, 100px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 20px;
  }
  .co-hero-sub {
    font-family: var(--font-secondary);
    font-size: clamp(18px, 1.8vw, 22px);
    font-weight: 400;
    color: rgba(255,255,255,0.85);
    line-height: 1.5;
    margin-bottom: 36px;
  }

  /* ─── SERVICE SECTIONS ─── */
  .co-hero + .svc-section { padding-top: 24px; }
  .svc-section {
    padding: 100px 0;
  }
  .svc-section:nth-child(odd) { background: var(--ae-bg-primary); }
  .svc-section:nth-child(even) { background: #000326; }

  .svc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .svc-even .svc-num-col { order: 1; }
  .svc-even .svc-text-col { order: 2; }
  .svc-odd .svc-num-col { order: 2; }
  .svc-odd .svc-text-col { order: 1; }

  .svc-num-img {
    width: 100%;
    max-width: 470px;
    height: auto;
    display: block;
  }
  .svc-even .svc-num-img { margin-left: auto; }
  .svc-odd .svc-num-img { margin-right: auto; }
  #custom .svc-num-img { max-width: 423px; }

  .svc-num-text {
    font-family: var(--font-primary);
    font-size: clamp(80px, 12vw, 160px);
    font-weight: 700;
    line-height: 1;
    color: rgba(255,255,255,0.12);
    display: block;
  }

  .svc-title :global(.t-ac) {
    color: #fff;
    text-decoration: none;
  }
  .svc-title :global(a.t-ac) {
    color: var(--action);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }
  .svc-title {
    font-family: var(--font-primary);
    font-size: clamp(26px, 3.5vw, 48px);
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
    margin-bottom: 24px;
  }
  .svc-desc {
    margin-bottom: 32px;
  }
  .svc-desc :global(.ac) {
    color: var(--text-secondary);
    font-weight: 900;
  }
  /* ─── APPS ─── */
  .apps-section {
    background: var(--ae-bg-primary);
    padding: 100px 0;
  }
  .section-label {
    font-family: var(--font-primary);
    font-size: clamp(26px, 3.5vw, 48px);
    font-weight: 600;
    color: #fff;
    line-height: 1.2;
    text-align: center;
    margin-bottom: 40px;
  }
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .app-card {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s;
  }
  .app-card:hover { border-color: rgba(13,212,205,0.3); transform: translateY(-2px); }
  .app-card-header {
    height: 260px;
    background-size: cover;
    background-position: center top;
  }
  .app-logo {
    width: 56px;
    height: 56px;
    object-fit: contain;
    display: block;
    margin-bottom: 16px;
  }
  .app-card-body { padding: 28px 32px 36px; flex: 1; display: flex; flex-direction: column; }
  .app-card-body h3 { font-size: clamp(20px, 2.5vw, 30px); font-weight: 600; margin-bottom: 10px; }
  .app-card-body p { font-size: 16px; color: var(--neutral-300); line-height: 1.6; margin-bottom: 20px; flex: 1; }
  .app-link { color: var(--action); font-size: 15px; font-weight: 500; }

  /* ─── CTA ─── */
  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity 0.2s; }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .svc-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .svc-even .svc-num-col,
    .svc-odd .svc-num-col { order: 1; }
    .svc-even .svc-text-col,
    .svc-odd .svc-text-col { order: 2; }
    .svc-num-img { max-width: 280px; }
    .svc-section { padding: 60px 0; }
    .apps-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .co-hero { min-height: 60vh; }
    .co-hero-inner { padding-bottom: 48px; }
    .svc-num-img { max-width: 200px; }
    .svc-section { padding: 48px 0; }
  }
</style>
