---
import PageLayout from '../../../layouts/PageLayout.astro';

const services = [
  {
    num: '01',
    numImg: '/no-01.svg',
    anchor: 'brand',
    title: 'We breathe design! We create SHOPIFY&nbsp;BRANDS with&nbsp;DX that customers never forget!',
    desc: '<strong class="ac">YOUR STORE\'S BRAND</strong> — personality, story, emotion and promise connected to you, and <strong class="ac">Digital Experience:</strong> everything the world discovers when it looks you up online. Whether that\'s an ad, a video, a banner, a LinkedIn photo or a forgotten tweet — we can create and align it all.',
    cta: 'I want to know more ➝',
    href: '/en/co-umime/potrebuji-brand',
  },
  {
    num: '02',
    numImg: '/no-02.svg',
    anchor: 'new-store',
    title: 'We build great SHOPIFY stores — from design and setup, through launch, to long-term support.',
    desc: '<strong class="ac">Choose Shopify – the best tool available.</strong> No limits on where you sell or in how many currencies. A platform with incredible scalability, support and momentum. Shopify is built to grow with you from&nbsp;StartUp to international mega-project.',
    cta: 'Alright, tell me more ➝',
    href: '/en/co-umime/novy-shopify-e-shop',
  },
  {
    num: '03',
    numImg: '/no-03.svg',
    anchor: 'migration',
    title: 'We\'ll kick off your SHOPIFY&nbsp;MIGRATION. We understand it\'s a big decision and nothing can go wrong.',
    desc: '<strong class="ac">Sure, the better you\'re doing now, the bigger the risk.</strong> But don\'t worry — we have multiple ways to handle everything safely. And it\'s worth exploring. From SEO analysis through redirect maps, UX design, all the way to data and system integrations including a direct line to Shopify.',
    cta: 'Show me how ➝',
    href: '/en/co-umime/prechod-na-shopify',
  },
  {
    num: '04',
    numImg: '/no-04.svg',
    anchor: 'expansion',
    title: 'Planning INTERNATIONAL&nbsp;EXPANSION? Got a plan? Let\'s refine it together and leverage what Shopify offers.',
    desc: 'Cross-border e-commerce is growing 18&nbsp;% annually. The fact that your home market is doing well is great — but why stop there? <strong class="ac">If your domestic market isn\'t enough, let\'s expand together</strong> with Shopify Markets — one admin for all markets, currencies, languages and taxes.',
    cta: 'Show me how ➝',
    href: '/en/co-umime/expanze-do-zahranici',
  },
  {
    num: '05',
    numImg: '/no-05.svg',
    anchor: 'support',
    title: 'DEVELOPMENT &amp; SUPPORT — whether you need technical help, a plan, or just extra hands, we\'re here.',
    desc: 'We know not every problem has a solution in a tutorial or a video — sometimes you need deeper technical insight and experience from multiple real projects to find the right path forward. <strong class="ac">Get in touch and we\'ll find the solution together.</strong>',
    cta: 'OK, I need help ➝',
    href: '/en/co-umime/rozvoj-a-podpora',
  },
  {
    num: '06',
    numImg: '/no-06.svg',
    anchor: 'custom',
    title: 'CUSTOM DEVELOPMENT &amp; APPS — when you need something new, local, or complex that no app currently solves.',
    desc: 'This part of our work is, on one hand, wonderfully simple to explain — and quite unpredictable on the other. <strong class="ac">In an ideal scenario you come to us with a problem definition and leave with a solution&nbsp;:o)</strong> Somewhere in between, we find or build that solution and you pay.',
    cta: 'Let\'s go ➝',
    href: '/en/co-umime/custom-vyvoj-a-aplikace',
  },
  {
    num: '07',
    numImg: null,
    anchor: 'analytics',
    title: 'ANALYTICS &amp; STRATEGY — stop guessing. Find out why.',
    desc: 'Your store\'s data tells you more than you think. We analyse GA4, ads, emails and deliver a strategy with concrete next steps. <strong class="ac">Clear numbers, clear priorities, clear plan.</strong>',
    cta: 'I want an audit ➝',
    href: '/en/co-umime/analyza-a-strategie',
  },
];

const quickNav = [
  { label: 'BRAND', anchor: 'brand' },
  { label: 'NEW STORE', anchor: 'new-store' },
  { label: 'MIGRATION', anchor: 'migration' },
  { label: 'EXPANSION', anchor: 'expansion' },
  { label: 'SUPPORT', anchor: 'support' },
  { label: 'CUSTOM DEV', anchor: 'custom' },
];
---

<PageLayout
  title="What We Do — Shopify Services"
  description="Full-cycle Shopify services: brand, new store, migration, international expansion, support, custom development."
  lang="en"
>

  <!-- HERO -->
  <section class="co-hero">
    <div class="co-hero-bg"></div>
    <div class="co-hero-overlay"></div>
    <div class="container co-hero-inner">
      <h1>What we do</h1>
      <a href="#brand" class="co-hero-cta">So what shall we work on together?</a>
    </div>
  </section>

  <!-- QUICK NAV -->
  <nav class="quick-nav" aria-label="Jump to section">
    <div class="container">
      <ul class="quick-nav-list">
        {quickNav.map((item) => (
          <li><a href={`#${item.anchor}`} class="quick-nav-link">{item.label}</a></li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- SERVICES -->
  {services.map((s, i) => (
    <section class={`svc-section ${i % 2 === 0 ? 'svc-even' : 'svc-odd'}`} id={s.anchor}>
      <div class="container svc-grid">
        <div class="svc-num-col">
          {s.numImg
            ? <img src={s.numImg} alt={`${s.num}`} class="svc-num-img" width="470" height="212" loading="lazy" />
            : <span class="svc-num-text">{s.num}</span>
          }
        </div>
        <div class="svc-text-col">
          <h2 class="svc-title" set:html={s.title} />
          <p class="svc-desc" set:html={s.desc} />
          <a href={s.href} class="svc-cta">{s.cta}</a>
        </div>
      </div>
    </section>
  ))}

  <!-- APPS -->
  <section class="apps-section">
    <div class="container">
      <h2 class="section-label">APPS</h2>
      <div class="apps-grid">
        <a href="/en/esyncer" class="app-card">
          <h3>eSyncer</h3>
          <p>Product data import, sync & automation for Shopify and beyond.</p>
          <span class="app-link">Learn more about eSyncer →</span>
        </a>
        <a href="/en/ae-translator" class="app-card">
          <h3>AE Translator</h3>
          <p>AI-powered Shopify content translation. DeepL, Claude or DeepSeek — your choice.</p>
          <span class="app-link">Learn more about AE Translator →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Not sure where to start?<br /><span class="cta-accent">Let's talk.</span></h2>
      <div class="cta-links">
        <a href="mailto:info@aethero.cz" class="btn-primary">info@aethero.cz</a>
        <a href="/en/kontakt" class="btn-ghost">Contact</a>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* ─── HERO ─── */
  .co-hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: #171a1c;
  }
  .co-hero-bg {
    position: absolute; inset: 0;
    background-image: url('/a-multitvar-bgr-v33.webp');
    background-size: cover;
    background-position: 52% 100%;
  }
  .co-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(1,0,19,0) 60%, #000326 95%);
  }
  .co-hero-inner {
    position: absolute;
    bottom: 150px;
    left: 0;
    right: 0;
  }
  .co-hero h1 {
    font-size: clamp(56px, 7.8vw, 100px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 40px;
  }
  .co-hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border: 2px solid rgba(255,255,255,0.55);
    border-radius: var(--radius-sm);
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #fff;
    transition: border-color 0.2s, color 0.2s;
  }
  .co-hero-cta:hover { border-color: #fff; color: #fff; }

  /* ─── QUICK NAV ─── */
  .quick-nav {
    background: var(--bg-elevated);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 0;
  }
  .quick-nav-list {
    display: flex;
    list-style: none;
    flex-wrap: wrap;
    gap: 0;
    margin: 0; padding: 0;
  }
  .quick-nav-link {
    display: block;
    padding: 18px 20px;
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .quick-nav-link:hover { color: var(--action); }

  /* ─── SERVICE SECTIONS ─── */
  .svc-section {
    padding: 100px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .svc-section:nth-child(odd) { background: var(--bg-primary); }
  .svc-section:nth-child(even) { background: #000326; }

  .svc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .svc-even .svc-num-col { order: 1; }
  .svc-even .svc-text-col { order: 2; }
  .svc-odd .svc-num-col { order: 2; }
  .svc-odd .svc-text-col { order: 1; }

  .svc-num-img {
    width: 100%;
    max-width: 470px;
    height: auto;
    display: block;
  }
  .svc-even .svc-num-img { margin-left: auto; }
  .svc-odd .svc-num-img { margin-right: auto; }

  .svc-num-text {
    font-family: var(--font-primary);
    font-size: clamp(80px, 12vw, 160px);
    font-weight: 700;
    line-height: 1;
    color: rgba(255,255,255,0.12);
    display: block;
  }

  .svc-title {
    font-family: var(--font-primary);
    font-size: clamp(22px, 2.4vw, 36px);
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
    margin-bottom: 24px;
  }
  .svc-desc {
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255,255,255,0.75);
    margin-bottom: 32px;
  }
  .svc-desc .ac {
    color: var(--action);
    font-weight: 700;
  }
  .svc-cta {
    display: inline-flex;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    color: var(--action);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: opacity 0.2s;
  }
  .svc-cta:hover { opacity: 0.75; }

  /* ─── APPS ─── */
  .apps-section {
    background: var(--bg-secondary);
    padding: 100px 0;
  }
  .section-label {
    font-family: var(--font-primary);
    font-size: 12px;
    font-weight: 600;
    color: var(--action);
    text-transform: uppercase;
    margin-bottom: 40px;
  }
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .app-card {
    background: var(--bg-elevated);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
    padding: 40px;
    transition: border-color 0.2s;
  }
  .app-card:hover { border-color: rgba(13,212,205,0.3); }
  .app-card h3 { font-size: clamp(22px, 3vw, 40px); font-weight: 600; margin-bottom: 16px; }
  .app-card p { font-size: 18px; color: var(--neutral-300); line-height: 1.6; margin-bottom: 24px; }
  .app-link { color: var(--action); font-size: 16px; font-weight: 500; }

  /* ─── CTA ─── */
  .cta-section {
    background: var(--bg-primary-alt);
    padding: 100px 0;
  }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: clamp(32px, 5vw, 70px); font-weight: 600; margin-bottom: 40px; }
  .cta-accent { color: var(--action); }
  .cta-links { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: #fff;
    color: #000326;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    transition: background 0.2s;
  }
  .btn-primary:hover { background: rgba(255,255,255,0.88); }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    border: 2px solid rgba(255,255,255,0.55);
    color: #fff;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: #fff; color: #fff; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .svc-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .svc-even .svc-num-col,
    .svc-odd .svc-num-col { order: 1; }
    .svc-even .svc-text-col,
    .svc-odd .svc-text-col { order: 2; }
    .svc-num-img { max-width: 280px; }
    .svc-section { padding: 60px 0; }
    .apps-grid { grid-template-columns: 1fr; }
    .quick-nav-link { font-size: 12px; padding: 14px 12px; }
  }
  @media (max-width: 600px) {
    .co-hero { min-height: 60vh; }
    .co-hero-inner { padding-bottom: 48px; }
    .svc-num-img { max-width: 200px; }
    .svc-section { padding: 48px 0; }
    .quick-nav-link { font-size: 11px; padding: 12px 10px; }
  }
</style>
