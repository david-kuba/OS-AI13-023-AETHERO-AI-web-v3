---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const features = [
  { title: 'Technical support & troubleshooting', desc: 'We solve complex technical problems in Liquid templates, custom apps, Shopify Functions, checkout and connected services. We identify the root cause of errors — not just the symptoms.', img: '/support.jpg', reverse: false },
  { title: 'Feature expansion & custom development', desc: 'We develop custom modifications to order — advanced work with products, pricing, checkout, shipping and payment logic, including custom apps.', img: '/custom.webp', reverse: true },
  { title: 'Integrations & system architecture', desc: 'We design and deliver robust integrations with ERP, CRM, warehouse and logistics systems. We automate data flows and set up scalable architecture without vendor lock-in.', img: '/system1.webp', reverse: false },
  { title: 'Shopify Markets setup for international expansion', desc: 'Technical configuration of multiple markets, currencies, languages, domains, tax rules, shipping and local payments. We prepare your store for operation across countries without duplicating solutions.', img: '/shopify-international.webp', reverse: true },
  { title: 'Performance, stability & scaling', desc: 'We keep template performance, app load, Core Web Vitals and overall store stability in a state that handles high traffic and sales peaks.', img: '/vykon.webp', reverse: false },
  { title: 'Design & UX support with technical depth', desc: 'We help with design adjustments, UX optimisation and design system implementation directly in Shopify — from working with an existing theme to custom solutions, all aligned with the brand and technical best practices.', img: '/ux-we-do.webp', reverse: true },
  { title: 'Technical consulting & long-term support', desc: 'We are your technical partner for continuous development — from audits and code reviews to strategic decisions about the future direction of your Shopify solution.', img: '/longtime-support.jpg', reverse: false },
];

const relatedServices = [
  { href: '/en/co-umime/potrebuji-brand', label: 'I need a brand' },
  { href: '/en/co-umime/novy-shopify-e-shop', label: 'New Shopify store' },
  { href: '/en/co-umime/prechod-na-shopify', label: 'Migration to Shopify' },
  { href: '/en/co-umime/expanze-do-zahranici', label: 'International expansion' },
  { href: '/en/co-umime/analyza-a-strategie', label: 'Strategy & analytics' },
  { href: '/en/co-umime/custom-vyvoj-a-aplikace', label: 'Custom development & apps' },
];
---

<PageLayout title="Development & Support | aethero" description="Long-term technical partner for your Shopify project. We are here for support, development, integrations and strategy." lang="en">
  <ServiceHero
    lang="en"
    label="Development & Support"
    title="DEVELOPMENT<br /><span style='color:var(--action)'>& SUPPORT</span>"
    subtitle="Shopify project? We are ready where help is needed. Missing people, time, knowledge? Write, call."
    ctaLabel="Let's talk"
    ctaHref="tel:+420776067663"
    cta2Label="Find out how"
    cta2Href="#what-we-do"
    image="/lifebuoy.webp"
    imageAlt="Shopify development and support"
  />

  <!-- Intro -->
  <section class="section-intro bg-elevated">
    <div class="container">
      <h2 class="intro-heading"><span class="text-action">WHAT DO YOU NEED HELP WITH</span><br />on your Shopify project?</h2>
      <p class="intro-text"><strong>Sometimes searching videos to solve a problem simply is not enough — you need deeper technical insight, experience from multiple real projects and the ability to find broader connections.</strong></p>
      <p class="intro-text">We want you to know that even after several years we have not grown a big nose — and if we can help, we will.</p>
      <p class="intro-text">Developing and supporting Shopify projects does not end at store launch. We know that not every problem has a solution in a tutorial or video — often you need deeper technical insight, experience from real projects and the ability to find wider context.</p>
      <a href="#what-we-do" class="intro-link">Let's get to it ➝</a>
    </div>
  </section>

  <!-- What we will do for you -->
  <section class="section bg-secondary">
    <div class="container">
      <h2 class="section-title" id="what-we-do">What we can do for you as part of our technical support</h2>
    </div>
  </section>

  <!-- Feature sections -->
  {features.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          <h2 class="feature-title">{f.title}</h2>
          <p class="feature-desc">{f.desc}</p>
        </div>
        <div class="feature-img-wrap">
          <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />
        </div>
      </div>
    </section>
  ))}

  <!-- Related -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Other services</h2>
      <ul class="related-services">
        {relatedServices.map((s) => (
          <li>
            <a href={s.href} class="related-link">
              <span>{s.label}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Can we help?<br />Get in touch</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading { font-size: clamp(32px, 4vw, 52px); font-weight: 700; line-height: 1.15; margin-bottom: var(--space-40); max-width: 760px; }
  .text-action { color: var(--action); }
  .intro-text { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.75; max-width: 720px; margin-bottom: var(--space-24); }
  .intro-link { display: inline-block; margin-top: var(--space-24); color: var(--action); font-size: 16px; font-weight: 600; text-decoration: none; }
  .intro-link:hover { opacity: 0.75; }

  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: clamp(24px, 3vw, 40px); font-weight: 700; margin-bottom: var(--space-40); text-align: center; }

  .feature-section { padding: var(--space-120) 0; }
  .feature-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: center; }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text,
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-title { font-size: clamp(20px, 2.5vw, 30px); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); color: var(--action); }
  .feature-desc { font-size: 16px; color: rgba(255,255,255,0.75); line-height: 1.75; }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }
  .feature-img { width: 100%; max-width: 560px; height: auto; border-radius: var(--radius-md); display: block; }

  .related-services { list-style: none; display: flex; flex-direction: column; }
  .related-link { display: flex; align-items: center; justify-content: space-between; padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 15px; color: var(--neutral-300); transition: color var(--transition-base); text-decoration: none; }
  .related-link:hover { color: var(--action); }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.1; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--brand-dark); text-decoration: underline; text-underline-offset: 4px; transition: opacity var(--transition-base); }
  .cta-contact:hover { opacity: 0.7; }

  @media (max-width: 1024px) {
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
