---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const services = [
  { title: 'Technical Support', desc: 'Bug fixing in Liquid templates, custom apps and third-party integrations.' },
  { title: 'Feature Development', desc: 'Custom functionality built precisely to what your store needs.' },
  { title: 'System Integrations', desc: 'ERP, CRM, logistics platforms and invoicing systems connected seamlessly.' },
  { title: 'Shopify Markets', desc: 'Setup and management of international markets from one admin.' },
  { title: 'Performance Optimisation', desc: 'Speed, Core Web Vitals and scaling for growing traffic.' },
  { title: 'Design & UX Support', desc: 'Technical implementation of design changes and UX improvements.' },
  { title: 'Long-term Consulting', desc: 'Code reviews, architectural advice and strategic planning.' },
];
---

<PageLayout title="Development & Support" description="Long-term technical partner for your Shopify project. Launch is just the beginning." lang="en">
  <ServiceHero
    label="Development & Support"
    title="DEVELOPMENT<br /><span style='color:var(--action)'>& SUPPORT</span>"
    subtitle="Growing a Shopify project does not end at launch — it begins. We are here as your long-term technical partner."
  />

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">How we can help</h2>
      <div class="services-grid">
        {services.map((s) => (
          <div class="service-card">
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Let's keep it running</h2>
      <p>Tell us where you are and where you want to go — we will map out the path.</p>
      <div class="cta-links">
        <a href="mailto:info@aethero.cz" class="btn-primary">info@aethero.cz</a>
        <a href="tel:+420776067663" class="btn-ghost">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .section-title { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-40); }
  .services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-24); }
  .service-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-40); }
  .service-card h3 { font-size: 20px; font-weight: 600; color: var(--action); margin-bottom: var(--space-16); }
  .service-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .cta-section { padding: var(--space-120) 0; background: var(--bg-secondary); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-16); }
  .cta-inner p { color: var(--neutral-300); margin-bottom: var(--space-40); }
  .cta-links { display: flex; gap: var(--space-16); justify-content: center; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--bg-elevated); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: background var(--transition-base); }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: border-color var(--transition-base), color var(--transition-base); }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }
  @media (max-width: 768px) { .services-grid { grid-template-columns: 1fr; } }
</style>
