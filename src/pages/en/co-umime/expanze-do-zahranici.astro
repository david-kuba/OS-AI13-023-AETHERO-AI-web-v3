---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const features = [
  { title: 'Shopify Sidekick AI right in your store', logo: '/sidekick.png', desc: 'Sidekick is an AI assistant integrated into the store admin that significantly speeds up your work in Shopify. It can handle operational tasks (create products, edit collections, analyse sales, prepare reports), help with marketing (writing descriptions, emails) and advise based on your own data as well as general market knowledge.', img: null, reverse: false },
  { title: 'A powerful "admin"', desc: 'We won\'t sugarcoat it — building a store takes work, and even then the road to success is not easy. So you will spend a lot of time in the "admin". And it helps when it is clear and keeps up with you. The Shopify admin has it all: analytics, hints, AI that sees your data and can even advise based on general experience from elsewhere. And that is just the beginning.', img: '/analytika.webp', reverse: true },
  { title: 'Built for international selling', desc: 'Markets in Shopify handles local currency, payment methods and languages. Additional features help you give global customers a familiar shopping environment that demonstrably increases conversions. You can tune the theme, content, product selection and pricing per market. With Shop Pay you can offer their preferred payment methods and even adapt address formats to local conventions.', img: '/international-sale-shopify.webp', reverse: false },
  { title: 'Sophisticated benchmarking against others', desc: 'Shopify shows you via AI and built-in benchmarks how similar stores around the world are performing. So you can measure your performance more accurately and use the information to your advantage.', img: '/store-benchmark.webp', reverse: true },
  { title: 'Multichannel marketing', desc: 'Organise your marketing activities clearly across email, social media, advertising and organic traffic into cohesive campaigns. Clear per-channel reports help you better understand where customers come from, how much it costs to acquire them and what the return on your marketing investment is.', img: '/marketing-measurement.webp', reverse: false },
  { title: 'Real-time store data overview', desc: 'With Shopify you have an immediate overview of how your store is truly performing — without waiting for daily recalculations or limited reports. Data updates in real time across the whole dashboard and reports. Customise the view to exactly what is decisive for you and monitor key metrics at a glance.', img: '/real-time-monitoring.png', reverse: true },
  { title: 'B2B ready', desc: 'In Shopify Plus you will find native B2B functionality designed for companies with high order volume, complex pricing and individual business relationships. It enables working with company accounts, custom price lists, approval processes and recurring purchases in one unified solution. Want a smaller B2B solution? That is handled by an app or custom development.', img: '/b2b-1.webp', reverse: false },
  { title: 'Shopify SHOP app, on your customer\'s phone', desc: 'Thanks to the Shop app, your brand reaches directly into customers\' mobile devices all over the world. An ideal user experience. Customers can easily track orders, return to favourite products and make repeat purchases without having to go through the entire checkout process again.', img: '/shopify-shop-app.webp', reverse: true },
  { title: 'Automation', desc: 'With growing order volumes, manual management stops making sense. Automation lets you move key processes — from order and customer management through pricing and inventory to marketing scenarios — into controlled, predictable flows. The result is less dependence on manual intervention, lower error rates and the ability to scale without constantly growing the team.', img: '/flow-automation.webp', reverse: false },
];

---

<PageLayout title="International Expansion | aethero" description="One Shopify store, the whole world. We help you expand into international markets using Shopify Markets." lang="en">
  <ServiceHero
    lang="en"
    label="International Expansion"
    title="INTERNATIONAL<br /><span style='color:#fff'>EXPANSION</span>"
    subtitle="Time to go full throttle — Europe? The whole world? Absolutely, we are going in with you."
    ctaLabel="Let's talk"
    ctaHref="tel:+420776067663"
    cta2Label="Find out how"
    cta2Href="#expansion-why"
    image="/chain.webp"
    imageAlt="International expansion"
  />

  <!-- Intro -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="intro-h2">Do you have a plan for<br /><span class="accent-purple">INTERNATIONAL EXPANSION</span>?</h2>
      <p class="intro-text">With Shopify, we'll open the door to growth that <strong class="hl">simply isn't possible on local platforms</strong>. Take the decisive step forward into international markets and global e-commerce.</p>
      <p class="intro-text">You'll get <strong class="hl">one global platform built from the ground up for international selling</strong> — enabling multiple currencies, languages, and localised customer experiences.</p>
      <a href="#cta" class="btn-action btn-action--lg">Let's expand</a>
    </div>
  </section>

  <!-- Stats -->
  <section class="section bg-primary" id="expansion-why">
    <div class="container two-col">
      <div>
        <h2 class="section-title">What does expansion with Shopify bring you?</h2>
        <p class="section-text body">You have everything you need to turn your store into a true global brand. Here is just a partial list of features that might interest you.</p>
      </div>
      <div class="intro-highlights">
        <div class="highlight-item">
          <span class="highlight-num">30+</span>
          <span class="highlight-label">countries available via Shopify Markets from a single admin</span>
        </div>
        <div class="highlight-item">
          <span class="highlight-num">1</span>
          <span class="highlight-label">platform for the whole world — no migration when scaling</span>
        </div>
        <div class="highlight-item">
          <span class="highlight-num">100%</span>
          <span class="highlight-label">localisation — language, currency, payments, taxes for each market</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature sections -->
  {features.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          {f.logo && <img src={f.logo} alt={f.title} class="feature-logo" loading="lazy" />}
          <h2 class="feature-title">{f.title}</h2>
          <p class="body">{f.desc}</p>
        </div>
        <div class="feature-img-wrap">
          {f.img && <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />}
        </div>
      </div>
    </section>
  ))}

  <!-- You are in the right place -->
  <section class="section bg-primary">
    <div class="container" style="text-align: center; max-width: 720px; margin: 0 auto;">
      <h3 class="tady-heading">You are in the right place!</h3>
      <p class="body">When it comes to global expansion, the question is not whether — but when. Shopify gives you the technological foundation so you can focus on growth instead of working around platform limitations. Is now the right time, and do you want to take your store further with us?</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Shall we EXPAND?<br />Get in touch</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .intro-heading { font-size: var(--fs-52); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-40); }
  .intro-h2 { font-size: var(--fs-80); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-40); }
  /* .hl (bold lavender) — globální utilita v global.css */
  .intro-text { font-size: var(--fs-20); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .section { padding: var(--space-120) 0; }
  .section-title { font-size: var(--fs-36); font-weight: 600; margin-bottom: var(--space-40); }
  .section-text { margin-bottom: var(--space-24); }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .intro-highlights { display: flex; flex-direction: column; gap: var(--space-40); padding-top: var(--space-8); }
  .highlight-item { display: flex; flex-direction: column; gap: var(--space-8); border-left: 2px solid var(--action); padding-left: var(--space-24); }
  .highlight-num { font-size: 48px; font-weight: 700; color: #fff; line-height: 1; font-family: var(--font-primary); }
  .highlight-label { font-size: 16px; color: rgba(255,255,255,0.6); line-height: 1.5; }

  .feature-section { padding: var(--space-120) 0; }
  .feature-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: center; }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text,
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-logo { height: 48px; width: auto; display: block; margin-bottom: var(--space-24); object-fit: contain; }
  .feature-title { font-size: var(--fs-30); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); color: #fff; }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }
  .feature-img { width: 100%; max-width: 560px; height: auto; border-radius: var(--radius-md); display: block; }

  .tady-heading { font-size: var(--fs-48); font-weight: 600; margin-bottom: var(--space-24); }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner h2 { font-family: var(--font-primary); font-size: var(--fs-70); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 1024px) {
    .two-col { grid-template-columns: 1fr; }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
