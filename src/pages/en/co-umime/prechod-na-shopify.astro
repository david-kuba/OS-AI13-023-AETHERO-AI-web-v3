---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const checkItems = [
  'Multi-currency and multilanguage without plugins',
  'ERP, CRM and logistics integrations',
  'Preserving SEO and URL structure',
  'Online + offline via Shopify POS',
  'Process automation via Shopify Flow',
  'International expansion without platform migration',
];

const features = [
  { title: 'Multichannel integration', desc: 'Sell from a single admin across all channels — Instagram, TikTok, Google Shopping, Amazon. One warehouse, one source of truth for inventory, everything from the Shopify admin.', img: '/shopify-chanels.webp', reverse: false },
  { title: 'Social media integration', desc: 'Direct selling via Instagram, TikTok, Facebook and YouTube. Unified management of campaigns, products and orders from one place. Customers buy where they already are.', img: '/fbandinsta.webp', reverse: true },
  { title: 'Taxonomy and categorisation', desc: 'Advanced product organisation with Shopify product taxonomy — over 10,000 standardised categories. Better search, SEO and customer experience.', img: '/shopify-produkt-taxonomy.webp', reverse: false },
  { title: 'Show it to the world in the app', desc: 'The Shopify Shop App gives customers a branded mobile experience. Notifications, order tracking, personalised feed — in every customer\'s phone.', img: '/shopapp.webp', reverse: true },
  { title: 'B2B pro solution', desc: 'Shopify Plus enables full B2B functionality — custom price lists, company accounts, approval processes, ERP connection and B2B checkout. Enterprise features without the enterprise price.', img: '/b2b.webp', reverse: false },
];

const relatedServices = [
  { href: '/en/co-umime/potrebuji-brand', label: 'I need a brand' },
  { href: '/en/co-umime/novy-shopify-e-shop', label: 'New Shopify store' },
  { href: '/en/co-umime/expanze-do-zahranici', label: 'International expansion' },
  { href: '/en/co-umime/rozvoj-a-podpora', label: 'Development & support' },
  { href: '/en/co-umime/analyza-a-strategie', label: 'Strategy & analytics' },
  { href: '/en/co-umime/custom-vyvoj-a-aplikace', label: 'Custom development & apps' },
];
---

<PageLayout title="Migration to Shopify | aethero" description="Migrate from Shoptet, WooCommerce or another platform to Shopify without losing SEO, data or customers." lang="en">
  <ServiceHero
    lang="en"
    label="Migration"
    title="MIGRATION<br /><span style='color:var(--action)'>TO SHOPIFY</span>"
    subtitle="Hesitating? Want advice? Or have you already decided? Then let's go."
    ctaLabel="Let's talk"
    ctaHref="tel:+420776067663"
    cta2Label="Find out how"
    cta2Href="#why-migrate"
    image="/donut.webp"
    imageAlt="Migration to Shopify"
  />

  <!-- Intro -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="intro-h2">We'll kickstart your <span class="accent-purple">MIGRATION TO SHOPIFY</span></h2>
      <p class="intro-text">If you've hit the limits of your current platform, <strong class="hl">Shopify is the logical next step</strong>. Instead of a closed system with limited customisation, you get an open global platform built for growth — and expansion into international markets.</p>
      <p class="intro-text">It supports <strong class="hl">multiple currencies and languages, integrations with external systems</strong>, and seamless connection between online and offline sales through a unified POS. We'll help you migrate smoothly — preserving your SEO, data and customer experience.</p>
      <a href="#cta" class="intro-btn">Yes, we want to migrate →</a>
    </div>
  </section>

  <!-- 2-col: text + checklist -->
  <section class="section bg-secondary" id="why-migrate">
    <div class="container two-col-check">
      <div>
        <h2 class="section-title">Shopify Edition Winter 2026</h2>
        <p class="section-text">Shopify releases major feature updates twice a year. Each release brings new features for merchants, developers and customers — and Shopify does not charge you separately for the upgrade. Are you used to that with other platforms?</p>
        <div class="edition-img-wrap">
          <img src="/shopify-update-winter-2026.webp" alt="Shopify Edition Winter 2026" class="edition-img" loading="lazy" />
        </div>
        <p class="section-text">As a Shopify partner we get access to new features before others — and deliver them directly into your store. <a href="https://www.shopify.com/editions" target="_blank" rel="noopener" class="section-link">Shopify Editions Winter 2026</a> — we bring what's new straight to your project.</p>
      </div>
      <div>
        <h2 class="section-title">How to get started</h2>
        <ul class="check-list">
          {checkItems.map((c) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{c}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class="container" style="margin-top: var(--space-64); text-align: center;">
      <a href="tel:+420776067663" class="btn-action">Get in touch</a>
    </div>
  </section>

  <!-- Feature heading -->
  <section class="section-heading bg-elevated">
    <div class="container">
      <h2 class="feature-section-heading">Features you will love:</h2>
      <p class="section-text">If you have been around standard stores for a while, you will certainly appreciate these features and capabilities that come built-in from the start</p>
    </div>
  </section>

  <!-- Feature sections -->
  {features.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          <h2 class="feature-title">{f.title}</h2>
          <p class="feature-desc">{f.desc}</p>
        </div>
        <div class="feature-img-wrap">
          <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />
        </div>
      </div>
    </section>
  ))}

  <!-- Related -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Other services</h2>
      <ul class="related-services">
        {relatedServices.map((s) => (
          <li>
            <a href={s.href} class="related-link">
              <span>{s.label}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Time to get going?<br />Get in touch</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading { font-size: clamp(32px, 4vw, 52px); font-weight: 700; line-height: 1.15; margin-bottom: var(--space-40); max-width: 760px; }
  .text-action { color: var(--action); }
  .intro-h2 { font-size: clamp(40px, 6vw, 80px); font-weight: 700; line-height: 1.1; margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-text { font-size: clamp(16px, 1.4vw, 20px); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .intro-btn { display: inline-flex; align-items: center; padding: 14px 32px; background: #fff; color: var(--brand-dark); font-family: var(--font-primary); font-size: 15px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border-radius: var(--radius-md); transition: background var(--transition-base), transform var(--transition-base); margin-top: var(--space-16); }
  .intro-btn:hover { background: rgba(255,255,255,0.88); transform: translateY(-1px); }
  .intro-text--spaced { margin-top: var(--space-40); }
  .btn-action { display: inline-flex; padding: 16px 40px; background: var(--action); color: #000; font-family: var(--font-primary); font-size: 15px; font-weight: 700; border-radius: var(--radius-md); text-decoration: none; margin: var(--space-32) 0; transition: background var(--transition-base); }
  .btn-action:hover { background: var(--action-hover); }
  .intro-link { display: inline-block; margin-top: var(--space-24); color: var(--action); font-size: 16px; font-weight: 600; text-decoration: none; }
  .intro-link:hover { opacity: 0.75; }

  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-40); }
  .section-text { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: var(--space-24); }
  .section-link { color: var(--action); text-decoration: none; font-weight: 600; }
  .section-link:hover { opacity: 0.75; }

  .two-col-check { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .edition-img-wrap { margin-bottom: var(--space-24); }
  .edition-img { width: 100%; max-width: 400px; height: auto; border-radius: var(--radius-md); display: block; }
  .check-list { list-style: none; display: flex; flex-direction: column; gap: 16px; padding-top: var(--space-8); }
  .check-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 15px; color: rgba(255,255,255,0.8); line-height: 1.5; }
  .check-list svg { flex-shrink: 0; margin-top: 2px; }

  .section-heading { padding: var(--space-80) 0 var(--space-40); }
  .feature-section-heading { font-size: clamp(24px, 3vw, 40px); font-weight: 700; margin-bottom: var(--space-16); }

  .feature-section { padding: var(--space-120) 0; }
  .feature-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: center; }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text,
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-title { font-size: clamp(24px, 3vw, 36px); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); }
  .feature-desc { font-size: 17px; color: rgba(255,255,255,0.75); line-height: 1.75; }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }
  .feature-img { width: 100%; max-width: 560px; height: auto; border-radius: var(--radius-md); display: block; }

  .related-services { list-style: none; display: flex; flex-direction: column; }
  .related-link { display: flex; align-items: center; justify-content: space-between; padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 15px; color: var(--neutral-300); transition: color var(--transition-base); text-decoration: none; }
  .related-link:hover { color: var(--action); }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.1; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--brand-dark); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 1024px) {
    .two-col-check { grid-template-columns: 1fr; }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
