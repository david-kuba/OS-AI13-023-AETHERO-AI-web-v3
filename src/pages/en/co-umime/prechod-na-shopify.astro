---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';


const features = [
  { title: 'Multichannel integration', desc: 'Sell from a single admin across all channels — Instagram, TikTok, Google Shopping, Amazon. One warehouse, one source of truth for inventory, everything from the Shopify admin.', img: '/shopify-chanels.webp', reverse: false },
  { title: 'Social media integration', desc: 'Direct selling via Instagram, TikTok, Facebook and YouTube. Unified management of campaigns, products and orders from one place. Customers buy where they already are.', img: '/fbandinsta.webp', reverse: true },
  { title: 'Taxonomy and categorisation', desc: 'Advanced product organisation with Shopify product taxonomy — over 10,000 standardised categories. Better search, SEO and customer experience.', img: '/shopify-produkt-taxonomy.webp', reverse: false },
  { title: 'Show it to the world in the app', desc: 'The Shopify Shop App gives customers a branded mobile experience. Notifications, order tracking, personalised feed — in every customer\'s phone.', img: '/shopapp.webp', reverse: true },
  { title: 'B2B pro solution', desc: 'Shopify Plus enables full B2B functionality — custom price lists, company accounts, approval processes, ERP connection and B2B checkout. Enterprise features without the enterprise price.', img: '/b2b.webp', reverse: false },
];

---

<PageLayout title="Migration to Shopify | aethero" description="Migrate from Shoptet, WooCommerce or another platform to Shopify without losing SEO, data or customers." lang="en">
  <ServiceHero
    lang="en"
    label="Migration"
    title="MIGRATION<br /><span style='color:#fff'>TO SHOPIFY</span>"
    subtitle="Hesitating? Want advice? Or have you already decided? Then let's go."
    ctaLabel="Let's talk"
    ctaHref="tel:+420776067663"
    cta2Label="Find out how"
    cta2Href="#why-migrate"
    image="/donut.webp"
    imageAlt="Migration to Shopify"
  />

  <!-- Intro -->
  <section class="section bg-primary">
    <div class="container">
      <h2 class="intro-h2">We'll kickstart your<br /><span class="accent-purple">MIGRATION TO SHOPIFY</span></h2>
      <p class="intro-text">If you've hit the limits of your current platform, <strong class="hl">Shopify is the logical next step</strong>. Instead of a closed system with limited customisation, you get an open global platform built for growth — and expansion into international markets.</p>
      <p class="intro-text">It supports <strong class="hl">multiple currencies and languages, integrations with external systems</strong>, and seamless connection between online and offline sales through a unified POS. We'll help you migrate smoothly — preserving your SEO, data and customer experience.</p>
      <a href="#cta" class="btn-action btn-action--lg">Yes, we want to migrate</a>
    </div>
  </section>

  <!-- Shopify Edition Winter 2026 -->
  <section class="section bg-primary" id="why-migrate">
    <div class="container edition-split">
      <div class="edition-media">
        <img src="/shopify-update-winter-2026.webp" alt="Shopify Edition Winter 2026" class="edition-img" loading="lazy" />
        <a href="/en/blog/shopify-editions-winter-2026" class="edition-label">Shopify<br />Edition<br />Winter 26 <span class="edition-arrow">→</span></a>
      </div>
      <div class="edition-text">
        <h2 class="section-title">Shopify Edition Winter 2026</h2>
        <p class="section-text body">New features for speed, automation and international growth push Shopify another step ahead of local platforms. If you feel your store is held back by technology, now is the ideal time for a change. <a href="/en/blog/shopify-editions-winter-2026" class="text-link">Read our overview of the most important things from Shopify Edition Winter 2026</a> or take a look right away at <a href="https://www.shopify.com/editions" target="_blank" rel="noopener noreferrer" class="text-link">everything Shopify can newly do on the official site</a>.</p>
        <a href="tel:+420776067663" class="btn-action btn-action--lg">Get in touch</a>
      </div>
    </div>
  </section>

  <!-- Feature heading -->
  <section class="section-heading bg-primary">
    <div class="container">
      <h2 class="feature-section-heading">Features you will love:</h2>
      <p class="section-text body">If you have been around standard stores for a while, you will certainly appreciate these features and capabilities that come built-in from the start</p>
    </div>
  </section>

  <!-- Feature sections -->
  {features.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          <h2 class="feature-title">{f.title}</h2>
          <p class="body">{f.desc}</p>
        </div>
        <div class="feature-img-wrap">
          <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Time to get going?<br />Get in touch</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading { font-size: var(--fs-52); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-40); max-width: 760px; }
  .text-action { color: #fff; }
  .intro-h2 { font-size: var(--fs-80); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-text { font-size: var(--fs-20); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .intro-text--spaced { margin-top: var(--space-40); }
  .section { padding: var(--space-120) 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }
  .section-title { font-size: var(--fs-70); font-weight: 600; margin-bottom: var(--space-40); }
  .section-text { margin-bottom: var(--space-24); }

  /* Shopify Edition blok — obrázek + fialový štítek vlevo, text+tlačítko vpravo */
  .edition-split { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: center; }
  .edition-media { position: relative; }
  .edition-img { width: 100%; height: auto; border-radius: var(--radius-md); display: block; }
  .edition-label {
    position: absolute; top: 50%; right: -8%; left: auto; transform: translateY(-50%);
    background: var(--accent-purple); color: #fff; text-decoration: none;
    font-family: var(--font-primary); font-size: var(--fs-30); font-weight: 700; line-height: 1.1;
    padding: var(--space-24) var(--space-32);
    box-shadow: 0 16px 40px rgba(0,0,0,0.4);
    transition: background var(--transition-base);
  }
  .edition-label:hover { background: var(--text-secondary); }
  .edition-arrow { display: block; margin-top: var(--space-16); }
  /* check-list → globální .check-list (global.css) */

  .section-heading { padding: var(--space-80) 0 var(--space-40); }
  .feature-section-heading { font-size: var(--fs-48); font-weight: 600; margin-bottom: var(--space-16); }

  .feature-section { padding: var(--space-120) 0; }
  .feature-inner { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: center; }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text,
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-title { font-size: var(--fs-36); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }
  .feature-img { width: 100%; max-width: 560px; height: auto; border-radius: var(--radius-md); display: block; }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: var(--fs-70); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 1024px) {
    .edition-split { grid-template-columns: 1fr; gap: var(--space-40); }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
