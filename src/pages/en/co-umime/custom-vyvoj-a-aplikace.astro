---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const services = [
  { title: 'Liquid Theme Customisation', desc: 'UX/CRO improvements, custom sections, design changes without limits.' },
  { title: 'Shopify Functions', desc: 'Custom checkout logic, discounts, shipping rules, B2B pricing.' },
  { title: 'API Integrations', desc: 'ERP, CRM, WMS, carriers, invoicing, PIM — we connect what you need.' },
  { title: 'Custom Apps', desc: 'Private/public Shopify apps, admin tools, customer dashboards.' },
  { title: 'Data Workflows', desc: 'Imports, exports, data validation and full process automation.' },
];

const examples = [
  'Supplier feed import with automatic synchronisation',
  'B2B pricing logic and customer groups',
  'Localised shipping and payment rules per country',
  'Real-time ERP/WMS integration',
  'Internal admin dashboards for operations teams',
];

const apps = [
  {
    name: 'eSyncer',
    desc: 'Product data import, sync & automation (not just) for Shopify.',
    href: '/en/esyncer',
  },
  {
    name: 'AE Translator',
    desc: 'AI translation of your store content. DeepL, Claude or DeepSeek — your choice.',
    href: '/en/ae-translator',
  },
];
---

<PageLayout title="Custom Development & Apps" description="Custom Shopify development — Liquid, Functions, API integrations and private apps." lang="en">
  <ServiceHero lang="en"
    label="Custom Development"
    title="CUSTOM<br /><span style='color:var(--action)'>DEVELOPMENT</span>"
    subtitle="When standard Shopify is not enough. We build exactly what your store needs — from Liquid tweaks to full private apps."
  />

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">What we build</h2>
      <div class="services-grid">
        {services.map((s) => (
          <div class="service-card">
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-secondary">
    <div class="container">
      <h2 class="section-title">Examples of what we've built</h2>
      <ul class="examples-list">
        {examples.map((e) => <li>{e}</li>)}
      </ul>
    </div>
  </section>

  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Our own apps</h2>
      <div class="apps-grid">
        {apps.map((app) => (
          <a href={app.href} class="app-card">
            <h3>{app.name}</h3>
            <p>{app.desc}</p>
            <span class="app-link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Have a custom requirement?</h2>
      <p>Tell us what you need — we will figure out how to build it.</p>
      <div class="cta-links">
        <a href="mailto:info@aethero.cz" class="btn-primary">info@aethero.cz</a>
        <a href="tel:+420776067663" class="btn-ghost">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-40); }
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .service-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .service-card h3 { font-size: 16px; font-weight: 600; color: var(--action); margin-bottom: var(--space-8); }
  .service-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }
  .examples-list { list-style: none; display: flex; flex-direction: column; gap: 16px; }
  .examples-list li { padding: 16px 24px; background: var(--bg-elevated); border-left: 3px solid var(--action); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; font-size: var(--text-small); }
  .apps-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-24); }
  .app-card { display: flex; flex-direction: column; background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); transition: border-color var(--transition-base); }
  .app-card:hover { border-color: var(--action); }
  .app-card h3 { font-size: 20px; font-weight: 700; color: var(--action); margin-bottom: var(--space-8); }
  .app-card p { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; flex: 1; }
  .app-link { margin-top: var(--space-16); font-size: 14px; font-weight: 600; color: var(--action); }
  .cta-section { padding: var(--space-120) 0; background: var(--bg-primary-alt); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-size: var(--text-h2); font-weight: 600; margin-bottom: var(--space-16); }
  .cta-inner p { color: var(--neutral-300); margin-bottom: var(--space-40); }
  .cta-links { display: flex; gap: var(--space-16); justify-content: center; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; padding: 14px 32px; background: var(--action); color: var(--bg-elevated); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: background var(--transition-base); }
  .btn-primary:hover { background: var(--action-hover); }
  .btn-ghost { display: inline-flex; padding: 14px 32px; border: 1px solid rgba(255,255,255,0.2); color: var(--text-primary); font-family: var(--font-primary); font-size: 15px; font-weight: 600; border-radius: var(--radius-md); transition: border-color var(--transition-base), color var(--transition-base); }
  .btn-ghost:hover { border-color: var(--action); color: var(--action); }
  @media (max-width: 768px) { .services-grid { grid-template-columns: 1fr; } .apps-grid { grid-template-columns: 1fr; } }
</style>
