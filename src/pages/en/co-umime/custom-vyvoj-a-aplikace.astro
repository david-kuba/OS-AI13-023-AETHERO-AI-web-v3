---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';

const whenCustom = [
  'you need to connect to an ERP / warehouse / supplier, but the data is "different"',
  'you want custom logic in the cart / shipping / discounts / B2B that generic apps cannot handle',
  'you deal with local requirements (CZ/SK and beyond) and do not want more "duct-tape" solutions',
  'you need automations that save time every single day',
];

const deliverables = [
  'Shopify theme modifications (Liquid, UX/CRO tweaks, performance)',
  'Shopify Functions & checkout logic (discounts, shipping, B2B rules — where Shopify allows it)',
  'API integrations (ERP, CRM, WMS, carriers, invoicing, PIM…)',
  'Custom apps (private/public), admin tools, dashboards',
  'Data workflows (imports/exports, validation, field mapping, automation)',
];

const steps = [
  { num: '01', title: 'Quick audit & brief', desc: 'What exactly the result should be and how we will know it works.' },
  { num: '02', title: 'Solution design', desc: 'Options: app vs. modification vs. integration (and why).' },
  { num: '03', title: 'MVP', desc: 'First version that already delivers value (and is safe for production).' },
  { num: '04', title: 'Iteration & scaling', desc: 'We smooth the edges, add automations, speed things up.' },
  { num: '05', title: 'Support', desc: 'So it keeps working three months from now — not just on launch day.' },
];

const hardCases = [
  { title: 'Supplier feeds & imports', desc: 'When a "universal" parser is not enough and you need custom mapping, rules, validation and monitoring.' },
  { title: 'B2B logic', desc: 'Login-based pricing, individual price lists, order approval, payment limits.' },
  { title: 'Shipping & payments', desc: 'Locally and internationally: rules that change per country, cart, warehouse, margin.' },
  { title: 'ERP/WMS integration', desc: 'Stock movements, invoicing, returns, order status — so data matches everywhere.' },
  { title: 'Admin tools', desc: 'Internal dashboards that speed up the team\'s work (and reduce errors).' },
];

const whyUs = [
  { title: 'Shopify-first approach', desc: 'Get the maximum out of the platform — and go custom only where it makes sense.' },
  { title: 'Value for money', desc: 'A smart solution rather than an expensive build for the sake of building.' },
  { title: 'E-commerce in our DNA', desc: 'We solve not just the code, but also UX, data and operational impact.' },
  { title: 'Sustainability', desc: 'So it is not a "one-off", but something you can continue to develop.' },
];

const faq = [
  { q: 'How much does it cost?', a: 'It depends. A small tweak can be a quick job, but an app is already a proper project. After a short brief we will give you options and a recommendation for the best value-for-money approach.' },
  { q: 'Do you also do "just" consulting?', a: 'Yes. Sometimes 60–90 minutes is all it takes for everyone to know what to build, what to buy as an app and what to avoid — and why.' },
  { q: 'Can you integrate something that "has no integration"?', a: 'If the service has an API (or at least a reasonable export/import), a path can usually be found.' },
];

const apps = [
  { name: 'eSyncer', desc: 'Want to easily manage hundreds of products from your supplier — or even from multiple suppliers? eSyncer automatically synchronises your product data between your supplier\'s XML data feed and your Shopify store.', href: '/en/esyncer' },
  { name: 'AE Translator', desc: 'AI-powered translator for the native, full Shopify text export with rules. The app uses Shopify\'s native export and import: export products, collections or pages into CSV or ZIP, upload the file and translate everything in bulk using AI (DeepL, Claude or DeepSeek — your choice).', href: '/en/ae-translator' },
];

const relatedServices = [
  { href: '/en/co-umime/potrebuji-brand', label: 'I need a brand' },
  { href: '/en/co-umime/novy-shopify-e-shop', label: 'New Shopify store' },
  { href: '/en/co-umime/prechod-na-shopify', label: 'Migration to Shopify' },
  { href: '/en/co-umime/expanze-do-zahranici', label: 'International expansion' },
  { href: '/en/co-umime/rozvoj-a-podpora', label: 'Development & support' },
  { href: '/en/co-umime/analyza-a-strategie', label: 'Strategy & analytics' },
];
---

<PageLayout title="Custom Development & Apps | aethero" description="Custom Shopify apps, integrations and theme modifications tailored to your needs." lang="en">
  <ServiceHero
    lang="en"
    label="Custom Development"
    title="APPS &<br /><span style='color:var(--action)'>CUSTOM DEVELOPMENT</span>"
    subtitle="Feel like you have exhausted all app options or have something atypical? OK — let's tackle it!"
    ctaLabel="Let's talk"
    ctaHref="tel:+420776067663"
    cta2Label="Find out how"
    cta2Href="#how-we-do-it"
    image="/infinity.webp"
    imageAlt="Custom development and apps for Shopify"
  />

  <!-- Do you need an APP or a <span class="accent-purple">CUSTOM MODIFICATION</span>? -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="intro-h2">Do you need an <span class="accent-purple">APP</span><br />or a <span class="accent-purple">CUSTOM MODIFICATION</span>?</h2>
      <p class="intro-text">This part of our work is, on one hand, wonderfully simple to explain — and on the other, <strong class="hl">quite unpredictable to actually build</strong>. In the ideal scenario, you come to us with a problem and leave with a solution. Somewhere in between, we find or build that solution, and you pay for it. Makes sense?</p>
      <p class="intro-text">We'll first check whether a ready-made solution already exists — then we'll break your problem down together so we can actually solve it. Sometimes it's one small tweak that lifts conversions. Other times it's an integration that <strong class="hl">straightens out data across your entire operation</strong>. And sometimes it's an app you simply can't do without.</p>
      <a href="#cta" class="intro-btn">Let's go →</a>
    </div>
  </section>

  <!-- When is it time for custom? -->
  <section class="section bg-secondary">
    <div class="container">
      <h2 class="section-title">When is it time for "custom"?</h2>
      <h3 class="when-subhead">An app sometimes is not enough when</h3>
      <ul class="when-list">
        {whenCustom.map((item) => (
          <li class="when-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <a href="tel:+420776067663" class="btn-action">Great, bring it on. ➝</a>
    </div>
  </section>

  <!-- Custom modifications, integrations and custom apps -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Custom modifications, integrations and custom apps</h2>
      <ul class="deliverables-list">
        {deliverables.map((d) => (
          <li class="deliverable-item">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{d}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Understand first, then solve -->
  <section class="section bg-secondary" id="how-we-do-it">
    <div class="container">
      <h2 class="section-title">Understand first, then solve.</h2>
      <p class="section-text">So that a custom solution does not burn through your budget or your nerves, we follow a simple logic: first understand the problem, then build anything.</p>
      <div class="process-list">
        {steps.map((s) => (
          <div class="process-item">
            <span class="step-num">{s.num}</span>
            <div>
              <h3 class="process-title">{s.title}</h3>
              <p class="process-desc">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Typical trickier nuts to crack -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">Typical "trickier nuts to crack"</h2>
      <div class="hard-grid">
        {hardCases.map((h) => (
          <div class="hard-card">
            <h3 class="hard-title">{h.title}</h3>
            <p class="hard-desc">{h.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="section bg-secondary">
    <div class="container">
      <h2 class="section-title">Why us</h2>
      <div class="why-grid">
        {whyUs.map((w) => (
          <div class="why-card">
            <h3 class="why-title">{w.title}</h3>
            <p class="why-desc">{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">FAQ (quick and no fluff)</h2>
      <div class="faq-list">
        {faq.map((f) => (
          <div class="faq-item">
            <p class="faq-q">Question: {f.q}</p>
            <p class="faq-a">Answer: {f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our current apps -->
  <section class="section bg-secondary">
    <div class="container">
      <h2 class="section-title">Our current apps</h2>
      <div class="apps-list">
        {apps.map((a) => (
          <a href={a.href} class="app-card">
            <strong class="app-name">{a.name}</strong>
            <p class="app-desc">{a.desc}</p>
            <span class="app-link">Find out more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="section bg-elevated">
    <div class="container">
      <h2 class="section-title">What else can we do for you around Shopify?</h2>
      <ul class="related-services">
        {relatedServices.map((s) => (
          <li>
            <a href={s.href} class="related-link">
              <span>{s.label}</span>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Shall we build something together?<br />Get in touch</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .section { padding: var(--space-120) 0; }
  .bg-elevated { background: var(--bg-elevated); }
  .bg-secondary { background: var(--bg-secondary); }
  .section-title { font-size: clamp(32px, 5vw, 70px); font-weight: 600; margin-bottom: var(--space-40); }
  .section-text { font-size: 17px; color: rgba(255,255,255,0.8); line-height: 1.6; margin-bottom: var(--space-24); max-width: 760px; }

  .intro-h2 { font-size: clamp(40px, 6vw, 80px); font-weight: 700; line-height: 1.1; margin-bottom: var(--space-40); }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-text { font-size: clamp(16px, 1.4vw, 20px); color: rgba(255,255,255,0.85); line-height: 1.6; max-width: 860px; margin-bottom: var(--space-24); }
  .intro-btn { display: inline-flex; align-items: center; padding: 14px 32px; background: #fff; color: var(--brand-dark); font-family: var(--font-primary); font-size: 15px; font-weight: 700; text-transform: uppercase; border-radius: var(--radius-sm); transition: background var(--transition-base), transform var(--transition-base); margin-top: var(--space-16); }
  .intro-btn:hover { background: rgba(255,255,255,0.88); transform: translateY(-1px); }
  .intro-wrap { max-width: 800px; }

  .when-subhead { font-size: 18px; font-weight: 600; color: var(--action); margin-bottom: var(--space-24); }
  .when-list { list-style: none; display: flex; flex-direction: column; gap: 16px; margin-bottom: var(--space-40); }
  .when-item { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.5; }
  .when-item svg { flex-shrink: 0; margin-top: 3px; }

  .btn-action { display: inline-flex; padding: 16px 40px; background: var(--action); color: #000; font-family: var(--font-primary); font-size: 15px; font-weight: 700; border-radius: var(--radius-sm); text-decoration: none; margin-top: var(--space-8); transition: background var(--transition-base); }
  .btn-action:hover { background: var(--action-hover); }

  .deliverables-list { list-style: none; display: flex; flex-direction: column; gap: 16px; max-width: 760px; }
  .deliverable-item { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.5; }
  .deliverable-item svg { flex-shrink: 0; margin-top: 3px; }

  .process-list { display: flex; flex-direction: column; gap: 0; max-width: 760px; }
  .process-item { display: flex; gap: var(--space-16); padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .process-item:last-child { border-bottom: none; }
  .step-num { display: block; font-family: var(--font-primary); font-size: 13px; font-weight: 600; color: var(--action); flex-shrink: 0; width: 28px; padding-top: 2px; }
  .process-title { font-size: 16px; font-weight: 600; margin-bottom: var(--space-8); }
  .process-desc { font-size: var(--text-small); color: var(--neutral-300); line-height: 1.6; }

  .hard-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-24); }
  .hard-card { background: var(--bg-secondary); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .hard-title { font-size: 15px; font-weight: 600; color: var(--action); margin-bottom: var(--space-12); }
  .hard-desc { font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.6; }

  .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-24); max-width: 800px; }
  .why-card { background: var(--bg-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); }
  .why-title { font-size: 15px; font-weight: 600; color: var(--action); margin-bottom: var(--space-8); }
  .why-desc { font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.6; }

  .faq-list { display: flex; flex-direction: column; gap: var(--space-32); max-width: 760px; }
  .faq-item { border-left: 2px solid var(--action); padding-left: var(--space-24); }
  .faq-q { font-size: 16px; font-weight: 600; margin-bottom: var(--space-8); }
  .faq-a { font-size: 15px; color: rgba(255,255,255,0.75); line-height: 1.6; }

  .apps-list { display: flex; flex-direction: column; gap: var(--space-16); max-width: 760px; }
  .app-card { display: block; background: var(--bg-elevated); border: 1px solid rgba(255,255,255,0.08); border-radius: var(--radius-md); padding: var(--space-24); transition: border-color var(--transition-base); text-decoration: none; }
  .app-card:hover { border-color: rgba(13,212,205,0.3); }
  .app-name { display: block; font-size: 16px; font-weight: 700; margin-bottom: var(--space-8); color: var(--text-primary); }
  .app-desc { font-size: 14px; color: rgba(255,255,255,0.7); margin-bottom: var(--space-8); line-height: 1.6; }
  .app-link { font-size: 13px; color: var(--action); }

  .related-services { list-style: none; display: flex; flex-direction: column; }
  .related-link { display: flex; align-items: center; justify-content: space-between; padding: var(--space-16) 0; border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 15px; color: var(--neutral-300); transition: color var(--transition-base); text-decoration: none; }
  .related-link:hover { color: var(--action); }

  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: clamp(40px, 5vw, 70px); font-weight: 700; color: #fff; line-height: 1.1; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: clamp(22px, 3vw, 40px); font-weight: 700; color: var(--brand-dark); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  @media (max-width: 1024px) {
    .hard-grid { grid-template-columns: repeat(2, 1fr); }
    .why-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .hard-grid { grid-template-columns: 1fr; }
  }
</style>
