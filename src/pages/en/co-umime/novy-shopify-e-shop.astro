---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';
import WorkSidebar from '../../../components/layout/WorkSidebar.astro';

const startSteps = [
  { icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>', title: 'Your plans & requirements', desc: 'Tell us how you envision the project and what you need.' },
  { icon: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>', title: 'Our analysis & recommendation', desc: 'We go through the details, clarify the unknowns and create a recommendation of scope and options.' },
  { icon: '<path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"/>', title: 'Quote → Contract', desc: 'After refinement from both sides, a quote emerges — and from it, a contract.' },
  { icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>', title: 'Project', desc: 'We kick off the project, set things up, connect and build together with you.' },
  { icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>', title: 'Management & development', desc: 'After launch the work doesn\'t end — it begins. You\'re on your way to a successful e-commerce project.' },
];

const features = [
  {
    title: 'AI partner, right in your store',
    logo: '/shopify-sidekick-logo2.webp',
    desc: 'Sidekick is an AI assistant integrated into the store admin that significantly speeds up your work in Shopify. It can handle operational tasks (create products, edit collections, analyse sales, prepare reports), help with marketing (writing descriptions, emails, SEO recommendations), propose and apply storefront modifications including appearance changes or edit the theme to order including Liquid code generation. Sidekick can explain how settings work in the admin, recommend steps for store growth, automate processes and suggest best practices. Answers are personalised based on your sales, customers and your store\'s specific configuration.',
    img: '/shopify-premium-story.webp',
    reverse: false,
  },
  {
    title: 'A clear and modern admin',
    logo: null,
    desc: 'An admin environment you get oriented in within minutes — even without technical knowledge. Products, orders, payments and content are all managed from one place, simply and logically. Instead of a complex system you get a tool that puts you in control of your store from day one. And don\'t worry — you can use it in English too.',
    img: null,
    reverse: true,
  },
  {
    title: 'Manage your store in the app',
    logo: null,
    desc: 'The Shopify mobile app lets you manage the entire store from your phone. Track revenue in real time, process orders, respond to customers and monitor performance from anywhere in the world.',
    img: '/appka.webp',
    reverse: false,
  },
  {
    title: 'Sell where life happens',
    logo: null,
    desc: 'Instagram, TikTok, Facebook, Google Shopping, Amazon — all connected to a single Shopify admin. One warehouse, one source of truth for inventory, one hub for all orders.',
    img: '/prodej-kdekoliv.webp',
    reverse: true,
  },
  {
    title: 'Analytics, marketing',
    logo: null,
    desc: 'Clear dashboards, trend tracking and smart customer segmentation. Shopify Email, SMS marketing and integrations with Google Analytics, Meta Ads or Klaviyo — all without complex setup.',
    img: '/data-marketing.webp',
    reverse: false,
  },
  {
    title: 'Automation',
    logo: null,
    desc: 'Shopify Flow responds to customer behaviour automatically. Order tagging, email sequences, discounts, warehouse notifications — set it once, then it runs without you.',
    img: '/flow-automation.webp',
    reverse: true,
  },
  {
    title: 'Shopify App Store',
    logo: null,
    desc: 'Apps.shopify.com — an ecosystem into which someone has already invested millions of hours. The Shopify App Store is not "just a list of add-ons". It is one of the largest e-commerce ecosystems in the world — a place where developers, technology companies and Shopify itself have spent the last 15+ years systematically solving problems that would otherwise cost you months of development, testing and fine-tuning. You will find over ten thousand apps that extend Shopify with practically anything you can think of.',
    img: '/aplikace.webp',
    reverse: false,
  },
];

const reasons = [
  'One of the 3 most-used e-commerce platforms in the world',
  'A year ahead of European competitors in updates and features',
  'Large international company — no dependence on a single local vendor',
  'International scaling without platform migration',
  'PCI DSS certified with top-tier security built in',
  'Shopify Plus for enterprise with dedicated support',
  'Community of partners and agencies worldwide',
];

const capabilities = [
  'Product, collection and pricing management',
  'Orders, inventory and carriers',
  'Customers and CRM',
  'Payment gateways and checkout',
  'SEO and marketing tools',
  'Analytics and reports',
  'Apps and integrations',
  'Multi-language and multi-currency',
];

---

<PageLayout title="New Shopify Store | aethero" description="We launch your new store on Shopify — from design through development to the first order. We skip the dead ends and launch a store that sells." lang="en">
  <ServiceHero
    lang="en"
    label="New store"
    title="NEW STORE<br /><span style='color:#fff'>ON SHOPIFY</span>"
    subtitle="Launch your e-commerce project on the international super-platform. We skip the dead ends and launch a store that sells."
    ctaLabel="Let's talk"
    ctaHref="tel:+420776067663"
    cta2Label="Find out how"
    cta2Href="#shopify-why"
    image="/infinity.webp"
    imageAlt="Shopify store by aethero"
  />

  <!-- Let's launch your new store -->
  <section class="section bg-primary">
    <div class="container intro-layout">
      <div class="intro-main">
        <h2 class="h1 intro-h2">Let's build your<br /><span class="accent-purple">NEW STORE</span> on Shopify</h2>
        <p class="intro-text">Everything starts the same — a great idea and a vague notion of how to launch it. Will you build it alone or with us? <strong class="hl">If you think Shopify is too big for you, we will convince you otherwise.</strong></p>
        <p class="intro-text">If your project is serious, <strong class="hl">we know what to do. Partnering with us will save you both time and money</strong> in the long run. Getting a great store right on the first try is more complex than it looks.</p>
        <a href="#cta" class="btn-action btn-action--lg">Let's get to it</a>
      </div>
      <WorkSidebar heading="HOW WE START" items={startSteps} />
    </div>
  </section>

  <!-- What do we get with Shopify? -->
  <section class="section bg-primary" id="shopify-why">
    <div class="container">
      <div class="two-col-capabilities">
        <ul class="plus-list" id="features">
          {capabilities.map((c) => (
            <li>{c}</li>
          ))}
        </ul>
        <div>
          <h2 class="section-title">Wondering what you get with Shopify?</h2>
          <p class="section-text body">A modern e-commerce platform backed by tens of millions of merchants and years of development — technological infrastructure, global distribution, PCI DSS compliance and over 10,000 apps.</p>
          <p class="section-text body">Shopify invests tens of billions of dollars annually in infrastructure. Which means you are not affected by outages, security incidents or falling behind the competition.</p>
          <a href="#features" class="text-link">What are those?</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature sections - alternating image/text -->
  {features.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          {f.logo && <img src={f.logo} alt={f.title} class="feature-logo" loading="lazy" />}
          <h2 class="feature-title">{f.title}</h2>
          <p class="body">{f.desc}</p>
        </div>
        {f.img && (
          <div class="feature-img-wrap">
            <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />
          </div>
        )}
        {!f.img && (
          <div class="feature-img-wrap feature-img-wrap--empty"></div>
        )}
      </div>
    </section>
  ))}

  <!-- Why Shopify + Groomo -->
  <section class="section bg-primary">
    <div class="container two-col-groomo">
      <div>
        <h2 class="section-title">WHY start on the Shopify platform?</h2>
        <p class="section-text body">Let us tell you why the most popular e-commerce platform in the world is the ideal choice for your business — regardless of size or products.</p>
        <ul class="reasons-list">
          {reasons.map((r) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l4 4 6-7" stroke="var(--action)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{r}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="groomo-wrap">
        <div class="groomo-card">
          <img src="/groomo-ref-na-vysku.webp" alt="Groomo — case study" class="groomo-img" loading="lazy" />
          <a href="/en/groomo-cz-na-shopify" class="groomo-cta">Read the<br/>case study</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Already decided?<br />Get in touch:</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* Intro section */
  .section-intro { padding: var(--space-120) 0; }
  .intro-heading {
    font-size: var(--fs-52);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-40);
    max-width: 760px;
  }
  .text-action { color: #fff; }
  .intro-h2 { margin-bottom: var(--space-40); }
  /* Intro + HOW WE START sidebar = 2 sloupce */
  .intro-layout { display: grid; grid-template-columns: 1fr 355px; gap: var(--space-64); align-items: start; }
  .intro-main { min-width: 0; }
  .intro-main .intro-text { max-width: none; }
  @media (max-width: 900px) { .intro-layout { grid-template-columns: 1fr; gap: var(--space-40); } }
  .accent-purple { color: var(--text-secondary); }
  .hl { color: var(--text-secondary); font-weight: 900; }
  .intro-text {
    font-size: var(--fs-20);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    max-width: 860px;
    margin-bottom: var(--space-24);
  }
  .intro-text--spaced { margin-top: var(--space-40); }
  /* Capabilities section */
  .section { padding: var(--space-120) 0; }
  .bg-primary { background: var(--ae-bg-primary); }
  .bg-primary { background: var(--ae-bg-primary); }
  .section-title { font-size: var(--fs-70); font-weight: 600; margin-bottom: var(--space-40); }
  .section-text { margin-bottom: var(--space-24); }
  .two-col-capabilities { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  /* plus-list — odrážky „+" 22px levandule (lokální varianta check-listu) */
  .plus-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-16); }
  .plus-list li { display: flex; align-items: flex-start; gap: 12px; font-family: var(--font-secondary); font-size: var(--text-body); color: rgba(255,255,255,0.8); line-height: 1.6; }
  .plus-list li::before { content: '+'; color: var(--text-secondary); font-size: 22px; line-height: 1.3; flex-shrink: 0; }
  /* capability-list → globální .check-list */

  /* Feature sections */
  .feature-section { padding: var(--space-120) 0; }
  .feature-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-80);
    align-items: center;
  }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text { direction: ltr; }
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-logo { display: block; height: 32px; width: auto; margin-bottom: var(--space-24); }
  .feature-title { font-size: var(--fs-36); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); }
  .feature-img-wrap { display: flex; align-items: center; justify-content: center; }
  .feature-img-wrap--empty { min-height: 200px; }
  .feature-img {
    width: 100%;
    max-width: 560px;
    height: auto;
    border-radius: var(--radius-md);
    display: block;
  }

  /* Why Shopify + Groomo */
  .two-col-groomo { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .reasons-list { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-top: var(--space-24); }
  .reasons-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.5; }
  .reasons-list svg { flex-shrink: 0; margin-top: 2px; }
  .groomo-wrap { display: flex; justify-content: center; }
  .groomo-card { position: relative; max-width: 340px; width: 100%; border-radius: 6px; overflow: hidden; }
  .groomo-img { display: block; width: 100%; height: auto; }
  .groomo-cta {
    position: absolute; bottom: 20px; left: 20px; right: 20px;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    padding: 14px 20px;
    background: rgba(255,255,255,0.18);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.45);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 4px 24px rgba(0,0,0,0.2);
    color: #000326;
    font-family: var(--font-primary); font-size: 16px; font-weight: 600;
    text-transform: uppercase; text-align: center; line-height: 1.4;
    text-decoration: none;
    transition: background var(--transition-base), border-color var(--transition-base);
  }
  .groomo-cta:hover { background: rgba(255,255,255,0.28); border-color: rgba(255,255,255,0.65); }

  /* CTA */
  .cta-section { padding: var(--space-120) 0; background: var(--action); }
  .cta-inner { text-align: center; }
  .cta-inner h2 { font-family: var(--font-primary); font-size: var(--fs-70); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: var(--space-40); }
  .cta-contacts { display: flex; gap: var(--space-40); justify-content: center; flex-wrap: wrap; }
  .cta-contact { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: var(--ae-straight-blue); text-decoration: none; transition: opacity var(--transition-base); }
  .cta-contact:hover { text-decoration: underline; text-underline-offset: 4px; }

  /* Responsive */
  @media (max-width: 1024px) {
    .two-col-capabilities { grid-template-columns: 1fr; }
    .two-col-groomo { grid-template-columns: 1fr; }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
