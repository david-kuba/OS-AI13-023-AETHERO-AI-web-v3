---
import PageLayout from '../../../layouts/PageLayout.astro';
import ServiceHero from '../../../components/layout/ServiceHero.astro';
import WorkSidebar from '../../../components/layout/WorkSidebar.astro';

const startSteps = [
  { icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>', title: 'Your plans & requirements', desc: 'Tell us how you envision the project and what you need.' },
  { icon: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>', title: 'Our analysis & recommendation', desc: 'We go through the details, clarify the unknowns and create a recommendation of scope and options.' },
  { icon: '<path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"/>', title: 'Quote → Contract', desc: 'After refinement from both sides, a quote emerges — and from it, a contract.' },
  { icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>', title: 'Project', desc: 'We kick off the project, set things up, connect and build together with you.' },
  { icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>', title: 'Management & development', desc: 'After launch the work doesn\'t end — it begins. You\'re on your way to a successful e-commerce project.' },
];

const features = [
  {
    title: 'AI partner, right in your store',
    logo: '/shopify-sidekick-logo2.webp',
    logoText: 'Shopify<br />Sidekick',
    desc: '<strong class="hl">Sidekick</strong> is an AI assistant integrated directly into your store\'s admin — and it will significantly speed up your work in Shopify. It can handle <strong class="hl">operational tasks</strong> (creating products, editing collections, analyzing sales, generating reports), support your <strong class="hl">marketing</strong> efforts (writing descriptions, emails, and SEO recommendations), and propose and apply <strong class="hl">storefront changes</strong> — including visual adjustments or theme edits based on your brief, right down to writing Liquid code. Sidekick can explain how admin settings work, recommend steps for growing your store, automate processes, and suggest best practices. Its responses are personalized based on your sales data, customers, and your store\'s specific configuration.',
    img: '/shopify-premium-story.webp',
    reverse: false,
  },
  {
    title: 'Clean and modern admin',
    logo: null,
    desc: 'An admin interface you\'ll find your way around in no time — no technical knowledge required. Products, orders, payments, and content are all managed from one place, simply and intuitively. Instead of a complex system, you get a tool that puts you in control of your store from day one. And don\'t worry — you can use it in your local language too.',
    img: '/shopify-admin.png',
    reverse: true,
  },
  {
    title: 'Manage your store from the app',
    logo: null,
    desc: 'Shopify\'s native mobile app gives you full control over your store from anywhere. Track sales in real time, manage orders, add products, or communicate with customers — all from your phone. Whether you\'re on the road, in a meeting, or simply away from your desk, your store keeps running and you\'ve got it right in your pocket.',
    img: '/appka.webp',
    reverse: false,
  },
  {
    title: 'Sell where your customers are',
    logo: null,
    desc: 'Shopify lets you sell not just through your own store, but directly where your customers spend their time — on Instagram, TikTok, Facebook, Google Shopping, or Amazon. All channels are managed from one place, with orders, inventory, and analytics connected across the board. Instead of waiting for customers to come to you, you go to them.',
    img: '/prodej-kdekoliv.webp',
    reverse: true,
  },
  {
    title: 'Analytics & marketing',
    logo: null,
    desc: 'Shopify\'s analytics give you a clear picture of what\'s actually working in your marketing. <strong class="hl">With intuitive dashboards and smart reports, you can easily track revenue trends, customer behavior, and campaign performance.</strong> Integrations with tools like Google Analytics, ad platforms, and email services let you see the entire customer journey in context. The right measurement setup helps you respond quickly to changes, optimize budgets, and focus your energy where marketing has the greatest impact.',
    img: '/data-marketing.webp',
    reverse: false,
  },
  {
    title: 'Automation',
    logo: null,
    desc: 'In-store automation — built primarily on Shopify Flow and an event-driven architecture — lets you act on data in real time and turn it into concrete actions without manual intervention. Using pre-built or custom workflows, you can automatically respond to customer behavior, order changes, or campaign performance. The result: saved time, fewer errors, and marketing that runs smoothly even when the team is focused elsewhere.',
    img: '/flow-automation.webp',
    reverse: true,
  },
  {
    title: 'Shopify App Store',
    logo: null,
    desc: '<a href="https://apps.shopify.com/" target="_blank" rel="noopener noreferrer" class="text-link">Apps.shopify.com</a> <strong class="hl"> — an ecosystem millions of hours have already been invested in.</strong> The Shopify App Store isn\'t "just a list of add-ons." It\'s one of the largest e-commerce ecosystems in the world — <strong class="hl">a place where developers, technology companies, and Shopify itself have spent more than 15 years systematically solving problems</strong> that would otherwise cost you months of development, testing, and fine-tuning. You\'ll find <strong class="hl">over ten thousand apps</strong> that extend Shopify with virtually anything you can think of — <strong class="hl">and often things you didn\'t yet know you\'d need.</strong>',
    img: '/aplikace.webp',
    reverse: false,
  },
];

const appStore = features[features.length - 1];
const featuresMain = features.slice(0, -1);

const reasons = [
  '<strong class="hl">It\'s among the three most widely used e-commerce platforms in the world</strong> — which means more than enough flexibility for your products and your project.',
  '<strong class="hl">Change in e-commerce moves fast</strong> — no question about it. <strong class="hl">You need a platform that\'s a year ahead of the European competition,</strong> not two years behind with a growing technical debt.',
  '<strong class="hl">This isn\'t a relatively small, local company</strong> focused on selling in the Czech Republic and Slovakia — and maybe a little in Poland and Hungary.',
  'You probably <strong class="hl">don\'t want to be dependent on a single service provider</strong> when something goes wrong — and by that, we mean us included.',
  'Because in the beginning, you can handle a lot on your own and <strong class="hl">save money — and two years from now, you can have an international business</strong> on the same platform, with a choice of both apps and agencies to support you. No migration needed.',
];

const capabilities = [
  'Product, collection and pricing management',
  'Orders, inventory and carriers',
  'Customers and CRM',
  'Payment gateways and checkout',
  'SEO and marketing tools',
  'Analytics and reports',
  'Apps and integrations',
  'Multi-language and multi-currency',
];

---

<PageLayout title="New Shopify Store | aethero" description="We launch your new store on Shopify — from design through development to the first order. We skip the dead ends and launch a store that sells." lang="en">
  <ServiceHero
    lang="en"
    label="New store"
    title="NEW STORE<br /><span style='color:#fff'>ON SHOPIFY</span>"
    subtitle="Launch your e-commerce project on the international super-platform. We skip the dead ends and launch a store that sells."
    ctaLabel="Let's talk"
    ctaHref="tel:+420776067663"
    cta2Label="Find out how"
    cta2Href="#shopify-why"
    image="/infinity.webp"
    imageAlt="Shopify store by aethero"
  />

  <!-- Let's launch your new store -->
  <section class="section bg-primary">
    <div class="container intro-layout">
      <div class="intro-main">
        <h2 class="h1 intro-h2">Let's build your<br /><span class="accent-purple">NEW STORE</span> on Shopify</h2>
        <p class="intro-text">Everything starts the same — a great idea and a vague notion of how to launch it. Will you build it alone or with us? <strong class="hl">If you think Shopify is too big for you, we will convince you otherwise.</strong></p>
        <p class="intro-text">If your project is serious, <strong class="hl">we know what to do. Partnering with us will save you both time and money</strong> in the long run. Getting a great store right on the first try is more complex than it looks.</p>
        <a href="#cta" class="btn-action btn-action--lg">Let's get to it</a>
      </div>
      <WorkSidebar heading="HOW WE START" items={startSteps} />
    </div>
  </section>

  <!-- What do we get with Shopify? -->
  <section class="section bg-primary" id="shopify-why">
    <div class="container">
      <h2 class="section-title">Wondering what you actually get<br />with Shopify?</h2>
      <div class="two-col-capabilities">
        <ul class="plus-list" id="features">
          {capabilities.map((c) => (
            <li>{c}</li>
          ))}
        </ul>
        <div>
          <p class="section-text body-maxi">A modern e-commerce platform with speed, stability, and security built in. The ability to sell globally without technical compromises. Native support for multiple languages, currencies, and markets. With Shopify, you can grow from your first orders all the way to an international brand — without rewriting your store every two years.</p>
          <p class="section-text body">We probably should back up all that praise with something solid, shouldn't we? So let's take a look. We've picked out some features we consider essential — and that are, perhaps surprisingly, not all that common elsewhere.</p>
          <p class="section-text body">At the end of this page, we've summed up why Shopify is the right platform to start on.</p>
          <a href="#proc-zacit" class="btn-action btn-action--ghost">Why start on Shopify</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature sections - alternating image/text -->
  {featuresMain.map((f) => (
    <section class={`feature-section${f.reverse ? ' feature-section--reverse' : ''}`}>
      <div class="container feature-inner">
        <div class="feature-text">
          <h2 class="feature-title">{f.title}</h2>
          <p class="body" set:html={f.desc}></p>
        </div>
        {f.img && (
          <div class="feature-img-wrap">
            {f.logo && (
              <div class="feature-logo-lockup">
                <img src={f.logo} alt={f.title} class="feature-logo" loading="lazy" />
                {f.logoText && <span class="feature-logo-text" set:html={f.logoText}></span>}
              </div>
            )}
            <img src={f.img} alt={f.title} class="feature-img" loading="lazy" />
          </div>
        )}
        {!f.img && (
          <div class="feature-img-wrap feature-img-wrap--empty"></div>
        )}
      </div>
    </section>
  ))}

  <!-- Shopify App Store — heading + text on top, icon grid full-width below -->
  <section class="section bg-primary appstore-section">
    <div class="container">
      <div class="appstore-head">
        <h2 class="appstore-title">Shopify<br />App Store</h2>
        <p class="body appstore-text" set:html={appStore.desc}></p>
      </div>
      <div class="appstore-grid">
        <img src={appStore.img} alt="Shopify App Store — app ecosystem" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Why Shopify + Groomo -->
  <section class="section bg-primary" id="proc-zacit">
    <div class="container">
      <h2 class="section-title">WHY start<br />on the Shopify platform?</h2>
      <div class="two-col-groomo">
        <div>
          <p class="section-text body">Find your own reasons to try Shopify with us</p>
          <ul class="reasons-list">
            {reasons.map((r) => (
              <li>
                <span class="reason-arrow" aria-hidden="true">➔</span>
                <span set:html={r}></span>
              </li>
            ))}
          </ul>
        </div>
        <div class="groomo-wrap">
          <div class="groomo-card">
            <img src="/groomo-ref-na-vysku.webp" alt="Groomo — case study" class="groomo-img" loading="lazy" />
            <a href="/en/groomo-cz-na-shopify" class="ref-card-cta">Read the<br/>case study</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="cta">
    <div class="container cta-inner">
      <h2>Already decided?<br />Get in touch:</h2>
      <div class="cta-contacts">
        <a href="mailto:info@aethero.cz" class="cta-contact">info@aethero.cz</a>
        <a href="tel:+420776067663" class="cta-contact">+420 776 067 663</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* Intro section */
  .intro-heading {
    font-size: var(--fs-52);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-40);
    max-width: 760px;
  }
  .intro-h2 { margin-bottom: var(--space-40); }
  /* Intro + HOW WE START sidebar = 2 sloupce */
  .intro-layout { display: grid; grid-template-columns: 1fr 355px; gap: var(--space-64); align-items: start; }
  .intro-main { min-width: 0; }
  .intro-main .intro-text { max-width: none; }
  @media (max-width: 900px) { .intro-layout { grid-template-columns: 1fr; gap: var(--space-40); } }
  /* .hl (bold lavender) — globální utilita v global.css */
  .intro-text {
    font-size: var(--fs-20);
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    max-width: 860px;
    margin-bottom: var(--space-24);
  }
  .intro-text--spaced { margin-top: var(--space-40); }
  /* Capabilities section */
  .section { padding: var(--space-120) 0; }
  #shopify-why { padding-top: calc(var(--space-120) - var(--space-40)); }
  .section-title { font-size: var(--fs-70); font-weight: 600; margin-bottom: var(--space-40); }
  .section-text { margin-bottom: var(--space-24); }
  .two-col-capabilities { display: grid; grid-template-columns: 1fr 2fr; gap: var(--space-80); align-items: start; }
  /* plus-list — odrážky „+" 22px levandule (lokální varianta check-listu) */
  .plus-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-16); }
  .plus-list li { display: flex; align-items: flex-start; gap: 12px; font-family: var(--font-secondary); font-size: var(--text-body); color: rgba(255,255,255,0.8); line-height: 1.6; }
  .plus-list li::before { content: '+'; color: var(--text-secondary); font-size: 24px; font-weight: 700; line-height: 1.3; flex-shrink: 0; }
  /* capability-list → globální .check-list */

  /* Feature sections */
  .feature-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-80);
    align-items: center;
  }
  .feature-section--reverse .feature-inner { direction: rtl; }
  .feature-section--reverse .feature-text { direction: ltr; }
  .feature-section--reverse .feature-img-wrap { direction: ltr; }
  .feature-logo-lockup { display: flex; align-items: center; align-self: flex-start; gap: var(--space-16); }
  .feature-logo { display: block; height: 64px; width: auto; transform: translateX(2px); }
  .feature-logo-text { font-family: var(--font-primary); font-size: var(--fs-30); font-weight: 700; color: #fff; line-height: 1.05; }
  .feature-title { font-size: var(--fs-36); font-weight: 700; line-height: 1.2; margin-bottom: var(--space-24); }
  .feature-img-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--space-24); }
  .feature-img-wrap--empty { min-height: 200px; }

  /* Shopify App Store — heading + text on top, icon grid full-width below */
  .appstore-head { display: grid; grid-template-columns: 280px 1fr; gap: var(--space-64); align-items: start; margin-bottom: var(--space-64); }
  .appstore-title { font-family: var(--font-primary); font-size: var(--fs-40); font-weight: 700; color: #fff; line-height: 1.05; margin: 0; }
  .appstore-text { max-width: 900px; }
  .appstore-grid img { width: 100%; height: auto; display: block; border-radius: var(--radius-md); }
  @media (max-width: 900px) { .appstore-head { grid-template-columns: 1fr; gap: var(--space-24); } }

  /* Why Shopify + Groomo */
  .two-col-groomo { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-80); align-items: start; }
  .reasons-list { list-style: none; display: flex; flex-direction: column; gap: 14px; margin-top: var(--space-24); }
  .reasons-list li { display: flex; align-items: flex-start; gap: 12px; font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.5; }
  .reason-arrow { flex-shrink: 0; color: var(--text-secondary); }
  .groomo-wrap { display: flex; justify-content: center; align-self: end; }
  .groomo-card { position: relative; max-width: 340px; width: 100%; border-radius: 6px; overflow: hidden; }
  .groomo-img { display: block; width: 100%; height: auto; }
  /* .ref-card-cta — globální utilita (global.css) */

  /* CTA */

  /* Responsive */
  @media (max-width: 1024px) {
    .two-col-capabilities { grid-template-columns: 1fr; }
    .two-col-groomo { grid-template-columns: 1fr; }
    .feature-inner { grid-template-columns: 1fr; }
    .feature-section--reverse .feature-inner { direction: ltr; }
    .feature-img-wrap { display: none; }
  }
</style>
