---
export interface Props { lang?: string; }
const { lang = 'cs' } = Astro.props;
const p = lang === 'en' ? '/en' : '/cs';

// Language switcher: swap /cs/ ↔ /en/ in current path
const currentPath = Astro.url.pathname;
const otherLang = lang === 'en' ? 'cs' : 'en';
const otherPath = lang === 'en'
  ? currentPath.replace(/^\/en/, '/cs')
  : currentPath.replace(/^\/cs/, '/en');

const navItems = lang === 'en'
  ? [
      { label: 'HOME', href: `${p}/` },
      {
        label: 'SERVICES',
        href: `${p}/co-umime`,
        dropdown: [
          { label: 'Brand & Identity', href: `${p}/co-umime/potrebuji-brand` },
          { label: 'New Shopify Store', href: `${p}/co-umime/novy-shopify-e-shop` },
          { label: 'Migration to Shopify', href: `${p}/co-umime/prechod-na-shopify` },
          { label: 'International Expansion', href: `${p}/co-umime/expanze-do-zahranici` },
          { label: 'Development & Support', href: `${p}/co-umime/rozvoj-a-podpora` },
          { label: 'Strategy & Analytics', href: `${p}/co-umime/analyza-a-strategie` },
          { label: 'Custom Development', href: `${p}/co-umime/custom-vyvoj-a-aplikace` },
        ],
      },
      {
        label: 'APPS',
        href: `${p}/esyncer`,
        dropdown: [
          { label: 'eSyncer', href: `${p}/esyncer` },
          { label: 'AE Translator', href: `${p}/ae-translator` },
        ],
      },
      { label: 'ABOUT', href: `${p}/o-nas` },
      { label: 'CONTACT', href: `${p}/kontakt` },
    ]
  : [
      { label: 'ÚVOD', href: `${p}/` },
      {
        label: 'CO UMÍME',
        href: `${p}/co-umime`,
        dropdown: [
          { label: 'Potřebuji brand', href: `${p}/co-umime/potrebuji-brand` },
          { label: 'Nový Shopify e-shop', href: `${p}/co-umime/novy-shopify-e-shop` },
          { label: 'Přechod na Shopify', href: `${p}/co-umime/prechod-na-shopify` },
          { label: 'Expanze do zahraničí', href: `${p}/co-umime/expanze-do-zahranici` },
          { label: 'Rozvoj a podpora', href: `${p}/co-umime/rozvoj-a-podpora` },
          { label: 'Analýza a strategie', href: `${p}/co-umime/analyza-a-strategie` },
          { label: 'Custom vývoj a aplikace', href: `${p}/co-umime/custom-vyvoj-a-aplikace` },
        ],
      },
      {
        label: 'APLIKACE',
        href: `${p}/esyncer`,
        dropdown: [
          { label: 'eSyncer', href: `${p}/esyncer` },
          { label: 'AE Translator', href: `${p}/ae-translator` },
        ],
      },
      { label: 'O NÁS', href: `${p}/o-nas` },
      { label: 'KONTAKT', href: `${p}/kontakt` },
    ];
---

<header id="site-header">
  <div class="header-inner container">
    <a href={`${p}/`} class="logo" aria-label="aethero">
      <img src="/ae-logo.svg" alt="æthero" width="140" height="35" loading="eager" />
    </a>

    <nav id="nav-menu" role="navigation" aria-label={lang === 'en' ? 'Main navigation' : 'Hlavní navigace'}>
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class={item.dropdown ? 'has-dropdown' : ''}>
            <a href={item.href} class="nav-link">
              {item.label}
              {item.dropdown && (
                <svg class="nav-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </a>
            {item.dropdown && (
              <ul class="dropdown">
                {item.dropdown.map((sub) => (
                  <li><a href={sub.href} class="dropdown-link">{sub.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
        <!-- mobile-only lang switch inside nav overlay -->
        <li class="mobile-lang-li">
          <a href={otherPath} class="mobile-lang-link" aria-label={`Switch to ${otherLang.toUpperCase()}`}>
            {otherLang.toUpperCase()}
          </a>
        </li>
      </ul>
    </nav>

    <a href={otherPath} class="lang-switch" aria-label={`Switch to ${otherLang.toUpperCase()}`}>
      {otherLang.toUpperCase()}
    </a>

    <button class="hamburger" id="hamburger" aria-label={lang === 'en' ? 'Open menu' : 'Otevřít menu'} aria-expanded="false" aria-controls="nav-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const hamburger = document.getElementById('hamburger')!;
  const navMenu = document.getElementById('nav-menu')!;

  // Transparent → solid on scroll
  const onScroll = () => {
    header.classList.toggle('scrolled', window.scrollY > 40);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Hamburger toggle
  hamburger.addEventListener('click', () => {
    const open = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!open));
    hamburger.classList.toggle('open', !open);
    navMenu.classList.toggle('open', !open);
    document.body.style.overflow = open ? '' : 'hidden';
  });

  // Close mobile menu on nav link click
  navMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.classList.remove('open');
      navMenu.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // Desktop dropdown: keyboard accessibility (Escape closes)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.has-dropdown').forEach((el) => {
        (el as HTMLElement).blur();
      });
    }
  });
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: background var(--transition-base), box-shadow var(--transition-base), padding var(--transition-base);
    padding: 22px 0 172px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.35) 0%, transparent 100%);
  }

  header.scrolled {
    background: rgba(0, 3, 38, 1);
    padding: 16px 0;
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 0 24px;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    transition: opacity var(--transition-base);
  }
  .logo img { display: block; }
  .logo:hover { opacity: 0.8; }

  /* Nav — col 2 (1fr, center) */
  nav {
    display: flex;
    justify-content: center;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li { position: relative; }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 14px;
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-primary);
    transition: color var(--transition-base);
    white-space: nowrap;
    line-height: 1.4;
  }
  .nav-link:hover { color: var(--action); }

  .nav-chevron {
    opacity: 0.5;
    transition: transform var(--transition-base), opacity var(--transition-base);
    flex-shrink: 0;
  }
  .has-dropdown:hover .nav-chevron,
  .has-dropdown:focus-within .nav-chevron {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* Dropdown — bridged gap so submenu is always clickable */
  .has-dropdown { position: relative; }

  /* Invisible bridge between nav-link and dropdown — prevents hover gap */
  .has-dropdown::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    right: 0;
    height: 6px;
  }

  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: 220px;
    background: #0a0d3a;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-md);
    box-shadow: 0 16px 40px rgba(0,0,0,0.5);
    padding: 6px 0;
    list-style: none;
    z-index: 500;
  }
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: block;
  }

  .dropdown-link {
    display: block;
    padding: 8px 20px;
    font-size: 14px;
    font-family: var(--font-primary);
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    line-height: 1.4;
    transition: color var(--transition-base), background var(--transition-base);
    white-space: nowrap;
  }
  .dropdown-link:hover {
    color: var(--action);
    background: rgba(13,212,205,0.08);
  }

  /* Language switcher — col 3 */
  .lang-switch {
    font-family: var(--font-primary);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.7);
    padding: 5px 10px;
    border: 1px solid rgba(255,255,255,0.18);
    border-radius: 4px;
    transition: color var(--transition-base), border-color var(--transition-base);
    white-space: nowrap;
  }
  .lang-switch:hover { color: #fff; border-color: var(--action); }

  /* Hamburger — col 4, hidden on desktop */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile lang switch inside nav — hidden on desktop */
  .mobile-lang-li { display: none; }

  /* ─── MOBILE ≤ 900px ─── */
  @media (max-width: 900px) {
    .header-inner {
      grid-template-columns: 1fr auto auto;
      gap: 0 12px;
      position: relative; /* creates stacking context so children sit above nav overlay */
      z-index: 2;
    }

    .hamburger { display: flex; }

    /* Collapse desktop lang-switch — mobile has it inside nav */
    .lang-switch { display: none; }

    /* Nav overlay */
    nav {
      position: fixed;
      inset: 0;
      background: rgba(0, 3, 38, 0.98);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      display: flex;
      align-items: center;
      justify-content: center;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      z-index: 1; /* within header stacking context — below header-inner (z-index: 2) */
      justify-self: unset;
    }
    nav.open { transform: translateX(0); }

    .nav-list {
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }

    .nav-link {
      font-size: 26px;
      font-weight: 600;
      padding: 10px 24px;
      justify-content: center;
    }

    /* Dropdowns always visible and expanded in mobile */
    .dropdown {
      position: static;
      display: block;
      background: transparent;
      border: none;
      box-shadow: none;
      padding: 0;
      margin-top: 4px;
      min-width: unset;
    }
    .has-dropdown::after { display: none; }
    .nav-chevron { display: none; }

    .dropdown-link {
      font-size: 15px;
      text-align: center;
      color: rgba(255,255,255,0.55);
      padding: 5px 20px;
    }
    .dropdown-link:hover { color: var(--action); background: transparent; }

    /* Mobile lang switch visible inside nav */
    .mobile-lang-li {
      display: flex;
      margin-top: 24px;
    }
    .mobile-lang-link {
      font-family: var(--font-primary);
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.5);
      padding: 6px 16px;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 4px;
      transition: color var(--transition-base), border-color var(--transition-base);
    }
    .mobile-lang-link:hover { color: #fff; border-color: var(--action); }
  }

  @media (max-width: 480px) {
    .nav-link { font-size: 22px; padding: 8px 20px; }
  }
</style>
