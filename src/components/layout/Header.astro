---
export interface Props { lang?: string; }
const { lang = 'cs' } = Astro.props;
const p = lang === 'en' ? '/en' : '/cs';

const navItems = lang === 'en'
  ? [
      { label: 'HOME', href: `${p}/` },
      {
        label: 'SERVICES',
        href: `${p}/co-umime`,
        dropdown: [
          { label: 'Brand & Identity', href: `${p}/co-umime/potrebuji-brand` },
          { label: 'New Shopify Store', href: `${p}/co-umime/novy-shopify-e-shop` },
          { label: 'Migration to Shopify', href: `${p}/co-umime/prechod-na-shopify` },
          { label: 'International Expansion', href: `${p}/co-umime/expanze-do-zahranici` },
          { label: 'Development & Support', href: `${p}/co-umime/rozvoj-a-podpora` },
          { label: 'Strategy & Analytics', href: `${p}/co-umime/analyza-a-strategie` },
          { label: 'Custom Development', href: `${p}/co-umime/custom-vyvoj-a-aplikace` },
        ],
      },
      {
        label: 'APPS',
        href: '#',
        dropdown: [
          { label: 'eSyncer', href: `${p}/esyncer` },
          { label: 'AE Translator', href: `${p}/ae-translator` },
        ],
      },
      { label: 'ABOUT', href: `${p}/o-nas` },
      { label: 'CONTACT', href: `${p}/kontakt` },
    ]
  : [
      { label: 'ÚVOD', href: `${p}/` },
      {
        label: 'CO UMÍME',
        href: `${p}/co-umime`,
        dropdown: [
          { label: 'Potřebuji brand', href: `${p}/co-umime/potrebuji-brand` },
          { label: 'Nový Shopify e-shop', href: `${p}/co-umime/novy-shopify-e-shop` },
          { label: 'Přechod na Shopify', href: `${p}/co-umime/prechod-na-shopify` },
          { label: 'Expanze do zahraničí', href: `${p}/co-umime/expanze-do-zahranici` },
          { label: 'Rozvoj a podpora', href: `${p}/co-umime/rozvoj-a-podpora` },
          { label: 'Analýza a strategie', href: `${p}/co-umime/analyza-a-strategie` },
          { label: 'Custom vývoj a aplikace', href: `${p}/co-umime/custom-vyvoj-a-aplikace` },
        ],
      },
      {
        label: 'APLIKACE',
        href: '#',
        dropdown: [
          { label: 'eSyncer', href: `${p}/esyncer` },
          { label: 'AE Translator', href: `${p}/ae-translator` },
        ],
      },
      { label: 'O NÁS', href: `${p}/o-nas` },
      { label: 'KONTAKT', href: `${p}/kontakt` },
    ];
---

<header id="site-header">
  <div class="container header-inner">
    <a href={`${p}/`} class="logo" aria-label="aethero">
      <img src="/ae-logo.svg" alt="æthero" width="120" height="30" loading="eager" />
    </a>

    <button class="hamburger" id="hamburger" aria-label={lang === 'en' ? 'Open menu' : 'Otevřít menu'} aria-expanded="false" aria-controls="nav-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav id="nav-menu" role="navigation" aria-label={lang === 'en' ? 'Main navigation' : 'Hlavní navigace'}>
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class={item.dropdown ? 'has-dropdown' : ''}>
            <a href={item.href} class="nav-link">
              {item.label}
            </a>
            {item.dropdown && (
              <ul class="dropdown">
                {item.dropdown.map((sub) => (
                  <li><a href={sub.href} class="dropdown-link">{sub.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const hamburger = document.getElementById('hamburger')!;
  const navMenu = document.getElementById('nav-menu')!;

  // Transparent → solid on scroll
  const onScroll = () => {
    header.classList.toggle('scrolled', window.scrollY > 40);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Hamburger toggle
  hamburger.addEventListener('click', () => {
    const open = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!open));
    hamburger.classList.toggle('open', !open);
    navMenu.classList.toggle('open', !open);
    document.body.style.overflow = open ? '' : 'hidden';
  });

  // Close mobile menu on nav link click
  navMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.classList.remove('open');
      navMenu.classList.remove('open');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background var(--transition-base), box-shadow var(--transition-base);
    padding: var(--space-16) 0;
  }

  header.scrolled {
    background: var(--bg-elevated);
    box-shadow: var(--shadow-md);
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  /* Logo */
  .logo {
    flex-shrink: 0;
    transition: opacity var(--transition-base);
    display: flex;
    align-items: center;
  }
  .logo img { display: block; }
  .logo:hover { opacity: 0.85; }

  /* Nav */
  nav { grid-column: 2; }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
  }

  li { position: relative; }

  .nav-link {
    display: flex;
    align-items: center;
    padding: 0 30px;
    font-family: var(--font-primary);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--text-primary);
    transition: color var(--transition-base);
    white-space: nowrap;
    line-height: 56px;
  }
  .nav-link:hover {
    color: var(--action);
  }

  /* Dropdown */
  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 220px;
    background: var(--bg-secondary);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    padding: var(--space-8) 0;
    list-style: none;
    z-index: 200;
  }
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: block;
  }

  .dropdown-link {
    display: block;
    padding: 10px var(--space-16);
    font-size: 14px;
    font-family: var(--font-secondary);
    font-weight: 500;
    color: var(--neutral-300);
    transition: color var(--transition-base), background var(--transition-base);
    white-space: nowrap;
  }
  .dropdown-link:hover {
    color: var(--action);
    background: rgba(13,212,205,0.07);
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 110;
    justify-self: end;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile */
  @media (max-width: 900px) {
    .header-inner { grid-template-columns: 1fr auto; }
    .hamburger { display: flex; }

    nav {
      grid-column: 1 / -1;
      position: fixed;
      inset: 0;
      background: var(--bg-elevated);
      display: flex;
      align-items: center;
      justify-content: center;
      transform: translateX(100%);
      transition: transform 0.3s ease;
    }
    nav.open { transform: translateX(0); }

    .nav-list {
      flex-direction: column;
      align-items: center;
      gap: var(--space-8);
    }

    .nav-link {
      font-size: 24px;
      padding: 12px 20px;
      line-height: 1.4;
    }

    .dropdown {
      position: static;
      display: block;
      background: transparent;
      border: none;
      box-shadow: none;
      padding: 0;
      margin-top: var(--space-8);
    }

    .has-dropdown .dropdown { display: none; }
    .has-dropdown:focus-within .dropdown { display: block; }

    .dropdown-link {
      font-size: 16px;
      text-align: center;
      color: var(--neutral-500);
    }
  }
</style>
