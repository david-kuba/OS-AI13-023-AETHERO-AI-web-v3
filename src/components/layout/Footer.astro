---
export interface Props { lang?: string; }
const { lang = 'cs' } = Astro.props;
const p = lang === 'en' ? '/en' : '/cs';

const intentLinks = lang === 'en'
  ? [
      { label: 'I need a brand', href: `${p}/co-umime/potrebuji-brand` },
      { label: "I'm planning a new Shopify store", href: `${p}/co-umime/novy-shopify-e-shop` },
      { label: 'I want to migrate to Shopify', href: `${p}/co-umime/prechod-na-shopify` },
      { label: "We're considering international expansion", href: `${p}/co-umime/expanze-do-zahranici` },
      { label: "I'm looking for a growth partner", href: `${p}/co-umime/rozvoj-a-podpora` },
      { label: 'I need custom development or an app', href: `${p}/co-umime/custom-vyvoj-a-aplikace` },
    ]
  : [
      { label: 'Potřebuji brand', href: `${p}/co-umime/potrebuji-brand` },
      { label: 'Přemýšlím o novém Shopify e-shopu', href: `${p}/co-umime/novy-shopify-e-shop` },
      { label: 'Chci přejít na Shopify', href: `${p}/co-umime/prechod-na-shopify` },
      { label: 'Zvažujeme zahraniční expanzi', href: `${p}/co-umime/expanze-do-zahranici` },
      { label: 'Hledám partnera pro rozvoj či podporu', href: `${p}/co-umime/rozvoj-a-podpora` },
      { label: 'Potřebuji custom úpravy či aplikace', href: `${p}/co-umime/custom-vyvoj-a-aplikace` },
    ];
---

<footer>
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href={`${p}/`} class="logo" aria-label="aethero">
        <img src="/ae-logo.svg" alt="æthero" width="140" height="35" loading="lazy" />
      </a>
      <img src="/shopify-plus-badge.svg" alt="Shopify Plus Partner" class="shopify-badge" width="130" height="45" loading="lazy" />
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <span>© {new Date().getFullYear()} AETHERO s.r.o. · IČO 05288762</span>
      <span class="separator">·</span>
      <a href={`${p}/o-nas`}>{lang === 'en' ? 'About' : 'O nás'}</a>
      <span class="separator">·</span>
      <a href={`${p}/kontakt`}>{lang === 'en' ? 'Contact' : 'Kontakt'}</a>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #000326;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-80);
    padding: var(--space-80) var(--space-24);
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 28px;
  }

  .logo { display: flex; align-items: center; }
  .logo img { opacity: 0.9; }
  .shopify-badge { display: block; opacity: 0.75; }

  .footer-label {
    font-family: var(--font-secondary);
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    margin-bottom: var(--space-16);
    line-height: 1.4;
  }

  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  ul a {
    font-size: var(--text-small);
    color: var(--action);
    transition: color var(--transition-base);
  }
  ul a:hover { color: #fff; }

  .footer-bottom {
    padding: var(--space-24);
  }

  .footer-bottom .container {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    font-size: var(--text-small);
    color: rgba(255,255,255,0.45);
    flex-wrap: wrap;
  }

  .footer-bottom a {
    color: rgba(255,255,255,0.6);
    transition: color var(--transition-base);
  }
  .footer-bottom a:hover { color: var(--action); }

  .separator { opacity: 0.4; }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--space-40);
      padding: var(--space-40) var(--space-24);
    }
  }
</style>
