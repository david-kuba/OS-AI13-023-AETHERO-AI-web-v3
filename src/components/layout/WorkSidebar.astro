---
// Znovupoužitelný sidebar "služby / kroky" (icon list)
// DS: design-system.astro → sekce "🔒 Sidebar — služby / kroky (icon list)"
export interface WorkSidebarItem {
  icon: string; // inner SVG (paths), viewBox 0 0 24 24
  title: string;
  desc: string;
}
export interface Props {
  heading: string;
  items: WorkSidebarItem[];
}
const { heading, items } = Astro.props;
---

<aside class="work-aside">
  <h2 class="work-heading">{heading}</h2>
  <div class="work-list">
    {items.map((c) => (
      <div class="work-item">
        <div class="work-item-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon}></svg></div>
        <div class="work-item-text">
          <h3 class="work-item-title">{c.title}</h3>
          <p class="work-item-desc">{c.desc}</p>
        </div>
      </div>
    ))}
  </div>
</aside>

<style>
  .work-aside {
    background: var(--ae-bg-deep);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: var(--radius-md);
    padding: var(--space-32);
  }
  .work-heading {
    font-family: var(--font-primary);
    font-size: var(--fs-18); font-weight: 700; letter-spacing: 0.08em;
    margin-bottom: var(--space-24); color: #fff;
    text-transform: uppercase; line-height: 1.3;
    padding-left: calc(42px + var(--space-16));
  }
  .work-list { display: flex; flex-direction: column; gap: var(--space-32); }
  .work-item { display: flex; gap: var(--space-16); align-items: flex-start; }
  .work-item-icon {
    flex-shrink: 0; width: 42px; height: 42px;
    display: grid; place-items: center; border-radius: 10px;
    color: var(--text-secondary);
    background: rgba(160,129,209,0.12);
    border: 1px solid rgba(160,129,209,0.28);
  }
  .work-item-icon svg { width: 22px; height: 22px; display: block; }
  .work-item-title {
    font-family: var(--font-primary);
    font-size: 15px; font-weight: 700; color: var(--text-secondary);
    margin-bottom: var(--space-8);
  }
  .work-item-desc {
    font-family: var(--font-secondary);
    font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.55;
  }
</style>
