---
export interface Props {
  label: string;
  title: string;
  subtitle: string;
  ctaLabel?: string;
  ctaHref?: string;
  cta2Label?: string;
  cta2Href?: string;
  lang?: 'cs' | 'en';
  image?: string;
  imageAlt?: string;
}
const { label, title, subtitle, ctaLabel = 'Zavolejme si', ctaHref = 'tel:+420776067663', cta2Label, cta2Href, lang = 'cs', image, imageAlt = '' } = Astro.props;
const contactHref = cta2Href || `/${lang}/kontakt`;
const contactLabel = cta2Label || (lang === 'en' ? 'Find out how' : 'Zjistěte jak');
---

<section class={`service-hero${image ? ' service-hero--with-image' : ''}`}>
  <div class="hero-bg-image" aria-hidden="true">
    <img src="/ae-bgr-w-glass-b-2x-v3.webp" alt="" loading="eager" />
  </div>
  <div class="hero-blob" aria-hidden="true"></div>
  <div class={`container${image ? ' service-hero-split' : ' service-hero-inner'}`}>
    <div class="hero-text">
      <h1 set:html={title} />
      <p class="hero-sub">{subtitle}</p>
      <div class="hero-ctas">
        <a href={ctaHref} class="btn-primary">{ctaLabel}</a>
        <a href={contactHref} class="btn-ghost">{contactLabel}</a>
      </div>
    </div>
    {image && (
      <div class="hero-image-wrap" aria-hidden="true">
        <img src={image} alt={imageAlt} class="hero-image" loading="eager" />
      </div>
    )}
  </div>
</section>

<style>
  .service-hero {
    position: relative;
    padding: 215px 0 153px;
    background: #07051B;
    overflow: hidden;
  }
  .hero-bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero-bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    display: block;
  }
  .hero-bg-image::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 160px;
    background: linear-gradient(to bottom, transparent 0%, #000326 100%);
  }
  .hero-blob {
    position: absolute;
    top: -20%;
    right: -5%;
    width: 600px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(203,0,215,0.15) 0%, rgba(9,32,102,0.2) 50%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }
  .service-hero-inner { position: relative; z-index: 1; max-width: 720px; }

  /* Split layout — text left, image right */
  .service-hero-split {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .service-hero--with-image { padding-bottom: 0; }
  .hero-text { position: relative; text-align: left; }
  .hero-image-wrap {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-top: 40px;
  }
  .hero-image {
    width: 100%;
    max-width: 540px;
    height: auto;
    display: block;
    filter: drop-shadow(0 40px 80px rgba(203,0,215,0.25));
  }

  @media (max-width: 900px) {
    .service-hero-split { grid-template-columns: 1fr; }
    .hero-image-wrap { display: none; }
  }
  h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-24);
    color: #fff;
    text-transform: uppercase;
  }
  h1 :global(span) { color: #fff !important; }
  .hero-sub {
    font-size: 20px;
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    margin-bottom: var(--space-40);
    max-width: 560px;
  }
  .hero-ctas { display: flex; gap: var(--space-16); flex-wrap: wrap; }

  @media (max-width: 768px) {
    .service-hero { padding: 154px 0 92px; }
    .hero-sub { font-size: 18px; }
  }
  @media (max-width: 480px) {
    .service-hero { padding: 123px 0 74px; }
    h1 { font-size: clamp(32px, 9vw, 48px); }
    .hero-sub { font-size: 16px; }
    .hero-blob { width: 300px; height: 300px; }
  }
</style>
