---
import { renderRichText } from '@storyblok/astro';

const { blok } = Astro.props;
const content = renderRichText(blok.content);
---

<div class="sb-blog-post">
  <div class="sb-content" set:html={content} />
</div>

<style>
  .sb-content :global(h2) { font-size: var(--fs-36); font-weight: 700; margin: 2em 0 0.75em; }
  .sb-content :global(h3) { font-size: var(--fs-28); font-weight: 600; margin: 1.75em 0 0.6em; }
  .sb-content :global(p) { font-size: 18px; color: var(--neutral-300); line-height: 1.6; margin-bottom: 1.4em; }
  .sb-content :global(ul), .sb-content :global(ol) { padding-left: 1.5em; margin-bottom: 1.4em; }
  .sb-content :global(li) { font-size: 18px; color: var(--neutral-300); line-height: 1.7; margin-bottom: 0.4em; }
  .sb-content :global(a) { color: var(--action); text-decoration: underline; text-underline-offset: 2px; }
  .sb-content :global(strong) { font-weight: 700; color: var(--text-primary); }
  .sb-content :global(blockquote) { border-left: 3px solid var(--action); padding-left: 1.5em; margin: 1.5em 0; font-style: italic; color: var(--neutral-400); }
  .sb-content :global(code) { background: rgba(255,255,255,0.07); padding: 2px 6px; border-radius: 4px; font-size: 0.9em; }
  .sb-content :global(pre) { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 1.5em; overflow-x: auto; margin-bottom: 1.4em; }
  .sb-content :global(img) { border-radius: 8px; max-width: 100%; margin: 1.5em 0; }
</style>
